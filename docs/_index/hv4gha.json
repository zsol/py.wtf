 from PEM to DER\n\n```\nparam private_pem\n\nPEM encoded private key\n\nreturn\n\nDER encoded private key\n```\n"]}, {"name": "hv4gha.helpers.vault_wrap_key", "asynchronous": false, "params": [{"name": "der_app_key", "type": {"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}, "default": null}, {"name": "wrapping_key", "type": {"name": "rsa.RSAPublicKey", "xref": {"fqname": "cryptography.hazmat.primitives.asymmetric.rsa.RSAPublicKey", "project": "cryptography"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Wrap a private key the way Vault wants it wrapped\n\n```\nparam der_app_key\n\nDER encoded private key\n\nparam wrapping_key\n\nVault provided wrapping key\n\nreturn\n\nWrapped key\n```\n"]}], "variables": [], "classes": [], "exports": []}, {"name": "hv4gha.gh", "documentation": ["GitHub specific code"], "functions": [], "variables": [{"name": "hv4gha.gh.PermARW", "type": null, "documentation": []}, {"name": "hv4gha.gh.PermRW", "type": null, "documentation": []}, {"name": "hv4gha.gh.PermR", "type": null, "documentation": []}, {"name": "hv4gha.gh.PermW", "type": null, "documentation": []}], "classes": [{"name": "hv4gha.gh.TokenResponse", "bases": ["TypedDict"], "methods": [], "class_variables": [{"name": "hv4gha.gh.TokenResponse.access_token", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "hv4gha.gh.TokenResponse.expires_at", "type": {"name": "datetime", "xref": {"fqname": "datetime.datetime", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "hv4gha.gh.TokenResponse.permissions", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functi