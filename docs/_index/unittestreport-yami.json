d `self` then it will be\nignored:\n\n```\n>>> def func(self, a): pass\n>>> p = param(1)\n>>> parameterized_argument_value_pairs(func, p)\n[(\"a\", 1)]\n```\n\nAdditionally, empty `*args` or `**kwargs` will be ignored:\n\n```\n>>> def func(foo, *args): pass\n>>> p = param(1)\n>>> parameterized_argument_value_pairs(func, p)\n[(\"foo\", 1)]\n>>> p = param(1, 16)\n>>> parameterized_argument_value_pairs(func, p)\n[(\"foo\", 1), (\"*args\", (16, ))]\n```\n"]}, {"name": "unittestreport_yami.core.parameterized.short_repr", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "n", "type": null, "default": "..."}], "returns": null, "documentation": ["A shortened repr of `x` which is guaranteed to be `unicode`:\n\n```\n>>> short_repr(\"foo\")\n```\n\nu\"foo\"\n\\>>> short_repr(\"123456789\", n=4)\nu\"12...89\"\n"]}, {"name": "unittestreport_yami.core.parameterized.default_doc_func", "asynchronous": false, "params": [{"name": "func", "type": null, "default": null}, {"name": "num", "type": null, "default": null}, {"name": "p", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.default_name_func", "asynchronous": false, "params": [{"name": "func", "type": null, "default": null}, {"name": "num", "type": null, "default": null}, {"name": "p", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.set_test_runner", "asynchronous": false, "params": [{"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.detect_runner", "asynchronous": false, "params": [], "returns": null, "documentation": ["Guess which test runner we're using by traversing the stack and looking\nfor the first matching module. This *should* be reasonably safe, as\nit's done during test disocvery where the test runner should be the\nstack frame immediately outside. "]}, {"name": "unittestreport_yami.core.parameterized.parameterized_class", "asynchronous": false, "params": [{"name": "attrs", "type": null, "default": null}, {"name": "input_values", "type": null, "default": "..."}, {"name": "class_name_func", "type": null, "default": "..."}, {"name": "classname_func", "type": null, "default": "..."}], "returns": null, "documentation": ["Parameterizes a test class by setting attributes on the class.\n\nCan be used in two ways:\n\n1. With a list of dictionaries containing attributes to override:\n\n   ```\n   @parameterized_class([\n       { \"username\": \"foo\" },\n       { \"username\": \"bar\", \"access_level\": 2 },\n   ])\n   class TestUserAccessLevel(TestCase):\n       ...\n   ```\n\n2. With a tuple of attributes, then a list of tuples of values:\n\n   > @parameterized_class((\"username\", \"access_level\"), \\[\n   >\n   > : (\"foo\", 1),\n   >   (\"bar\", 2)\n   >\n   > \\])\n   > class TestUserAccessLevel(TestCase):\n   >\n   > > ...\n"]}, {"name": "unittestreport_yami.core.parameterized.get_class_name_suffix", "asynchronous": false, "params": [{"name": "params_dict", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.default_class_name_func", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "num", "type": null, "default": null}, {"name": "params_dict", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "unittestreport_yami.core.parameterized.MaybeOrderedDict", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.PY3", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.PY2", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.lzip", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.text_type", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.string_types", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.bytes_type", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.CompatArgSpec", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized._param", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized._test_runner_override", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized._test_runner_guess", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized._test_runners", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized._test_runner_aliases", "type": null, "documentation": []}], "classes": [{"name": "unittestreport_yami.core.parameterized.SkipTest", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "unittestreport_yami.core.parameterized.InstanceType", "bases": [], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "unittestreport_yami.core.parameterized.param", "bases": ["_param"], "methods": [{"name": "unittestreport_yami.core.parameterized.param.__new__", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.param.explicit", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "args", "type": null, "default": "..."}, {"name": "kwargs", "type": null, "default": "..."}], "returns": null, "documentation": ["Creates a `param` by explicitly specifying `args` and\n`kwargs`:\n\n```\n>>> param.explicit([1,2,3])\nparam(*(1, 2, 3))\n>>> param.explicit(kwargs={\"foo\": 42})\nparam(*(), **{\"foo\": \"42\"})\n```\n"]}, {"name": "unittestreport_yami.core.parameterized.param.from_decorator", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "args", "type": null, "default": null}], "returns": null, "documentation": ["Returns an instance of `param()` for `@parameterized` argument\n`args`:\n\n```\n>>> param.from_decorator((42, ))\nparam(args=(42, ), kwargs={})\n>>> param.from_decorator(\"foo\")\nparam(args=(\"foo\", ), kwargs={})\n```\n"]}, {"name": "unittestreport_yami.core.parameterized.param.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Represents a single parameter to a test case.\n\nFor example:\n\n```\n>>> p = param(\"foo\", bar=16)\n>>> p\nparam(\"foo\", bar=16)\n>>> p.args\n('foo', )\n>>> p.kwargs\n{'bar': 16}\n```\n\nIntended to be used as an argument to `@parameterized`:\n\n```\n@parameterized([\n    param(\"foo\", bar=16),\n])\ndef test_stuff(foo, bar=16):\n    pass\n```\n"]}, {"name": "unittestreport_yami.core.parameterized.QuietOrderedDict", "bases": ["MaybeOrderedDict"], "methods": [], "class_variables": [{"name": "unittestreport_yami.core.parameterized.QuietOrderedDict.__str__", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.QuietOrderedDict.__repr__", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["When OrderedDict is available, use it to make sure that the kwargs in\ndoc strings are consistently ordered. "]}, {"name": "unittestreport_yami.core.parameterized.parameterized", "bases": ["object"], "methods": [{"name": "unittestreport_yami.core.parameterized.parameterized.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "input", "type": null, "default": null}, {"name": "doc_func", "type": null, "default": "..."}, {"name": "skip_on_empty", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.parameterized.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test_func", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.parameterized.param_as_nose_tuple", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test_self", "type": null, "default": null}, {"name": "func", "type": null, "default": null}, {"name": "num", "type": null, "default": null}, {"name": "p", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.parameterized.assert_not_in_testcase_subclass", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.parameterized._terrible_magic_get_defining_classes", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns the set of parent classes of the class currently being defined.\nWill likely only work if called from the `parameterized` decorator.\nThis function is entirely @brandon_rhodes's fault, as he suggested\nthe implementation: <http://stackoverflow.com/a/8793684/71522>\n"]}, {"name": "unittestreport_yami.core.parameterized.parameterized.input_as_callable", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "input", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.parameterized.check_input_values", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "input_values", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.parameterized.expand", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "input", "type": null, "default": null}, {"name": "name_func", "type": null, "default": "..."}, {"name": "doc_func", "type": null, "default": "..."}, {"name": "skip_on_empty", "type": null, "default": "..."}, {"name": "**legacy", "type": null, "default": null}], "returns": null, "documentation": ["A \"brute force\" method of parameterizing test cases. Creates new\ntest cases and injects them into the namespace that the wrapped\nfunction is being defined in. Useful for parameterizing tests in\nsubclasses of 'UnitTest', where Nose test generators don't work.\n\n```pycon\n>>> @parameterized.expand([(\"foo\", 1, 2)])\n... def test_add1(name, input, expected):\n...     actual = add1(input)\n...     assert_equal(actual, expected)\n...\n>>> locals()\n... 'test_add1_foo_0': <function ...> ...\n>>>\n```\n"]}, {"name": "unittestreport_yami.core.parameterized.parameterized.param_as_standalone_func", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "p", "type": null, "default": null}, {"name": "func", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.parameterized.parameterized.to_safe_name", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Parameterize a test case:\n\nclass TestInt(object):\n\n: @parameterized(\\[\n\n  : (\"A\", 10),\n    (\"F\", 15),\n    param(\"10\", 42, base=42)\n\n  \\])\n  def test_int(self, input, expected, base=16):\n\n  > actual = int(input, base=base)\n  > assert_equal(actual, expected)\n\n@parameterized(\\[\n\n: (2, 3, 5)\n  (3, 5, 8),\n\n\\])\ndef test_add(a, b, expected):\n\n> assert_equal(a + b, expected)\n"]}], "exports": []}, {"name": "unittestreport_yami.core.testRunner", "documentation": ["encoding=utf-8"], "functions": [], "variables": [{"name": "unittestreport_yami.core.testRunner.Load", "type": null, "documentation": []}, {"name": "unittestreport_yami.core.testRunner.IMG_TMPL", "type": null, "documentation": []}], "classes": [{"name": "unittestreport_yami.core.testRunner.TestRunner", "bases": [], "methods": [{"name": "unittestreport_yami.core.testRunner.TestRunner.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "suite", "type": {"name": "unittest.TestSuite", "xref": {"fqname": "unittest.TestSuite", "project": "--std--"}, "params": null}, "default": null}, {"name": "filename", "type": null, "default": "..."}, {"name": "report_dir", "type": null, "default": "..."}, {"name": "title", "type": null, "default": "..."}, {"name": "tester", "type": null, "default": "..."}, {"name": "desc", "type": null, "default": "..."}, {"name": "templates", "type": null, "default": "..."}, {"name": "report_url", "type": null, "default": "..."}, {"name": "only_failed", "type": null, "default": "..."}, {"name": "render", "type": null, "default": "..."}], "returns": null, "documentation": ["---\nparam filename: Report file name\nparam suites: test suite\n---\n\n\\:param report_dir:The path to the report file\n\\:param title:Test suite title\n\\:param templates: You can specify the style template for the report by parameter value 1 or 2. Currently, there are only two templates\n\\:param tester:Tester\n"]}, {"name": "unittestreport_yami.core.testRunner.TestRunner.__classification_suite", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unittestreport_yami.core.testRunner.TestRunner.__do_with_base_result", "asynchronous": 