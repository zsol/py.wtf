ict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Validate entry `match` in `item`. Check it is not repeated.\n"]}, {"name": "sphinx_nefertiti.links.HeaderLinksProvider._validate_dropdown", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dropdown_elem", "type": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Validate the items given for a dropdown element.\n\nDropdown items can be of 2 types:\n1\\. A dict with `text` and `link` keys (optional `reg_exps`), or\n2\\. A dict with a `divider` key.\n"]}, {"name": "sphinx_nefertiti.links.HeaderLinksProvider._validate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Validate entries in the `header_links` option in `conf.py`.\n"]}, {"name": "sphinx_nefertiti.links.HeaderLinksProvider.__iter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "sphinx_nefertiti.links.HeaderLinksProvider.__next__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "sphinx_nefertiti.links.FooterLinksProvider", "bases": [], "methods": [{"name": "sphinx_nefertiti.links.FooterLinksProvider.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "app", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "sphinx_nefertiti.links.FooterLinksProvider._validate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Validate entries in the `footer_links` opt