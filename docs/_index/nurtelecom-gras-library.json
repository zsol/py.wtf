ecom_gras_library import get_db_connection, get_all_cred_dict, make_table_query_from_pandas\r\n\r\nall_cred_dict = get_all_cred_dict(\r\n    vault_url=url, vault_token=token, path_to_secret='path_to_secret', mount_point='mount_point')\r\n\r\n\r\n#create connection\r\ndatabase_connection = get_db_connection('login', 'database', all_cred_dict)\r\n\r\n#create query\r\ntest_query = \"select 1 from dual\"\r\n\r\n#makes pandas df \r\ntest_data = database_connection.get_data(query = test_query)\r\n\r\n#make new_create query from pandas df\r\nnew_table_name_for_sql = \"test_table_name\"\r\nquery_from_tabel = make_table_query_from_pandas(df = test_data, table_name= new_table_name_for_sql)\r\n\r\n#execute query\r\ndatabase_connection.execute(query_from_tabel)\r\n\r\n\r\n```\r\n\r\nOld connection \r\n```ruby\r\nfrom nurtelecom_gras_library import PLSQL_data_importer, make_table_query_from_pandas\r\n\r\n#create connection\r\ndatabase_connection = PLSQL_data_importer(user = 'user', password = 'pass', host= '192.168.1.1', port = '1521')\r\n\r\n#create query\r\ntest_query = \"select 1 from dual\"\r\n\r\n#makes pandas df \r\ntest_data = database_connection.get_data(query = test_query)\r\n\r\n#make new_create query from pandas df\r\nnew_table_name_for_sql = \"test_table_name\"\r\nquery_from_tabel = make_table_query_from_pandas(df = test_data, table_name= new_table_name_for_sql)\r\n\r\n#execute query\r\ndatabase_connection.execute(query_from_tabel)\r\n\r\n\r\n```\r\n\r\n\r\n\r\n"], "modules": [{"name": "nurtelecom_gras_library", "documentation": [], "functions": [], "variables": [{"name": "nurtelecom_gras_library.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "nurtelecom_gras_library.get_db_connection", "xref": {"fqname": "nurtelecom_gras_library.updated_connection.get_db_connection", "project": null}}, {"name": "nurtelecom_gras_library.PLSQL_data_importer", "xref": {"fqname": "nurtelecom_gras_library.PLSQL_data_importer.PLSQL_data_importer", "