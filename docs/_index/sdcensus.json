"name": "sdcensus.core.APIKeyError.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "sdcensus.core.APIKeyError.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Invalid API key\n    "]}, {"name": "sdcensus.core.CensusException", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "sdcensus.core.UnsupportedYearException", "bases": ["CensusException"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "sdcensus.core.Client", "bases": ["object"], "methods": [{"name": "sdcensus.core.Client.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}, {"name": "year", "type": null, "default": "..."}, {"name": "session", "type": null, "default": "..."}, {"name": "retries", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "sdcensus.core.Client.tables", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "year", "type": null, "default": "..."}], "returns": null, "documentation": ["Returns a list of the data tables available from this source."]}, {"name": "sdcensus.core.Client.fields", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "year", "type": null, "default": "..."}, {"name": "flat", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "sdcensus.core.Client.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "fields", "type": null, "default