tweets the user has posted.\n    is_verified (bool | None): Whether the user is verified."]}], "exports": []}, {"name": "x_lolo", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "x_lolo.cookie", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "x_lolo.cookie.Cookie", "bases": [], "methods": [{"name": "x_lolo.cookie.Cookie.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dict", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "x_lolo.cookie.Cookie.encode", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "x_lolo.session", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "x_lolo.session.Session", "bases": [], "methods": [{"name": "x_lolo.session.Session.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "load_from", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}], "returns": null, "documentation": ["Initializes a new session.\n\nIf load_from is specified, loads session data from a YAML file.\nOtherwise, initializes a new session with cookies and a guest token."]}, {"name": "x_lolo.session.Session.login", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "username_email", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "password", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": 