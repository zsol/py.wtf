ach.functional.resize", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "size", "type": null, "default": null}, {"name": "interpolation", "type": null, "default": "..."}, {"name": "align_corners", "type": null, "default": "..."}], "returns": null, "documentation": ["resize batch of images to given spatial size with given interpolation mode"]}, {"name": "ttach.functional.crop", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "x_min", "type": null, "default": "..."}, {"name": "x_max", "type": null, "default": "..."}, {"name": "y_min", "type": null, "default": "..."}, {"name": "y_max", "type": null, "default": "..."}], "returns": null, "documentation": ["perform crop on batch of images"]}, {"name": "ttach.functional.crop_lt", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "crop_h", "type": null, "default": null}, {"name": "crop_w", "type": null, "default": null}], "returns": null, "documentation": ["crop left top corner"]}, {"name": "ttach.functional.crop_lb", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "crop_h", "type": null, "default": null}, {"name": "crop_w", "type": null, "default": null}], "returns": null, "documentation": ["crop left bottom corner"]}, {"name": "ttach.functional.crop_rt", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "crop_h", "type": null, "default": null}, {"name": "crop_w", "type": null, "default": null}], "returns": null, "documentation": ["crop right top corner"]}, {"name": "ttach.functional.crop_rb", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "crop_h", "type": null, "default": null}, {"name": "crop_w", "type": null, "default": null}], "returns": null, "documentation": ["crop right bottom corner"]}, {"name": "ttach.functional.center_crop", "asynchronous": false, "params": [{"name": "x", "