l.stop", "xref": {"fqname": "rel.rel.stop", "project": null}}, {"name": "rel.supported_methods", "xref": {"fqname": "rel.rel.supported_methods", "project": null}}, {"name": "rel.thread", "xref": {"fqname": "rel.rel.thread", "project": null}}, {"name": "rel.tick", "xref": {"fqname": "rel.rel.tick", "project": null}}, {"name": "rel.timeout", "xref": {"fqname": "rel.rel.timeout", "project": null}}, {"name": "rel.write", "xref": {"fqname": "rel.rel.write", "project": null}}]}, {"name": "rel.version", "documentation": [], "functions": [], "variables": [{"name": "rel.version.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "rel.buff", "documentation": ["This module has a BuffWriter and a convenience function, buffwrite()."], "functions": [{"name": "rel.buff.buffwrite", "asynchronous": false, "params": [{"name": "sock", "type": null, "default": null}, {"name": "data", "type": null, "default": null}, {"name": "sender", "type": null, "default": null}, {"name": "onerror", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "rel.buff.WMAX", "type": null, "documentation": []}, {"name": "rel.buff.writings", "type": null, "documentation": []}], "classes": [{"name": "rel.buff.BuffWrite", "bases": ["object"], "methods": [{"name": "rel.buff.BuffWrite.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "data", "type": null, "default": null}, {"name": "sender", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.buff.BuffWrite.log", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*msg", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.buff.BuffWrite.reset", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.buff.BuffWrite.write", "asynchronous": false,