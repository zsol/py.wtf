rel.supported_methods", "type": null, "documentation": []}, {"name": "rel.rel.mapping", "type": null, "documentation": []}, {"name": "rel.rel.SAFE_READ", "type": null, "documentation": []}], "classes": [{"name": "rel.rel.Thread_Checker", "bases": ["object"], "methods": [{"name": "rel.rel.Thread_Checker.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "threaded", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.rel.Thread_Checker.go", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.rel.Thread_Checker.stop", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.rel.Thread_Checker.release", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.rel.Thread_Checker.check", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "rel.util", "documentation": ["This module contains five functions: emit(), ask(), listen(),\nwhen(), and transpire().\n\n### listen(channel, cb)\nThis function registers a listener callback on a channel.\n\n### emit(channel, *args, **kwargs)\nThis function emits an event to all listen()ers on a channel.\n\n### ask(channel, *args, **kwargs)\nThis function requests an answer from the first registered\nlisten()er on a channel.\n\n### when(event, cb, *args, **kwargs)\nThis function calls cb if an event has transpire()d or\nregisters it to be called the first time it transpire()s.\n\n### transpire(event)\nThis function triggers any when()-registered event\nlisteners, and notes that the event has transpired."], "functions": [{"name": "rel.util.loudListen", "asynchronous": false, "params": [{"name": "isloud", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.util.notListening", "asynchronous": false, "params": [{"name": "variety", "type": null, "default": null}, {"name": "channel", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.util.emit", "asynchronous": false, "params": [{"name": "channel", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.util.ask", "asynchronous": false, "params": [{"name": "channel", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.util.listen", "asynchronous": false, "params": [{"name": "channel", "type": null, "default": null}, {"name": "cb", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.util.when", "asynchronous": false, "params": [{"name": "event", "type": null, "default": null}, {"name": "cb", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rel.util.transpire", "asynchronous": false, "params": [{"name": "event", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "rel.util.listeners", "type": null, "documentation": []}, {"name": "rel.util.happenings", "type": null, "documentation": []}, {"name": "rel.util.LOUD", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "rel", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "rel.__version__", "xref": {"fqname": "rel.version.__version__", "proje