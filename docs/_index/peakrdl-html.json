lse, "params": [{"name": "node", "type": {"name": "Node", "xref": {"fqname": "systemrdl.node.Node", "project": null}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Test if node has a description defined"]}, {"name": "peakrdl_html.exporter.friendly_access", "asynchronous": false, "params": [{"name": "obj", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Convert access types into a human-friendly string"]}, {"name": "peakrdl_html.exporter.has_enum_encoding", "asynchronous": false, "params": [{"name": "field", "type": {"name": "FieldNode", "xref": {"fqname": "systemrdl.node.FieldNode", "project": null}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Test if field is encoded with an enum"]}, {"name": "peakrdl_html.exporter.reg_fields_are_low_to_high", "asynchronous": false, "params": [{"name": "node", "type": {"name": "RegNode", "xref": {"fqname": "systemrdl.node.RegNode", "project": null}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "peakrdl_html.exporter.copy_recursive", "asynchronous": false, "params": [{"name": "src", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "dst", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["distutils.dir_util.copy_tree is deprecated, 