null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "peakrdl_html.search_indexer.SearchIndexer.add_word", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "word", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "page_id", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "loc_code", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "peakrdl_html.search_indexer.SearchIndexer.get_shorthash", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prefix", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "peakrdl_html.search_indexer.SearchIndexer.write_index_js", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "output_dir", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Writes out js files\n\nOne or more bucket files (bkt-#.json):\n    {\n        \"word_prefix\": [    # bucket entry\n            [               # word entry\n                \"word\",\n                [           # List of word locations\n                    [page_id, location_code],\n                    [page_id, location_code],\n                