 law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n\n[git repository]: https://github.com/hat-open/hat-doit.git\n[hat open]: https://hat-open.com\n[kon\u010dar digital]: https://www.koncar.hr/en\n[pydoit]: https://pydoit.org\n[pypi project]: https://pypi.org/project/hat-doit\n"], "modules": [{"name": "hat.doit.pep517", "documentation": [], "functions": [{"name": "hat.doit.pep517.build_wheel", "asynchronous": false, "params": [{"name": "wheel_directory", "type": null, "default": null}, {"name": "config_settings", "type": null, "default": "..."}, {"name": "metadata_directory", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hat.doit.pep517.build_editable", "asynchronous": false, "params": [{"name": "wheel_directory", "type": null, "default": null}, {"name": "config_settings", "type": null, "default": "..."}, {"name": "metadata_directory", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hat.doit.pep517.build_sdist", "asynchronous": false, "params": [{"name": "sdist_directory", "type": null, "default": null}, {"name": "config_settings", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hat.doit.pep517.get_requires_for_build_wheel", "asynchronous": false, "params": [{"name": "config_settings", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hat.doit.pep517.get_requires_for_build_editable", "asynchronous": false, "params": [{"name": "config_settings", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hat.doit.pep517._build_wheel", "asynchronous": false, "params": [{"name": "whl_dir", "type": null, "default": null}, {"name": "editable", "type": null, "default": null}], "return