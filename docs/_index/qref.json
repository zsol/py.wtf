lueError: if `version` does not match any known version schema."]}], "variables": [{"name": "qref.SCHEMA_GENERATORS", "type": null, "documentation": []}, {"name": "qref.MODELS", "type": null, "documentation": []}, {"name": "qref.LATEST_SCHEMA_VERSION", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "qref.generate_program_schema", "xref": {"fqname": "qref.generate_program_schema", "project": null}}, {"name": "qref.SchemaV1", "xref": {"fqname": "qref.schema_v1.SchemaV1", "project": null}}, {"name": "qref.verify_topology", "xref": {"fqname": "qref.verification.verify_topology", "project": null}}]}, {"name": "qref.experimental.rendering", "documentation": ["Experimental visualization capabilities for QREF.\n\nCurrently, the visualizations are done with graphviz, which does not suport\nhierarchical structures. Therefore, we have to use a somewhat hacky representation\nof our routines:\n\n- The leaf nodes are drawn as a single graphviz node (this is not surprising) with\n  Mrecord shape. This allows to visually separate routine name from its ports.\n- The non-leaf nodes are represented as clusters.\n  - Clusters can't use Mrecord shape, and so the ports are drawn as separate nodes.\n  - Input and output ports are grouped into subgraphs with the same rank, which\n    forces all inputs / all outputs to be placed in a single column.\n\nBecause of the above dichotomy, care has to be taken when constructing edges.\n- If addressing port of a leaf, it must be specified as graphviz port, e.g:\n  \"root.child:in_0\"\n- If addressing port of a non-leaf, you use normal node reference, e.g:\n  \"root.child.in_0\"", "Copyright 2024 PsiQuantum, Corp.", "Licensed under the Apache License, Version 2.0 (the \"License\");", "you may not use this file except in compliance with the License.", "You may obtain a copy of the License at", "http://www.apache.org/licenses/LICENSE-2.0", "Unless required by applicable law or agreed to in writing, software", "distributed under the License is distributed on an \"AS IS\" BASIS,", "WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.", "See the License for the specific language governing permissions and", "limitations under the License."], "functions": [{"name": "qref.experimental.rendering._format_node_name", "asynchronous": false, "params": [{"name": "node_name", "type": null, "default": null}, {"name": "parent", "type": null, "default": null}, {"name": "full_path", "type": null, "default": null}], "returns": null, "documentation": ["Given a node name and a parent container, format it accordingly.\n\nRead the module-level docstring for explanation why different port formats\nof ports are being used."]}, {"name": "qref.experimental.rendering._add_nonleaf_ports", "asynchronous": false, "params": [{"name": "ports", "type": null, "default": null}, {"name": "parent_cluster", "type": null, "default": null}, {"name": "parent_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "group_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "qref.experimental.rendering._split_ports", "asynchronous": false, "params": [{"name": "ports", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "qref.experimental.rendering._add_nonleaf", "asynchronous": false, "params": [{"name": "routine", "type": null, "default": null}, {"name": "dag", "type": {"name": "graphviz.Digraph", "xref": {"fqname": "graphviz.Digraph", "project": "graphviz"}, "params": null}, "default": null}, {"name": "parent_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "qref.experimental.rendering._ports_row", "asynchronous": false, "params": [{"name": "ports", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "qref.experimental.rendering._add_leaf", "asynchronous": false, "params": [{"name": "routine", "type": null, "default": null}, {"name": "dag", "type": {"name": "graphviz.Digraph", "xref": {"fqname": "graphviz.Digraph", "project": "graphviz"}, "params": null}, "default": null}, {"name": "parent_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "qref.experimental.rendering._add_routine", "asynchronous": false, "params": [{"name": "routine", "type": null, "default": null}, {"name": "dag", "type": {"name": "graphviz.Digraph", "xref": {"fqname": "graphviz.Digraph", "project": "graphviz"}, "params": null}, "default": null}, {"name": "parent_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "qref.experimental.rendering.to_graphviz", "asynchronous": false, "params": [{"name": "routine", "type": {"name": "RoutineV1", "xref": {"fqname": "qref.schema_v1.RoutineV1", "project": null}, "params": null}, "default": null}], "returns": {"name": "graphviz.Digraph", "xref": {"fqname": "graphviz.Digraph", "project": "graphviz"}, "params": null}, "documentation": ["Convert routine encoded with v1 schema to a graphviz DAG."]}, {"name": "qref.experimental.rendering.render_entry_point", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "qref.experimental.rendering.GRAPH_ATTRS", "type": null, "documentation": []}, {"name": "qref.experimental.rendering.LEAF_NODE_KWARGS", 