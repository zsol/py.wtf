gitValidator.validate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "document", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "gms_cli.utils.NumberValidator", "bases": ["Validator"], "methods": [{"name": "gms_cli.utils.NumberValidator.validate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "document", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "gms_cli", "documentation": ["cli-gms\n=======\n\ncli-gms is a command-line gym management system (GMS) application. \nIt provides a user-friendly interface for managing members, their plans, packages, and payments. \nThe application also allows you to view member details, payment history, and plan details. \n\nThe CLI application is built using Python and leverages the Click library for command-line interface functionality. \nIt stores data in a MySQL database and uses the Rich library for enhanced user interface experience."], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "gms_cli.main", "documentation": [], "functions": [{"name": "gms_cli.main.gms", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "gms_cli.main.view_members", "asynchronous": false, "params": [], "returns": null, "documentation": ["Displays a list of all members along with their details in a tabular format.\n\nThe table includes the following columns: Serial Number, Member Name, Gender,\nDate of Birth, Phone, and Status. The data is retrieved from the database."]}, {"name": "gms_cli.main.add_member", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gms_cli.main.manage_members", "asynchronous": false, "params": [], "returns": null, "documentation": ["Provides options to manage members in the gym management system.\n\nOptions:\n\n1. Add Members   - Adds new members to the system.\n2. Modify Member - Modifies existing member details.\n3. Delete Member - Deletes existing members from the system."]}, {"name": "gms_cli.main.view_member_plan", "asynchronous": false, "params": [{"name": "member_id", "type": null, "default": null}], "returns": null, "documentation": ["Displays the plan details of a specific member.\n\nRetrieves the member's plan information from the database using their ID,\nand displays it in a formatted table. If the member ID is invalid, an error\nmessage is printed.\n\nArgs:\n    member_id : The ID of the member whose plan details are to be viewed."]}, {"name": "gms_cli.main.manage_packages", "asynchronous": false, "params": [], "returns": null, "documentation": ["Manages the packages available in the gym.\n\nOptions:\n1. Add Package    - Adds a new package to the system with details such as name, duration, amount, and training type.\n2. Modify Package - Modifies existing package details. Requires package ID and allows modification of name, duration, amount, and training type.\n3. Delete Package - Deletes selected packages from the system.\n\nThe user is prompted to select an option and provide necessary inputs for the chosen action."]}, {"name": "gms_cli.main.view_packages", "asynchronous": false, "params": [], "returns": null, "documentation": ["Displays a list of all packages in the gym.\n\nRetrieves the package details from the database and displays them in a\nformatted table. The table includes the following columns: Serial Number,\nPackage Name, Duration, Amount, and Training Type."]}, {"name": "gms_cli.main.view_payment_history", "asynchronous": false, "params": [], "returns": null, "documentation": ["Displays the payment history of all members in the gym management system.\n\nRetrieves the payment details from the database and displays them in a\nformatted table. The table includes the following columns: Member Name,\nPackage Name, Payment Amount, Payment Date, and Payment Mode."]}, {"name": "gms_cli.main.reset_database", "asynchronous": false, "params": [], "returns": null, "documentation": ["Resets the entire database.\n\nThis will delete all data in the database. Only use this if you want to\nstart fresh or if you are having some issues with your database."]}, {"name": "gms_cli.main.manage_member_plan", "asynchronous": false, "params": [{"name": "member_id", "type": null, "default": null}], "returns": null, "documentation": ["Manages the plan of a member in the gym.\n\nAllows the user to create a new plan, renew an existing plan, remove an existing\nplan, or make a payment for the plan.\n\nArgs:\n    member_id : The ID of the member for whom the plan needs to be managed."]}], "variables": [{"name": "gms_cli.main.database", "type": null, "documentation": []}, {"name": "gms_cli.main.console", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "gms_cli.database", "documentation": [], "functions": [], "variables": [{"name": "gms_cli.database.MEMBER_DETAILS", "type": null, "documentation": []}, {"name": "gms_cli.database.CURRENT_PLAN", "type": null, "documentation": []}, {"name": "gms_cli.database.RENEWED_PLAN", "type": null, "documentation": []}, {"name": "gms_cli.database.EXPIRED_PLAN", "type": null, "documentation": []}, {"name": "gms_cli.database.PACKAGES", "type": null, "documentation": []}, {"name": "gms_cli.database.PAYMENT_HISTORY", "type": null, "documentation": []}, {"name": "gms_cli.database.DATABASE_TABLES", "type": null, "documentation": []}], "classes": [{"name": "gms_cli.database.Database", "bases": [], "methods": [{"name": "gms_cli.database.Database.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project