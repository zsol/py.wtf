tion": []}, {"name": "class_registry.Registry", "bases": ["dict"], "methods": [{"name": "class_registry.Registry.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key_name", "type": null, "default": "..."}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "class_registry.Registry.register", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "klass", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "class_registry.Registry.unregister", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "klass", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "class_registry.Registry._get_key_from_class", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "klass", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "class_registry.Registry.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": ["The registry is a dictionary. Raising `NotRegistered` instead of\na `KeyError` seems more appropriate."]}, {"name": "class_registry.Registry.get_registered_class", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "class_registry.Registry.classes", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Dictionary like object representing a collection of objects.\n\nTo add items to the registry, decorate the class with the `register`\nmethod.\n\nmy_registry = Registry()\n\n@my_registry.register\nclass Example(object):\n\n> key = 'HDR0'\n\nThen when you'll be able to get the registered class back out of the\nregistry by accessing it like a dictionary with the key\n\\>>> my_registry['HDR0']\n\\<class 'path.to.module.Example'>\n"]}], "exports": []}]}