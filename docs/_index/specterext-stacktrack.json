env\n# or do this instead to avoid 3.10, as it isn't yet supported\n# $ virtualenv --python=python3.9 .env\n$ source .env/bin/activate\n$ pip3 install -r requirements.txt\n$ pip3 install -e .\n$ python3 setup.py install\n$ pip3 install cryptoadvance.specter\n$ python3 -m cryptoadvance.specter server --config DevelopmentConfig --debug\n```\n\nThen point your browser to http://localhost:25441 and choose Services &rarr; StackTrack.\n\n## Development\n\nRunning unit tests:\n\n```shell\n$ pytest\n```\n"], "modules": [{"name": "cryptoadvance.specterext.stacktrack.service", "documentation": [], "functions": [], "variables": [{"name": "cryptoadvance.specterext.stacktrack.service.logger", "type": null, "documentation": []}], "classes": [{"name": "cryptoadvance.specterext.stacktrack.service.StacktrackService", "bases": ["Service"], "methods": [{"name": "cryptoadvance.specterext.stacktrack.service.StacktrackService.callback_after_serverpy_init_app", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "scheduler", "type": {"name": "APScheduler", "xref": {"fqname": "flask_apscheduler.APScheduler", "project": null}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "cryptoadvance.specterext.stacktrack.service.StacktrackService.callback_add_wallettabs", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "documentation": ["'type' object not subscriptable in Python 3.7, so just use bare list.", "def callback_add_wallettabs(self) -> list[dict[str, str]]:"]}, {"name": "cryptoadvance.specterext.stacktrack.service.StacktrackService.callback_adjust_view_model", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "view_model", "type": {"name": "WalletsOverviewVm", "xref": {"fqname": "cryptoadvance.specter.server_endpoints.wallets.wallets_vm.