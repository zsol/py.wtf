!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\n% !! source digest: sha256:36a760d26275a450f243a1983580ab56329ed798c90fd944603a926c108d3919\n% !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\n\n{{ badge1 }} {{ badge2 }} {{ badge3 }} {{ badge4 }} {{ badge5 }}\n\n**Italiano**\n\nTabella con codici tipo documento previsti dall'Agenzia delle Entrate.\n\n**English**\n\nDocument type table with codes as provided for by the Italian Revenue Agency.\n\n**Table of contents**\n\n```{contents}\n:local: true\n```\n\n## Configuration\n\n**Italiano**\n\nPer configurare i tipi di documento fiscale selezionare:\n\nContabilit\u00e0 \u2192 Configurazione \u2192 Contabilit\u00e0 \u2192 Localizzazione italiana \u2192 Tipi documento fiscale\n\n**Inglese**\n\nYou can configure fiscal document types choosing:\n\nAccounting \u2192 Configuration \u2192 Accounting \u2192 Italian Localization \u2192 Fiscal document types\n\n## Bug Tracker\n\nBugs are tracked on [GitHub Issues](https://github.com/OCA/l10n-italy/issues).\nIn case of trouble, please check there if your issue has already been reported.\nIf you spotted it first, help us to smash it by providing a detailed and welcomed\n[feedback](https://github.com/OCA/l10n-italy/issues/new?body=module:%20l10n_it_fiscal_document_type%0Aversion:%2012.0%0A%0A**Steps%20to%20reproduce**%0A-%20...%0A%0A**Current%20behavior**%0A%0A**Expected%20behavior**).\n\nDo not contact contributors directly about support or help with technical issues.\n\n## Credits\n\n### Authors\n\n- Link It srl\n\n### Contributors\n\n- Alessandro Camilli \\<<mailto:alessandrocamilli@openforce.it>>\n- Lorenzo Battistini \\<<mailto:lorenzo.battistini@agilebg.com>>\n- Gianmarco Conte \\<<mailto:gconte@dinamicheaziendali.it>>\n- Sergio Zanchetta \\<<https://github.com/primes2h>>\n\n### Other credits\n\nThe development of this module has been financially supported by:\n\n- Odoo Italia Network\n\n### Maintainers\n\nThis module is maintained by the OCA.\n\n```{image} https://odoo-community.org/logo.png\n:alt: Odoo Community Association\n:target: https://odoo-community.org\n```\n\nOCA, or the Odoo Community Association, is a nonprofit organization whose\nmission is to support the collaborative development of Odoo features and\npromote its widespread use.\n\nThis module is part of the [OCA/l10n-italy](https://github.com/OCA/l10n-italy/tree/12.0/l10n_it_fiscal_document_type) project on GitHub.\n\nYou are welcome to contribute. To learn how please visit <https://odoo-community.org/page/Contribute>.\n"], "modules": [{"name": "odoo.addons.l10n_it_fiscal_document_type.models.account_fiscal_position", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.l10n_it_fiscal_document_type.models.account_fiscal_position.AccountFiscalPosition", "bases": ["models.Model"], "methods": [], "class_variables": [{"name": "odoo.addons.l10n_it_fiscal_document_type.models.account_fiscal_position.AccountFiscalPosition._inherit", "type": null, "documentation": []}, {"name": "odoo.addons.l10n_it_fiscal_document_type.models.account_fiscal_position.AccountFiscalPosition.fiscal_document_type_id", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "odoo.addons.l10n_it_fiscal_document_type.models", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "odoo.addons.l10n_it_fiscal_document_type.models.account_fiscal_position", "xref": {"fqname": "odoo.addons.l10n_it_fiscal_document_type.models..account_fiscal_position", "project": null}}, {"name": "odoo.addons.l10n_it_fiscal_document_type.models.account_invoice", "xref": {"fqname": "odoo.addons.l10n_it_fiscal_document_type.models..account_invoice", "project": null}}, {"name": "odoo.addons.l10n_it_fiscal_document_type.models.fiscal_document_type", "xref": {"fqname": "odoo.addons.l10n_it_fiscal_document_type.models..fiscal_document_type", "project": null}}, {"name": "odoo.addons.l10n_it_fiscal_d