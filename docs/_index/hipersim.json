{"name": "hipersim", "metadata": {"name": "hipersim", "version": "0.1.7", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": null, "license": null, "documentation_url": null, "dependencies": ["xarray", "netcdf4", "h5netcdf", "scipy", "tqdm", "matplotlib"], "summary": "A collection of wind energy simulation tools", "upload_time": 1730458539}, "documentation": ["# Hipersim\n\n## Introduction\nHipersim is a collection of tools for computationally-efficient simulation of Wind Energy problems using statistical and machine learning methods. Currently, the package contains the following submodules:\n\n- **turbgen**: \n    - Generation of 3D frozen turbulence fields (\"turbulence boxes\") with the Mann turbulence spectrum\n    - Constrained turbulence field generation and application of constraints on pre-generated turbulence fields\n\n- **surrogates**:\n    - A feedforward neural network toolbox, training and evaluation of feedforward neural networks. \n\t- A set of tools for surrogate-based modeling and analysis of wind farms\n\n## Links\n\n- [Online documentation of new interface](https://hipersim.pages.windenergy.dtu.dk/hipersim/)\n- [Manual describing old interface + theory references]( https://gitlab.windenergy.dtu.dk/HiperSim/hipersim/-/blob/master/doc/Turbgen_Manual_0.0.24.pdf?ref_type=heads)\n- [MIT License](https://gitlab.windenergy.dtu.dk/TOPFARM/PyWake/blob/master/LICENSE)\n\n"], "modules": [{"name": "hipersim.surrogates.os_utils", "documentation": ["Created on Thu Sep 30 16:31:27 2021\n\n@author: nkdi", "-*- coding: utf-8 -*-"], "functions": [{"name": "hipersim.surrogates.os_utils.load_packaged_model", "asynchronous": false, "params": [{"name": "model_file", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "hipersim.surrogates", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "hipersim.surrogates.farm_utils", "documentation": ["Created on Mon Sep 27 23:07:00 2021\n\n@author: nkdi", "-*- coding: utf-8 -*-"], "functions": [{"name": "hipersim.surrogates.farm_utils.TrigonometricToAzimuth", "asynchronous": false, "params": [{"name": "Theta", "type": null, "default": null}, {"name": "AzimuthToTrigonometric", "type": null, "default": "..."}, {"name": "Rad", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim.surrogates.farm_utils.FarmUpwindDisturbances", "asynchronous": false, "params": [{"name": "ThetaRange", "type": null, "default": null}, {"name": "TurbineIDs", "type": null, "default": null}, {"name": "TurbinePosLon", "type": null, "default": null}, {"name": "TurbinePosLat", "type": null, "default": null}, {"name": "OutputTurbineIDs", "type": null, "default": "..."}, {"name": "ThetaRelRange", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim.surrogates.farm_utils.CircularMean_D", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.surrogates.farm_utils.EncodeWindFarmGeometry", "asynchronous": false, "params": [{"name": "TurbinePosLon", "type": null, "default": null}, {"name": "TurbinePosLat", "type": null, "default": null}, {"name": "ThetaRange", "type": null, "default": null}, {"name": "method", "type": null, "default": "..."}, {"name": "inputs", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "hipersim._hipersim", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "hipersim._hipersim.MannTurbulenceField", "bases": ["MannTurbulenceInput"], "methods": [{"name": "hipersim._hipersim.MannTurbulenceField.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "uvw", "type": null, "default": null}, {"name": "alphaepsilon", "type": null, "default": null}, {"name": "L", "type": null, "default": null}, {"name": "Gamma", "type": null, "default": null}, {"name": "Nxyz", "type": null, "default": null}, {"name": "dxyz", "type": null, "default": null}, {"name": "seed", "type": null, "default": "..."}, {"name": "HighFreqComp", "type": null, "default": "..."}, {"name": "double_xyz", "type": null, "default": "..."}, {"name": "n_cpu", "type": null, "default": "..."}, {"name": "random_generator", "type": null, "default": "..."}, {"name": "generator", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.from_netcdf", "asynchronous": false, "params": [{"name": "filename", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.from_hawc2", "asynchronous": false, "params": [{"name": "filenames", "type": null, "default": null}, {"name": "alphaepsilon", "type": null, "default": null}, {"name": "L", "type": null, "default": null}, {"name": "Gamma", "type": null, "default": null}, {"name": "Nxyz", "type": null, "default": null}, {"name": "dxyz", "type": null, "default": null}, {"name": "seed", "type": null, "default": null}, {"name": "HighFreqComp", "type": null, "default": null}, {"name": "double_xyz", "type": null, "default": "..."}, {"name": "generator", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.to_xarray", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return xarray dataarray with u,v,w along x,y,z,uvw axes with all input parameters as attributes:\n- x: In direction of U, i.e. first yz-plane hits wind turbine last\n- y: to the left, when looking in the direction of the wind\n- z: up"]}, {"name": "hipersim._hipersim.MannTurbulenceField.to_netcdf", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "folder", "type": null, "default": "..."}, {"name": "filename", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.to_hawc2", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "folder", "type": null, "default": "..."}, {"name": "basename", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.generate", "asynchronous": false, "params": [{"name": "alphaepsilon", "type": null, "default": "..."}, {"name": "L", "type": null, "default": "..."}, {"name": "Gamma", "type": null, "default": "..."}, {"name": "Nxyz", "type": null, "default": "..."}, {"name": "dxyz", "type": null, "default": "..."}, {"name": "seed", "type": null, "default": "..."}, {"name": "HighFreqComp", "type": null, "default": "..."}, {"name": "double_xyz", "type": null, "default": "..."}, {"name": "n_cpu", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}, {"name": "random_generator", "type": null, "default": "..."}, {"name": "cache_spectral_tensor", "type": null, "default": "..."}], "returns": null, "documentation": ["Generate a MannTurbulenceField\n\nParameters\n----------\nalphaepsilon : float, optional\n    Mann model turbulence parameter $(\\alpha \\varepsilon)^{2/3}$ (Mann, 1994), default is 1.\nL : float, optional\n    Mann model turbulence length scale parameter $L$ (Mann, 1994), default is 33.6\nGamma : float, optional\n    Mann model turbulence anisotropy parameter $\\Gamma$ (Mann, 1994), default is 3.9\nNxyz: (int,int,int)\n    Dimension of the turbulence box in x (longitudinal), y (transveral) and z (vertical) direction.\n    Default is (8192,64,64)\ndxyz : (float, float, float), optional\n    Spacing in meters between data points along the x,y,z coordinates. Default is (1,1,1)\nseed : int, optional\n    Seed number for random generator. Default is 1\nHighFreqComp : bool, optional\n    Defines whether high-frequency compensation is applied. There are three options\n    0 or False (default): No high-frequency compensation applied\n    1 or True: A fast high-Frequency compensation method is applied. This method differs from the method in Mann (1998)\n    2: The high-Frequency compensation method from the C++ version is applied.\n    The method corresponds to Eq. A.6 in Mann (1998) except that the convolution is only applied in the (k2,k3),\n    i.e. -2<=n_l<=2, l=(2,3)\ndouble_xyz : (bool,bool,bool)\n    Defines whether doubling is enabled along the x, y and z direction.\n    When doubling is applied, a box with the double size is generated and the first half is returned. In this\n    way periodicity is avoided.\n    Default is False in the x direction and True in the y and z direction\nn_cpu : int or None, optional\n    Number of CPUs to use for the turbulence generation. Default is 1 (no parallelization).\n    If None, all available CPUs are used.\nverbose : bool\n    If true, status messages and progress bars are printed\nrandom_generator : function or None, optional\n    If None (default), the random generator depends on n_cpu:\n        n_cpu=1: hipersim.turbgen.spectral_tensor.random_generator_seq\n        n_cpu!=1: hipersim.turbgen.spectral_tensor.random_generator_par\n    Alternatively a function, f(MannSpectralTensor) -> RandomNumbers, dim=(3, N1r, N2, N3), can be specified\ncache_spectral_tensor : boolean, optional\n    If True, the spectral tensor is loaded from file if exists otherwise it is calculated and saved to file\n    If False, the spectral tensor is always recalculated\n\nReturns\n-------\nMannTurbulenceField-object"]}, {"name": "hipersim._hipersim.MannTurbulenceField.spectral_vars", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.scale_TI", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "TI", "type": null, "default": null}, {"name": "U", "type": null, "default": null}, {"name": "T", "type": null, "default": "..."}, {"name": "cutoff_frq", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.spectra", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "log10_bin_size", "type": null, "default": "..."}, {"name": "min_bin_count", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.coherence", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dy", "type": null, "default": null}, {"name": "dz", "type": null, "default": null}, {"name": "component", "type": null, "default": "..."}, {"name": "bin_size", "type": null, "default": "..."}, {"name": "min_bin_count", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "z", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim._hipersim.MannTurbulenceField.constrain", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "Constraints", "type": null, "default": null}, {"name": "method", "type": null, "default": "..."}], "returns": null, "documentation": ["===============================================\nAPPLY CONSTRAINTS\n==============================================="]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "hipersim.surrogates.math_utils", "documentation": ["Created on Fri Mar 22 10:37:43 2019\n\n@auth