{"name": "self", "type": null, "default": null}, {"name": "f", "type": null, "default": null}, {"name": "args_lst", "type": null, "default": null}, {"name": "desc", "type": null, "default": null}, {"name": "N", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput._integration_grid", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "k1", "type": null, "default": "..."}, {"name": "k23_resolution", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput._spectra_integrated_k1", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput.spectra_integrated", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "k1", "type": null, "default": "..."}, {"name": "k23_resolution", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput.spectra_lookup", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "k1", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput.get_k", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "Lx", "type": null, "default": "..."}, {"name": "dx", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the wave numbers from 1/Lx*2pi to nyquist frq i.e. Nx/2/Lx*2pi=1/(2dx)*2pi\n\nParameters\n----------\nLx : float, optional\n    Longest resolvable wave length [m]\n    If None, Lx is set to Nx*dx (taken from the box properties)\ndx : float or None\n    Distance, such that shortest resolvable wave = 2*dx\n    If None, dx is set to the grid spacing (taken from the box properties)"]}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput.spectrum_variance", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "Lx", "type": null, "default": "..."}, {"name": "dx", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the variance of the theoretical Mann model spectrum of the current box\n\nParameters\n----------\nLx : float, optional\n    Longest resolvable wave length [m]\n    If None, Lx is set to Nx*dx (taken from the box properties)\ndx : float or None\n    Distance, such that shortest resolvable wave = 2*dx\n    If None, dx is set to the grid spacing (taken from the box properties)"]}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput.spectrum_TI", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "U", "type": null, "default": null}, {"name": "T", "type": null, "default": "..."}, {"name": "cutoff_frq", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the Turbulence intensity of the theoretical Mann model spectrum of the current box\nParameters\n----------\nU : float\n    Wind speed [m/s]\nT : float, int or None, optional\n    Time period [s] that the TI value represents used to calculate the longest resolvable wave, Lx.\n    If None, Lx is set to the box length, Nx*dx (taken from the box properties)\ncutoff_frq : float or None\n    Cutoff frequency of the TI measuring device used to calculate the shortest resolvable wave, 2*dx\n    If None, dx is set to the grid spacing (taken from the box properties)"]}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput._coherence_k1", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput.coherence_integrated", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dy", "type": null, "default": null}, {"name": "dz", "type": null, "default": null}, {"name": "component", "type": null, "default": "..."}, {"name": "k1", "type": null, "default": "..."}, {"name": "k23_resolution", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannTurbulenceInput.get_alpha_epsilon", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "TI", "type": null, "default": null}, {"name": "U", "type": null, "default": null}, {"name": "T", "type": null, "default": "..."}, {"name": "cutoff_frq", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the ae^2/3 value that gives the specified TI for the given box properties (L, Gamma, [Nx], [dx])\n\nParameters\n----------\nTI : float\n    Desired turbulence intensity\nU : float\n    Wind speed [m/s]\nT : float, int or None, optional\n    Time period [s] that the TI value represents used to calculate the longest resolvable wave, Lx.\n    If None, Lx is set to the box length, Nx*dx (taken from the box properties)\ncutoff_frq : float or None\n    Cutoff frequency of the TI measuring device used to calculate the shortest resolvable wave, 2*dx\n    If None, dx is set to the grid spacing (taken from the box properties)"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor", "bases": ["MannTurbulenceInput"], "methods": [{"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "alphaepsilon", "type": null, "default": "..."}, {"name": "L", "type": null, "default": "..."}, {"name": "Gamma", "type": null, "default": "..."}, {"name": "Nxyz", "type": null, "default": "..."}, {"name": "dxyz", "type": null, "default": "..."}, {"name": "HighFreqComp", "type": null, "default": "..."}, {"name": "double_xyz", "type": null, "default": "..."}, {"name": "n_cpu", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}, {"name": "seed", "type": null, "default": "..."}, {"name": "cache_spectral_tensor", "type": null, "default": "..."}], "returns": null, "documentation": ["Generate a MannSpectralTensor\n\nParameters\n----------\nalphaepsilon : float, optional\n    Mann model turbulence parameter $(\\alpha \\varepsilon)^{2/3}$ (Mann, 1994), default is 1.\nL : float, optional\n    Mann model turbulence length scale parameter $L$ (Mann, 1994), default is 33.6\nGamma : float, optional\n    Mann model turbulence anisotropy parameter $\\Gamma$ (Mann, 1994), default is 3.9\nNxyz: (int,int,int)\n    Dimension of the turbulence box in x (longitudinal), y (transveral) and z (vertical) direction.\n    Default is (8192,64,64)\ndxyz : (float, float, float), optional\n    Spacing in meters between data points along the x,y,z coordinates. Default is (1,1,1)\nHighFreqComp : bool, optional\n    Defines whether high-frequency compensation is applied. There are three options\n    0 or False (default): No high-frequency compensation applied\n    1 or True: A fast high-Frequency compensation method is applied. This method differs from the method in Mann (1998)\n    2: The high-Frequency compensation method from the C++ version is applied.\n    The method corresponds to Eq. A.6 in Mann (1998) except that the convolution is only applied in the (k2,k3),\n    i.e. -2<=n_l<=2, l=(2,3)\ndouble_xyz : (bool,bool,bool)\n    Defines whether doubling is enabled along the x, y and z direction.\n    When doubling is applied, a box with the double size is generated and the first half is returned. In this\n    way periodicity is avoided.\n    Default is False in the x direction and True in the y and z direction\nn_cpu : int or None, optional\n    Number of CPUs to use for the turbulence generation. Default is 1 (no parallelization).\n    If None, all available CPUs are used.\nverbose : bool\n    If true, status messages and progress bars are printed\nseed : int, optional\n    Seed number for random generator. Default is 1\ncache_spectral_tensor : boolean, optional\n    If True, the spectral tensor is loaded from file if exists otherwise it is calculated and saved to file\n    If False, the spectral tensor is always recalculated"]}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.generate_spectral_tensor", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor._generate_spectral_tensor_k1", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor._HighFreqCompVarRatio", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "k1", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.generate_uvw", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "seed", "type": null, "default": null}, {"name": "alphaepsilon", "type": null, "default": "..."}, {"name": "random_generator", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.log", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.cache_name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.spectral_vars", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.k1", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.k23", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor.generate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "seed", "type": null, "default": null}, {"name": "alphaepsilon", "type": null, "default": "..."}, {"name": "n_cpu", "type": null, "default": "..."}, {"name": "random_generator", "type": null, "default": "..."}], "returns": null, "documentation": ["Generate turbulence field\n\nParameters\n----------\nseed : int, optional\n    Seed number for random generator\nalphaepsilon : float, optional\n    Mann model turbulence parameter $(\\alpha \\varepsilon)^{2/3}$ (Mann, 1994), default is 1.\nn_cpu : int or None, optional\n    Number of CPUs to use for the turbulence generation.\n    Default is -1 (same number as used to make the spectral tensor).\n    If None, all available CPUs are used.\nrandom_generator : function or None, optional\n    If None (default), the random generator depends on n_cpu:\n        n_cpu=1: hipersim.turbgen.spectral_tensor.random_generator_seq\n        n_cpu!=1: hipersim.turbgen.spectral_tensor.random_generator_par\n    Alternatively a function, f(MannSpectralTensor) -> RandomNumbers, dim=(3, N1r, N2, N3), can be specified\n\nReturns\n-------\nMannTurbulenceField"]}], "class_variables": [{"name": "hipersim.turbgen.spectral_tensor.MannSpectralTensor._spectral_vars", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "hipersim.turbgen.spectral_tensor.OnetimeMannSpectralTensor", "bases": ["MannSpectralTensor"], "methods": [{"name": "hipersim.turbgen.spectral_tensor.OnetimeMannSpectralTensor.spectral_vars", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "hipersim.turbgen.mannspectrum", "documentation": ["Created on Sun Nov 28 22:16:52 2021\n\n@author: nkdi", "-*- coding: utf-8 -*-"], "functions": [{"name": "hipersim.turbgen.mannspectrum.USvaluesMann", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "hipersim.turbgen.mannspectrum.MannSpectrum_TableLookup", "asynchronous": false, "params": [{"name": "Gamma", "type": null, "default": null}, {"name": "L", "type": null, "default": null}, {"name": "alphaepsilon", "type": null, "default": null}, {"name": "kinput", "type": null, "default": "..."}, {"name": "order", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}]}