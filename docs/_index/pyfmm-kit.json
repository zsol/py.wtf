.c_interfaces.PINT", "type": null, "documentation": []}, {"name": "pyfmm.c_interfaces.USE_FLOAT", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["libfmm\u5e93\u4e2d\u8d70\u65f6\u548c\u6162\u5ea6\u6570\u7ec4\u662f\u5426\u4f7f\u7528\u5355\u7cbe\u5ea6\u6d6e\u70b9\u6570"]}, {"name": "pyfmm.c_interfaces.NPCT_REAL_TYPE", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pyfmm.c_interfaces.C_FastMarching", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pyfmm.c_interfaces.C_FMM_raytracing", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pyfmm.c_interfaces.C_FastSweeping", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pyfmm.c_interfaces.C_set_fsm_num_threads", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": []}], "classes": [], "exports": []}, {"name": "pyfmm.traveltime", "documentation": [":file:     traveltime.py  \n:author:   Zhu Dengda (zhudengda@mail.iggcas.ac.cn)  \n:date:     2023-04"], "functions": [{"name": "pyfmm.traveltime.get_FSM_nsweep", "asynchronous": false, "params": [], "returns": null, "documentation": ["\u8fd4\u56de\u4f7f\u7528FSM\u8ba1\u7b97\u8d70\u65f6\u573a\u65f6\uff0csweep\u7684\u6b21\u6570"]}, {"name": "pyfmm.traveltime.travel_time_source", "asynchronous": false, "params": [{"name": "srcloc", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}, {"name": "xarr", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}, {"name": "yarr", "type": {"name": "np.ndarray