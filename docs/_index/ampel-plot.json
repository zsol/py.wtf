"default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.get_ext_name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "ampel_id", "type": {"name": "StockId", "xref": {"fqname": "ampel.types.StockId", "project": null}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["If no id mapper is avail, the stringified ampel id is returned "]}, {"name": "ampel.model.PlotProperties.PlotProperties.get_compression_behavior", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [{"name": "ampel.model.PlotProperties.PlotProperties.file_name", "type": {"name": "FormatModel", "xref": {"fqname": "ampel.model.PlotProperties.FormatModel", "project": null}, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.title", "type": {"name": "None | FormatModel", "xref": null, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.fig_include_title", "type": {"name": "None | bool", "xref": null, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.fig_text", "type": {"name": "None | FormatModel", "xref": null, "params": null}, "documentation": ["for matplotlib"]}, {"name": "ampel.model.PlotProperties.PlotProperties.tags", "type": {"name": "None | Tag | list[Tag]", "xref": null, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.width", "type": {"name": "None | int", "xref": null, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.height", "type": {"name": "None | int", "xref": null, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.compression_behavior", "type": {"name": "None | int", "xref": null, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.compression_alg", "type": {"name": "TCompression", "xref": {"fqname": "ampel.util.compression.TCompression", "project": null}, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.compression_level", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.detached", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.id_mapper", "type": {"name": "None | str | type[AbsIdMapper]", "xref": null, "params": null}, "documentation": []}, {"name": "ampel.model.PlotProperties.PlotProperties.disk_save", "type": {"name": "None | str", "xref": null, "params": null}, "documentation": ["Local folder path"]}, {"name": "ampel.model.PlotProperties.PlotProperties.mpl_kwargs", "type": {"name": "None | dict[str, Any]", "xref": null, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Contains customization values for:\n- given matplotlib properties (width, height, title, ...)\n- properties associated with the figure (save filename and path, compression, tags, ...)\n\nIf id_mapper is set (ex: ZTFIdMapper) and FormatModel.arg_keys contains 'stock',\nthen the native ampel stock id will be converted to the 'external' id.\nNote that for this feature to work, an AmpelContext must have been loaded once.\n\nParameter disk_save is optional and when used, makes sure that plots are additionally save to disk\n(std save procedure saves plots into the DB).\n\nFor example:\n{\n        \"tags\": [\"SALT\", \"SNCOSMO\"],\n        \"file_name\": {\n                \"format_str\": \"%s_%s_fit.svg\",\n                \"arg_keys\": [\"stock\", \"model\"]\n        },\n        \"title\": {\n                \"format_str\": \"%s %s lightcurve fit\",\n                \"arg_keys\": [\"stock\", \"catalog\"]\n        },\n        \"width\": 10,\n        \"height\": 6,\n        \"id_mapper\": \"ZTFIdMapper\",\n        \"disk_save\": \"/tmp/\"\n}\nwill create a file called /tmp/ZTF27dpytkhq_salt2.svg for a transient with internal id 274878346346.\nThe plot title will be \"ZTF27dpytkhq Ned based lightcurve fit\".\n\nNote that it is up to the class using PlotProperties to make sure that\nthe right arguments are passed to the methods get_file_name() or get_title().\nFor example, if arg_keys = [\"stock\", \"model\"] (FormatModel),\nthen {'stock': 123, 'model': 'salt'} must be passed as argument.\n\n\nExamples:\nIn []: a = PlotProperties(**{\"file_name\": {\"format_str\": \"%s_%s_fit.svg\", \"arg_keys\": [\"stock\", \"model\"]}})\n\nIn []: a.get_file_name(extra={'stock': 12345678, 'model': 'salt2'})\nOut[]: '12345678_salt2_fit.svg'\n\n# Note the reversed order of arg_keys\nIn []: a = PlotProperties(**{\"file_name\": {\"format_str\": \"%s_%s_fit.svg\", \"arg_keys\": [\"model\", \"stock\"]}})\n\nIn []: a.get_file_name(extra={'stock': 12345678, 'model': 'salt2'})\nOut[]: 'salt2_12345678_fit.svg'\n\n# Examples using id_mapper (error is intentional, explanation follows):\nIn []: a = PlotProperties(**{\"file_name\": {\"format_str\": \"%s_%s_fit.svg\", \"arg_keys\": [\"model\", \"stock\"]}, \"id_mapper\": \"ZTFIdMapper\"})\n---------------------------------------------------------------------------\nValidationError: 1 validation error for PlotProperties\nid_mapper\n        Unknown auxiliary unit ZTFIdMapper (type=value_error)\n\n# As stated further above, an AmpelContext must have been loaded once for ID mapping to work.\n# For production, you need not worry about this.\n# But you might encounter this error in your local / notebook if you did not load a context.\n\n# The following should fix the error from above:\nIn []: ctx = DevAmpelContext.load(\"ampel_conf.yaml\")\n\n# Then:\nIn []: a = PlotProperties(**{\"file_name\": {\"format_str\": \"%s_%s_fit.svg\", \"arg_keys\": [\"model\", \"stock\"]}, \"id_mapper\": \"ZTFIdMapper\"})\nIn []: a.get_file_name(extra={'stock': 12345678, 'model': 'salt2'})\nOut[]: 'salt2_ZTF31aabrxlc_fit.svg'"]}], "exports": []}, {"name": "ampel.plot.create", "documentation": ["!/usr/bin/env python", "-*- coding: utf-8 -*-", "File:                Ampel-plot/ampel-plot/ampel/plot/create.py", "License:             BSD-3-Clause", "Author:              valery brinnel <firstname.lastname@gmail.com>", "Date:                17.05.2019", "Last Modified Date:  27.04.2022", "Last Modified By:    valery brinnel <firstname.lastname@gmail.com>"], "functions": [{"name": "ampel.plot.create.create_plot_record", "asynchronous": false, "params": [{"name": "mpl_fig", "type": {"name": "Figure", "xref": {"fqname": "matplotlib.figure.Figure", "project": null}, "params": null}, "default": null}, {"name": "props", "type": {"name": "PlotProperties", "xref": {"fqname": "ampel.model.PlotProperties.PlotProperties", "project": null}, "params": null}, "default": null}, {"name": "extra", "type": {"name": "None | dict[str, Any]", "xref": null, "params": null}, "default": "..."}, {"name": "tag_complement", "type": {"name": "None | OneOrMany[Tag]", "xref": null, "params": null}, "default": "..."}, {"name": "close", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "logger", "type": {"name": "None | LoggerProtocol", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "NewSVGRecord", "xref": {"fqname": "ampel.content.NewSVGRecord.NewSVGRecord", "project": null}, "params": null}, "documentation": ["---\nparam extra: required if file_name, title or fig_text in PlotProperties use a format\n  string (\"such\\_%s_this\")\n---\n"]}, {"name": "ampel.plot.create.fig_to_plot_record", "asynchronous": false, "params": [{"name": "mpl_fig", "type": {"name": "Figure", "xref": {"fqname": "matplotlib.figure.Figure", "project": null}, "params": null}, "default": null}, {"name": "file_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "title", "type": {"name": "None | str", "xref": null, "params": null}, "default": "..."}, {"name": "tags", "type": {"name": "None | OneOrMany[Tag]", "xref": null, "params": null}, "default": "..."}, {"name": "compression_behavior", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "compression_alg", "type": {"name": "TCompression", "xref": {"fqname": "ampel.util.compression.TCompression", "project": null}, "params": null}, "default": "..."}, {"name": "compression_level", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "width", "type": {"name": "None | int", "xref": null, "params": null}, "default": "..."}, {"name": "height", "type": {"name": "None | int", "xref": null, "params": null}, "default": "..."}, {"name": "close", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "fig_include_title", "type": {"name": "None | bool", "xref": null, "params": null}, "default": "..."}, {"name": "detached", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "logger", "type": {"name": "None | LoggerProtocol", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "NewSVGRecord", "xref": {"fqname": "ampel.content.NewSVGRecord.NewSVGRecord", "project": null}, "params": null}, "documentation": ["---\nparam compression_behavior: |-\n  0: no compression, 'svg' value will be a string\n  1: compression_behavior svg, 'svg' value will be compressed bytes (usage: store plots into db)\n  2: compression_behavior svg and include uncompressed string into key 'sgv_str'\n  (useful for saving plots into db and additionaly to disk for offline analysis)\nparam height: figure height, for example 10 inches\nparam mpl_fig: matplotlib figure\nparam tags: one or many plot tags\nparam width: figure width, for example 10 inches\nreturns: svg dict instance\n---\n"]}, {"name": "ampel.plot.create.get_tags_as_str", "asynchronous": false, "params": [{"name": "plot_tag", "type": {"name": "None | OneOrMany[Tag]", "xref": null, "params": null}, "default": "..."}, {"name": "extra_tags", "type": {"name": "None | OneOrMany[Tag]", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}]}