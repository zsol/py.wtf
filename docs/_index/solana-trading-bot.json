, "documentation": []}], "classes": [], "exports": []}, {"name": "solana-trading-bot.tools.get_kaiko_data.orderbook_full_data", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "solana-trading-bot.tools.get_kaiko_data.trades_data", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "solana-trading-bot.tools.get_kaiko_data.ohlcvvwap_data", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "solana-trading-bot.tools.notification.email_notification", "documentation": ["Aim: Send email if any new trades are executed during the past 5 minutes.\nIn the email body, include the action taken, and the graph of the traded token."], "functions": [{"name": "solana-trading-bot.tools.notification.email_notification.df_to_html", "asynchronous": false, "params": [{"name": "df", "type": {"name": "pd.DataFrame", "xref": {"fqname": "pandas.DataFrame", "project": null}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.tools.notification.email_notification.send_email", "asynchronous": false, "params": [{"name": "receiver_email_list", "type": null, "default": null}, {"name": "subject", "type": null, "default": null}, {"name": "body", "type": null, "default": null}, {"name": "tables", "type": null, "default": "..."}, {"name": "table_titles", "type": null, "default": "..."}, {"name": "images_paths", "type": null, "default": "..."}], "returns": null, "documentation": ["noinspection PyShadowingNames"]}], "variables": [{"name": "solana-trading-bot.tools.notification.email_notification.data1", "type": null, "documentation": []}, {"name": "solana-trading-bot.tools.notification.email_notification.data2", "type": null, "documentation": []}, {"name": "solana-trading-bot.tools.notification.email_notification.df1", "type": null, "documentation": []}, {"name": "solana-trading-bot.tools.notification.email_notification.df2", "type": null, "documentation": []}, {"name": "solana-trading-bot.tools.notification.email_notification.images_paths", "type": null, "documentation": []}, {"name": "solana-trading-bot.tools.notification.email_notification.params", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip", "documentation": ["According to JUP SOL/USDC price graph, very often the price would dip a bit, example:\nNormal level =106.7, dip level = [102-106].\n\nI don't believe the price can be as low as 80, so I will set a range.\n\nStrategy details:\n1. When there is a dip for once (0.66% - 4.6%), start to buy a fixed amount of SOL instantly\n2. When checked the price went back to normal, sell it instantly - if failed, sell it after 5 seconds\n   after the status is confirmed\n3. If the transaction price is not expected (didn't buy the dip), sell it instantly\n4. How to calculate the dip level? I will compare the latest price with the average of the past 20 prices\n5. Every 2 transactions should have at least 1 minute interval\n\n\nReminders:\n1. Always leave 0.1 SOL in the account for transaction fee\n2. If you have bought SOL, but somehow didn't trigger the sell, after 15 seconds, sell it\n3. If the transaction price is not expected, sell it\n4. Always check the balance before buying or selling\n5. Always record the gas fee\n6. When started the program, self.records_for_trading should always be more than 30 rows before making any decision\n7. When initializing the program, always check if the balance is correct, if there is no USDC, don't start the program\n   or sell all the SOL"], "functions": [], "variables": [{"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.base", "type": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.quote", "type": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.dip_level", "type": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.upload_records_measurement_name", "type": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.bucket_name", "type": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.TMP_DATABASE_DIR", "type": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.file_path", "type": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.records_path", "type": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.strategy", "type": null, "documentation": []}], "classes": [{"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip", "bases": [], "methods": [{"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "base", "type": null, "default": null}, {"name": "quote", "type": null, "default": null}, {"name": "dip_level", "type": null, "default": null}, {"name": "upload_records_measurement_name", "type": null, "default": null}, {"name": "bucket_name", "type": null, "default": null}, {"name": "abnormal_price_range", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.__get_unit_buy_price", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.__get_unit_buy_price_every_second", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["This function will be called twice every second"]}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.__detect_back_to_normal", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.__detect_dip", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.__transaction_status", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.__buy_instantly", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.__sell_instantly", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.execute_transaction", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "solana-trading-bot.all_strategies.strategy_buy_dip.strategy_buy_dip.BuyInstantDip.run_strategy", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["noinspection PyShadowingNames"]}], "exports": []}, {"name": "solana-trading-bot.tools.exceptions_in_trade", "documentation": [], "functions": [],