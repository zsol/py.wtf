}, {"name": "number_of_feature_filters", "type": null, "default": "..."}, {"name": "number_of_back_projection_stages", "type": null, "default": "..."}, {"name": "convolution_kernel_size", "type": null, "default": "..."}, {"name": "strides", "type": null, "default": "..."}, {"name": "last_convolution", "type": null, "default": "..."}, {"name": "number_of_loss_functions", "type": null, "default": "..."}, {"name": "interpolation", "type": null, "default": "..."}], "returns": null, "documentation": ["define the DBPN network - this uses a model definition that is general to<br>", "both 2D and 3D. recommended parameters for different upsampling rates can<br>", "be found in the papers by Haris et al.  We make one significant change to<br>", "the original architecture by allowing standard interpolation for upsampling<br>", "instead of convolutional upsampling.  this is controlled by the interpolation<br>", "option."]}, {"name": "siq.get_data.get_random_base_ind", "asynchronous": false, "params": [{"name": "full_dims", "type": null, "default": null}, {"name": "patchWidth", "type": null, "default": null}, {"name": "off", "type": null, "default": "..."}], "returns": null, "documentation": ["generate a random corner index for a patch"]}, {"name": "siq.get_data.get_random_patch", "asynchronous": false, "params": [{"name": "img", "type": null, "default": null}, {"name": "patchWidth", "type": null, "default": null}], "returns": null, "documentation": ["extract a random patch"]}, {"name": "siq.get_data.get_random_patch_pair", "asynchronous": false, "params": [{"name": "img", "type": null, "default": null}, {"name": "img2", "type": null, "default": null}, {"name": "patchWidth", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "siq.get_data.pseudo_3d_vgg_features", "asynchronous": false, "params": [{"name": "inshape", "type": null, "default": "..."}, {"name": "layer", "type": null, "default": "..."}, {"name": "angle", "type": null, "default": "..."}, {