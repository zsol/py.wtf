ers.huggingface.provider.HuggingfaceBase._pii_detection_endpoint", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "input", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase._pii_detection_with_cot_reasons_endpoint", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "input", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}]}, {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}]}, "documentation": []}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase._hallucination_evaluator_endpoint", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "input", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase.language_match", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text1", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "text2", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": null}]}, "documentation": ["Uses Huggingface's papluca/xlm-roberta-base-language-detection model.\n\nA function that uses language detection on `text1` and `text2` and\ncalculates the probit difference on the language detected on text1. The\nfunction is: `1.0 - (|probit_language_text1(text1) -\nprobit_language_text1(text2))`\n\nExample:\n    ```python\n    from trulens.core import Feedback\n    from trulens.providers.huggingface import Huggingface\n    huggingface_provider = Huggingface()\n\n    feedback = Feedback(huggingface_provider.language_match).on_input_output()\n    ```\n\nArgs:\n    text1: Text to evaluate.\n\n    text2: Comparative text to evaluate.\n\nReturns:\n    float: A value between 0 and 1. 0 being \"different languages\" and 1\n        being \"same languages\".", "TODEP"]}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase.groundedness_measure_with_nli", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "source", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "statement", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}]}, "documentation": ["A measure to track if the source material supports each sentence in the statement using an NLI model.\n\nFirst the response will be split into statements using a sentence tokenizer.The NLI model will process each statement using a natural language inference model, and will use the entire source.\n\nExample:\n    ```\n    from trulens.core import Feedback\n    from trulens.providers.huggingface import Huggingface\n\n    huggingface_provider = Huggingface()\n\n    f_groundedness = (\n        Feedback(huggingface_provider.groundedness_measure_with_nli)\n        .on(context)\n        .on_output()\n    ```\n\nArgs:\n    source (str): The source that should support the statement\n    statement (str): The statement to check groundedness\n\nReturns:\n    Tuple[float, str]: A tuple containing a value between 0.0 (not grounded) and 1.0 (grounded) and a string containing the reasons for the evaluation."]}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase.context_relevance", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prompt", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "context", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": ["Uses Huggingface's truera/context_relevance model, a\nmodel that uses computes the relevance of a given context to the prompt.\nThe model can be found at https://huggingface.co/truera/context_relevance.\n\nExample:\n    ```python\n    from trulens.core import Feedback\n    from trulens.providers.huggingface import Huggingface\n    huggingface_provider = Huggingface()\n\n    feedback = (\n        Feedback(huggingface_provider.context_relevance)\n        .on_input()\n        .on(context)\n        .aggregate(np.mean)\n        )\n    ```\n\nArgs:\n    prompt (str): The given prompt.\n    context (str): Comparative contextual information.\n\nReturns:\n    float: A value between 0 and 1. 0 being irrelevant and 1 being a relevant context for addressing the prompt."]}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase.positive_sentiment", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": ["Uses Huggingface's cardiffnlp/twitter-roberta-base-sentiment model. A\nfunction that uses a sentiment classifier on `text`.\n\nExample:\n    ```python\n    from trulens.core import Feedback\n    from trulens.providers.huggingface import Huggingface\n    huggingface_provider = Huggingface()\n\n    feedback = Feedback(huggingface_provider.positive_sentiment).on_output()\n    ```\n\nArgs:\n    text (str): Text to evaluate.\n\nReturns:\n    float: A value between 0 (negative sentiment) and 1 (positive sentiment).", "TODEP"]}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase.toxic", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": ["A function that uses a toxic comment classifier on `text`.\n\nUses Huggingface's martin-ha/toxic-comment-model model.\n\nExample:\n    ```python\n    from trulens.core import Feedback\n    from trulens.providers.huggingface import Huggingface\n\n    huggingface_provider = Huggingface()\n    feedback = Feedback(huggingface_provider.toxic).on_output()\n    ```\n\nArgs:\n    text: Text to evaluate.\n\nReturns:\n    float: A value between 0 (not toxic) and 1 (toxic).", "TODEP"]}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase._summarized_groundedness", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "premise", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "hypothesis", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": ["A groundedness measure best used for summarized premise against\nsimple hypothesis.\n\nThis Huggingface implementation uses NLI.\n\nArgs:\n    premise (str): NLI Premise hypothesis (str): NLI Hypothesis\n\nReturns:\n    float: NLI Entailment", "TODEP"]}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase.pii_detection", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": ["NER model to detect PII.\n\nExample:\n    ```python\n    hugs = Huggingface()\n\n    # Define a pii_detection feedback function using HuggingFace.\n    f_pii_detection = Feedback(hugs.pii_detection).on_input()\n    ```\n\nArgs:\n    text: A text prompt that may contain a PII.\n\nReturns:\n    float: The likelihood that a PII is contained in the input text."]}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase.pii_detection_with_cot_reasons", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["NER model to detect PII, with reasons.\n\nExample:\n    ```python\n    hugs = Huggingface()\n\n    # Define a pii_detection feedback function using HuggingFace.\n    f_pii_detection = Feedback(hugs.pii_detection).on_input()\n    ```\n\n    Args:\n        text: A text prompt that may contain a name.\n\n    Returns:\n        Tuple[float, str]: A tuple containing a the likelihood that a PII is contained in the input text and a string containing what PII is detected (if any)."]}, {"name": "trulens.providers.huggingface.provider.HuggingfaceBase.hallucination_evaluator", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "model_output", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "retrieved_text_chunks", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": ["Evaluates the hallucination score for a combined input of two statements as a float 0<x<1 representing a\ntrue/false boolean. if the return is greater than 0.5 the statement is evaluated as true. if the return is\nless than 0.5 the statement is evaluated as a hallucination.\n\nExample:\n    ```python\n    from trulens.providers.huggingface import Huggingface\n    huggingface_provider = Huggingface()\n\n    score = huggingface_provider.hallucination_evaluator(\"The sky is blue. [SEP] Apples are red , the grass is green.\")\n    ```\n\nArgs:\n    model_output (str): This is what an LLM returns based on the text chunks retrieved during RAG\n\n    retrieved_text_chunks (str): These are th