{"name": "pagefind", "metadata": {"name": "pagefind", "version": "1.3.0", "classifiers": ["License :: OSI Approved :: MIT License", "Programming Language :: Python :: 3", "Programming Language :: Python :: 3.10", "Programming Language :: Python :: 3.11", "Programming Language :: Python :: 3.12", "Programming Language :: Python :: 3.13", "Programming Language :: Python :: 3.9", "Topic :: Text Processing :: Indexing", "Topic :: Text Processing :: Markup :: HTML"], "home_page": null, "license": "MIT", "documentation_url": null, "dependencies": [], "summary": "Python API for Pagefind", "upload_time": 1734487330}, "documentation": ["# `pagefind`\nAn async python API for the [pagefind](https://pagefind.app) binary.\n\n## Installation\n\n```sh\npython3 -m pip install 'pagefind[bin]'\npython3 -m pagefind --help\n```\n\n## Usage\n<!--[[[cog\n  print(\"```py\")\n  print(open('./src/tests/integration.py').read())\n  print(\"```\")\n]]] -->\n```py\nimport asyncio\nimport json\nimport logging\nimport os\nfrom pagefind.index import PagefindIndex, IndexConfig\n\nlogging.basicConfig(level=os.environ.get(\"LOG_LEVEL\", \"INFO\"))\nlog = logging.getLogger(__name__)\nhtml_content = (\n    \"<html>\"\n    \"  <body>\"\n    \"    <main>\"\n    \"      <h1>Example HTML</h1>\"\n    \"      <p>This is an example HTML page.</p>\"\n    \"    </main>\"\n    \"  </body>\"\n    \"</html>\"\n)\n\n\ndef prefix(pre: str, s: str) -> str:\n    return pre + s.replace(\"\\n\", f\"\\n{pre}\")\n\n\nasync def main():\n    config = IndexConfig(\n        root_selector=\"main\", logfile=\"index.log\", output_path=\"./output\", verbose=True\n    )\n    async with PagefindIndex(config=config) as index:\n        log.debug(\"opened index\")\n        new_file, new_record, new_dir = await asyncio.gather(\n            index.add_html_file(\n                content=html_content,\n                url=\"https://example.com\",\n                source_path=\"other/example.html\",\n            ),\n            index.add_custom_record(\n                url=\"/elephants/\",\n                content=\"Some testing content regarding elephants\",\n                language=\"en\",\n                meta={\"title\": \"Elephants\"},\n            ),\n            index.add_directory(\"./public\"),\n        )\n        print(prefix(\"new_file    \", json.dumps(new_file, indent=2)))\n        print(prefix(\"new_record  \", json.dumps(new_record, indent=2)))\n        print(prefix(\"new_dir     \", json.dumps(new_dir, indent=2)))\n\n        files = await index.get_files()\n        for file in files:\n            print(prefix(\"files\", f\"{len(file['content']):10}B {file['path']}\"))\n\n\nif __name__ == \"__main__\":\n    asyncio.run(main())\n\n```\n<!-- [[[end]]] -->\n\n"], "modules": [{"name": "pagefind.service.types", "documentation": [], "functions": [], "variables": [{"name": "pagefind.service.types.InternalRequestPayload", "type": null, "documentation": []}, {"name": "pagefind.service.types.InternalResponsePayload", "type": null, "documentation": []}], "classes": [{"name": "pagefind.service.types.InternalRequestType", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "pagefind.service.types.InternalRequestType.NEW_INDEX", "type": null, "documentation": []}, {"name": "pagefind.service.types.InternalRequestType.ADD_FILE", "type": null, "documentation": []}, {"name": "pagefind.service.types.InternalRequestType.ADD_RECORD", "type": null, "documentation": []}, {"name": "pagefind.service.types.InternalRequestType.ADD_DIR", "type": null, "documentation": []}, {"name": "pagefind.service.types.InternalRequestType.WRITE_FILES", "type": null, "documentation": []}, {"name": "pagefind.service.types.InternalRequestType.GET_FILES", "type": null, "documentation": []}, {"name": "pagefind.service.types.InternalRequestType.DELETE_INDEX", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pagefind.service.types.InternalPagefindServiceCo