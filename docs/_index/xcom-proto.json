nous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "package", "type": {"name": "Package", "xref": {"fqname": "xcom_proto.XcomLAN.protocol.Package", "project": null}, "params": null}, "default": null}], "returns": {"name": "Package", "xref": {"fqname": "xcom_proto.XcomLAN.protocol.Package", "project": null}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["#", "Class abstracting Xcom-LAN TCP network protocol", "#"]}, {"name": "xcom_proto.XcomLAN.XcomLANUDP", "bases": ["XcomAbs"], "methods": [{"name": "xcom_proto.XcomLAN.XcomLANUDP.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "serverIP", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "dstPort", "type": null, "default": "..."}, {"name": "srcPort", "type": null, "default": "..."}], "returns": null, "documentation": ["Package requests are being sent to serverIP : dstPort using UDP protocol.\n\nThe srcPort is needed, because XcomLAN will send the UDP response NOT\nto the corresponding UDP source endpoint (like every fucking server on this\nplanet would do) but rather to <yourIP> : srcPort.\n\nSo in order to make this work, we need to listen on srcPort for incoming\ndata."]}, {"name": "xcom_proto.XcomLAN.XcomLANUDP.sendPackage", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "package", "type": {"name": "Package", "xref": {"fqname": "xcom_proto.XcomLAN.protocol.Package", "project": null}, "params": null}, "default": null}], "returns": {"name": "Package", "xref": {"fqname": "xcom_proto.XcomLAN.protocol.Package", "project": null}, "params": null}, "documentation": []}, {"name": "xcom_proto.XcomLAN.XcomLANUDP._awaitUDPResponse", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "udpSocket", "type