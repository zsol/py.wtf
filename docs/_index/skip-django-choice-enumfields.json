t to string\nto enable integers to be serialized natively."]}, {"name": "enumfields.fields.EnumFieldMixin.get_default", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "enumfields.fields.EnumFieldMixin.deconstruct", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "enumfields.fields.EnumFieldMixin.get_choices", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "include_blank", "type": null, "default": "..."}, {"name": "blank_choice", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "enumfields.fields.EnumFieldMixin.formfield", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "form_class", "type": null, "default": "..."}, {"name": "choices_form_class", "type": null, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "enumfields.fields.EnumFieldMixin.validate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": null, "default": null}, {"name": "model_instance", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "enumfields.fields.CharEnumField", "bases": ["EnumFieldMixin", "models.CharField"], "methods": [{"name": "enumfields.fields.CharEnumField.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "enum", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "enumfields.fields.IntegerEnumField", "bases": ["EnumFieldMixin",