t_generics.TestBulkAPIView", "bases": ["TestCase"], "methods": [{"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.setUp", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that GET request is successful on bulk view."]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_post_single", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that POST request with single resource only creates a single resource."]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_post_bulk", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that POST request with multiple resources creates all posted resources."]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_put", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that PUT request updates all submitted resources."]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_put_without_update_key", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that PUT request updates all submitted resources."]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_patch", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that PATCH request partially updates all submitted resources."]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_delete_not_filtered", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that DELETE is not allowed when results are not filtered."]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_delete_filtered", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that DELETE removes all filtered resources."]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIView.test_options", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that OPTIONS request is successful on bulk view."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet", "bases": ["TestCase"], "methods": [{"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet.setUp", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet.test_get_single", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that we are still able to query single resource"]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet.test_get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that GET returns 200"]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet.test_post_single", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that POST with single resource returns 201"]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet.test_post_bulk", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that POST with multiple resources returns 201"]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet.test_put", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that PUT with multiple resources returns 200"]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet.test_patch", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that PATCH with multiple partial resources returns 200"]}, {"name": "rest_framework_bulk.tests.test_generics.TestBulkAPIViewSet.test_delete", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test that PATCH with multiple partial resources returns 200"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Integration class testing that viewset requests are correctly\nrouted via bulk router and that expected status code is returned."]}], "exports": []}, {"name": "rest_framework_bulk.models", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "rest_framework_bulk.drf3.mixins", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "rest_framework_bulk.drf3.mixins.BulkCreateModelMixin", "bases": ["CreateModelMixin"], "methods": [{"name": "rest_framework_bulk.drf3.mixins.BulkCreateModelMixin.create", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "request", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rest_framework_bulk.drf3.mixins.BulkCreateModelMixin.perform_bulk_create", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "seri