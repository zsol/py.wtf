": null, "documentation": ["(Re)Load config file."]}, {"name": "yamlconf.config.Config.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "var", "type": null, "default": null}, {"name": "section", "type": null, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Retrieve a config var.\nReturn environment variable if it exists\n(ie [self.prefix + \\_] + [section + \\_] + var)\notherwise var from config file.\n\nIf both are null and no default is set a ConfigError will be raised,\notherwise default will be returned.\n\n```\nparam var\n\nkey to look up\n\nparam default\n\ndefault value, must be supplied as keyword\n```\n"]}, {"name": "yamlconf.config.Config.keys", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": "..."}], "returns": null, "documentation": ["Provide dict like keys method"]}, {"name": "yamlconf.config.Config.items", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": "..."}], "returns": null, "documentation": ["Provide dict like items method"]}, {"name": "yamlconf.config.Config.values", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": "..."}], "returns": null, "documentation": ["Provide dict like values method"]}, {"name": "yamlconf.config.Config.__copy__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yamlconf.config.Config.copy", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Raise error"]}, {"name": "yamlconf.config.Config.__deepcopy__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "memo", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yamlconf.config.Config._get_filepath", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "filename", "type": null, "default": "..."}, {"name": "config_dir", "type": null, "default": "..."}], "returns": null, "documentation": ["Get config file.\n\n> ```\n> param filename\n>\n> name of config file (not path)\n>\n> param config_dir\n>\n> dir name prepended to file name.\n> ```\n\nNote: we use e.g. GBR_CONFIG_DIR here, this is the default\nvalue in GBR but it is actually self.env_prefix + '\\_DIR' etc.\n\nIf config_dir is not supplied it will be set to the value of the\nenvironment variable GBR_CONFIG_DIR or None.\n\nIf filename is not supplied and the environment variable GBR_CONFIG\nis set and contains a path, its value will be tested to see if a file\nexists, if so that is returned as the config file otherwise filename\nwill be set to GBR_CONFIG, if it exists, otherwise 'config.yaml'.\n\nIf a filename is supplied or GBR_CONFIG is not an existing file:\n\n> If the environment variable GBR_CONFIG_PATH exists the path\n> GBR_CONFIG_PATH/config_dir/filename is checked.\n>\n> If it doesn't exist config/CONFIG_DIR/filename is checked\n>\n> : (relative to the root of the (GBR) repo)\n>\n> finally GBR_CONFIG_DEFAULT/CONFIG_DIR/filename is tried\n\nIf no file is found None will be returned.\n"]}], "class_variables": [{"name": "yamlconf.config.Config.default_file", "type": null, "documentation": []}, {"name": "yamlconf.config.Config.default_config_root", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Class for retrieving configuration variables.\n\nN.B. Recommended usage is to subclass this class to define default_file\nand/or default_config_root as necessary, or to override __init__ with\nrelevant defaults.\neg:\nclass GBRConfig(Config):\n    default_file = 'config.yaml'\n    default_config_root = os.path.join(BASE_PATH, 'config')\n\n    def __init__(self, config_file=None, config_dir=None, section=None):\n        super(GBRConfig, self).__init__(\n            config_file=config_file, config_dir=config_dir,\n            section=section, env_prefix='GBR_CONFIG'\n        )"]}], "exports": []}, {"name": "yamlconf.tests.test_config", "documentation": ["copyright (c) 2016 Earth Advantage. All rights reserved.\n..codeauthor::Paul Munday <paul@paulmunday.net>\n\nTests for Config store", "!/usr/bin/env python", "encoding: utf-8"], "functions": [], "variables": [{"name": "yamlconf.tests.test_config.PY3", "type": null, "documentation": []}, {"name": "yamlconf.tests.test_config.BASE_PATH", "type": null, "documentation": []}, {"name": "yamlconf.tests.test_config.TEST_CONFIG_ROOT", "type": null, "documentation": []}], "classes": [{"name": "yamlconf.tests.test_config.TESTConfig", "bases": ["Config"], "methods": [{"name": "yamlconf.tests.test_config.TESTConfig.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "config_file", "type": null, "default": "..."}, {"name": "config_dir", "type": null, "default": "..."}, {"name": "section", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [{"name": "yamlconf.tests.test_config.TESTConfig.default_file", "type": null, "documentation": []}, {"name": "yamlconf.tests.test_config.TESTConfig.default_config_root", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Config class for TEST", "Constants", "Helper Functions & Classes"]}, {"name": "yamlconf.tests.test_config.ConfigTests", "bases": ["unittest.TestCase"], "methods": [{"name": "yamlconf.tests.test_config.ConfigTests.setUp", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["pylint:disable=protected-access, invalid-name"]}, {"name": "yamlconf.tests.test_config.ConfigTests.tearDown", "asynchronous": fal