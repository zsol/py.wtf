], "returns": null, "documentation": ["Return the version as a human-format string."]}], "variables": [{"name": "rosetta.VERSION", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "rosetta.poutil", "documentation": [], "functions": [{"name": "rosetta.poutil.timestamp_with_timezone", "asynchronous": false, "params": [{"name": "dt", "type": null, "default": "..."}], "returns": null, "documentation": ["Return a timestamp with a timezone for the configured locale.  If all else\nfails, consider localtime to be UTC."]}, {"name": "rosetta.poutil.find_pos", "asynchronous": false, "params": [{"name": "lang", "type": null, "default": null}, {"name": "project_apps", "type": null, "default": "..."}, {"name": "django_apps", "type": null, "default": "..."}, {"name": "third_party_apps", "type": null, "default": "..."}], "returns": null, "documentation": ["scans a couple possible repositories of gettext catalogs for the given\nlanguage code"]}, {"name": "rosetta.poutil.pagination_range", "asynchronous": false, "params": [{"name": "first", "type": null, "default": null}, {"name": "last", "type": null, "default": null}, {"name": "current", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "rosetta.poutil.cache", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "rosetta.apps", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "rosetta.apps.RosettaAppConfig", "bases": ["AppConfig"], "methods": [{"name": "rosetta.apps.RosettaAppConfig.ready", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "rosetta.apps.RosettaAppConfig.name", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "rosetta.urls", "documentation": [], "functions": [], "variables": [{"name": "rosetta.urls.urlpatterns"