{"name": "backtrace", "metadata": {"name": "backtrace", "version": "0.2.1", "classifiers": ["Environment :: Console", "Intended Audience :: Developers", "Intended Audience :: Information Technology", "Intended Audience :: System Administrators", "License :: OSI Approved :: Apache Software License", "Natural Language :: English", "Operating System :: Microsoft", "Operating System :: POSIX :: Linux", "Programming Language :: Python", "Programming Language :: Python :: 2.7", "Programming Language :: Python :: 3.4", "Programming Language :: Python :: 3.5", "Programming Language :: Python :: 3.6", "Topic :: Software Development :: Libraries :: Python Modules"], "home_page": "https://github.com/nir0s/backtrace", "license": "LICENSE", "documentation_url": null, "dependencies": ["colorama"], "summary": "Makes tracebacks humanly readable", "upload_time": 1514132927}, "documentation": ["backtrace\n=========\n\nSee `Official Github Repo <https://github.com/nir0s/backtrace>`_.\n\n"], "modules": [{"name": "backtrace", "documentation": [], "functions": [{"name": "backtrace._flush", "asynchronous": false, "params": [{"name": "message", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace.hook", "asynchronous": false, "params": [{"name": "reverse", "type": null, "default": "..."}, {"name": "align", "type": null, "default": "..."}, {"name": "strip_path", "type": null, "default": "..."}, {"name": "enable_on_envvar_only", "type": null, "default": "..."}, {"name": "on_tty", "type": null, "default": "..."}, {"name": "conservative", "type": null, "default": "..."}, {"name": "styles", "type": null, "default": "..."}, {"name": "tb", "type": null, "default": "..."}, {"name": "tpe", "type": null, "default": "..."}, {"name": "value", "type": null, "default": "..."}], "returns": null, "documentation": ["Hook the current excepthook to the backtrace.\n\nIf `align` is True, all parts (line numbers, file names, etc..) will be\naligned to the left according to the longest entry.\n\nIf `strip_path` is True, only the file name will be shown, not its full\npath.\n\nIf `enable_on_envvar_only` is True, only if the environment variable\n`ENABLE_BACKTRACE` is set, backtrace will be activated.\n\nIf `on_tty` is True, backtrace will be activated only if you're running\nin a readl terminal (i.e. not piped, redirected, etc..).\n\nIf `convervative` is True, the traceback will have more seemingly original\nstyle (There will be no alignment by default, 'File', 'line' and 'in'\nprefixes and will ignore any styling provided by the user.)\n\nSee https://github.com/nir0s/backtrace/blob/master/README.md for\ninformation on `styles`."]}, {"name": "backtrace.unhook", "asynchronous": false, "params": [], "returns": null, "documentation": ["Restore the default excepthook\n    "]}, {"name": "backtrace._extract_traceback", "asynchronous": false, "params": [{"name": "text", "type": null, "default": null}], "returns": null, "documentation": ["Receive a list of strings representing the input from stdin and return\nthe restructured backtrace.\n\nThis iterates over the output and once it identifies a hopefully genuine\nidentifier, it will start parsing output.\nIn the case the input includes a reraise (a Python 3 case), the primary\ntraceback isn't handled, only the reraise.\n\nEach of the traceback lines are then handled two lines at a time for each\nstack object.\n\nNote that all parts of each stack object are stripped from newlines and\nspaces to keep the output clean."]}, {"name": "backtrace._stdin_hook", "asynchronous": false, "params": [{"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace._add_reverse_argument", "asynchronous": false, "params": [{"name": "parser", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace._add_align_argument", "asynchronous": false, "params": [{"name": "parser", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace._add_strip_path_argument", "asynchronous": false, "params": [{"name": "parser", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace._add_conservative_argument", "asynchronous": false, "params": [{"name": "parser", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace.parse_args", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "backtrace.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "backtrace.DESCRIPTION", "type": null, "documentation": []}, {"name": "backtrace.TRACEBACK_IDENTIFIER", "type": null, "documentation": []}, {"name": "backtrace.STYLES", "type": null, "documentation": []}, {"name": "backtrace.CONVERVATIVE_STYLES", "type": null, "documentation": []}], "classes": [{"name": "backtrace._Hook", "bases": ["object"], "methods": [{"name": "backtrace._Hook.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "entries", "type": null, "default": null}, {"name": "align", "type": null, "default": "..."}, {"name": "strip_path", "type": null, "default": "..."}, {"name": "conservative", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "backtrace._Hook.reverse", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace._Hook.rebuild_entry", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "entry", "type": null, "default": null}, {"name": "styles", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace._Hook.align_all", "asynchronous": false, "params": [{"name": "entries", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace._Hook.align_entry", "asynchronous": false, "params": [{"name": "entry", "type": null, "default": null}, {"name": "lengths", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "backtrace._Hook.generate_backtrace", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "styles", "type": null, "default": null}], "returns": null, "documentation": ["Return the (potentially) aligned, rebuit traceback\n\nYes, we iterate over the entries thrice. We sacrifice\nperformance for code readability. I mean.. come on, how long can\nyour traceback be that it matters?"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}