{"name": "pydantic-sqlalchemy-filter", "metadata": {"name": "pydantic-sqlalchemy-filter", "version": "0.0.11", "classifiers": ["License :: OSI Approved :: MIT License", "Programming Language :: Python :: 3", "Programming Language :: Python :: 3.10", "Programming Language :: Python :: 3.11", "Programming Language :: Python :: 3.12", "Programming Language :: Python :: 3.13"], "home_page": "https://github.com/Deskent/pydantic_sqlalchemy_filter", "license": "MIT", "documentation_url": null, "dependencies": ["sqlalchemy", "pydantic"], "summary": "Implement simple API filter interface for Sqlalchemy", "upload_time": 1733301130}, "documentation": ["### Stack:\n\n- [x] <a href=\"https://www.python.org/\"><img src=\"https://raw.githubusercontent.com/devicons/devicon/master/icons/python/python-plain.svg\" alt=\"python\" width=\"15\" height=\"15\"/>\n  Python 3.11+ <br/></a>\n- [x] <a href=\"https://docs.sqlalchemy.org/en/20\"><img src=\"https://raw.githubusercontent.com/devicons/devicon/master/icons/sqlalchemy/sqlalchemy-plain.svg\" alt=\"sqlalchemy\" width=\"15\" height=\"15\"/>\n  SqlAlchemy 2<br/></a>\n- [x] <a href=\"https://docs.pydantic.dev/\">\ud83d\udd73 Pydantic 2<br/></a>\n\n### Installation\n\n    pip install pydantic-sqlalchemy-filter\n\n### Usage\n\n#### Implement UserFilter\n\n    from pydantic_sqlalchemy_filter import BaseQueryBuilder, DatabaseModel\n\n\n    class UserFilter(BaseQueryBuilder):\n        username: str | None = Field(default=None)\n        order_by: str | None = Field(default='username', alias='orderBy')\n\n        def _filter(\n            self,\n            model: DatabaseModel,\n            exclude_deleted: bool = False,\n            query: sqlalchemy.Select | None = None,\n        ) -> sqlalchemy.Select:\n            if query is None:\n                query = self.build_base_query(\n                    model=model,\n                    exclude_deleted=exclude_deleted,\n                )\n\n            if self.username is not None\n                query = query.filter_by(username=self.username)\n\n            return query\n\n#### In FastAPI router:\n\n        @router.get(path='')\n        async def get_all_filtered_users(\n            query_builder: Annotated[UserFilter, Depends()],\n            session: Annotated[AsyncSession, Depends(get_async_session)],\n        ) -> list[Users]:\n            query = query_builder.build_select_query(model=User)\n            results = await session.execute(query)\n            users = results.scalars().all()\n\n            return list(users)\n"], "modules": [{"name": "pydantic_sqlalchemy_filter.interfaces.query_builder", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "pydantic_sqlalchemy_filter.interfaces.query_builder.IQueryBuilder", "bases": ["abc.ABC"], "methods": [{"name": "pydantic_sqlalchemy_filter.interfaces.query_builder.IQueryBuilder.build_count_query", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "model", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "DatabaseModel", "xref": {"fqname": "pydantic_sqlalchemy_filter.types.DatabaseModel", "project": null}, "params": null}]}, "default": null}, {"name": "exclude_deleted", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": null}, {"name": "query", "type": {"name": "Select | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "Select", "xref": {"fqname": "sqlalchemy.Select", "project": "sqlalchemy"}, "params": null}, "documentation": []}, {"name": "pydantic_sqlalchemy_filter.interfaces.query_builder.IQueryBuilder.build_select_query", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "model", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "DatabaseModel", "xref": {"fqname": "pydantic_sqlalchemy_filter.types.D