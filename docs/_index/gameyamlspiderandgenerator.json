il.plugin_manager import pkg\n\nconfig.load(\"/home/user/desktop/config.yaml\")\npkg.init()\nprint(produce_yaml(\"https://store.steampowered.com/app/1470120/Atopes/\"))\n```\n\n### More: see [API Reference](https://github.com/FurryGamesIndex/GameYamlSpiderAndGenerator/wiki/Api-Reference)\n"], "modules": [{"name": "gameyamlspiderandgenerator.plugin", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "gameyamlspiderandgenerator.plugin.BasePlugin", "xref": {"fqname": "gameyamlspiderandgenerator.plugin._base.BasePlugin", "project": null}}]}, {"name": "gameyamlspiderandgenerator.plugin._base", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "gameyamlspiderandgenerator.plugin._base.BasePlugin", "bases": ["abc.ABC"], "methods": [{"name": "gameyamlspiderandgenerator.plugin._base.BasePlugin.verify", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["\u9a8c\u8bc1 URL \u662f\u5426\u7b26\u5408\u63d2\u4ef6\u7684\u8981\u6c42\n\nArgs:\n    url: URL\n\nReturns:\n    \u662f\u5426\u7b26\u5408\u8981\u6c42"]}, {"name": "gameyamlspiderandgenerator.plugin._base.BasePlugin._load_hook", "asynchronous": false, "params": [{"name": "data", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["\u52a0\u8f7d\u94a9\u5b50\n\nArgs:\n    data: \u94a9\u5b50\u6570\u636e"]}, {"name": "gameyamlspiderandgenerator.plugin._base.BasePlugin.get_name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["\