"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "radius", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["Do a wikipedia geo search for `latitude` and `longitude`\nusing HTTP API described in http://www.mediawiki.org/wiki/Extension:GeoData\n\nArguments:\n\n* latitude (float or decimal.Decimal)\n* longitude (float or decimal.Decimal)\n\nKeyword arguments:\n\n* title - The title of an article to search for\n* results - the maximum number of results returned\n* radius - Search radius in meters. The value must be between 10 and 10000"]}, {"name": "mediawikiapi.mediawikiapi.MediaWikiAPI.suggest", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "query", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": ["Get a Wikipedia search suggestion for `query`.\nReturns a string or None if no suggestion was found."]}, {"name": "mediawikiapi.mediawikiapi.MediaWikiAPI.random", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pages", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": ["Get a list of random Wikipedia article titles.\n\n:::{note}\nRandom only gets articles from namespace 0, meaning no Category, User talk, or other meta-Wikipedia pages.\n:::\n\nKeyword arguments:\n\n- pages - the number of random pages returned (max of 10)\n"]}, {"name": "mediawikiapi.mediawikiapi.MediaWikiAPI.summary", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "title", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "sentences", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "chars", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "auto_suggest", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "redirect", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": ["Plain text summary of the page.\n.. note:: This is a convenience wrapper - auto_suggest and redirect are enabled by default\nKeyword arguments:\n\\* sentences - if set, return the first `sentences` sentences (can be no greater than 10).\n\\* chars - if set, return only the first `chars` characters (actual text returned may be slightly longer).\n\\* auto_suggest - let Wikipedia find a valid page title for the query\n\\* redirect - allow redirection without raising RedirectError\n"]}, {"name": "mediawikiapi.mediawikiapi.MediaWikiAPI.page", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "title", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "pageid", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "auto_suggest", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "redirect", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "preload", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "WikipediaPage", "xref": {"fqname": "mediawikiapi.mediawikiapi.wikipediapage.WikipediaPage", "project": null}, "params": null}, "documentation": ["Get a WikipediaPage object for the page with title `title` or the pageid\n`pageid` (mutually exclusive).\n\nKeyword arguments:\n\n* title - the title of the page to load\n* pageid - the numeric pageid of the page to load\n* auto_suggest - let Wikipedia find a valid page title for the query\n* redirect - allow redirection without raising RedirectError\n* preload - load content, summary, images, references, and links during initialization\n\nAttention!\n\nThe usage of auto_suggest may provide you with different page than you searched.\n\nFor example:\n\n`page(\"The Squires (disambiguation)\", auto_suggest=True)` returns page with title `Squires (disambiguation)`\n\n`page(\"The Squires (disambiguation)\", auto_suggest=False)` returns page with title `The Squires (disambiguation)`"]}, {"name": "mediawikiapi.mediawikiapi.MediaWikiAPI.languages", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["List all the currently supported language prefixes (usually ISO language code).\n\nCan be inputted to WikipediaPage.conf to change the Mediawiki that `wikipedia` requests\nresults from.\n\nReturns: dict of <prefix>: <local_lang_name> pairs. To get just a list of prefixes,\nuse `wikipedia.languages().keys()`."]}, {"name": "mediawikiapi.mediawikiapi.MediaWikiAPI.category_members", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "title", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "pageid", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "cmlimit", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "cmtype", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["Get list of page titles belonging to a category.\nKeyword arguments:\n\n* title - category title. Cannot be used together with \"pageid\"\n* pageid - page id of category page. Cannot be used together with \"title\"\n* cmlimit - the maximum number of titles to return\n* cmtype - which type of page to include. (\"page\", \"subcat\", or \"file\")"]}, {"name": "mediawikiapi.mediawikiapi.MediaWikiAPI.donate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Open up the Wikimedia donate page in your favorite browser."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "mediawikiapi.exceptions", "documentation": ["Global wikipedia exception and warning classes."], "functions": [], "variables": [{"name": "mediawikiapi.exceptions.ODD_ERROR_MESSAGE", "type": null, "documentation": []}], "classes": [{"name": "mediawikiapi.exceptions.MediaWikiAPIException", "bases": ["Exception"], "methods": [{"name": "mediawikiapi.exceptions.MediaWikiAPIException.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "error", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "mediawikiapi.exceptions.MediaWikiAPIException.__unicode__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "mediawikiapi.exceptions.MediaWikiAPIException.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Base Wikipedia exception class."]}, {"name": "mediawikiapi.exceptions.PageError", "bases": ["MediaWikiAPIException"], "methods": [{"name": "mediawikiapi.exceptions.PageError.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pageid", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, 