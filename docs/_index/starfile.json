name": "typing.Dict", "project": "--std--"}, "params": [{"name": "DataBlock", "xref": {"fqname": "starfile.functions.typing.DataBlock", "project": null}, "params": null}]}]}, "documentation": ["Read data from a STAR file.\n\nBasic data blocks are read as dictionaries. Loop blocks are read as pandas\ndataframes. When multiple data blocks are present a dictionary of datablocks is\nreturned. When a single datablock is present only the block is returned by default.\nTo force returning a dectionary even when only one datablock is present set\n`always_dict=True`.\n\nParameters\n----------\nfilename: PathLike\n    File from which to read data.\nread_n_blocks: int | None\n    Limit reading the file to the first n data blocks.\nalways_dict: bool\n    Always return a dictionary, even when only a single data block is present.\nparse_as_string: list[str]\n    A list of keys or column names which will not be coerced to numeric values."]}, {"name": "starfile.functions.write", "asynchronous": false, "params": [{"name": "data", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "DataBlock", "xref": {"fqname": "starfile.functions.typing.DataBlock", "project": null}, "params": null}, {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "DataBlock", "xref": {"fqname": "starfile.functions.typing.DataBlock", "project": null}, "params": null}]}, {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "DataBlock", "xref": {"fqname": "starfile.functions.typing.DataBlock", "project": null}, "params": null}]}]}, "default": null}, {"name": "filename", "type": {"name": "PathLike", "xref": {"fqname": "os.PathLike", "project": "--std--"}, "params": null}, "default": null}, {"name": "float_format", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "sep", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "na_rep", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "quote_character", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "quote_all_strings", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Write data to disk in the STAR format.\n\nParameters\n----------\ndata: DataBlock | Dict[str, DataBlock] | List[DataBlock]\n    Data to be saved to file. DataBlocks are dictionaries or dataframes.\n    If a dictionary of datablocks are passed the keys will be the data block names.\nfilename: PathLike\n    Path where the file will be saved.\nfloat_format: str\n    Float format string which will be passed to pandas.\nsep: str\n    Separator between values, will be passed to pandas.\nna_rep: str\n    Representation of null values, will be passed to pandas."]}, {"name": "starfile.functions.to_string", "asynchronous": false, "params": [{"name": "data", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "DataBlock", "xref": {"fqname": "starfile.functions.typing.DataBlock", "project": null}, "params": null}, {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "DataBlock", "xref": {"fqname": "starfile.functions.typing.DataBlock", "project": null}, "params": null}]}, {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "DataBlock", "xref": {"fqname": "starfile.fun