provided.\n```\n\n## Tags\n\n```\n$ linkace tag --help\nUsage: linkace tag [OPTIONS] COMMAND [ARGS]...\n\nOptions:\n  --help  Show this message and exit.\n\nCommands:\n  create  Create a new tag with the info provided.\n  delete  Delete a tag with the given ID\n  get     Get all tags or, if --id is provided, get the details of just one...\n  update  Update a tag with the info provided.\n```\n\n## Search\n\n```\n$ linkace search --help\nUsage: linkace search [OPTIONS] COMMAND [ARGS]...\n\nOptions:\n  --help  Show this message and exit.\n\nCommands:\n  by-list   Search for links in lists\n  by-query  Search for tags by query\n  by-tag    Search for links with tags\n```\n"], "modules": [{"name": "linkace_cli.models.tag", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "linkace_cli.models.tag.Tag", "bases": ["Schema"], "methods": [], "class_variables": [{"name": "linkace_cli.models.tag.Tag.id", "type": null, "documentation": []}, {"name": "linkace_cli.models.tag.Tag.user_id", "type": null, "documentation": []}, {"name": "linkace_cli.models.tag.Tag.name", "type": null, "documentation": []}, {"name": "linkace_cli.models.tag.Tag.is_private", "type": null, "documentation": []}, {"name": "linkace_cli.models.tag.Tag.created_at", "type": null, "documentation": []}, {"name": "linkace_cli.models.tag.Tag.updated_at", "type": null, "documentation": []}, {"name": "linkace_cli.models.tag.Tag.deleted_at", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [{"name": "linkace_cli.models.tag.Tag.Meta", "bases": [], "methods": [], "class_variables": [{"name": "linkace_cli.models.tag.Tag.Meta.unknown", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "documentation": []}, {"name": "linkace_cli.models.tag.TagsPagination", "bases": ["Schema"], "methods": [], "class_variables": [{"name": "linkace_cli.models.tag.TagsPagination.total", "type": null, "documentation": []}, {"name": 