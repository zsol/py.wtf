{"name": "cloudpath", "metadata": {"name": "cloudpath", "version": "0.2.0", "classifiers": ["Intended Audience :: Science/Research", "License :: OSI Approved :: MIT License", "Programming Language :: Python :: 3"], "home_page": "http://github.com/danijar/cloudpath", "license": null, "documentation_url": null, "dependencies": [], "summary": "Optimized pathlib backend for Google Cloud", "upload_time": 1733610793}, "documentation": ["[![PyPI](https://img.shields.io/pypi/v/cloudpath.svg)](https://pypi.python.org/pypi/cloudpath/#history)\n\n# \ud83d\uddc2\ufe0f Cloudpath\n\nOptimized pathlib backend for Google Cloud.\n\nA filesystem abstraction similar to `pathlib` that is extensible to new\nfilesystems. Comes with support for local filesystems and GCS buckets.\n\n```python\npath = cloudpath.Path('gs://bucket/path/to/file.txt')\n\n# String operations\npath.parent                           # gs://bucket/path/to\npath.name                             # file.txt\npath.stem                             # file\npath.suffix                           # .txt\n\n# File operations\npath.read(mode='r')                   # Content of the file as string\npath.read(mode='rb')                  # Content of the file as bytes\npath.write(content, mode='w')         # Write string to the file\npath.write(content, mode='wb')        # Write bytes to the file\nwith path.open(mode='r') as f:        # Create a file pointer\n  pass\n\n# File system checks\npath.parent.glob('*')                 # Get all sibling paths\npath.exists()                         # True\npath.isdir()                          # False\npath.isfile()                         # True\n\n# File system changes\n(path.parent / 'foo').mkdir()         # Creates directory including parents\npath.remove()                         # Deletes a file or empty directory\npath.parent.rmtree()                  # Deletes directory and its content\npath.copy(path.parent / 'copy.txt')   # Makes a copy\npath.move(path.parent / 'moved.txt')  # Moves the file\n```\n"], "modules": [{"name": "setup", "documentation": [], "functions": [{"name": "setup.parse_requirements", "asynchronous": false, "params": [{"name": "filename", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "cloudpath.cloudpath", "documentation": [], "functions": [{"name": "cloudpath.cloudpath.gcs_retry", "asynchronous": false, "params": [{"name": "duration", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cloudpath.cloudpath._copy_across_filesystems", "asynchronous": false, "params": [{"name": "source", "type": null, "default": null}, {"name": "dest", "type": null, "default": null}, {"name": "recursive", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "cloudpath.cloudpath.GCS_LOCK", "type": null, "documentation": []}, {"name": "cloudpath.cloudpath.GCS_CLIENT", "type": null, "documentation": []}, {"name": "cloudpath.cloudpath.GCS_BUCKETS", "type": null, "documentation": []}, {"name": "cloudpath.cloudpath.Path.filesystems", "type": null, "documentation": []}], "classes": [{"name": "cloudpath.cloudpath.Path", "bases": [], "methods": [{"name": "cloudpath.cloudpath.Path.__new__", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cloudpath.cloudpath.Path.__getnewargs__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cloudpath.cloudpath.Path.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cloudpath.cloudpath.Path.__truediv__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "part", "type": 