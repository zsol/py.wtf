pe": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": ["Univariate rational interpolation of f(t), samples taken modulo prime. See arXiv:1608.01902 section 3.3"]}, {"name": "pyadic.interpolation.multivariate_Newton_polynomial_interpolation", "asynchronous": false, "params": [{"name": "f", "type": null, "default": null}, {"name": "prime", "type": null, "default": null}, {"name": "seed", "type": null, "default": "..."}, {"name": "depth", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": ["Recursive multivariate polynomial interpolation of f(ts), samples taken modulo prime."]}, {"name": "pyadic.interpolation.interpolation_t_sequence", "asynchronous": false, "params": [{"name": "length", "type": null, "default": null}, {"name": "prime", "type": null, "default": null}, {"name": "seed", "type": null, "default": "..."}], "returns": null, "documentation": ["Returns the pseudo-random sequence of t-values (mod prime) used in Newton polynomial intrpolation and in Thiele rational interpolation."]}], "variables": [], "classes": [{"name": "pyadic.interpolation.FFSequenceGenerator", "bases": ["Iterator"], "methods": [{"name": "pyadic.interpolation.FFSequenceGenerator.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prime", "type": null, "default": null}, {"name": "seed", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "pyadic.interpolation.FFSequenceGenerator.__next__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Random number generator decoupled from global state."]}], "exports": []}, {"name": "pyadic.padic", "documentation": [], "functions": [{"name": "pyadic.padic.to_base", "asynchronous": fa