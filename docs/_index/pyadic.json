cumentation": ["Given (s | s^2 - x << 1), makes s^2 closer to x.", "~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ #"]}, {"name": "pyadic.padic.padic_sqrt", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}], "returns": null, "documentation": ["Working precision padic sqrt."]}], "variables": [{"name": "pyadic.padic.fixed_relative_precision", "type": null, "documentation": []}, {"name": "pyadic.padic.all_precision_loss_warning", "type": null, "documentation": []}], "classes": [{"name": "pyadic.padic.PAdic", "bases": ["object"], "methods": [{"name": "pyadic.padic.PAdic.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "num", "type": null, "default": null}, {"name": "p", "type": null, "default": "..."}, {"name": "k", "type": null, "default": "..."}, {"name": "n", "type": null, "default": "..."}, {"name": "from_addition", "type": null, "default": "..."}], "returns": null, "documentation": ["0 \u2264 num \u2264 p ^ k - 1; p: prime; k: significant digits; n: power of prefactors of p (valuation).", "This allows the intantiation step to return a field extension,", "but doubles instantiation time, even when no field extension is required.", "def __new__(cls, num, p=None, k=None, n=0, from_addition=False):", "try:", "PAdic_obj = super(PAdic, cls).__new__(cls)", "PAdic_obj.__init__(num, p, k, n, from_addition)", "return PAdic_obj", "except ValueError:", "if hasattr(num, \"imag\"):", "a = PAdic(num.real, p, k, n, from_addition)", "b = PAdic(num.imag, p, k, n, from_addition)", "i = padic_sqrt(PAdic(-1, p, k, n, from_addition))", "return a + i * b  # this is in a FieldExtension now", "else:", "raise Exception(\"Invalid p-adic initialisation\")"]}, {"name": "pyadic.padic.PAdic.num", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["0 \u2264 num \u2264 p ^ k - 1", "GETTERS and SETTERS"]}, {"name": "pyadic