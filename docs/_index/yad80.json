xports": []}, {"name": "yad80.mnemonic_dd_fd", "documentation": [], "functions": [{"name": "yad80.mnemonic_dd_fd.add_reg16", "asynchronous": false, "params": [{"name": "op1", "type": null, "default": null}, {"name": "op2", "type": null, "default": null}, {"name": "_", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yad80.mnemonic_dd_fd.ld_reg8_indexed", "asynchronous": false, "params": [{"name": "op1", "type": null, "default": null}, {"name": "op2", "type": null, "default": null}, {"name": "mem", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yad80.mnemonic_dd_fd.ld_indexed_reg8", "asynchronous": false, "params": [{"name": "op1", "type": null, "default": null}, {"name": "op2", "type": null, "default": null}, {"name": "mem", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yad80.mnemonic_dd_fd.ld_index_n", "asynchronous": false, "params": [{"name": "op1", "type": null, "default": null}, {"name": "_", "type": null, "default": null}, {"name": "mem", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yad80.mnemonic_dd_fd.ld_mem_index", "asynchronous": false, "params": [{"name": "op1", "type": null, "default": null}, {"name": "_", "type": null, "default": null}, {"name": "mem", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yad80.mnemonic_dd_fd.ld_index_mem", "asynchronous": false, "params": [{"name": "op1", "type": null, "default": null}, {"name": "_", "type": null, "default": null}, {"name": "mem", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yad80.mnemonic_dd_fd.ld_indexed_n", "asynchronous": false, "params": [{"name": "op1", "type": null, "default": null}, {"name": "_", "type": null, "default": null}, {"name": "mem", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yad80.mnemonic_dd_fd.inc_dec_indexed", "asynchronous": false, "params