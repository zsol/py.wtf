{"name": "quantumnatfs", "metadata": {"name": "QuantumNatFS", "version": "0.0.1", "classifiers": [], "home_page": "https://github.com/PremSRajanampalle/QuantumBasedGeneticAlgorithm/tree/main", "license": null, "documentation_url": null, "dependencies": [], "summary": "A python package for implementing feature selection using quantum-based nature inspired algorithms", "upload_time": 1734865552}, "documentation": ["# QuantumBasedGeneticAlgorithm\r\nImplements Quantum Based Genetic Algorithm for Feature Selection\r\n\r\nHow to use:\r\n\r\nStep 1: Preprocess the dataset (Encoding, Imputing, Removing null values etc...)\r\n\r\nStep 2: Split the dataset into X, y where both X and y are PandasDataFrame\r\n\r\nStep 3: run the QGA_Algorithm \r\n\r\nStep 4: initialize the algorithm\r\n\r\n              qga = QGA(X, y, n_of_pop, n_of_gen) # where X and y are dependent and independent variables. And n_of_pop and n_of_gen is numnber of population and number of generations\r\n              \r\nStep 5: Run generation 0\r\n\r\n              Q = qga.run_gen_0()\r\n              \r\nStep 6: Run QGA\r\n\r\n              best_individuals = qga.run_qga(Q[0]) # Q[0] because Q is a numpy array in a tuple... we only need numpy array\r\n              \r\nStep 7: Build a new dataset with reduced features\r\n\r\n              qga.build_new_dataset(best_individuals)\r\n\r\n"], "modules": [{"name": "QuaNatFS", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "QuaNatFS.QGA", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "QuaNatFS.QGA.QGA", "bases": [], "methods": [{"name": "QuaNatFS.QGA.QGA.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "X", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "n_of_pop", "type": null, "default": null}, {"name": "n_of_gen", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "QuaNatFS.QGA.QGA.initialize", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "QuaNatFS.QGA.QGA.observe", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "Q", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "QuaNatFS.QGA.QGA.evaluate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "X_obs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "QuaNatFS.QGA.QGA.storage", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pop_acc", "type": null, "default": null}, {"name": "alpha", "type": null, "default": null}, {"name": "beta", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "QuaNatFS.QGA.QGA.run_gen_0", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "QuaNatFS.QGA.QGA.crossover", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "crossover_X", "type": null, "default": null}, {"name": "X_fitness", "type": null, "default": null}, {"name": "B", "type": null, "default": null}, {"name": "B_fitness", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "QuaNatFS.QGA.QGA.run_qga", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "Q", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "QuaNatFS.QGA.QGA.build_new_dataset", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "final_best_individual", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}