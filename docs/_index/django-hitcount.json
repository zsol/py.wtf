ch will be 45 days.\n\nFor example: hits_in_last(days=7).\n\nAccepts days, seconds, microseconds, milliseconds, minutes,\nhours, and weeks.  It's creating a datetime.timedelta object."]}], "class_variables": [{"name": "hitcount.models.HitCountBase.hits", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.modified", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.content_type", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.object_pk", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.content_object", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.objects", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [{"name": "hitcount.models.HitCountBase.Meta", "bases": [], "methods": [], "class_variables": [{"name": "hitcount.models.HitCountBase.Meta.abstract", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.Meta.ordering", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.Meta.get_latest_by", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.Meta.verbose_name", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.Meta.verbose_name_plural", "type": null, "documentation": []}, {"name": "hitcount.models.HitCountBase.Meta.unique_together", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "documentation": ["Base class for hitcount models.\n\nModel that stores the hit totals for any content object."]}, {"name": "hitcount.models.HitCount", "bases": ["HitCountBase"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [{"name": "hitcount.models.HitCount.Meta", "bases": ["HitCountBase.Meta"], "methods": [], "class_variables": [{"name": "hitcount.models.HitCount.Meta.db_table", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "documentation": ["Built-in hitcount class. Default functionality."]}, {"name": "hitcount.models.Hit", "bases": ["models.Model"], "methods": [{"name": "hitcount.models.Hit.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hitcount.models.Hit.save", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["The first time the object is created and saved, we increment\nthe associated HitCount object by one. The opposite applies\nif the Hit is deleted."]}, {"name": "hitcount.models.Hit.delete", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "save_hitcount", "type": null, "default": "..."}], "returns": null, "documentation": ["If a Hit is deleted and save_hitcount=True, it will preserve the\nHitCount object's total. However, under normal circumstances, a\ndelete() will trigger a subtraction from the HitCount object's total.\n\nNOTE: This doesn't work at all during a queryset.delete()."]}], "class_variables": [{"name": "hitcount.models.Hit.created", "type": null, "documentation": []}, {"name": "hitcount.models.Hit.ip", "type": null, "documentation": []}, {"name": "hitcount.models.Hit.session", "type": null, "documentation": []}, {"name": "hitcount.models.Hit.user_agent", "type": null, "documentation": []}, {"name": "hitcount.models.Hit.user", "type": null, "documentation": []}, {"name": "hitcount.models.Hit.hitcount", "type": null, "documentation": []}, {"name": "hitcount.models.Hit.objects", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [{"name": "hitcount.models.Hit.Meta", "bases": [], "methods": [], "class_variables": [{"name": "hitcount.models.Hit.Meta.ordering", "type": null, "documentation": []