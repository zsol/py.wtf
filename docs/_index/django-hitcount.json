lAdmin"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "hitcount.views", "documentation": [], "functions": [{"name": "hitcount.views._update_hit_count", "asynchronous": false, "params": [{"name": "request", "type": null, "default": null}, {"name": "hitcount", "type": null, "default": null}], "returns": null, "documentation": ["Deprecated in 1.2. Use hitcount.views.Hit CountMixin.hit_count() instead."]}, {"name": "hitcount.views.update_hit_count_ajax", "asynchronous": false, "params": [{"name": "request", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Deprecated in 1.2. Use hitcount.views.HitCountJSONView instead."]}], "variables": [], "classes": [{"name": "hitcount.views.HitCountMixin", "bases": [], "methods": [{"name": "hitcount.views.HitCountMixin.hit_count", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "request", "type": null, "default": null}, {"name": "hitcount", "type": null, "default": null}], "returns": null, "documentation": ["Called with a HttpRequest and HitCount object it will return a\nnamedtuple:\n\nUpdateHitCountResponse(hit_counted=Boolean, hit_message='Message').\n\n`hit_counted` will be True if the hit was counted and False if it was\nnot.  `'hit_message` will indicate by what means the Hit was either\ncounted or ignored."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Mixin to evaluate a HttpRequest and a HitCount and determine whether or not\nthe HitCount should be incremented and the Hit recorded."]}, {"name": "hitcount.views.HitCountJSONView", "bases": ["View", "HitCountMixin"], "methods": [{"name": "hitcount.views.HitCountJSONView.dispatch", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "request", 