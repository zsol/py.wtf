seful Python helpers"], "functions": [], "variables": [{"name": "mmguero._package_name", "type": null, "documentation": []}, {"name": "mmguero.__version__", "type": null, "documentation": []}, {"name": "mmguero.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "mmguero.PackageNotFoundError", "xref": {"fqname": "importlib.metadata.PackageNotFoundError", "project": null}}, {"name": "mmguero.version", "xref": {"fqname": "importlib.metadata.version", "project": null}}]}, {"name": "mmguero.mmguero", "documentation": ["!/usr/bin/env python3", "-*- coding: utf-8 -*-"], "functions": [{"name": "mmguero.mmguero._DialogInit", "asynchronous": false, "params": [], "returns": null, "documentation": ["##################################################################################################"]}, {"name": "mmguero.mmguero.pushd", "asynchronous": false, "params": [{"name": "directory", "type": null, "default": null}], "returns": null, "documentation": ["##################################################################################################", "a context manager for entering a directory and leaving it upon leaving the context"]}, {"name": "mmguero.mmguero.TemporaryFilename", "asynchronous": false, "params": [{"name": "suffix", "type": null, "default": "..."}], "returns": null, "documentation": ["##################################################################################################", "a context manager returning a temporary filename which is deleted upon leaving the context"]}, {"name": "mmguero.mmguero.Touch", "asynchronous": false, "params": [{"name": "filename", "type": null, "default": null}], "returns": null, "documentation": ["##################################################################################################", "open a file and close it, updating its access time"]}, {"name": "mmguero.mmguero.AppendToFile", "asynchronous": false, "params": [{"name": "filename", "type": null, "default": null}, {"name"