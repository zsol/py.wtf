": null, "documentation": []}, {"name": "catboost_extensions.optuna.OptunaTuneCV.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "trial", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Class for tuning Catboost models with Optuna and cross-validation\n\n# Parameters\n\nmodel\n\n: Catboost model to tune\n\nparam_space\n\n: Dictionary with parameters for tuning or function that returns dictionary with parameters\n\nx\n\n: Features\n\ny\n\n: Target\n\nlast_best_score\n\n: Last best score\n\ntrial_timeout\n\n: Timeout for trial\n\nparams_post_processing\n\n: Function for post-processing parameters\n\ncv\n\n: Cross-validation strategy\n\nscoring\n\n: Scoring function or name from 'sklearn.metrics' (see sklearn.metrics.get_scorer_names()).\n  If None, model's default scoring function will be used.\n\ndirection\n\n: Direction of optimization. 'maximize' or 'minimize'\n\nweight_column\n\n: Column with weights if needed\n\nhas_pruner\n\n: If True, trials will be check for pruning. Default is False\n\nn_folds_start_prune\n\n: Number of folds before starting pruning. Default is 0\n\nerror_handling\n\n: Error handling strategy. 'raise' or 'prune'. Default is 'raise'\n\n# Examples\n\n```pycon\n>>> from catboost import CatBoostClassifier\n>>> from catboost_extensions import OptunaTuneCV, CatboostParamSpace\n>>> from sklearn.datasets import make_classification\n>>> from sklearn.model_selection import StratifiedKFold\n>>> from sklearn.metrics import roc_auc_score\n>>> import optuna\n```\n\n```pycon\n>>> X, y = make_classification(n_samples=1000, n_features=20, n_informative=10, random_state=0)\n>>> model = CatBoostClassifier(task_type='CPU', verbose=0)\n>>> param_space_getter = CatboostParamSpace(params_preset='general', task_type='GPU')\n>>> objective = OptunaTuneCV(model, param_space_getter, X, y, cv=5, scoring='roc_auc', direction='maximize')\n>>> study = optuna.create_study(direction='maximize')\n>>> study.optimize(objective, n_trials=100)\n```\n"]}, {"name": "catboost_extensions.optuna.CatboostParamSpace", "bases": [], "methods": [{"name": "catboost_extensions.optuna.CatboostParamSpace.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "task_type", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "cook_params", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}]}, "default": "..."}, {"name": "params_preset", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}, {"name": "catboost_extensions.optuna.CatboostParamSpace.fold_len_multiplier", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "catboost_extensions.optuna.CatboostParamSpace.fold_len_multiplier", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "catboost_extensions.optuna.CatboostParamSpace.model_size_reg", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "catboost_extensions.optuna.CatboostParam