ited'))\n    serializer = self.get_serializer(data=data)\n    serializer.is_valid(raise_exception=True)\n    serializer.save()\n    return Response(data=serializer.data)"]}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "huscy.recruitment.urls", "documentation": [], "functions": [], "variables": [{"name": "huscy.recruitment.urls.subject_group_router", "type": null, "documentation": []}, {"name": "huscy.recruitment.urls.urlpatterns", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "huscy.recruitment.models", "documentation": [], "functions": [{"name": "huscy.recruitment.models._get_setting", "asynchronous": false, "params": [{"name": "key", "type": null, "default": null}, {"name": "default", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "huscy.recruitment.models.DEFAULT_AGE_RANGE", "type": null, "documentation": []}], "classes": [{"name": "huscy.recruitment.models.SubjectGroup", "bases": ["models.Model"], "methods": [], "class_variables": [{"name": "huscy.recruitment.models.SubjectGroup.experiment", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.SubjectGroup.name", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.SubjectGroup.description", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.SubjectGroup.order", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "huscy.recruitment.models.RecruitmentCriteria", "bases": ["models.Model"], "methods": [], "class_variables": [{"name": "huscy.recruitment.models.RecruitmentCriteria.subject_group", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.RecruitmentCriteria.minimum_age_in_months", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.RecruitmentCriteria.maximum_age_in_months", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.RecruitmentCriteria.attribute_filterset", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "huscy.recruitment.models.ParticipationRequest", "bases": ["models.Model"], "methods": [], "class_variables": [{"name": "huscy.recruitment.models.ParticipationRequest.recruitment_criteria", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.ParticipationRequest.pseudonym", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.ParticipationRequest.status", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.ParticipationRequest.created_at", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [{"name": "huscy.recruitment.models.ParticipationRequest.STATUS", "bases": ["Enum"], "methods": [{"name": "huscy.recruitment.models.ParticipationRequest.STATUS.get_value", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "member", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "huscy.recruitment.models.ParticipationRequest.STATUS.pending", "type": null, "documentation": []}, {"name": "huscy.recruitment.models.ParticipationRequest.STATUS.invited", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "documentation": []}], "exports": []}, {"name": "huscy.recruitment.services.participation_requests", "documentation": ["from datetime import timedelta\n\nfrom django.contrib.contenttypes.models import ContentType\n\nfrom huscy.appointments.services import create_appointment\nfrom huscy.pseudonyms.models import Pseudonym\nfrom huscy.pseudonyms.services import get_or_create_pseudonym\nfrom huscy.recruitment.models import ParticipationRequest, Recall\n\n\ndef get_participation_requests_for_experiment(experiment):\n    return (ParticipationRequest.objects\n                                .filter(attribute_filterset__subject_group__experiment=experiment))\n\n\ndef create_or_update_participation_request(subject, attribute_filterset, status, **kwargs):\n    content_type = ContentType.objects.get_by_natural_key('recruitment', 'participationrequest')\n    pseudonym = get_or_create_pseudonym(\n        subject=subject,\n        content_type=content_type,\n        object_id=attribute_filterset.subject_group.experiment_id\n    )\n\n    participation_request, created = ParticipationRequest.objects.get_or_create(\n        pseudonym=pseudonym.code,\n        attribute_filterset=attribute_filterset,\n        defaults=dict(status=status),\n    )\n\n    if not created and not participation_request.status == status:\n        participation_request.status = status\n        participation_request.save(update_fields=['status'])\n\n    if status == ParticipationRequest.STATUS.get_value('pending') and 'appointment' in kwargs:\n        creator = kwargs['user']\n        start = kwargs['appointment']\n        end = start + timedelta(minutes=30)\n\n        try:\n            recall = participation_request.recall.get()\n            # TODO: create new appointment, if appointment.start is in the past\n            recall.appointment.creator = creator\n            recall.appointment.start = start\n            recall.appointment.end = end\n            recall.appointment.save()\n        except Recall.DoesNotExist:\n            appointment = create_appointment(creator=creator, start=start, end=end,\n                                             title='recall appointment')\n            Recall.objects.create(participation_request=participation_request,\n                                  appointment=appointment)\n\n    return participation_request\n\n\ndef get_participation_requests(subject=None, attribute_filterset=None):\n    if attribute_filterset is None and subject is None:\n        raise ValueError('Expected either attribute_filterset or subject args')\n\n    pseudonyms = []\n    if subject:\n        content_type = ContentType.objects.get_by_natural_key('recruitment', 'participationrequest')\n        pseudonyms = (Pseudonym.objects.filter(subject=subject, content_type=content_type)\n                                       .values_list('code', flat=True))\n    if attribute_filterset and subject:\n        return ParticipationRequest.objects.filter(pseudonym__in=pseudonyms,\n                                                   attribute_filterset=attribute_filterset)\n    elif attribute_filterset:\n        return ParticipationRequest.objects.filter(attribute_filterset=attribute_filterset)\n    return ParticipationRequest.objects.filter(pseudonym__in=pseudonyms)"], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "huscy.recruitment.services.attribute_filtersets", "documentation": [], "functions": [{"name": "huscy.recruitment.services.attribute_filtersets.apply_recruitment_criteria", "asynchronous": false, "params": [{"name": "recruitment_criteria", "type": null, "default": null}, {"name": "include_children", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "huscy.recruitment.services.attribute_filtersets._filter_attributesets_by_filterset", "asynchronous": false, "params": [{"name": "recruitment_criteria", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "huscy.recruitment.services.attribute_filtersets._get_filters", "asynchronous": false, "params": [{"name": "attribute_filterset", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "huscy.recruitment.services.attribute_filtersets._get_attribute_type", "asynchronous": false, "params": [{"name": "schema", "type": null, "default": null}, {"name": "attribute_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "huscy.recruitment.services.attribute_filtersets._exclude_invited_subjects", "asynchronous": false, "params": [{"name": "subjects", "type": n