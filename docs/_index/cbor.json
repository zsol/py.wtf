{"name": "cbor", "metadata": {"name": "cbor", "version": "1.0.0", "classifiers": ["Development Status :: 5 - Production/Stable", "Intended Audience :: Developers", "License :: OSI Approved :: Apache Software License", "Operating System :: OS Independent", "Programming Language :: C", "Programming Language :: Python :: 2.7", "Programming Language :: Python :: 3.4", "Programming Language :: Python :: 3.5", "Topic :: Software Development :: Libraries :: Python Modules"], "home_page": "https://bitbucket.org/bodhisnarkva/cbor", "license": "Apache", "documentation_url": null, "dependencies": [], "summary": "RFC 7049 - Concise Binary Object Representation", "upload_time": 1455059472}, "documentation": ["An implementation of RFC 7049 - Concise Binary Object Representation (CBOR).\n\nCBOR is comparable to JSON, has a superset of JSON's ability, but serializes to a binary format which is smaller and faster to generate and parse.\n\nThe two primary functions are cbor.loads() and cbor.dumps().\n\nThis library includes a C implementation which runs 3-5 times faster than the Python standard library's C-accelerated implementanion of JSON. This is also includes a 100% Python implementation."], "modules": [{"name": "cbor.VERSION", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "cbor", "documentation": ["!python"], "functions": [], "variables": [], "classes": [], "exports": [{"name": "cbor.__version__", "xref": {"fqname": "cbor.VERSION.__doc__", "project": null}}, {"name": "cbor.ClassTag", "xref": {"fqname": "cbor.tagmap.ClassTag", "project": null}}, {"name": "cbor.dump", "xref": {"fqname": "cbor.cbor.dump", "project": null}}, {"name": "cbor.dumps", "xref": {"fqname": "cbor.cbor.dumps", "project": null}}, {"name": "cbor.load", "xref": {"fqname": "cbor.cbor.load", "project": null}}, {"name": "cbor.loads", "xref": {"fqname": "cbor.cbor.loads", "project": null}}, {"name": "cbor.Tag", "xref": {"fqname": "cbor.cbor.Tag", "project": null}}, {