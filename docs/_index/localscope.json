{"name": "localscope", "metadata": {"name": "localscope", "version": "0.2.3", "classifiers": ["Development Status :: 4 - Beta", "License :: OSI Approved :: MIT License"], "home_page": null, "license": null, "documentation_url": "https://localscope.readthedocs.io", "dependencies": [], "summary": "Restrict the scope of functions for reproducible code execution and peace of mind.", "upload_time": 1734404376}, "documentation": ["Restrict the scope of functions for reproducible code execution and peace of mind. See the [documentation](https://localscope.readthedocs.io) for details.\n"], "modules": [{"name": "tests.test_localscope", "documentation": [], "functions": [{"name": "tests.test_localscope.test_vanilla_function", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_missing_global", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_forbidden_global", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_builtin", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_allowed", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_closure", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_allow_any_closure", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_allow_custom_predicate", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_comprehension", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_recursive", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_localscope.test_recur