aclass.\n\nSo you don't have to add a \\_\\_post_init\\_\\_ method, or if you have one, you don't have\nto remember to add the dataclass_type_validator(self) call to it; just decorate your\ndataclass with this instead.\n\n```\nparam strict\n\nbool\n\nparam before_post_init\n\nbool - if True, force the validation logic to occur before\n__post_init__ is called.  Only has effect if the class defines __post_init__.\nThis setting allows you to ensure the field values are already validated to\nbe the correct type before any additional logic in __post_init__ does further\nvalidation.  Default: False.\n```\n"]}], "variables": [{"name": "dataclass_type_validator.GlobalNS_T", "type": null, "documentation": []}, {"name": "dataclass_type_validator._validate_typing_mappings", "type": null, "documentation": []}], "classes": [{"name": "dataclass_type_validator.TypeValidationError", "bases": ["Exception"], "methods": [{"name": "dataclass_type_validator.TypeValidationError.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "target", "type": {"name": "dataclasses.dataclass", "xref": {"fqname": "dataclasses.dataclass", "project": "--std--"}, "params": null}, "default": null}, {"name": "errors", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "dataclass_type_validator.TypeValidationError.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "dataclass_type_validator.TypeValidationError.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Exception raised on type validation errors.\n    "]}], "exports": [{"name": 