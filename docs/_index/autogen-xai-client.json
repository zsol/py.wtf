_weather],\n    )\n\n    # Define termination condition\n    termination = TextMentionTermination(\"TERMINATE\")\n\n    # Define a team\n    agent_team = RoundRobinGroupChat([weather_agent], termination_condition=termination)\n\n    # Run the team and stream messages to the console\n    stream = agent_team.run_stream(task=\"What is the weather in New York?\")\n    await Console(stream)\n\n\n# NOTE: if running this inside a Python script you'll need to use asyncio.run(main()).\nawait main()\n```\n"], "modules": [{"name": "autogen_xai_client", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "autogen_xai_client.XAIChatCompletionClient", "xref": {"fqname": "autogen_xai_client._xai_client.XAIChatCompletionClient", "project": null}}, {"name": "autogen_xai_client.XAIClientConfiguration", "xref": {"fqname": "autogen_xai_client.config.XAIClientConfiguration", "project": null}}]}, {"name": "autogen_xai_client.config", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "autogen_xai_client.config.ResponseFormat", "bases": ["TypedDict"], "methods": [], "class_variables": [{"name": "autogen_xai_client.config.ResponseFormat.type", "type": {"name": "Literal", "xref": {"fqname": "typing.Literal", "project": "--std--"}, "params": [{"name": "\"text\"", "xref": null, "params": null}, {"name": "\"json_object\"", "xref": null, "params": null}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "autogen_xai_client.config.CreateArguments", "bases": ["TypedDict"], "methods": [], "class_variables": [{"name": "autogen_xai_client.config.CreateArguments.frequency_penalty", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "autogen_xai_client.config.CreateArguments.logit_bias", "type": {"name": "Optio