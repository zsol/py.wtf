synchronous": false, "params": [{"name": "field", "type": {"name": "KEYNAME", "xref": {"fqname": "KEYNAME", "project": null}, "params": null}, "default": null}, {"name": "sep", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "serializer", "type": {"name": "Serializer", "xref": {"fqname": "json_flattener.flattener.Serializer", "project": null}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "json_flattener.flattener.flatten", "asynchronous": false, "params": [{"name": "objs", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "OBJECT", "xref": {"fqname": "OBJECT", "project": null}, "params": null}]}, "default": null}, {"name": "config", "type": {"name": "GlobalConfig", "xref": {"fqname": "json_flattener.flattener.GlobalConfig", "project": null}, "params": null}, "default": "..."}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "ROW", "xref": {"fqname": "ROW", "project": null}, "params": null}]}, "documentation": ["Flattens a list of dicts into a denormalized representation according to a configuration\n\n```\nparam objs\n\na list of dicts to be flattened\n\nparam config\n\nmapping configuration\n\nreturn\n\nlist of flattened dicts\n```\n"]}, {"name": "json_flattener.flattener.unflatten", "asynchronous": false, "params": [{"name": "objs", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "ROW", "xref": {"fqname": "ROW", "project": null}, "params": null}]}, "default": null}, {"name": "config", "type": {"name": "GlobalConfig", "xref": {"fqname": "json_flattener.flattener.GlobalConfig", "project": null}, "params": null}, "default": "..."}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "