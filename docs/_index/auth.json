t permissions of a user"]}, {"name": "auth.CAS.authorization.Authorization.which_roles_can", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": ["Which role can SendMail? "]}, {"name": "auth.CAS.authorization.Authorization.which_users_can", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": ["Which role can SendMail? "]}, {"name": "auth.CAS.authorization.Authorization.get_role", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "role", "type": null, "default": null}], "returns": null, "documentation": ["Returns a role object\n        "]}, {"name": "auth.CAS.authorization.Authorization.add_role", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "role", "type": null, "default": null}, {"name": "description", "type": null, "default": "..."}], "returns": null, "documentation": ["Creates a new group "]}, {"name": "auth.CAS.authorization.Authorization.del_role", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "role", "type": null, "default": null}], "returns": null, "documentation": ["deletes a group "]}, {"name": "auth.CAS.authorization.Authorization.add_membership", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": null}, {"name": "role", "type": null, "default": null}], "returns": null, "documentation": ["make user a member of a group "]}, {"name": "auth.CAS.authorization.Authorization.del_membership", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": null}, {"name": "role", "type": null, "default": null}], "returns": null, "documentation": ["dismember user from a group "]}, {"name": "auth.CAS.authorization.Authorization.has_membership", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": null}, {"name": "role", "type": null, "default": null}], "returns": null, "documentation": ["checks if user is member of a group"]}, {"name": "auth.CAS.authorization.Authorization.add_permission", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "role", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": ["authorize a group for something "]}, {"name": "auth.CAS.authorization.Authorization.del_permission", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "role", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": ["revoke authorization of a group "]}, {"name": "auth.CAS.authorization.Authorization.has_permission", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "role", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": ["verify groups authorization "]}, {"name": "auth.CAS.authorization.Authorization.user_has_permission", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": ["verify user has permission "]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Main Authorization class "]}], "exports": []}, {"name": "auth.CAS.REST.service", "documentation": ["try:", "import eventlet", "eventlet.monkey_patch()", "except:", "pass"], "functions": [{"name": "auth.CAS.REST.service.stringify", "asynchronous": false, "params": [{"name": "req", "type": null, "default": nu