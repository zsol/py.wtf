t.\n\nArgs:\n    make_pool: A function that returns a urllib3.Pool-like object. This\n        allows you to specify special arguments to your connection pool if\n        needed. By default, this will create a urllib3.PoolManager with\n        SSL verification enabled using the certifi certificates."]}, {"name": "httplib2shim._is_ipv6", "asynchronous": false, "params": [{"name": "addr", "type": null, "default": null}], "returns": null, "documentation": ["Checks if a given address is an IPv6 address."]}, {"name": "httplib2shim._certifi_where_for_ssl_version", "asynchronous": false, "params": [], "returns": null, "documentation": ["Gets the right location for certifi certifications for the current SSL\nversion.\n\nOlder versions of SSL don't support the stronger set of root certificates."]}, {"name": "httplib2shim._map_response", "asynchronous": false, "params": [{"name": "response", "type": null, "default": null}, {"name": "decode", "type": null, "default": "..."}], "returns": null, "documentation": ["Maps a urllib3 response to a httplib/httplib2 Response."]}, {"name": "httplib2shim._map_exception", "asynchronous": false, "params": [{"name": "e", "type": null, "default": null}], "returns": null, "documentation": ["Maps an exception from urlib3 to httplib2."]}], "variables": [], "classes": [{"name": "httplib2shim.Http", "bases": ["httplib2.Http"], "methods": [{"name": "httplib2shim.Http.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cache", "type": null, "default": "..."}, {"name": "timeout", "type": null, "default": "..."}, {"name": "proxy_info", "type": null, "default": "..."}, {"name": "ca_certs", "type": null, "default": "..."}, {"name": "disable_ssl_certificate_validation", "type": null, "default": "..."}, {"name": "pool", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "httplib2shim.Http._conn_request", "asynchronous": false, "params": [{"name": "self", "type": null, "defau