obPool", "bases": [], "methods": [{"name": "job_pool.job_pool.JobPool.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "processes", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "warningFilter", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "queue", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "multiprocessing.Queue", "xref": {"fqname": "multiprocessing.Queue", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "timeout", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "maxtasksperchild", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "write_progress_to_logger", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Creates a JobPool object\n\nIn the GUIs, the actual processing runs in a child process to allow user\ninteraction with the GUI itself. In this case, we need a\nNoDaemonProcess to allow this child process to spawn children,\nwhich is implemented in the NestablePool class.\nWe also need to pass the logger to these grandchildren processes\nusing the multiprocessing.Queue and QueueListener classes.\n\nArgs:\n    processes: number of processes. Defaults to 1.\n    warningFilter: level of warnings (https://docs.python.org/3/library/warnings.html#warning-filter). Defaults to \"default\".\n    queue: a multiprocessing.Queue object. If None, a new queue is automatically created. Defaults to None.\n    timeout: maximum time out for each job in seconds. Defaults to 10000 (~3 hours).\n    maxtasksperchild: number of jobs a process can execute before respawning a new process. If None, the number of jobs is unlimited. Default to None."]}, {"name": "job_pool.job_pool.JobPool.applyAsync", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "f", "type": null, "default": null}, {"name": "fargs", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "job_pool.job_pool.JobPool.checkPool", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "printProgressEvery", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}, {"name": "job_pool.job_pool.JobPool.stopPool", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "job_pool.job_pool.JobPool.checkForTerminatedProcess", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "res", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}