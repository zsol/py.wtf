ear in all", "copies.", "THE SOFTWARE IS PROVIDED \"AS IS\" AND THE AUTHOR DISCLAIMS ALL", "WARRANTIES WITH REGARD TO THIS SOFTWARE INCLUDING ALL IMPLIED", "WARRANTIES OF MERCHANTABILITY AND FITNESS. IN NO EVENT SHALL THE", "AUTHOR BE LIABLE FOR ANY SPECIAL, DIRECT, INDIRECT, OR CONSEQUENTIAL", "DAMAGES OR ANY DAMAGES WHATSOEVER RESULTING FROM LOSS OF USE, DATA OR", "PROFITS, WHETHER IN AN ACTION OF CONTRACT, NEGLIGENCE OR OTHER", "TORTIOUS ACTION, ARISING OUT OF OR IN CONNECTION WITH THE USE OR", "PERFORMANCE OF THIS SOFTWARE."], "functions": [{"name": "json_database.xdg_utils._path_from_env", "asynchronous": false, "params": [{"name": "variable", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "default", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "documentation": ["Read an environment variable as a path.\n\nThe environment variable with the specified name is read, and its\nvalue returned as a path. If the environment variable is not set, is\nset to the empty string, or is set to a relative rather than\nabsolute path, the default value is returned.\n\nParameters\n----------\nvariable : str\n    Name of the environment variable.\ndefault : Path\n    Default value.\n\nReturns\n-------\nPath\n    Value from environment or default."]}, {"name": "json_database.xdg_utils._paths_from_env", "asynchronous": false, "params": [{"name": "variable", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "default", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "documentation": ["Read an environment variable as a list of paths.\n\nThe environment variable with the specified name is read, and its\nvalue split on colons and returned as a list of paths. If the\nenvironment variable is not set, or set to the empty string, the\ndefault value is returned. Relative paths are ignored, as per the\nspecification.\n\nParameters\n----------\nvariable : str\n    Name of the environment variable.\ndefault : List[Path]\n    Default value.\n\nReturns\n-------\nList[Path]\n    Value from environment or default."]}, {"name": "json_database.xdg_utils.xdg_cache_home", "asynchronous": false, "params": [], "returns": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "documentation": ["Return a Path corresponding to XDG_CACHE_HOME."]}, {"name": "json_database.xdg_utils.xdg_config_dirs", "asynchronous": false, "params": [], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "documentation": ["Return a list of Paths corresponding to XDG_CONFIG_DIRS."]}, {"name": "json_database.xdg_utils.xdg_config_home", "asynchronous": false, "params": [], "returns": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "documentation": ["Return a Path corresponding to XDG_CONFIG_HOME."]}, {"name": "json_database.xdg_utils.xdg_data_dirs", "asynchronous": false, "params": [], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "documentation": ["Return a list of Paths corresponding to XDG_DATA_DIRS."]}, {"name": "json_database.xdg_utils.xdg_data_home", "asynchronou