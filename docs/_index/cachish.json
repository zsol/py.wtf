other python package to access the linkat(2)\nfunction (and linux kernel 3.11 or later)."]}, {"name": "cachish.cache._get_cache_file", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "cachish.cache._get_cache_filename", "asynchronous": false, "params": [{"name": "url", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}]}