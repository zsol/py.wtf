{"name": "tezzcrawler", "metadata": {"name": "TezzCrawler", "version": "0.2.0", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/TezzLabs/TezzCrawler", "license": null, "documentation_url": null, "dependencies": ["requests", "typer", "beautifulsoup4", "markdownify", "lxml"], "summary": "A web crawler that converts web pages to markdown and prepares them for LLM consumption", "upload_time": 1733146549}, "documentation": ["# TezzCrawler\n\nTezzCrawler is a command-line tool for crawling entire websites and converting HTML files to Markdown. It\u2019s designed for developers who need to feed structured content from a website into a language model or process it for other analytical tasks.\n\n## Features\n- **Site-wide Crawling**: Crawl all pages listed in a sitemap.\n- **Single-page Scraping**: Scrape and convert individual pages.\n- **Markdown Conversion**: Convert HTML pages to Markdown for easy ingestion by LLMs.\n- **Proxy Support**: Crawl sites using a proxy for added flexibility and access.\n\n"], "modules": [{"name": "tezzcrawler.main", "documentation": [], "functions": [{"name": "tezzcrawler.main.get_proxy", "asynchronous": false, "params": [{"name": "proxy_url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "proxy_port", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "proxy_username", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "proxy_password", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "tezzcrawler.main.get_headers", "asynchronous": false, "params": [], "returns": null, "documenta