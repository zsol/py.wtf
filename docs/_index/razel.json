e": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": null, "documentation": ["Run the native razel binary to execute the commands.\n\nCommands are written to `<workspace_dir>/razel.jsonl`. That file is processed with `razel exec`.\nIf the native razel binary is not available, it will be downloaded.\n\nOutput files are created in `<cwd>/razel-out`."]}, {"name": "razel.razel.Razel.write_razel_file", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "razel.razel.Razel.read_log_file", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "razel.razel.Razel._add", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "command", "type": {"name": "_Command", "xref": {"fqname": "_Command", "project": null}, "params": null}, "default": null}], "returns": {"name": "_Command", "xref": {"fqname": "_Command", "project": null}, "params": null}, "documentation": []}, {"name": "razel.razel.Razel._sanitize_name", "asynchronous": false, "params": [{"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "razel.razel.Razel._rel_path", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "file_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [{"name": "razel.razel.Razel.version", "type": {"name": "Cl