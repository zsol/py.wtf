ms": [{"name": "value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "i8", "xref": {"fqname": "i8", "project": null}, "params": null}, "documentation": []}, {"name": "range_typed_integers.check.u16_checked", "asynchronous": false, "params": [{"name": "value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "u16", "xref": {"fqname": "u16", "project": null}, "params": null}, "documentation": []}, {"name": "range_typed_integers.check.i16_checked", "asynchronous": false, "params": [{"name": "value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "i16", "xref": {"fqname": "i16", "project": null}, "params": null}, "documentation": []}, {"name": "range_typed_integers.check.u32_checked", "asynchronous": false, "params": [{"name": "value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "u32", "xref": {"fqname": "u32", "project": null}, "params": null}, "documentation": []}, {"name": "range_typed_integers.check.i32_checked", "asynchronous": false, "params": [{"name": "value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "i32", "xref": {"fqname": "i32", "project": null}, "params": null}, "documentation": []}, {"name": "range_typed_integers.check.u64_checked", "asynchronous": false, "params": [{"name": "value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "u64", "xref": {"fqname": "u64", "project": null}, "params": null}, "documentation": []}, {"name": "range_typed_integers.check.i64_checked", "asynchronous": false, "params": [{"name": "value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "i64", "xref": {"fqname": "i64", "project": null}, "params": null}, "documentation": []}, {"name": "range_typed_integers.check.check_int", "asynchronous": false, "params": [{"name": "typ", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "V", "xref": {"fqname": "V", "project": null}, "params": null}, {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "object", "xref": {"fqname": "functions.object", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}]}, "default": null}, {"name": "value", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}, {"name": "suppress_warning_for_unresolved_hints", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Checks if the specified integer fits into the type typ.\n\ntyp can either be a type or an object and an attribute name as a tuple. In the second case,\nthe type info is extracted from the object using typing.get_type_info and the type annotation for the\ngiven attribute by name is used.\n\nIf the type is an integer type and the value is an integer, this checks the range of the integer and returns\nwhether it fits. If the integer type is not annotated with a range, this returns True.\n\nThis will raise a ValueError if the type passed in is a valid integer type, but the value is not an integer.\n\nIf the type is not a subclass of int, this always returns True."]}, {"name": "range_typed_integers.check.get_range", "asynchronous": false, "params": [{"name": "typ", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "ValueRange", "xref": {"fqname": "ValueRange", "project": null}, "params": null}]}, "documentation": ["Returns the ValueRange object that `typ` is annotated with. If it's not annotated, None is returned.\n"]}, {"name": "range_typed_integers.check.is_optional", "asynchronous": false, "params": [{"name": "typ", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [{"name": "range_typed_integers.check.V", "type": null, "documentation": []}], "classes": [{"name": "range_typed_integers.check.CheckIntWarning", "bases": ["UserWarning"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["This warning is emitted when check_int could not find a type annotation for the given type."]}, {"name": "range_typed_integers.check.IntegerBoundError", "bases": ["OverflowError"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Raised when an integer did not fit into its declared type."]}], "exports": []}]}