{"name": "jinjasql2", "metadata": {"name": "jinjasql2", "version": "0.1.11", "classifiers": ["Development Status :: 4 - Beta", "Environment :: Console", "Intended Audience :: Developers", "License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python", "Programming Language :: Python :: 2.7", "Programming Language :: Python :: 3"], "home_page": "https://github.com/pythonutilities/jinjasql", "license": "MIT", "documentation_url": null, "dependencies": ["Jinja2"], "summary": "Generate SQL Queries and Corresponding Bind Parameters using a Jinja2 Template", "upload_time": 1700500779}, "documentation": ["\r\nGenerate SQL Queries using a Jinja Template, without worrying about SQL Injection\r\n\r\nJinjaSQL automatically binds parameters that are inserted into the template.\r\nAfter JinjaSQL evaluates the template, you get 1) Query with placeholders\r\nfor parameters, and 2) List of values that need to be bound to the query. \r\n\r\nJinjaSQL doesn't actually execute the query - it only prepares the \r\nquery and the bind parameters. You can execute the query using any \r\ndatabase engine / driver you are working with.\r\n\r\n"], "modules": [{"name": "jinjasql", "documentation": [], "functions": [], "variables": [{"name": "jinjasql.__version__", "type": null, "documentation": []}, {"name": "jinjasql.VERSION", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "jinjasql.JinjaSql", "xref": {"fqname": "jinjasql.core.JinjaSql", "project": null}}]}, {"name": "jinjasql.core", "documentation": [], "functions": [{"name": "jinjasql.core.sql_safe", "asynchronous": false, "params": [{"name": "value", "type": null, "default": null}], "returns": null, "documentation": ["Filter to mark the value of an expression as safe for inserting\nin a SQL statement"]}, {"name": "jinjasql.core.identifier", "asynchronous": false, "params": [{"name": "value", "type": null, "default": null}], "returns": null, "documentation": ["A filter that escapes a SQL identifier, usually database objects\nsuch as tables or fields"]}, {"name": "jinjasql.core.escape_postgres", "asynchronous": false, "params": [{"name": "tuple_or_str", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "jinjasql.core.bind", "asynchronous": false, "params": [{"name": "value", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": ["A filter that prints %s, and stores the value \nin an array, so that it can be bound using a prepared statement\n\nThis filter is automatically applied to every {{variable}} \nduring the lexing stage, so developers can't forget to bind"]}, {"name": "jinjasql.core.bind_in_clause", "asynchronous": false, "params": [{"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "jinjasql.core._bind_param", "asynchronous": false, "params": [{"name": "already_bound", "type": null, "default": null}, {"name": "key", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "jinjasql.core.build_escape_identifier_filter", "asynchronous": false, "params": [{"name": "identifier_quote_character", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "jinjasql.core.requires_in_clause", "asynchronous": false, "params": [{"name": "obj", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "jinjasql.core.is_dictionary", "asynchronous": false, "params": [{"name": "obj", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "jinjasql.core._thread_local", "type": null, "documentation": []}, {"name": "jinjasql.core.random", "type": null, "documentation": []}], "classes": [{"name": "jinjasql.core.JinjaSqlException", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "jinjasql.core.MissingInClauseException", "bases": ["JinjaSqlException"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "jinjasql.core.InvalidBindParameterException", "bases": ["JinjaSqlException"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "jinjasql.core.SqlExtension", "bases": ["Extension"], "methods": [{"name": "jinjasql.core.SqlExtension.extract_param_name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "tokens", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "jinjasql.core.SqlExtension.filter_stream", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "stream", "type": null, "default": null}], "returns": null, "documentation": ["We convert \n{{ some.variable | filter1 | filter 2}}\n    to \n{{ ( some.variable | filter1 | filter 2 ) | bind}}\n\n... for all variable declarations in the template\n\nNote the extra ( and ). We want the | bind to apply to the entire value, not just the last value.\nThe parentheses are mostly redundant, except in expressions like {{ '%' ~ myval ~ '%' }}\n\nThis function is called by jinja2 immediately \nafter the lexing stage, but before the parser is called. "]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "jinjasql.core.JinjaSql", "bases": ["object"], "methods": [{"name": "jinjasql.core.JinjaSql.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "env", "type": null, "default": "..."}, {"name": "param_style", "type": null, "default": "..."}, {"name": "db_engine", "type": null, "default": "..."}, {"name": "identifier_quote_character", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "jinjasql.core.JinjaSql._prepare_environment", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "jinjasql.core.JinjaSql.prepare_query", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "source", "type": null, "default": null}, {"name": "data", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "jinjasql.core.JinjaSql._prepare_query", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "template", "type": null, "default": null}, {"name": "data", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "jinjasql.core.JinjaSql.VALID_PARAM_STYLES", "type": null, "documentation": []}, {"name": "jinjasql.core.JinjaSql.VALID_ID_QUOTE_CHARS", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}