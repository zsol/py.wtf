{"name": "pyinn", "metadata": {"name": "pyinn", "version": "0.1.0", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": null, "license": null, "documentation_url": null, "dependencies": [], "summary": "Interpolating Neural Networks", "upload_time": 1733366362}, "documentation": ["![INN](/Figure1.png)\r\n\r\n\r\n## Interpolating Neural Network\r\n\r\nThis is the github repo for the paper [\"Interpolating neural network (INN): A novel unification of machine learning and interpolation theory\"](https://arxiv.org/abs/2404.10296).\r\n\r\nINN is a lightweight yet precise network architecture that can replace MLPs for data training, partial differential equation (PDE) solving, and parameter calibration. The key features of INNs are:\r\n\r\n* Less trainable parameters than MLP without sacrificing accuracy\r\n* Faster and proven convergent behavior\r\n* Fully differntiable and GPU-optimized\r\n\r\n\r\n\r\n## License\r\nThis project is licensed under the GNU General Public License v3 - see the [LICENSE](https://www.gnu.org/licenses/) for details.\r\n\r\n## Citations\r\nIf you found this library useful in academic or industry work, we appreciate your support if you consider 1) starring the project on Github, and 2) citing relevant papers:\r\n\r\n```bibtex\r\n@article{park2024engineering,\r\n  title={Engineering software 2.0 by interpolating neural networks: unifying training, solving, and calibration},\r\n  author={Park, Chanwook and Saha, Sourav and Guo, Jiachen and Zhang, Hantao and Xie, Xiaoyu and Bessa, Miguel A and Qian, Dong and Chen, Wei and Wagner, Gregory J and Cao, Jian and others},\r\n  journal={arXiv preprint arXiv:2404.10296},\r\n  year={2024}\r\n}\r\n```\r\n"], "modules": [{"name": "pyinn", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "pyinn.model", "documentation": ["INN trainer\n----------------------------------------------------------------------------------\nCopyright (C) 2024  Chanwook Park\n Northwestern University, Evanston, Illinois, US, chanwookpark2024@u.northwestern.edu"], "functions": [{"name": "pyinn.model.relu", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}], "returns": null, "documentation": ["# MLP"]}, {"name": "pyinn.model.forward_MLP", "asynchronous": false, "params": [{"name": "params", "type": null, "default": null}, {"name": "activation", "type": null, "default": null}, {"name": "x_idata", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "pyinn.model.v_forward_MLP", "type": null, "documentation": ["returns (ndata,)"]}, {"name": "pyinn.model.vv_forward_MLP", "type": null, "documentation": ["returns (ndata,)"]}], "classes": [{"name": "pyinn.model.INN_linear", "bases": [], "methods": [{"name": "pyinn.model.INN_linear.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "grid", "type": null, "default": null}, {"name": "config", "type": null, "default": null}], "returns": null, "documentation": ["1D linear interpolation\n--- input --- \ngrid: (J,) 1D vector of the grid\nvalues: (J,) 1D vector of nodal values"]}, {"name": "pyinn.model.INN_linear.get_Ju_idata_imd_idm_ivar", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x_idata_idm", "type": null, "default": null}, {"name": "u_imd_idm_ivar_nds", "type": null, "default": null}], "returns": null, "documentation": ["compute interpolation for a single mode, 1D function\n--- input ---\nx_idata_idm: scalar, jnp value / this can be any input\nu_imd_idm_ivar_nds: (J,) jnp 1D array\n--- output ---\nJu_idata_imd_idm_ivar: scalar, 1D interpolated value"]}, {"name": "pyinn.model.INN_linear.tucker", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "G", "type": null, "default": null}, {"name": "factors", "type": null, "default": null}], "returns": null, "documentation": ["serior computation of tucker decomposition \n--- input ---\nG: core tensor, (M, M, ..., M) \nfactors: factor matrices, (dim, M)", "# CP decomposition", "def get_Ju_idata_imd(self, x_idata_dms, u_imd_dms_vars_nds):", "# x_idata_dms: (dim,)", "# x_dms_nds: (dim, nnode)", "# u_imd_dms_vars_nds: (dim, var, nnode)", "Ju_idata_imd_dims_vars = self.get_Ju_idata_imd_dms_vars(x_idata_dms, u_imd_dms_vars_nds) # output: (dim, var)", "Ju_idata_imd = jnp.prod(Ju_idata_imd_dims_vars, axis=0)", "return Ju_idata_imd # (var,)", "get_Ju_idata_mds = jax.vmap(get_Ju_idata_imd, in_axes = (None,None,0)) # output: (mds,var)", "def get_Ju_idata(self, x_idata_dms, u_mds_dms_vars_nds):", "Ju_idata_mds = self.get_Ju_idata_mds(x_idata_dms, u_mds_dms_vars_nds) # (mds,var)", "Ju_idata = jnp.sum(Ju_idata_mds, axis=0) # returns (var,)", "return Ju_idata", "# @partial(jax.jit, static_argnames=[]) # jit necessary", "# @jax.jit", "@partial(jax.jit, static_argnames=['self'])", "def forward(self, params, x_idata):", "\"\"\" Prediction function", "run one forward pass on given input data", "--- input ---", "params: u_mds_dms_vars_nds, (nmode, dim, var, nnode)", "x_dms_nds: nodal coordinates (dim, nnode)", "x_idata: x_idata_dms (dim,)", "--- return ---", "predicted output (var,)", "\"\"\"", "pred = self.get_Ju_idata(x_idata, params)", "return pred", "v_forward = jax.vmap(forward, in_axes=(None,None, 0)) # returns (ndata,)", "vv_forward = jax.vmap(v_forward, in_axes=(None,None, 0)) # returns (ndata,)"]}, {"name": "pyinn.model.INN_linear.forward", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "params", "type": null, "default": null}, {"name": "x_idata", "type": null, "default": null}], "returns": null, "documentation": ["Prediction function\nrun one forward pass on given input data\n--- input ---\nparams: u_mds_dms_vars_nds, (nmode, dim, var, nnode)\nx_dms_nds: nodal coordinates (dim, nnode)\nx_idata: x_idata_dms (dim,)\n--- return ---\npredicted output (var,)"]}], "class_variables": [{"name": "pyinn.model.INN_linear.get_Ju_idata_imd_idm_vars", "type": null, "documentation": ["input: scalar, (var,J) / output: (var,)"]}, {"name": "pyinn.model.INN_linear.get_Ju_idata_imd_dms_vars", "type": null, "documentation": ["input: (dim,), (dim,var,J) / output: (dim,var)"]}, {"name": "pyinn.model.INN_linear.get_Ju_idata_mds_dms_vars", "type": null, "documentation": ["input: (dim,), (M,dim,var,J) / output: (M,dim,var)"]}, {"name": "pyinn.model.INN_linear.v_tucker", "type": null, "documentation": ["returns (var,)"]}, {"name": "pyinn.model.INN_linear.v_forward", "type": null, "documentation": ["returns (ndata,)"]}, {"name": "pyinn.model.INN_linear.vv_forward", "type": null, "documentation": ["returns (ndata,)"]}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pyinn.model.INN_nonlinear", "bases": ["INN_linear"], "methods": [{"name": "pyinn.model.INN_nonlinear.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "grid", "type": null, "default": null}, {"name": "config", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "pyinn.main", "documentation": ["INN trainer\n----------------------------------------------------------------------------------\nCopyright (C) 2024  Chanwook Park\n Northwestern University, Evanston, Illinois, US, chanwookpark2024@u.northwestern.edu"], "functions": [], "variables": [{"name": "pyinn.main.settings", "type": null, "documentation": []}, {"name": "pyinn.main.gpu_idx", "type": null, "documentation": ["set which GPU to run on Athena"]}, {"name": "pyinn.main.run_type", "type": null, "documentation": []}, {"name": "pyinn.main.interp_method", "type": null, "documentation": []}, {"name": "pyinn.main.data_name", "type": null, "documentation