us": false, "params": [{"name": "args", "type": null, "default": "..."}, {"name": "plugins", "type": null, "default": "..."}], "returns": null, "documentation": ["Run tests"]}], "variables": [{"name": "skmisc.__version__", "type": null, "documentation": []}, {"name": "skmisc.msg", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "skmisc.__version__", "xref": {"fqname": "skmisc.__version__", "project": null}}]}, {"name": "skmisc.loess", "documentation": ["# Locally-weighted regression ({mod}`skmisc.loess`)\n\nLoess is a procedure for estimating a regression surface by a multivariate\nsmoothing procedure. A linear or quadratic function of the independent\nvariables is fit in a moving fashion that is analogous to how a moving\naverage is computed for a time series.\n\nCompared to approaches that fit global parametric functions, loess\nsubstantially increases the domain of surfaces that can be estimated without\ndistortion. However, analogues of the statistical procedures used\nin parametric function fitting -- for example, ANOVA and t intervals --\ninvolve statistics whose distributions are well approximated by familiar\ndistributions.\n\n```\n.. autosummary::\n   :toctree: generated/\n   :template: cython_class.rst\n\n   loess\n   loess_inputs\n   loess_model\n   loess_control\n   loess_outputs\n   loess_prediction\n   loess_confidence_intervals\n   loess_anova\n```\n\n## Source\n\nThe original source code was written by William S. Cleveland, Eric Grosse\nand Ming-Jen Shyu. It is available at <http://www.netlib.org/a/dloess>. It\nwas initially adapted to for use in Scipy by Pierre GF Gerard-Marchant.\n\nFor more see references [^footnote-1] [^footnote-2] and [^footnote-3].\n\n[^footnote-1]: W. S. Cleveland, E. Grosse, and M. J. Shyu. Local Regression Models.\n    In J. M. Chambers and T. Hastie, editors, Statistical Models in S,\n    pages 309--376. Chapman and Hall, New York, 1992.\n\n[^footnote-2]: W. S. Cleveland, S. J. Devlin, and E. Grosse. Regression by Local\n    Fitting: Methods, Properties, and Computing. Journal of Econometrics, 37:\n    pp. 87--114. 1988.\n\n[^footnote-3]: W. S. Cleveland. Robust Locally Weighted Regression and Smoothing\n    Scatterplots. Journal of the American Statistical Association, 74:\n    pp. 829--836. 1979.\n"], "functions": [], "variables": [], "classes": [], "exports": [{"name": "skmisc.loess.loess", "xref": {"fqname": "skmisc.loess._loess.loess", "project": null}}, {"name": "skmisc.loess.loess_anova", "xref": {"fqname": "skmisc.loess._loess.loess_anova", "project": null}}, {"name": "skmisc.loess.loess_confidence_intervals", "xref": {"fqname": "skmisc.loess._loess.loess_confidence_intervals", "project": null}}, {"name": "skmisc.loess.loess_control", "xref": {"fqname": "skmisc.loess._loess.loess_control", "project": null}}, {"name": "skmisc.loess.loess_inputs", "xref": {"fqname": "skmisc.loess._loess.loess_inputs", "project": null}}, {"name": "skmisc.loess.loess_model", "xref": {"fqname": "skmisc.loess._loess.loess_model", "project": null}}, {"name": "skmisc.loess.loess_outputs", "xref": {"fqname": "skmisc.loess._loess.loess_outputs", "project": null}}, {"name": "skmisc.loess.loess_prediction", "xref": {"fqname": "skmisc.loess._loess.loess_prediction", "project": null}}]}, {"name": "skmisc._version", "documentation": ["This file is dynamically generated by the build system to support", "versioning with source control. Do not edit by hand"], "functions": [], "variables": [{"name": "skmisc._version.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "skmisc._distributor_init", "documentation": ["Distributor init file\n\nDistributors: you can add custom code here to support particular distributions\nof scikit-misc.\n\nFor example, this is a good place to put any checks for hardware requirements.\n\nThe scikit-misc standard source distribution will not put code in this file, so\nyou can safely replace this file with your own version.