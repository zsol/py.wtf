"documentation": []}, {"name": "gpstime.test.TestGPStime.test_gpstime_fromgps_timestamp", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gpstime.test.TestGPStime.test_gpstime_tconvert_classmethod", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gpstime.test.TestGPStime.test_gpstime_tconvert_iso", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gpstime.test.TestGPStime.test_gpstime_tconvert_gps", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gpstime.test.TestGPStime.test_gpstime_parse_leap", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gpstime.test.TestGPStime.test_gpstime_parse_gps_leap", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gpstime.test.TestGPStime.test_gpstime_add", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gpstime.test.TestGPStime.test_gpstime_subtract", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "gpstime.__main__", "documentation": [], "functions": [{"name": "gpstime.__main__.tzname", "asynchronous": false, "params": [{"name": "tz", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "gpstime.__main__.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "gpstime.__main__.PARSER", "type": null, "documentation": []}, {"name": "gpstime.__main__.zg", "type": null, "documentation": []}, {"name": "gpstime.__main__.fg", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "gpstime", "documentation": ["datetime with GPS time support\n\nThis module primarily provides functions for converting to/from UNIX\nand GPS times, as well as a `gpstime` class that directly inherits\nfrom the builtin `datetime` class, adding additional methods for GPS\ntime input and output.\n\nLeap seconds are expected to be provided by the core libc Time Zone\nDatabase tzdata.  If for some reason the tzdata leapsecond file is not\navailable, a local cache of the IETF leap second record will be\nmaintained:\n\n  https://www.ietf.org/timezones/data/leap-seconds.list\n\nKNOWN BUGS: This module does not currently handle conversions of time\nstrings describing the actual leap second themselves, which are\nusually represented as the 60th second of the minute during which the\nleap second occurs."], "functions": [{"name": "gpstime.unix2gps", "asynchronous": false, "params": [{"name": "unix", "type": null, "default": null}], "returns": null, "documentation": ["Convert UNIX timestamp to GPS time.\n\n    "]}, {"name": "gpstime.gps2unix", "asynchronous": false, "params": [{"name": "gps", "type": null, "default": null}], "returns": null, "documentation": ["Convert GPS time to UNIX timestamp.\n\n    "]}, {"name": "gpstime._cu_date_parse", "asynchronous": false, "params": [{"name": "string", "type": null, "default": "..."}], "returns": null, "documentation": ["Parse date/time string to UNIX timestamp with GNU coreutils date\n\n    ", "#################################################"]}, {"name": "gpstime._du_date_parse", "asynchronous": false, "params": [{"name": "string", "type": null, "default": "..."}], "returns": null, "documentation": ["Parse date/time string to UNIX timestamp with dateutils parse\n\n    "]}, {"name": "gpstime.tconvert", "asynchronous": false, "params": [{"name": "string", "type": null, "default": "..."}, {"name": "form", "type": null, "default": "..."}], "returns": null, "documentation": ["Reimplementation of LIGO \"tconvert\" binary behavior\n\nGiven a GPS time string, return the date/time string with the\nspecified format.  Given a date/time string, return the GPS time.\n\nThis just uses the gpstime.parse() method internally."]}, {"name": "gpstime.gpsnow", "asynchronous": false, "params": [], "returns": null, "documentation": ["Return current GPS time as a float.\n\n    "]}], "variables": [{"name": "gpstime.__version__", "type": null, "documentation": []}, {"name": "gpstime.__version__", "type": null, "documentation": []}, {"name": "gpstime.__version__", "type": null, "documentation": []}, {"name": "gpstime.ISO_FORMAT", "type": null, "documentation": []}, {"name": "gpstime.GPS0", "type": null, "documentation": []}, {"name": "gpstime._date_parse", "type": null, "documentation": []}, {"name": "gpstime._date_parse", "type": null, "documentation": []}, {"name": "gpstime.parse", "type": null, "documentation": []}], "classes": [{"name": "gpstime.GPSTimeException", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["#################################################"]}, {"name": "gpstime.gpstime", "bases": ["datetime"], "methods": [{"name": "gpstime.gpstime.fromdatetime", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "datetime", "type": null, "default": null}], "returns": null, "documentation": ["Return gpstime object from datetime object"]}, {"name": "gpstime.gpstime.fromgps", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "gps", "type": null, "default": null}], "returns": null, "documentation": ["Return gpstime object corresponding to GPS time."]}, {"name": "gpstime.gpstime.parse", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "string", "type": null, "default": "..."}], "returns": null, "documentation": ["Parse an arbitrary time string into a gpstime object.\n\nIf string not specified 'now' is assumed.  Strings that can be\ncast to float are assumed to be GPS times.  Prepend '@' to a\nfloat to specify a UNIX timestamp.\n\nThis parse uses the natural lanuage parsing abilities of the\nGNU coreutils 'date' utility.  See \"DATE STRING\" in date(1)\nfor information on possible date/time descriptions."]}, {"name": "gpstime.gpstime.gps", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return GPS time as a float."]}, {"name": "gpstime.gpstime.iso", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return time in standard UTC ISO format."]}], "class_variables": [{"name": "gpstime.gpstime.tconvert", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["GPS-aware datetime class\n\nAn extension of the datetime class, with the addition of methods\nfor converting to/from GPS times:\n\n```pycon\n>>> from gpstime import gpstime\n>>> gt = gpstime.fromgps(1088442990)\n>>> gt.gps()\n1088442990.0\n>>> gt.strftime('%Y-%m-%d %H:%M:%S %Z')\n'2014-07-03 17:16:14 UTC'\n>>> gpstime.now().gps()\n1133737481.204008\n```\n\nIn addition a natural language parsing `parse` classmethod returns\na gpstime object for a arbitrary time string:\n\n```pycon\n>>> gpstime.parse('2014-07-03 17:16:14 UTC').gps()\n1088442990.0\n>>> gpstime.parse('2 days ago').gps()\n1158440653.553765\n```\n", "#################################################"]}, {"name": "gpstime.GPSTimeParseAction", "bases": ["argparse.Action"], "methods": [{"name": "gpstime.GPSTimeParseAction.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parser", "type": null, "default": null}, {"name": "namespace", "type": null, "default": null}, {"name": "values", "type": null, "default": null}, {"name": "option_string", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["gpstime argparse argumention parser Action.\n\nParses an arbitrary date/time string into a gpstime object."]}], "exports": [{"name": "gpstime.__version__", "xref": {"fqname": "gpstime.__version__.version", "project": null}}, {"name": "gpstime.datetime", "xref": {"fqname": "datetime.datetime", "project": null}}, {"name": "gpstime.LEAPDATA", "xref": {"fqname": "gpstime.leaps.LEAPDATA", "project": null}}, {"name": "gpstime.tzlocal", "xref": {"fqname": "dateutil.tz.tzlocal", "project": "python-dateutil"}}, {"name": "gpstime.tzutc", "xref": {"fqname": "dateutil.tz.tzutc", "project": "python-dateutil"}}]}]}