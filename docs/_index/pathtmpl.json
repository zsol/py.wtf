{"name": "pathtmpl", "metadata": {"name": "pathtmpl", "version": "0.2.0", "classifiers": ["Programming Language :: Python :: 3", "Programming Language :: Python :: 3.13"], "home_page": null, "license": null, "documentation_url": null, "dependencies": ["jinja2", "pydantic"], "summary": "Path Template", "upload_time": 1732432453}, "documentation": ["# Path Template\n\n## Install\n\n```shell\npoetry add pathtmpl\n```\n\n\n## Usage\n\n```python\nimport uuid\nfrom pathlib import PurePath\nfrom datetime import date as Date\nfrom pathtmpl import DocumentContext, CField, get_evaluated_path\n\n\npath_tmpl = \"\"\"\n{% if document.cf['Effective Date'] %}\n    /home/Tax/{{ document.cf['Effective Date'] | datefmt(\"%Y\") }}.pdf\n{% else %}\n    /home/Tax/{{ document.id }}.pdf\n{% endif %}\n\"\"\"\ncustom_fields = [\n    CField(name=\"Total\", value=245.02),\n    CField(name=\"Effective Date\", value=Date(2024, 12, 23)),\n]\ndoc = DocumentContext(\n    id=uuid.uuid4(),\n    title=\"coco\",\n    custom_fields=custom_fields,\n)\n\nev_path = get_evaluated_path(doc, path_template=path_tmpl)\nassert ev_path == PurePath(\"/home/Tax/2024.pdf\")\n```\n\n## Tests\n\n\n```shell\npoetry run pytest\n```\n"], "modules": [{"name": "pathtmpl", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "pathtmpl.CField", "xref": {"fqname": "pathtmpl.models.CField", "project": null}}, {"name": "pathtmpl.DocumentContext", "xref": {"fqname": "pathtmpl.models.DocumentContext", "project": null}}, {"name": "pathtmpl.get_evaluated_path", "xref": {"fqname": "pathtmpl.template.get_evaluated_path", "project": null}}]}, {"name": "pathtmpl.models", "documentation": [], "functions": [], "variables": [{"name": "pathtmpl.models.CFValueType", "type": {"name": "TypeAlias", "xref": {"fqname": "typing.TypeAlias", "project": "--std--"}, "params": null}, "documentation": []}], "classes": [{"name": "pathtmpl.models.CField", "bases": ["BaseModel"], "methods": [{"name": "pathtmpl.models