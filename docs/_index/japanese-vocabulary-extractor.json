unctions": [{"name": "sample.dictionary.get_jamdict_instance", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "sample.dictionary.get_word_info", "asynchronous": false, "params": [{"name": "word", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "jam", "type": null, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}]}