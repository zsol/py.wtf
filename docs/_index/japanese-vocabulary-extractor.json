ams": [{"name": "provided_path", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "main.main.get_files", "asynchronous": false, "params": [{"name": "provided_path", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}, {"name": "extension", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "main.main.get_output_file_path", "asynchronous": false, "params": [{"name": "provided_path", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}, {"name": "type", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "is_parent", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "main.csv", "documentation": ["!/usr/bin/env python3", "-*- coding: utf-8 -*-", "Standard Library Imports"], "functions": [{"name": "main.csv.save_vocab_to_csv", "asynchronous": false, "params": [{"name": "vocab", "type": {"name": "set", "xref": {"fqname": "functions.set", "project": "--std--"}, "params": null}, "default": null}, {"name": "output_file", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []