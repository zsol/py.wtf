 "params": null}, "default": null}, {"name": "n", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Just like `moreorless.unified_diff` except using `click.secho`."]}, {"name": "moreorless.click.echo_color_precomputed_diff", "asynchronous": false, "params": [{"name": "diff", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Like `echo_color_unified_diff`, but for precomputed diff results."]}, {"name": "moreorless.click.main", "asynchronous": false, "params": [{"name": "afile", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "bfile", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "moreorless.tests.click", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "moreorless.tests.click.ColorTest", "bases": ["unittest.TestCase"], "methods": [{"name": "moreorless.tests.click.ColorTest.test_echo_color_unified_diff", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "secho", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "moreorless.tests.click.ColorTest.test_echo_color_precomputed_diff", "asynchronous