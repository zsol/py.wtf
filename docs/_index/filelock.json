es": [], "instance_variables": [], "inner_classes": [], "documentation": ["Uses the {func}`msvcrt.locking` function to hard lock the lock file on windows systems.\n"]}], "exports": [{"name": "filelock._windows.WindowsFileLock", "xref": {"fqname": "filelock._windows.WindowsFileLock", "project": null}}]}, {"name": "filelock._api", "documentation": [], "functions": [], "variables": [{"name": "filelock._api._LOGGER", "type": null, "documentation": []}], "classes": [{"name": "filelock._api.AcquireReturnProxy", "bases": [], "methods": [{"name": "filelock._api.AcquireReturnProxy.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "lock", "type": {"name": "BaseFileLock", "xref": {"fqname": "BaseFileLock", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "filelock._api.AcquireReturnProxy.__enter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "BaseFileLock", "xref": {"fqname": "BaseFileLock", "project": null}, "params": null}, "documentation": []}, {"name": "filelock._api.AcquireReturnProxy.__exit__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "exc_type", "type": {"name": "type[BaseException] | None", "xref": null, "params": null}, "default": null}, {"name": "exc_value", "type": {"name": "BaseException | None", "xref": null, "params": null}, "default": null}, {"name": "traceback", "type": {"name": "TracebackType | None", "xref": null, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["A context aware object that will release the lock file when exiting.", "This is a helper class which is returned by :meth:`BaseFileLock.acquire` and wraps the lock to make sure __enter__", "is not called twice when entering the with statement. If we would simply return *self*, the lock would be acquired", "again in the *__enter__* method of the BaseFileLock, but not released again automatically. issue #37 (memory leak)"]}, {"name": "filelock._api.BaseFileLock", "bases": ["ABC", "contextlib.ContextDecorator"], "methods": [{"name": "filelock._api.BaseFileLock.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "lock_file", "type": {"name": "str | os.PathLike[Any]", "xref": null, "params": null}, "default": null}, {"name": "timeout", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Create a new lock object.\n\n```{eval-rst}\n\n:param lock_file: path to the file\n```\n\nthe acquire method, if no timeout value (`None`) is given. If you want to disable the timeout, set it\nto a negative value. A timeout of 0 means, that there is exactly one attempt to acquire the file lock.\n"]}, {"name": "filelock._api.BaseFileLock.lock_file", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": [":return: path to the lock file"]}, {"name": "filelock._api.BaseFileLock.timeout", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": ["---\nreturn: the default timeout value, in seconds\n---\n\n:::{versionadded} 2.0.0\n:::\n"]}, {"name": "filelock._api.BaseFileLock.timeout", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": {"name": "float | str", "xref": null, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Change the default timeout value.\n\n:param value: the new value, in seconds"]}, {"name": "filelock._api.BaseFileLock._acquire", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["If the file lock could be acquired, self._lock_file_fd holds the file descriptor of the lock file."]}, {"name": "filelock._api.BaseFileLock._release", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Releases the lock and sets self._lock_file_fd to None."]}, {"name": "filelock._api.BaseFileLock.is_locked", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["---\nreturn: A boolean indicating if the lock file is holding the lock currently.\n---\n\n:::{versionchanged} 2.0.0\nThis was previously a method and is now a property.\n:::\n"]}, {"name": "filelock._api.BaseFileLock.acquire", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "timeout", "type": {"name": "float | None", "xref": null, "params": null}, "default": "..."}, {"name": "poll_interval", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "poll_intervall", "type": {"name": "float | None", "xref": null, "params": null}, "default": "..."}, {"name": "blocking", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "AcquireReturnProxy", "xref": {"fqname": "filelock._api.AcquireReturnProxy", "project": null}, "params": null}, "documentation": ["Try to acquire the file lock.\n\n```{eval-rst}\n\nif ``timeout < 0``, there is no timeout and this method will block until the lock could be acquired\n:param poll_interval: interval of trying to acquire the lock file\n:param poll_intervall: deprecated, kept for backwards compatibility, use ``poll_interval`` instead\n:param blocking: defaults to True. If False, function will return immediately if it cannot obtain a lock on the\n first attempt. Otherwise this method will block until the timeout expires or the lock is acquired.\n:raises Timeout: if fails to acquire lock within the timeout period\n:return: a context object that will unlock the file when the context is exited\n```\n\n```python\n# You can use this method in the context manager (recommended)\nwith lock.acquire():\n    pass\n\n# Or use an equivalent try-finally construct:\nlock.acquire()\ntry:\n    pass\nfinally:\n    lock.release()\n```\n\n:::{versionchanged} 2.0.0\nThis method returns now a *proxy* object instead of *self*,\nso that it can be used in a with statement without side effects.\n:::\n"]}, {"name": "filelock._api.BaseFileLock.release", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "force", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Releases the file lock. Please note, that the lock is only completely released, if the lock counter is 0. Also\nnote, that the lock file itself is not automatically deleted.\n\n:param force: If true, the lock counter is ignored and the lock is released in every case/"]}, {"name": "filelock._api.BaseFileLock.__en