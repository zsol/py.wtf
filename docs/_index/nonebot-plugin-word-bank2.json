f": {"fqname": "nonebot.adapters.onebot.v11.Message", "project": "nonebot-adapter-onebot"}, "params": null}, "default": null}, {"name": "match_type", "type": {"name": "MatchType", "xref": {"fqname": "nonebot_plugin_word_bank2.word_entry.models.MatchType", "project": null}, "params": null}, "default": null}, {"name": "to_me", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "nonebot_plugin_word_bank2.util", "documentation": [], "functions": [{"name": "nonebot_plugin_word_bank2.util.parse_msg", "asynchronous": false, "params": [{"name": "msg", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": [":\u8bf4\u660e: `parse_msg`\n> \u66ff\u6362\u56de\u7b54\u4e2d\u7684 `/at`, `/self`, `/atself`\n\n:\u53c2\u6570:\n  * `msg: str`: \u5f85\u5904\u7406\u7684\u6d88\u606f\n\n:\u8fd4\u56de:\n  - `str`: \u6d88\u606f"]}, {"name": "nonebot_plugin_word_bank2.util.get_img", "asynchronous": true, "params": [{"name": "url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "nonebot_plugin_word_bank2.util.save_img", "asynchronous": true, "params": [{"name": "img", "type": {"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}, "default": null}, {"name": "file