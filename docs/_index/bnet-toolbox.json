\nbnet install wow_beta\n```\n\nCurrent Commands:\n- `install <agent_uid>`: Installs a product\n  - If the TACT product ID does not match the agent UID, you can provide the TACT product ID with `--tact_product=$product_name_here`\n- `uninstall <agent_uid>`: Uninstalls a product\n- `update <agent_uid>`: Updates a product\n- `products`: Lists the currently installed products\n- `sessions`: Lists active game sessions\n- `repair`: Requests repair of an installed product\n- `hardware`: Returns some hardware information\n\n> [!TIP]\n> The product IDs that Agent uses (agent_uids) are not the same as those that TACT uses. Most of the IDs will end up being the same, but some won't match.\n> You can find a list of products and their Agent UIDs on the [TACT](https://wowdev.wiki/TACT#Product_Information) wiki page.\n"], "modules": [{"name": "bnet_toolbox", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "bnet_toolbox.tools", "documentation": [], "functions": [{"name": "bnet_toolbox.tools.is_agent_accessible", "asynchronous": false, "params": [], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "bnet_toolbox.tools.is_authenticated", "asynchronous": false, "params": [], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "bnet_toolbox.tools.auth", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.requires_auth", "asynchronous": false, "params": [{"name": "func", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.is_game_initialized", "asynchronous": false, "params": [{"name": "product", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.get_game_data", "asynchronous": false, "params": [{"name": "product", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.game_has_pending_update", "asynchronous": false, "params": [{"name": "product", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.get_install_summary", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.get_install_dir", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.is_game_installed", "asynchronous": false, "params": [{"name": "product", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.initialize_product", "asynchronous": false, "params": [{"name": "product", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "tact_product", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.queue_product_install", "asynchronous": false, "params": [{"name": "product", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.update_product", "asynchronous": false, "params": [{"name": "product", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "bnet_toolbox.tools.remove_product", "asynchronou