ally adds current file's package root to Python load path (i.e. `sys.path`) unless already added.\nThis makes it possible to always ensure module imports behave same no matter how the file is loaded.\n\nExamples:\n\n    rootpath.append()\n    rootpath.append(__file__)\n    rootpath.append('./src')", "=========================================", "FUNCTIONS", "--------------------------------------"]}], "variables": [{"name": "rootpath.append.CURRENT_PATH", "type": null, "documentation": []}, {"name": "rootpath.append.ROOT_PATH", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "rootpath.tests.helper", "documentation": ["=========================================", "IMPORTS", "--------------------------------------"], "functions": [{"name": "rootpath.tests.helper.validate", "asynchronous": false, "params": [], "returns": null, "documentation": ["=========================================", "HELPERS", "--------------------------------------", "See: https://www.pythonsheets.com/notes/python-tests.html"]}, {"name": "rootpath.tests.helper.run", "asynchronous": false, "params": [{"name": "test", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rootpath.tests.helper.suite", "asynchronous": false, "params": [{"name": "root", "type": null, "default": "..."}, {"name": "pattern", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "rootpath.tests.helper.load", "asynchronous": false, "params": [{"name": "root", "type": null, "default": "..."}, {"name": "pattern", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "rootpath.tests.helper.deepdiff", "asynchronous": false, "params": [{"name": "a", "type": null, "default": null}, {"name": "b", "type": null, "default": null}, {"name": "exclude_types", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "rootpath.tests.helper.pretty", "asynchronous": false, "params": [{"name": "data", "typ