ules to accommodate special cases or exceptions."]}], "exports": []}, {"name": "frformat.geo.code_postal_frozenset", "documentation": [], "functions": [], "variables": [{"name": "frformat.geo.code_postal_frozenset.CODES_POSTAUX", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "frformat.geo.code_commune_insee_frozenset", "documentation": [], "functions": [], "variables": [{"name": "frformat.geo.code_commune_insee_frozenset.CODES_COMMUNES_INSEE_COG_2023", "type": null, "documentation": []}, {"name": "frformat.geo.code_commune_insee_frozenset.CODES_COMMUNES_INSEE_COG_2024", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "frformat.geo.commune_frozenset", "documentation": [], "functions": [], "variables": [{"name": "frformat.geo.commune_frozenset.COMMUNES_COG_2023", "type": null, "documentation": []}, {"name": "frformat.geo.commune_frozenset.COMMUNES_COG_2024", "type": null, "documentation": []}], "classes": [], "exports": []}]}