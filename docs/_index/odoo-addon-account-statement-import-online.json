 "type": null, "default": null}, {"name": "statement_date_since", "type": null, "default": null}, {"name": "statement_date_until", "type": null, "default": null}], "returns": null, "documentation": ["Both log error, and post a message on the provider record."]}, {"name": "odoo.addons.account_statement_import_online.models.online_bank_statement_provider.OnlineBankStatementProvider._create_or_update_statement", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "data", "type": null, "default": null}, {"name": "statement_date_since", "type": null, "default": null}, {"name": "statement_date_until", "type": null, "default": null}], "returns": null, "documentation": ["Create or update bank statement with the data retrieved from provider.\n\nWe can not use statement.date as a unique key within the statements\nof a journal, because this is now a computed field based on the last date in\nthe statement lines.\n\nHowever we can still ensure unique and predictable names, so we wil use that\nto find existing statements."]}, {"name": "odoo.addons.account_statement_import_online.models.online_bank_statement_provider.OnlineBankStatementProvider.make_statement_name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "statement_date_since", "type": null, "default": null}], "returns": null, "documentation": ["Make name for statement using date and journal name."]}, {"name": "odoo.addons.account_statement_import_online.models.online_bank_statement_provider.OnlineBankStatementProvider._statement_create_or_write", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "statement_values", "type": null, "default": null}], "returns": null, "documentation": ["Final creation of statement if new, else write."]}, {"name": "odoo.addons.account_statement_import_online.models.online_bank_statement_provider.OnlineBankStatementProvider._get_statement_filtered_lines", "asynchronous"