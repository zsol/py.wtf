r first time working on the project, using:\n# poetry install\n```\n\n```bash\n# In order to run the package without building, you can do:\npoetry run python -m scientiflow_cli.main --help\n```\n"], "modules": [{"name": "scientiflow_cli.main", "documentation": [], "functions": [{"name": "scientiflow_cli.main.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "scientiflow_cli.main.AUTH_TOKEN", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "scientiflow_cli.pipeline.container_manager", "documentation": [], "functions": [{"name": "scientiflow_cli.pipeline.container_manager.get_job_containers", "asynchronous": false, "params": [{"name": "auth_token", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "job", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [{"name": "scientiflow_cli.pipeline.container_manager.API_BASE", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "scientiflow_cli.pipeline", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "scientiflow_cli", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "scientiflow_cli.pipeline.get_jobs", "documentation": [], "functions": [{"name": "scientiflow_cli.pipeline.get_jobs.get_jobs", "asynchronous": false, "params": [{"name": "auth_token", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "para