bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Determine if a class is a dataclass."]}, {"name": "flake8_pydantic._utils.is_function", "asynchronous": false, "params": [{"name": "node", "type": {"name": "ast.Call", "xref": {"fqname": "ast.Call", "project": "--std--"}, "params": null}, "default": null}, {"name": "function_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "flake8_pydantic._utils.is_name", "asynchronous": false, "params": [{"name": "node", "type": {"name": "ast.expr", "xref": {"fqname": "ast.expr", "project": "--std--"}, "params": null}, "default": null}, {"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "flake8_pydantic._utils.extract_annotations", "asynchronous": false, "params": [{"name": "node", "type": {"name": "ast.expr", "xref": {"fqname": "ast.expr", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "set", "xref": {"fqname": "functions.set", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}], "variables": [{"name": "flake8_pydantic._utils.PYDANTIC_FIELD_ARGUMENTS", "type": null, "documentation": []}, {"name": "flake8_pydantic._utils.PYDANTIC_DECORATORS", "type": null, "documentation": []}, {"name": "flake8_pydantic._utils.PYDANTIC_METHODS", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "flake8_pydantic.visitor", "documentation": [], "functions": [], "variables": [{"name": "flake8_pydantic.visitor.ClassType",