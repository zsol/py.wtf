ams": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "test.TestRecursive.test_only_directories", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "test.TestRecursive.test_parent_dir", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "test.TestRecursive.test_fixed_basename", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "test.TestRecursive.test_all_files", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "test.TestRecursive.test_root_directory_not_returned", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "test.TestRecursive.test_non_glob", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "test.TestIncludeHidden", "bases": ["BaseTest"], "methods": [{"name": "test.TestIncludeHidden.setup_files", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "test.TestIncludeHidden.test_hidden", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "glob2.fnmatch", "documentation": ["Filename matching with shell patterns.\n\nfnmatch(FILENAME, PATTERN) matches according to the local convention.\nfnmatchcase(FILENAME, PATTERN) always takes case in account.\n\nThe functions operate by translating the pattern into a regular\nexpression.  They cache the compiled regular expressions for speed.\n\nThe function translate(PATTERN) returns a regular expression\ncorresponding to PATTERN.  (It does not compile it.)"], "functions": [{"name": "glob2.fnmatch._norm_paths", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}, {"name": "norm_paths", "type": null, "default": null}, {"name": "sep", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "glob2.fnmatch.fnmatch", "asynchronous": false, "params": [{"name": "name", "type": null, "default": null}, {"name": "pat", "type": null, "default": null}, {"name": "norm_paths", "type": null, "default": "..."}, {"name": "case_sensitive", "type": null, "default": "..."}, {"name": "sep", "type": null, "default": "..."}], "returns": null, "documentation": ["Test whether FILENAME matches PATTERN.\n\nPatterns are Unix shell style:\n\n- matches everything\n\n?       matches any single character\n\\[seq\\]   matches any character in seq\n\\[!seq\\]  matches any char not in seq\n\nAn initial period in FILENAME is not special.\nBoth FILENAME and PATTERN are first case-normalized\nif the operating system requires it.\nIf you don't want this, use fnmatchcase(FILENAME, PATTERN).\n\n```\nparam slashes\n\n\n\nparam norm_paths\n\nA tri-state boolean:\nwhen true, invokes  on both paths,\nwhen , just equalize slashes/backslashes to ,\nwhen false, does not touch paths at all.\n\nNote that a side-effect of  on Windows is that\nit converts to lower-case all matches of  functions.\n\nparam case_sensitive\n\ndefines the case-sensitiviness of regex doing the matches\n\nparam sep\n\nin case only slahes replaced, what sep-char to substitute with;\nif false,  is used.\n```\n\nNotice that by default, `normcase()` causes insensitive matching\non *Windows*, regardless of `case_insensitive` param.\nSet `norm_paths=None, case_sensitive=False` to preserve\nverbatim mathces.\n"]}, {"name": "glob2.fnmatch._compile_pattern", "asynchronous": false, "params": [{"name": "pat", "type": null, "default": null}, {"name": "case_sensitive", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "glob2.fnmatch.filter", "asynchronous": false, "params": [{"name": "names", "type": null, "default": null}, {"name": "pat", "type": null, "default": null}, {"name": "norm_paths", "type": null, "default": "..."}, {"name": "case_sensitive", "type": null, "default": "..."}, {"name": "sep", "type": null, "default": "..."}], "returns": null, "documentation": ["Return the subset of the list NAMES that match PAT."]}, {"name": "glob2.fnmatch.fnmatchcase", "asynchronous": false, "params": [{"name": "name", "type": null, "default": null}, {"name": "pat", "type": null, "default": null}, {"name": "case_sensitive", "type": null, "default": "..."}], "returns": null, "documentation": ["Test whether FILENAME matches PATTERN, including case.\n\nThis is a version of fnmatch() which doesn't case-normalize\nits arguments."]}, {"name": "glob2.fnmatch.translate", "asynchronous": false, "params": [{"name": "pat", "type": null, "default": null}], "returns": null, "documentation": ["Translate a shell PATTERN to a regular expression.\n\nThere is no way to quote meta-characters."]}], "variables": [], "classes": [], "exports": [{"name": "glob2.fnmatch.filter", "xref": {"fqname": "glob2.fnmatch.filter", "project": null}}, {"name": "glob2.fnmatch.fnmatch", "xref": {"fqname": "glob2.fnmatch.fnmatch", "project": null}}, {"name": "glob2.fnmatch.fnmatchcase", "xref": {"fqname": "glob2.fnmatch.fnmatchcase", "project": null}}, {"name": "glob2.fnmatch.translate", "xref": {"fqname": "glob2.fnmatch.translate", "project": null}}]}, {"name": "glob2.compat", "documentation": ["Back-port functools.lru_cache to Python 2 (and <= 3.2)", "{{{ http://code.activestate.com/recipes/578078/ (r6)"], "functions": [{"name": "glob2.compat._make_key", "asynchronous": false, "params": [{"name": "args", "type": null, "default": null}, {"name": "kwds", "type": null, "default": null}, {"name": "typed", "type": null, "default": null}, {"name": "kwd_mark", "type": null, "default": "..."}, {"name": "fasttypes", "type": null, "default": "..."}, {"name": "sorted", "type": null, "default": "..."}, {"name": "tuple", "type": null, "default": "..."}, {"name": "type", "type": null, "default": "..."}, {"name": "len", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "glob2.compat.lru_cache", "asynchronous": false, "params": [{"name": "maxsize", "type": null, "default": "..."}, {"name": "typed", "type": null, "default": "..."}], "returns": null, "documentation": ["Least-recently-used cache decorator.\n\nIf *maxsize* is set to None, the LRU features are disabled and the cache\ncan grow without bound.\n\nIf *typed* is True, arguments of different types will be cached separately.\nFor example, f(3.0) and f(3) will be treated as distinct calls with\ndistinct results.\n\nArguments to the cached function must be hashable.\n\nView the cache statistics named tuple (hits, misses, maxsize, currsize) with\nf.cache_info().  Clear the cache and statistics with f.cache_clear().\nAccess the underlying function with f.__wrapped__.\n\nSee:  http://en.wikipedia.org/wiki/Cache_algorithms#Least_Recently_Used"]}], "variables": [{"name": "glob2.compat._CacheInfo", "type": null, "documentation": []}], "classes": [{"name": "glob2.compat._HashedSeq", "bases": ["list"], "methods": [{"name": "glob2.compat._HashedSeq.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "tup", "type": null, "default": null}, {"name": "hash", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "glob2.compat._HashedSeq.__hash__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "glob2.compat._HashedSeq.__slots__", 