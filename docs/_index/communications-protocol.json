{"name": "communications-protocol", "metadata": {"name": "communications-protocol", "version": "0.1.0", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/yourusername/yourproject", "license": null, "documentation_url": null, "dependencies": ["PySide6"], "summary": "A package for communication protocol handling", "upload_time": 1735799469}, "documentation": ["# Communications Protocol\n\n\u8fd9\u662f\u4e00\u4e2a\u7528\u4e8e\u5904\u7406\u901a\u4fe1\u534f\u8bae\u7684Python\u5305\uff0c\u63d0\u4f9b\u4e86\u4e00\u4e9b\u5e38\u7528\u7684\u901a\u4fe1\u547d\u4ee4\u548c\u5e27\u521b\u5efa\u529f\u80fd\u3002\n\n## \u529f\u80fd\n\n- \u63e1\u624b\u8bf7\u6c42\n- \u6570\u636e\u8bf7\u6c42\n- \u8bbe\u7f6e\u901f\u5ea6\n- \u505c\u6b62\u8fd0\u52a8\n- \u8bbe\u7f6e\u96f6\u4f4d\n- \u5355\u8f74\u8fd0\u52a8\n\n## \u5b89\u88c5\n\n\u4f60\u53ef\u4ee5\u901a\u8fc7\u4ee5\u4e0b\u547d\u4ee4\u5b89\u88c5\u6b64\u5305\uff1a\npip install communications_protocol-0.1.0-py3-none-any.whl\n\n## \u4f7f\u7528\u793a\u4f8b\n\n### \u4ee5\u4e0b\u662f\u5982\u4f55\u4f7f\u7528`CommunicationsProtocol`\u7c7b\u7684\u793a\u4f8b\uff1a\n\nfrom communications_protocol import CommunicationsProtocol\n\n### \u521b\u5efa\u534f\u8bae\u5b9e\u4f8b\nprotocol = CommunicationsProtocol()\n\n### \u751f\u6210\u63e1\u624b\u8bf7\u6c42\u5e27\nhandshake_frame = protocol.handshake()\nprint(\"Handshake Frame:\", handshake_frame)\n\n### \u8bf7\u6c42\u6570\u636e\ndata_request_frame = protocol.request_data()\nprint(\"Data Request Frame:\", data_request_frame)\n\n### \u8bbe\u7f6e\u901f\u5ea6\nspeed_frame = protocol.set_speed(1.5)\nprint(\"Set Speed Frame:\", speed_frame)\n\n### \u505c\u6b62\u8fd0\u52a8\nstop_frame = protocol.stop_motion(0x01)\nprint(\"Stop Motion Frame:\", stop_frame)\n\n### \u8bbe\u7f6e\u96f6\u4f4d\nzero_position_frame = protocol.zero_position()\nprint(\"Zero Position Frame:\", zero_position_frame)\n\n### \u5355\u8f74\u8fd0\u52a8\nsingle_axis_frame = protocol.single_axis_motion(1000)\nprint(\"Single Axis Motion Frame:\", single_axis_frame)\n\n\n"], "modules": [{"name": "communications_protocol", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "communications_protocol.communications_protocol", "documentation": [], "functions": [], "variables": [{"name": "communications_protocol.communications_protocol.protocol", "type": null, "documentation": []}], "classes": [{"name": "communications_protocol.communications_protocol.Command", "bases": ["IntEnum"], "methods": [], "class_variables": [{"name": "communications_protocol.communications_protocol.Command.HANDSHAKE", "type": null, "documentation": []}, {"name": "communications_protocol.communications_protocol.Command.REQUEST_DATA", "type": null, "documentation": []}, {"name": "communications_protocol.communications_protocol.Command.SET_SPEED", "type": null, "documentation": []}, {"name": "communications_protocol.communications_protocol.Command.STOP_MOTION", "type": null, "documentation": []}, {"name": "communications_protocol.communications_protocol.Command.ZERO_POSITION", "type": null, "documentation": []}, {"name": "communications_protocol.communications_protocol.Command.SINGLE_AXIS_MOTION", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["\u901a\u4fe1\u547d\u4ee4\u679a\u4e3e"]}, {"name": "communications_protocol.communications_protocol.FrameHeader", "bases": [], "methods": [], "class_variables": [{"name": "communications_protocol.communications_protocol.FrameHeader.START_BYTE", "type": null, "documentation": []}, {"name": "communications_protocol.communications_protocol.FrameHeader.VERSION", "type": null, "documentation": []}, {"name": "communications_protocol.communications_protocol.FrameHeader.DEVICE_ID", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["\u5e27\u5934\u914d\u7f6e"