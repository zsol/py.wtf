ook.newref", "asynchronous": false, "params": [{"name": "obj", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fishhook.fishhook.patch_object", "asynchronous": false, "params": [], "returns": null, "documentation": ["adds fake class to inheritance chain so that object can be modified\nalso patches type.__base__ to never return fake class\nin theory is safe, if not, possible alternative would be injecting a class\ninto all lookups by modifying type.__bases__?"]}, {"name": "fishhook.fishhook.force_setattr", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "attr", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fishhook.fishhook.force_delattr", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "attr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fishhook.fishhook.build_orig", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "fishhook.fishhook.reduce_classes", "asynchronous": false, "params": [{"name": "*cls", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fishhook.fishhook.hook", "asynchronous": false, "params": [{"name": "_cls", "type": null, "default": null}, {"name": "*more_classes", "type": null, "default": null}, {"name": "name", "type": null, "default": "..."}, {"name": "func", "type": null, "default": "..."}], "returns": null, "documentation": ["Decorator, allows for the decoration of functions to hook a specified dunder on a static class\nex:\n\n@hook(int)\ndef __add__(self, other):\n    ...\n\nwould set the implementation of `int.__add__` to the `__add__` specified above"]}, {"name": "fishhook.fishhook.unhook", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null,