ne", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "bioio_ome_tiff.tests.test_reader.test_micromanager_ome_tiff_main_file", "asynchronous": false, "params": [{"name": "filename", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "bioio_ome_tiff.tests.test_reader.test_ome_metadata", "asynchronous": false, "params": [{"name": "filename", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "bioio_ome_tiff.utils", "documentation": ["!/usr/bin/env python", "-*- coding: utf-8 -*-"], "functions": [{"name": "bioio_ome_tiff.utils.transform_metadata_with_xslt", "asynchronous": false, "params": [{"name": "tree", "type": {"name": "ET.Element", "xref": {"fqname": "xml.etree.ElementTree.Element", "project": "--std--"}, "params": null}, "default": null}, {"name": "xslt", "type": {"name": "types.PathLike", "xref": {"fqname": "bioio_base.types.PathLike", "project": "bioio-base"}, "params": null}, "default": null}], "returns": {"name": "OME", "xref": {"fqname": "ome_types.OME", "project": null}, "params": null}, "documentation": ["Given an in-memory metadata Element and a path to an XSLT file, convert\nmetadata to OME.\n\nParameters\n----------\ntree: ET.Element\n    The metadata tree to convert.\nxslt: PathLike\n    Path to the XSLT file.\n\nReturns\n-------\nome: OME\n    The generated / translated OME metadata.\n\nNotes\n-----\nThis function will briefly update your processes current working directory\nto the directory that stores the XSLT file.", "##############################################################################"]}, {"name": "bioio_ome_tiff.utils.generate_ome_image_id", "asynchronous": false, "params": [{"name": "image_id", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Naively generates the standard OME image ID using a provided ID.\n\nParameters\n----------\nimage_id: Union[str, int]\n    A string or int representing the ID for an image.\n    In the context of the usage of this function, this is usually used with the\n    index of the scene / image.\n\nReturns\n-------\nome_image_id: str\n    The OME standard for image IDs."]}, {"name": "bioio_ome_tiff.utils.generate_ome_channel_id", "asynchronous": false, "params": [{"name": "image_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "channel_id", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Naively generates the standard OME channel ID using a provided ID.\n\nParameters\n----------\nimage_id: str\n    An image id to pull the image specific index from.\n    See: `generate_ome_image_id` for more details.\nchannel_id: Union[str, int]\n    A string or int representing the ID for a channel.\n    In the context of the usage of this function, this is usually used with the\n    index of the channel.\n\nReturns\n-------\nome_channel_id: str\n    The OME standard for channel IDs.\n\nNotes\n-----\nImageIds are usually: \"Image:0\", \"Image:1\", or \"Image:N\",\nChannelIds are usually the combination of image index + channel index --\n\"Channel:0:0\" for the first channel of the first image for example."]}, {"name": "bioio_ome_tiff.utils.generate_ome_instrument_id", "asynchronous": false, "params": [{"name": "instrument_id", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Naively generates the standard OME instrument ID using a provided ID.\n\nParameters\n----------\ninstrument_id: Union[str, int]\n    A string or int representing the ID for an instrument.\n\nReturns\n-------\nome_instrument_id: str\n    The OME standard for instrument IDs."]}, {"name": "bioio_ome_tiff.utils.generate_ome_detector_id", "asynchronous": false, "params": [{"name": "detector_id", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Naively generates the standard OME detector ID using a provided ID.\n\nParameters\n----------\ndetector_id: Union[str, int]\n    A string or int representing the ID for a detector.\n\nReturns\n-------\nome_detector_id: str\n    The OME standard for detector IDs."]}, {"name": "bioio_ome_tiff.utils.clean_ome_xml_for_known_issues", "asynchronous": false, "params": [{"name": "xml", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Clean an OME XML string for known issues created by AICS or MicroManager\nsystems and tools.\n\nCommonly this is used for cleaning a file produced by AICS prior to noticing the\nissue (2021), or for other users of aicsimageio as a whole prior to 4.x series of\nreleases.\n\nThe result of this function should be an OME XML string that is relatively the\nsame (no major pieces missing) but that validates against the reference OME\nXSD.\n\nParameters\n----------\nxml: str\n    The OME XML string to clean for errors.\n\nReturns\n-------\ncleaned_xml: str\n    The cleaned OME XML string.\n\nRaises\n------\nValueError\n    Provided XML does not contain a namespace."]}, {"name": "bioio_ome_tiff.utils.dtype_to_ome_type", "asynchronous": false, "params": [{"name": "npdtype", "type": {"name": "np.dtype", "xref": {"fqname": "numpy.dtype", "project": "numpy"}, "params": null}, "default": null}], "returns": {"name": "PixelType", "xref": {"fqname": "ome_types.model.simple_types.PixelType", "project": null}, "params": null}, "documentation": ["Convert numpy dtype to OME PixelType\n\nParameters\n----------\nnpdtype: numpy.dtype\n    A numpy datatype.\n\nReturns\n-------\nome_type: PixelType\n    One of the supported OME Pixels types\n\nRaises\n------\nValueError\n    No matching pixel type for provided numpy type."]}, {"name": "bioio_ome_tiff.utils.ome_to_numpy_dtype", "asynchronous": false, "params": [{"name": "ome_type", "type": {"name": "PixelType", "xref": {"fqname": "ome_types.model.simple_types.PixelType", "project": null}, "params": null}, "default": null}], "returns": {"name": "np.dtype", "xref": {"fqname": "numpy.dtype", "project": "numpy"}, "param