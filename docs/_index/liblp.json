"name": "liblp.include.metadata_format", "documentation": ["Copyright (C) 2022 Sebastiano Barezzi", "SPDX-License-Identifier: Apache-2.0"], "functions": [], "variables": [{"name": "liblp.include.metadata_format.LP_METADATA_GEOMETRY_MAGIC", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_METADATA_GEOMETRY_SIZE", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_METADATA_HEADER_MAGIC", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_METADATA_MAJOR_VERSION", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_METADATA_MINOR_VERSION_MIN", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_METADATA_MINOR_VERSION_MAX", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_METADATA_VERSION_FOR_UPDATED_ATTR", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_METADATA_VERSION_FOR_EXPANDED_HEADER", "type": null, "documentation": ["Attributes for the LpMetadataPartition::attributes field.\n\nREADONLY - The partition should not be considered writable. When used with\ndevice mapper, the block device will be created as read-only."]}, {"name": "liblp.include.metadata_format.LP_PARTITION_ATTR_NONE", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_PARTITION_ATTR_READONLY", "type": null, "documentation": ["This flag is only intended to be used with super_empty.img and super.img on\nretrofit devices. On these devices there are A and B super partitions, and\nwe don't know ahead of time which slot the image will be applied to.\n\nIf set, the partition name needs a slot suffix applied. The slot suffix is\ndetermined by the metadata slot number (0 = _a, 1 = _b)."]}, {"name": "liblp.include.metadata_format.LP_PARTITION_ATTR_SLOT_SUFFIXED", "type": null, "documentation": ["This flag is applied automatically when using MetadataBuilder::NewForUpdate.\nIt signals that the partition was created (or modified) for a snapshot-based\nupdate. If this flag is not present, the partition was likely flashed via\nfastboot."]}, {"name": "liblp.include.metadata_format.LP_PARTITION_ATTR_UPDATED", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_PARTITION_ATTR_DISABLED", "type": null, "documentation": ["Mask that defines all valid attributes. When changing this, make sure to\nupdate ParseMetadata()."]}, {"name": "liblp.include.metadata_format.LP_PARTITION_ATTRIBUTE_MASK_V0", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_PARTITION_ATTRIBUTE_MASK_V1", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_PARTITION_ATTRIBUTE_MASK", "type": null, "documentation": ["Default name of the physical partition that holds logical partition entries.\nThe layout of this partition will look like:\n\n        +--------------------+\n        | Disk Geometry      |\n        +--------------------+\n        | Geometry Backup    |\n        +--------------------+\n        | Metadata           |\n        +--------------------+\n        | Backup Metadata    |\n        +--------------------+\n        | Logical Partitions |\n        +--------------------+"]}, {"name": "liblp.include.metadata_format.LP_METADATA_DEFAULT_PARTITION_NAME", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_SECTOR_SIZE", "type": null, "documentation": ["Amount of space reserved at the start of every super partition to avoid\ncreating an accidental boot sector."]}, {"name": "liblp.include.metadata_format.LP_PARTITION_RESERVED_BYTES", "type": null, "documentation": ["This structure is stored at block 0 in the first 4096 bytes of the\npartition, and again in the following block. It is never modified and\ndescribes how logical partition information can be located."]}, {"name": "liblp.include.metadata_format.LP_HEADER_FLAG_VIRTUAL_AB_DEVICE", "type": null, "documentation": ["This struct defines a logical partition entry, similar to what would be\npresent in a GUID Partition Table."]}, {"name": "liblp.include.metadata_format.LP_TARGET_TYPE_LINEAR", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_TARGET_TYPE_ZERO", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LP_GROUP_SLOT_SUFFIXED", "type": null, "documentation": ["This struct defines an entry in the block_devices table. There must be at\nleast one device, and the first device must represent the partition holding\nthe super metadata."]}, {"name": "liblp.include.metadata_format.LP_BLOCK_DEVICE_SLOT_SUFFIXED", "type": null, "documentation": ["For ease of writing compatibility checks, the original metadata header is\npreserved below, and typedefs are provided for the current version."]}, {"name": "liblp.include.metadata_format.LpMetadataHeaderV1_2", "type": null, "documentation": []}], "classes": [{"name": "liblp.include.metadata_format.LpMetadataGeometry", "bases": ["Structure"], "methods": [], "class_variables": [{"name": "liblp.include.metadata_format.LpMetadataGeometry._fields_", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LpMetadataGeometry._pack_", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "liblp.include.metadata_format.LpMetadataTableDescriptor", "bases": ["Structure"], "methods": [], "class_variables": [{"name": "liblp.include.metadata_format.LpMetadataTableDescriptor._fields_", "type": null, "documentation": []}, {"name": "liblp.include.metadata_format.LpMetadataTableDescriptor._pack_", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "liblp.include.metadata_format.LpMetadataHeader", "bases": ["Structure"], "methods": [], "class_variables": [{"name": "liblp.include.metadata_format.LpMetadataHeader._fields_", "type": null, "documentation": []}, {"name": "liblp.