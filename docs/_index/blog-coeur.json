 [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "coeur.apps.ssg.admin", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "coeur.apps.ssg.admin.UserAdminPostBase", "bases": ["ModelView"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "coeur.apps.ssg.admin.AdminPanel", "bases": [], "methods": [{"name": "coeur.apps.ssg.admin.AdminPanel.handler", "asynchronous": false, "params": [], "returns": null, "documentation": ["Initializes and starts a FastAPI application with an admin interface for managing posts from multiple SQLite databases.\n\nThis method dynamically loads all post classes from the ShardingManager and configures\nthe database bindings for each post class. It then creates a FastAPI application and\nadds a custom Admin view for each post class, allowing users to manage posts via the\nadmin interface.\n\nThe method performs the following steps:\n1. Retrieves the post classes from the ShardingManager.\n2. Configures the database engine bindings for each post class (SQLite database for each).\n3. Sets up a FastAPI app and an Admin interface with user-specific views for managing posts.\n4. Enables editing and deletion of posts for a single database or disables it for multiple databases.\n5. Adds a view to the Admin interface for each post class, defining the columns and features.\n6. Starts a local development server for the Admin interface at `http://localhost:8000/admin`.\n\nNotes:\n- The method currently supports one database with the ability to edit/delete posts.\n  Multi-database support for editing and deleting posts is planned for future implementation.\n- The `count_query` for each post class is a placeholder and needs to be implemented.\n\nExample:\n    To run the application with the admin interface:\n    ```\n    AdminPanel().handler()\n    ```"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "coeur.apps.ssg.markdown", "documentation": [], "functions": [], "variables": [{"name": "coeur.apps.ssg.markdown.HANDLE_BATCH_SIZE", "type": null, "documentation": []}, {"name": "coeur.apps.ssg.markdown.benchmark", "type": null, "documentation": []}], "classes": [{"name": "coeur.apps.ssg.markdown.MarkdownHandler", "bases": [], "methods": [{"name": "coeur.apps.ssg.markdown.MarkdownHandler.handler", "asynchronous": false, "params": [{"name": "posts_directory", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "coeur.apps.ssg.markdown.MarkdownHandler.find_index_md_files", "asynchronous": false, "params": [{"name": "directory", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "coeur.apps.ssg.markdown.MarkdownHandler.bulk_create_db_post", "asynchronous": false, "params": [{"name": "base_directory", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "batch", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "coeur.apps.ssg.markdown.MarkdownHandler.get_post_path", "asynchronous": false, "params": [{"name": "base_directory", "type": null, "default": null}, {"name": "file_path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "coeur.apps.ssg.markdown.MarkdownHandler.extract_markdown_parts", "asynchronous": false, "params": [{"name": "markdown_content", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "coeur.apps.ssg.markdown.MarkdownHandler.ser