oject": "pydantic"}, "params": null}]}, "default": null}, {"name": "configs", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "default": null}, {"name": "constant", "type": {"name": "dict[str, Any] | None", "xref": null, "params": null}, "default": "..."}, {"name": "default", "type": {"name": "dict[str, Any] | None", "xref": null, "params": null}, "default": "..."}, {"name": "to", "type": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "at", "type": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "pydantic.BaseModel", "xref": {"fqname": "pydantic.BaseModel", "project": "pydantic"}, "params": null}]}, "documentation": []}, {"name": "pydantic_sweep._model.initialize", "asynchronous": false, "params": [{"name": "model", "type": {"name": "type", "xref": {"fqname": "functions.type", "project": "--std--"}, "params": [{"name": "pydantic.BaseModel", "xref": {"fqname": "pydantic.BaseModel", "project": "pydantic"}, "params": null}]}, "default": null}, {"name": "configs", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "default": null}, {"name": "constant", "type": {"name": "dict[str, Any] | None", "xref": null, "params": null}, "default": "..."}, {"name": "default", "type": {"name": "dict[str, Any] | None", "xref": null, "params": null}, "default": "..."}, {"name": "to", "type": {"name": "Path | None", "xref": null, "params": null}, "default": "..."}, {"name": "at", "type": {"name": "Path | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "list[Config] | list[pydantic.BaseModel]", "xref": null, "params": null}, "documentation": ["Instantiate the models with the given parameters.\n\n# Parameters\n\nmodel:\n\n: The pydantic model that we want to finalize. This can be either a model cass\n  or an instance of a specific model. In both cases, the configuration is checked\n  for safety and the models are instantiated.\n\nconfigs:\n\n: The partial config dictionaries that we want to initialize with pydantic.\n\nconstant:\n\n: Constant values that should be initialized for all models. These are safely\n  merged with the parameters.\n\ndefault:\n\n: Default parameter that are initialized for all models, but may be overwritten by\n  other fields without any error checking.\n\nto:\n\n: If provided, will first initialize the model and then return a\n  configuration dictionary that sets the model as the values at the given path.\n  Essentially a shortcut to first passing the models to `field(to, models)`.\n\nat:\n\n: If provided, will initialize the model at the given path in the configuration.\n"]}, {"name": "pydantic_sweep._model.field", "asynchronous": false, "params": [{"name": "values", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": null}, "default": null}, {"name": "path", "type": {"name": "Path", "xref": {"fqname": "pydantic_sweep.types.Path", "project": null}, "params": null}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "documentation": ["Assign various values to a field in a pydantic Model.\n\n# Parameters\n\npath :\n\n: The path to the key in the model. Can either be a dot-separated string of\n  keys (e.g., `my.key`) or a tuple of keys (e.g., `('my', 'key')`.\n\nvalues :\n\n: The different values that should be assigned to the field. Note that the\n  `DefaultValue` class has a special meaning, since it will be effectively\n  ignored, allowing it to be kept to the default model.\n\n# Returns\n\nlist\\[Config\\]:\n\n: A list of partial configuration dictionaries that can be passed to the pydantic\n  model.\n\n# Examples\n\n```pycon\n>>> import pydantic_sweep as ps\n```\n\n```pycon\n>>> class Sub(ps.BaseModel):\n...     x: int = 5\n...     y: int = 6\n```\n\n```pycon\n>>> class Model(ps.BaseModel):\n...     sub: Sub = Sub()\n...     seed: int = 5\n```\n\n```pycon\n>>> configs = ps.field(\"sub.x\", [10, 20])\n>>> ps.initialize(Model, configs)\n[Model(sub=Sub(x=10, y=6), seed=5), Model(sub=Sub(x=20, y=6), seed=5)]\n```\n"]}, {"name": "pydantic_sweep._model.config_combine", "asynchronous": false, "params": [{"name": "*configs", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "default": null}, {"name": "combiner", "type": {"name": "Combiner | None", "xref": null, "params": null}, "default": "..."}, {"name": "chainer", "type": {"name": "Chainer | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "documentation": ["Flexible combination of configuration dictionaries.\n\nIn contrast to the more specific functions below, this allows you to flexibly use\nexisting functions from `itertools` in order to create new combiners. All\nexisting combiners build on top of this function.\n\nThe output of this function is a valid input to both itself and other combiner\nfunctions.\n\n# Parameters\n\nconfigs :\n\n: The configurations we want to combine.\n\ncombiner :\n\n: A function that takes as input multiple iterables and yields tuples.\n  For example: `itertools.product`.\n\nchainer :\n\n: A function that takes as input multiple iterables and yields a single new\n  iterable. For example: `itertools.chain`.\n\n# Returns\n\nlist\\[Config\\]:\n\n: A list of new configuration objects after combining or chaining.\n"]}, {"name": "pydantic_sweep._model.config_product", "asynchronous": false, "params": [{"name": "*configs", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "documentation": ["A product of existing configuration dictionaries.\n\nThis is the most common way of constructing searches. It constructs the product\nof the inputs.\n\n```pycon\n>>> config_product(field(\"a\", [1, 2]), field(\"b\", [3, 4]))\n[{'a': 1, 'b': 3}, {'a': 1, 'b': 4}, {'a': 2, 'b': 3}, {'a': 2, 'b': 4}]\n```\n\nThe output of this function is a valid input to both itself and other combiner\nfunctions.\n"]}, {"name": "pydantic_sweep._model.config_zip", "asynchronous": false, "params": [{"name": "*configs", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "documentation": ["Return the zip-combination of configuration dictionaries.\n\n```pycon\n>>> config_zip(field(\"a\", [1, 2]), field(\"b\", [3, 4]))\n[{'a': 1, 'b': 3}, {'a': 2, 'b': 4}]\n```\n"]}, {"name": "pydantic_sweep._model.config_chain", "asynchronous": false, "params": [{"name": "*configs", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "documentation": ["Chain configuration dictionaries behind each other.\n\n```pycon\n>>> config_chain(field(\"a\", [1, 2]), field(\"b\", [3, 4]))\n[{'a': 1}, {'a': 2}, {'b': 3}, {'b': 4}]\n```\n"]}, {"name": "pydantic_sweep._model.config_roundrobin", "asynchronous": false, "params": [{"name": "*configs", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "Config", "xref": {"fqname": "pydantic_sweep.types.Config", "project": null}, "params": null}]}, "documentation": ["Interleave the configuration dictionaries.\n\nThis is the same behavior as `config_chain`, but instead of chaining them behind\neach other, takes from the different iterables in turn.\n\n```pycon\n>>> config_roundrobin(field(\"a\", [1, 2, 3]), field(\"b\", [3, 4]))\n[{'a': 1}, {'b': 3}, {'a': 2}, {'b': 4}, {'a': 3}]\n```\n"]}], "variables": [{"name": "pydantic_sweep._model.T", "type": null, "documentation": []}], "classes": [{"name": "pydantic_sweep._model.BaseModel", "bases": ["pydantic.BaseModel"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Base model with validation enabled by default."]}, {"name": "pydantic_sweep._model.DefaultValue", "bases": [], "methods": [{"name": "pydantic_sweep._model.DefaultValue.__new__", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "*args", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}, {"name": "**kwargs", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Self", "xref": {"fqname": "typing.Self", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pydantic_sweep._model.DefaultValue.__init_subclass__", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "**kwargs", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Indicator class for a default value in the `field` method.\n"]}], "exports": [{"name": "pydantic_sweep._model.BaseModel", "xref": {"fqname": "pydantic_sweep._model.BaseModel", "project": null}}, {"name": "pydantic_sweep._model.check_model", "xref": {"fqname": "pydantic_sweep._model.check_model", "project": null}}, {"name": "pydantic_sweep._model.config_chain", "xref": {"fqname": "pydantic_sweep._model.config_chain", "project": null}}, {"name": "pydantic_sweep._model.config_combine", "xref": {"fqname": "pydantic_sweep._model.config_combine", "project": null}}, {"name": "pydantic_sweep._model.config_product", "xref": {"fqname": "pydantic_sweep._model.config_product", "project": null}}, {"name": "pydantic_sweep._model.config_roundrobin", "xref": {"fqname": "pydantic_sweep._model.config_roundrobin", "project": null}}, {"name": "pydantic_sweep._model.config_zip", "xref": {"fqname": "pydantic_sweep._model.