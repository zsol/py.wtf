{"name": "python-geoip-yplan", "metadata": {"name": "python-geoip-yplan", "version": "1.2", "classifiers": ["License :: OSI Approved :: BSD License", "Programming Language :: Python", "Programming Language :: Python :: 2", "Programming Language :: Python :: 2.6", "Programming Language :: Python :: 2.7", "Programming Language :: Python :: 3", "Programming Language :: Python :: 3.3", "Programming Language :: Python :: 3.4"], "home_page": "https://github.com/yplan/python-geoip", "license": "UNKNOWN", "documentation_url": null, "dependencies": [], "summary": "Provides GeoIP functionality for Python.", "upload_time": 1448989573}, "documentation": ["python-geoip\n============\n\npython-geoip is a library that provides access to GeoIP databases.\nCurrently it only supports accessing MaxMind databases.  It's similar to\nother GeoIP libraries but comes under the very liberal BSD license and\nalso provides an extra library that optionally ships a recent version of\nthe Geolite2 database as provided by MaxMind.\n\nDocumentation is available at https://python-geoip-yplan.readthedocs.org/en/latest/"], "modules": [{"name": "geoip", "documentation": [], "functions": [{"name": "geoip._native_str", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}], "returns": null, "documentation": ["Attempts to coerce a string into native if it's ASCII safe."]}, {"name": "geoip.pack_ip", "asynchronous": false, "params": [{"name": "ip", "type": null, "default": null}], "returns": null, "documentation": ["Given an IP string, converts it into packed format for internal\nusage."]}, {"name": "geoip._read_mmdb_metadata", "asynchronous": false, "params": [{"name": "buf", "type": null, "default": null}], "returns": null, "documentation": ["Reads metadata from a given memory mapped buffer."]}, {"name": "geoip.make_struct_parser", "asynchronous": false, "params": [{"name": "code", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "geoip.open_databa