null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["in a formulary you annot have the same string as representation", "for two different symbols, representing two different entities", "if you put multiple formulas inside a dictionary, each defining ", "and using a symbol represented by an \"f\", in fact you are have multiple,", "unrelated symbols with the same representation. So a reworking of the formulas", "is needed to unify the symbols variable in order to have a common \"f\" symbols", "shared by the formulas. This allows a reasonable composition of the expressions."]}], "exports": []}, {"name": "seeing.sympyHelpers", "documentation": [], "functions": [{"name": "seeing.sympyHelpers.getSymbolByName", "asynchronous": false, "params": [{"name": "expr", "type": null, "default": null}, {"name": "sname", "type": null, "default": null}], "returns": null, "documentation": ["Gets a symbol from a sympy expressions, given the symbols name\n\nParameters\n----------\nexpr : sympy expression\n    A sympy expression \nsname : string\n    A string containing the symbol name\n\nReturns\n-------\nSymbol\n    The symbol having the required name. None is returned if the symbol is not found"]}, {"name": "seeing.sympyHelpers.subsParamsByName", "asynchronous": false, "params": [{"name": "expr", "type": null, "default": null}, {"name": "subsDict", "type": null, "default": null}], "returns": null, "documentation": ["Generate a new sympy expression from a given one by substitution of a set of its symbols. \nSubstitutions are specified as a dictionay of string:value pairs (value can be any sympy expression \nor numerical value).\n\nParameters\n----------\nexpr : sympy expression\n    A sympy expression \nsubsDict : dict\n    A dictionary containing the \"symbol name\":value substitution pairs\n\nReturns\n-------\nexpr\n    The resulting sympy expression"]}, {"name": "seeing.sympyHelpers.lambdifyByName", "asynchronous": false, "params": [{"name": "expr", "type": null, "default": null}, {"name": "symbolsNames", "type": null, "default": null}, {"name": "modules_", "type": null, "default": null}], "returns": null, "documentation": ["Wraps around sympy.lambdify to generate a lambda function from a given sympy expression. \nThe set of symbols to be passed to sympy.lambdify is specified as a list of strings. \n\nParameters\n----------\nexpr : sympy expression\n    A sympy expression \nsymbolsNames : string\n    A list of strings containing the symbols name\nmodules_ : see sympy lambdify modules \n\nReturns\n-------\nlambda\n    The resulting lambda "]}, {"name": "seeing.sympyHelpers.getRestrictedLambda", "asynchronous": false, "params": [{"name": "expr", "type": null, "default": null}, {"name": "subsDict", "type": null, "default": null}, {"name": "independentVarNames", "type": null, "default": null}, {"name": "modules", "type": null, "default": "..."}], "returns": null, "documentation": ["Wraps around sympy.lambdify to generate a lambda function from a given sympy expression. \nThe set of symbols to be passed to sympy.lambdify is specified as a list of strings. \nIf one or more symbols are not found in the expressions, dummy symbols are introduced.\n\nParameters\n----------\nexpr : sympy expression\n    A sympy expression \nsymbolsNames : string\n    A list of strings containing the symbols names\nmodules_ : see sympy lambdify modules \n\nReturns\n-------\nlambda\n    The resulting lambda "]}, {"name": "seeing.sympyHelpers.evaluateLambda", "asynchronous": false, "params": [{"name": "p_f", "type": null, "default": null}, {"name": "independentVarNames", "type": null, "default": null}, {"name": "samples", "type": null, "default": null}, {"name": "xp", "type": null, "default": "..."}], "returns": null, "documentation": ["Evaluates a given a ufunc (numpy or cupy)\n\nParameters\n----------\np_f : ufunc\n    A numpy or cupy ufunc \nindependentVarNames : string list \n    A list of strings containing the names of the symbols to be used as evaluations variables\nsamples : a list of numpy or cupy arrays \n    A samples vector for each variable, to be used generate the grid to evaluate the ufunc\nxp : Array library, either np (numpy) or cp (cupy)\n\nReturns\n-------\narray\n    The result of the function evaluation "]}, {"name": "seeing.sympyHelpers.evaluateFormula", "asynchronous": false, "params": [{"name": "expr", "type": null, "default": null}, {"name": "subsDict", "type": null, "default": null}, {"name": "independentVarNames", "type": null, "default": null}, {"name": "samples", "type": null, "default": null}, {"name": "modules", "type": null, "default": "..."}], "returns": null, "documentation": ["Evaluates a given a sympy expression\n\nParameters\n----------\nexpr : sympy expressions\n    The expressions to be evaluated\nsubsDict : dict\n    A dictionary containing the \"symbol name\":value substitution pairs\nindependentVarNames : string list \n    A list of strings containing the names of the symbols to be used as evaluations variables\nsamples : a list of numpy or cupy arrays \n    A samples vector for each variable, to be used generate the grid to evaluate the expressions\nmodules : either cpulib (numpy) or gpulib (cupy)\n\nReturns\n-------\narray\n    The result of the expressions evaluation "]}, {"name": "seeing.sympyHelpers.latexToSympy", "asynchronous": false, "params": [{"name": "latexText", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "seeing.sympyHelpers.sympyToLatex", "asynchronous": false, "params": [{"name": "expr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "seeing.sympyHelpers.sympyToString", "asynchronous": false, "params": [{"name": "expr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "seeing.sympyHelpers.subsSpecialParams", "asynchronous": false, "params": [{"name": "expr", "type": null, "defau