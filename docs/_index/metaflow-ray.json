"retry_count", "type": null, "default": null}, {"name": "max_user_code_retries", "type": null, "default": null}, {"name": "ubf_context", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "metaflow_extensions.ray.plugins.ray_decorator.RayDecorator.setup_distributed_env", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "flow", "type": null, "default": null}], "returns": null, "documentation": ["This function will setup the same Ray environment for all tasks (control and worker):\n- Wait for tasks to have started.\n- start the subsequent ray processes.\n- Wait for all ray nodes to join the cluster (on both worker and control.)"]}], "class_variables": [{"name": "metaflow_extensions.ray.plugins.ray_decorator.RayDecorator.name", "type": null, "documentation": []}, {"name": "metaflow_extensions.ray.plugins.ray_decorator.RayDecorator.defaults", "type": null, "documentation": []}, {"name": "metaflow_extensions.ray.plugins.ray_decorator.RayDecorator.IS_PARALLEL", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "metaflow_extensions.ray.plugins.ray_utils", "documentation": [], "functions": [{"name": "metaflow_extensions.ray.plugins.ray_utils.resolve_main_ip", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "metaflow_extensions.ray.plugins.ray_utils.ensure_ray_installed", "asynchronous": false, "params": [{"name": "step_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "metaflow_extensions.ray.plugins.ray_utils.warning_message", "asynchronous": false, "params": [{"name": "message", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "metaflow_extensions.ray.plugins.ray_utils.start_ray_processes", "asynchronous": false, "params": [{"name": "ubf_context", "type": null, "d