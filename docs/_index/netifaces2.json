ion": []}], "variables": [{"name": "python.netifaces.routes.IFACE", "type": null, "documentation": []}, {"name": "python.netifaces.routes.DESTINATION", "type": null, "documentation": []}, {"name": "python.netifaces.routes.GATEWAY", "type": null, "documentation": []}, {"name": "python.netifaces.routes.NIL_ADDR", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "tests.basic_functionality_test", "documentation": [], "functions": [{"name": "tests.basic_functionality_test.test_interfaces_returns_something", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "tests.basic_functionality_test.test_interfaces_by_index_returns_same_interface_list", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "tests.basic_functionality_test.test_has_ipv4_or_ipv6", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "tests.basic_functionality_test.test_has_link_layer", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "tests.basic_functionality_test.test_interface_display_formats_windows", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Check that the InterfaceDisplay argument can be used to select between a UUID\nand a human readable name"]}, {"name": "tests.basic_functionality_test.test_loopback_addr_is_returned", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Test that the loopback address is returned in the lists of addresses\n(regression test for a bug)"]}, {"name": "tests.basic_functionality_test.test_all_ifaces_have_ipv4", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Test that all interfaces which return IPv4 addresses have a \"real\" IPv4 address\nand not 0.0.0.0.\n(regression test for a bug)"]}], "variables": [], "classes": [], "exports": []}, {"name": "python.netifaces", "documentation": ["netifaces(2), netifaces reborn\nSee https://github.com/SamuelYvon/netifaces-2"], "functions": [{"name": "python.netifaces.interfaces", "asynchronous": false, "params": [{"name": "display", "type": {"name": "InterfaceDisplay", "xref": {"fqname": "python.netifaces.InterfaceDisplay", "project": null}, "params": null}, "default": "..."}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "InterfaceName", "xref": {"fqname": "python.netifaces.defs.InterfaceName", "project": null}, "params": null}]}, "documentation": ["List the network interfaces that are available\n\n```\nparam display\n\nHint for how to display the interface names.\nSee the  enum for the values. By default,\nhuman-readable.\n```\n\n\\:return the list of network interfaces that are available\n"]}, {"name": "python.netifaces.interfaces_by_index", "asynchronous": false, "params": [{"name": "display", "type": {"name": "InterfaceDisplay", "xref": {"fqname": "python.netifaces.InterfaceDisplay", "project": null}, "params": null}, "default": "..."}], "returns": {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, {"name": "InterfaceName", "xref": {"fqname": "python.netifaces.defs.InterfaceName", "project": null}, "params": null}]}, "documentation": ["List the network interfaces by their index\n\n```\nparam display\n\nHint for how to display the interface names.\nSee the  enum for the values. By default,\nhuman-readable.\n```\n\n:return the list of network interfaces on the machine, with the\n\n: interface's Index mapped to its Name\n"]}, {"name": "python.netifaces.ifaddresses", "asynchronous": false, "params": [{"name": "if_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Addresses", "xref": {"fqname": "python.netifaces.defs.Addresses", "project": null}, "params": null}, "documentation": ["List the network addresses for the given interface\n\n```\nparam if_name\n\nthe interface name\n```\n\n\\:return a map of network addresses indexed by network address type.\nThe values are the addresses, indexed by their roles\n"]}, {"name": "python.netifaces._ip_tool_path", "asynchronous": false, "params": [], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "python.netifaces.gateways", "asynchronous": false, "params": [{"name": "old_api", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "GatewaysTable", "xref": {"fqname": "python.netifaces.defs.GatewaysTable", "project": null}, "params": null}, "documentation": ["Get the routing table indexed by interface type\n\n:return a routing table"]}, {"name": "python.netifaces.default_gateway", "asynchronous": false, "params": [{"name": "old_api", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "DefaultGatewayEntry", "xref": {"fqname": "python.netifaces.defs.DefaultGatewayEntry", "project": null}, "params": null}, "documentation": ["Get the default gateway for