KDOWNX_IMAGE_MAX_SIZE\n   ```\n3. \ud504\ub85c\uc81d\ud2b8 urls.py\uc5d0 \ub2e4\uc74c\uc744 \ucd94\uac00\ud55c\ub2e4.\n   ```python\n   from django.urls import path, include\n   from shared_lib import utils\n   \n   urlpatterns = [\n    # robots.txt\ub294 \ubc18\ub4dc\uc2dc \uac00\uc7a5 \uba3c\uc800\n    path('robots.txt', utils.robots),\n    path('admin/', admin.site.urls),\n    path('', include('zenblog.urls', namespace='zenblog')),\n    path('shared_lib/', include('shared_lib.urls', namespace='shared_lib')),\n    path('markdownx/', include('markdownx.urls')),\n   ]\n   \n   # \uac1c\ubc1c \ud658\uacbd\uc5d0\uc11c \ubbf8\ub514\uc5b4 \ud30c\uc77c \uc11c\ube59\n   from django.conf import settings\n   from django.conf.urls.static import static\n   \n   if settings.DEBUG:\n    urlpatterns += static(settings.MEDIA_URL, document_root=settings.MEDIA_ROOT)\n   ```\n4. \ud504\ub85c\uc81d\ud2b8\uc5d0 media/\ud3f4\ub354\ub97c \uc0dd\uc131\ud558\uace0 default_modal.bg.webp \uc640 default_thumbnail.jpg \ub97c \ub123\uc5b4 \ubaa8\ub2ec \uae30\ubcf8 \ubc30\uacbd\uc73c\ub85c \uc0ac\uc6a9\ud55c\ub2e4.\n5. \ubaa8\ub378 \ub9c8\uc774\uadf8\ub808\uc774\uc158 \uc0dd\uc131(\ubaa8\ub2ec, \uce98\ub9b0\ub354, \ud3ec\ud2b8\ud3f4\ub9ac\uc624, \ube14\ub85c\uadf8 \ubaa8\ub378 \uc124\uce58)\n    ```shell\n    python manage.py makemigrations\n    ```\n6. \ub9c8\uc774\uadf8\ub808\uc774\uc158 \uc801\uc6a9\n    ```shell\n    python manage.py migrate\n    ```\n7. _data/shared_lib.py \uc640 _data/zenblog.py\uc5d0 \ub370\uc774\ud130 \uc900\ube44\n\n\n\n\n"], "modules": [{"name": "zenblog.templatetags", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "zenblog", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "zenblog.apps", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "zenblog.apps.ZenblogConfig", "bases": ["AppConfig"], "methods": [], "class_variables": [{"name": "zenblog.apps.Z