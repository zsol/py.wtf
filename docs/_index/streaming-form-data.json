[{"name": "streaming_form_data.targets.ValueTarget.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "streaming_form_data.targets.ValueTarget.on_data_received", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "chunk", "type": {"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "streaming_form_data.targets.ValueTarget.value", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["ValueTarget stores the input in an in-memory list of bytes.\n\nThis is useful in case you'd like to have the value contained in an in-memory\nstring."]}, {"name": "streaming_form_data.targets.ListTarget", "bases": ["BaseTarget"], "methods": [{"name": "streaming_form_data.targets.ListTarget.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "_type", "type": null, "default": "..."}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "streaming_form_data.targets.ListTarget.on_data_received", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "chunk", "type": {"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "streaming_form_data.targets.ListTarget.on_finish", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "streaming_form_data.targets.ListTarget.value", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "streaming_form_data.targets.ListTarget.finished", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["ListTarget stores the input in an in-memory list of bytes, which is then joined\ninto the final value and appended to an in-memory list of byte strings when each\nvalue is finished.\n\nThis is useful for situations where more than one value may be submitted for the\nsame argument."]}, {"name": "streaming_form_data.targets.FileTarget", "bases": ["BaseTarget"], "methods": [{"name": "streaming_form_data.targets.FileTarget.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "filename", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "allow_overwrite", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Args:\n    filename:\n        The name of the file to write to. This can also be a callable that\n        accepts no arguments and returns a string.\n    allow_overwrite:\n        Whether or not an existing file should be overwritten"]}, {"name": "streaming_form_data.targets.FileTarget.on_start", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name":