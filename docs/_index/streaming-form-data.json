f": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "streaming_form_data.targets.BaseTarget.set_multipart_content_type", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "content_type", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Targets determine what to do with some input once the parser is done processing it.\nAny new Target should inherit from this base class and override the `data_received`\nmethod.\n\nAttributes:\n    multipart_filename:\n        the name of the file extracted from the `Content-Disposition` header.\n        Please note that this value comes directly from the user input and is not\n        sanitized.\n    multipart_content_type:\n        MIME Content-Type of the file, extracted from the `Content-Type` HTTP header"]}, {"name": "streaming_form_data.targets.MultipleTargets", "bases": ["BaseTarget"], "methods": [{"name": "streaming_form_data.targets.MultipleTargets.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "next_target", "type": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Args:\n    next_target:\n        A callable that returns a new target which should be used for the next\n        input of the multiple inputs allowed for the specific field"]}, {"name": "streaming_form_data.targets.MultipleTargets.on_start", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "streaming_form_data.targets.MultipleTargets.on_data_received", "asynchronous": false, "params": [{"name": "self", "