ult": null}, {"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "k", "type": null, "default": "..."}, {"name": "tree_options", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cosmic_toolbox.NearestWeightedNDInterpolator.NearestWeightedNDInterpolator.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "xi", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "cosmic_toolbox.colors", "documentation": [], "functions": [{"name": "cosmic_toolbox.colors.get_colors", "asynchronous": false, "params": [{"name": "cycle", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cosmic_toolbox.colors.set_cycle", "asynchronous": false, "params": [{"name": "cycle", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "cosmic_toolbox.arraytools", "documentation": [], "functions": [{"name": "cosmic_toolbox.arraytools.view_fields", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}, {"name": "names", "type": null, "default": null}], "returns": null, "documentation": ["`rec` must be a numpy structured array.\n`names` is the collection of field names to keep.\n\nReturns a view of the array `a` (not a copy)."]}, {"name": "cosmic_toolbox.arraytools.delete_cols", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}, {"name": "col_names", "type": null, "default": null}], "returns": null, "documentation": ["Delete columns from a numpy recarray.\n\n```\nparam rec\n\nnumpy recarray\n\nparam col_names\n\nlist of names of the columns to delete\n\nreturn\n\nnumpy recarray\n```\n"]}, {"name": "cosmic_toolbox.arraytools.delete_columns", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}, {"name": "col_names", "type": null, "default": null}], "returns": null, "documentation": ["Delete columns from a numpy recarray. (alias for delete_cols for backwards compatibility)\n\n```\nparam rec\n\nnumpy recarray\n\nparam col_names\n\nlist of names of the columns to delete\n```\n"]}, {"name": "cosmic_toolbox.arraytools.add_cols", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}, {"name": "names", "type": null, "default": null}, {"name": "shapes", "type": null, "default": "..."}, {"name": "data", "type": null, "default": "..."}, {"name": "dtype", "type": null, "default": "..."}], "returns": null, "documentation": ["Add columns to a numpy recarray. By default, the new columns are filled with zeros.\nIf `data` is a numpy array, it is used to fill the new columns. If each column should\nshould be filled with different data, `data` should be a list of numpy arrays or an\narray of shape (n_cols, n_rows).\n\n```\nparam rec\n\nnumpy recarray\n\nparam names\n\nlist of names for the columns\n\nparam shapes\n\nlist of shapes for the columns\n\nparam data\n\ndata to fill the columns with\n\nparam dtype\n\ndtype of the columns\n\nreturn\n\nnumpy recarray\n```\n"]}, {"name": "cosmic_toolbox.arraytools.ensure_cols", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}, {"name": "names", "type": null, "default": null}, {"name": "shapes", "type": null, "default": "..."}, {"name": "data", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cosmic_toolbox.arraytools.arr2rec", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}, {"name": "names", "type": null, "default": null}], "returns": null, "documentation": ["Convert a numpy array to a numpy structured array.\n\n```\nparam arr\n\nnumpy array\n\nparam names\n\nlist of names for the columns\n\nreturn\n\nnumpy structured array\n```\n"]}, {"name": "cosmic_toolbox.arraytools.rec2arr", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}, {"name": "return_names", "type": null, "default": "..."}], "returns": null, "documentation": ["Convert a numpy structured array to a numpy array.\n\n```\nparam rec\n\nnumpy structured array\n\nparam return_names\n\nif True, also return the names of the columns\n\nreturn\n\nnumpy array\n```\n\n# Example\n\n```pycon\n>>> rec = np.array([(1, 4), (2, 4), (3, 4)],\n        dtype=[('a', '<i8'), ('b', '<i8')])\n>>> arr = rec2arr(rec)\n>>> arr\narray([[1, 4], [2, 4], [3, 4]])\n>>> arr, names = rec2arr(rec, return_names=True)\n>>> arr\narray([[1, 4], [2, 4], [3, 4]])\n>>> names\n['a', 'b']\n```\n"]}, {"name": "cosmic_toolbox.arraytools.dict2rec", "asynchronous": false, "params": [{"name": "d", "type": null, "default": null}], "returns": null, "documentation": ["Convert a dictionary of arrays/lists to a numpy structured array.\n\n```\nparam d\n\nDictionary with arrays/lists as values\n\nreturn\n\nnumpy structured array\n```\n"]}, {"name": "cosmic_toolbox.arraytools.rec2dict", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}], "returns": null, "documentation": ["Convert a numpy structured array to a dictionary.\n\n```\nparam rec\n\nnumpy structured array\n\nreturn\n\ndictionary\n```\n\n# Example\n\n```pycon\n>>> rec = np.array([(1, 4), (2, 4), (3, 4)],\n        dtype=[('a', '<i8'), ('b', '<i8')])\n>>> d = rec2dict(rec)\n>>> d\n{'a': array([1, 2, 3]), 'b': array([4, 4, 4])}\n```\n"]}, {"name": "cosmic_toolbox.arraytools.dict2class", "asynchronous": false, "params": [{"name": "d", "type": null, "default": null}], "returns": null, "documentation": ["Convert a dictionary to a class.\n\n```\nparam d\n\ndictionary\n\nreturn\n\nclass\n```\n\n# Example\n\n```pycon\n>>> d = {'a': [1, 2, 3], 'b': 4}\n>>> c = dict2class(d)\n>>> c.a\n[1, 2, 3]\n>>> c.b\n4\n```\n"]}, {"name": "cosmic_toolbox.arraytools.rec2class", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}], "returns": null, "documentation": ["Convert a numpy structured array to a class.\n\n```\nparam rec\n\nnumpy structured array\n\nreturn\n\nclass\n```\n"]}, {"name": "cosmic_toolbox.arraytools.class2dict", "asynchronous": false, "params": [{"name": "c", "type": null, "default": null}], "returns": null, "documentation": ["Convert a class to a dictionary.\n\n```\nparam c\n\nclass\n\nreturn\n\ndictionary\n```\n"]}, {"name": "cosmic_toolbox.arraytools.class2rec", "asynchronous": false, "params": [{"name": "c", "type": null, "default": null}], "returns": null, "documentation": ["Convert a class to a numpy structured array.\n\n```\nparam c\n\nclass\n\nreturn\n\nnumpy structured array\n```\n"]}, {"name": "cosmic_toolbox.arraytools.pd2rec", "asynchronous": false, "params": [{"name": "df", "type": null, "default": null}], "returns": null, "documentation": ["Convert a pandas dataframe to a numpy structured array.\n\n```\nparam df\n\npandas dataframe\n\nreturn\n\nnumpy structured array\n```\n"]}, {"name": "cosmic_toolbox.arraytools.rec2pd", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cosmic_toolbox.arraytools.get_nan_mask", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}], "returns": null, "documentation": ["Get a mask for rows with NaNs in a numpy structured array.\n\n```\nparam rec\n\nnumpy structured array\n\nreturn\n\nnumpy structured array\n```\n"]}, {"name": "cosmic_toolbox.arraytools.remove_nans", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}], "returns": null, "documentation": ["Remove rows with NaNs from a numpy structured array.\n\n```\nparam rec\n\nnumpy structured array\n\nreturn\n\nnumpy structured array\n```\n"]}, {"name": "cosmic_toolbox.arraytools.get_inf_mask", "asynchronous": false, "params": [{"name": "rec", "type": null, "default": null}], "returns": null, "document