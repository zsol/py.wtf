tput onto the bound\nprinter (which by default will print to STDOUT).\n\nIf one process terminates, all the others will be terminated by\nHoncho, and {func}`~honcho.manager.Manager.loop` will return.\n\nThis method will block until all the processes have terminated.\n"]}, {"name": "honcho.manager.Manager.terminate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Terminate all processes managed by this ProcessManager."]}, {"name": "honcho.manager.Manager.kill", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Kill all processes managed by this ProcessManager."]}, {"name": "honcho.manager.Manager._killall", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "force", "type": null, "default": "..."}], "returns": null, "documentation": ["Kill all remaining processes, forcefully if requested."]}, {"name": "honcho.manager.Manager._start", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "honcho.manager.Manager._all_started", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "honcho.manager.Manager._all_stopped", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "honcho.manager.Manager._any_stopped", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "honcho.manager.Manager._system_print", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "data", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "honcho.manager.Manager.returncode", "type": null, "documentation": []}], "instance_