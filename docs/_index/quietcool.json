"params": null}, "documentation": []}, {"name": "quietcool.api.Parameters.minute", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "quietcool.api.Parameters.time_range", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Fan operating parameters.\n\nAttributes:\n    mode: Current operating mode\n    fan_type: Type of fan\n    temp_high: High temperature threshold\n    temp_medium: Medium temperature threshold\n    temp_low: Low temperature threshold\n    humidity_high: High humidity threshold\n    humidity_low: Low humidity threshold\n    humidity_range: Humidity range setting\n    hour: Hour setting\n    minute: Minute setting\n    time_range: Time range setting"]}, {"name": "quietcool.api.Preset", "bases": [], "methods": [{"name": "quietcool.api.Preset.from_response", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "response", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Self", "xref": {"fqname": "typing.Self", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [{"name": "quietcool.api.Preset.name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "quietcool.api.Preset.temp_high", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "quietcool.api.Preset.temp_med", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "quietcool.api.Preset.temp_low", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}