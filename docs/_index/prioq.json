)\n>>> queue\nPriorityQueue(-1, 0, 1, 2, 3, 4, key=None, reverse=False)\n>>> queue.push(10)\n>>> queue\nPriorityQueue(-1, 0, 1, 2, 3, 4, 10, key=None, reverse=False)\n```\n"]}, {"name": "prioq.base.PriorityQueue.remove", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": {"name": "_Value", "xref": {"fqname": "prioq.base.core.hints.Value", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Removes value from the queue and if absent raises `ValueError`.\n\nComplexity: O(len(self)).\n\n```pycon\n>>> queue = PriorityQueue(*range(5))\n>>> queue.remove(0)\n>>> queue\nPriorityQueue(1, 2, 3, 4, key=None, reverse=False)\n>>> queue.remove(4)\n>>> queue\nPriorityQueue(1, 2, 3, key=None, reverse=False)\n```\n"]}, {"name": "prioq.base.PriorityQueue.values", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "_t.List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "_Value", "xref": {"fqname": "prioq.base.core.hints.Value", "project": null}, "params": null}]}, "documentation": ["Returns elements of the queue.\n\nComplexity: O(len(self) * log len(self)).\n\n```pycon\n>>> queue = PriorityQueue(*range(5))\n>>> queue.values()\n[0, 1, 2, 3, 4]\n```\n"]}], "class_variables": [{"name": "prioq.base.PriorityQueue._items", "type": {"name": "_t.List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "_Item", "xref": {"fqname": "prioq.base.core.item.Item", "project": null}, "params": [{"name": "_Key", "xref": {"fqname": "prioq.base.core.hints.Key", "project": null}, "params": null}, {"name": "_Value", "xref": {"fqname": "prioq.base.core.hints.Value", "project": null}, "params": null}]}]}, "documentation": []}, {"name": "prioq.base.PriorityQueue._sorting_key", "type": {"name": "_SortingKey", "xref": {"