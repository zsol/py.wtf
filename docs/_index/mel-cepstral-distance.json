"mel_cepstral_distance.types.Penalty", "project": null}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "mel_cepstral_distance.mcd_computation", "documentation": [], "functions": [{"name": "mel_cepstral_distance.mcd_computation.get_metrics_wavs", "asynchronous": false, "params": [{"name": "wav_file_1", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}, {"name": "wav_file_2", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}, {"name": "hop_length", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "n_fft", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "window", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "center", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "n_mels", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "htk", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "norm", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "dtype", "type": {"name": "np.dtype", "xref": {"fqname": "numpy.dtype", "project": "numpy"}, "params": null}, "default": "..."}, {"name": "n_mfcc", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "use_dtw", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "MelCepstralDistance", "xref": {"fqname": "mel_cepstral_distance.types.MelCepstralDistance", "project": null}, "params": null}, {"name": "Penalty", "xref": {"fqname": "mel_cepstral_distance.types.Penalty", "project": null}, "params": null}, {"name": "Frames", "xref": {"fqname": "mel_cepstral_distance.types.Frames", "project": null}, "params": null}]}, "documentation": ["Compute the mel-cepstral distance between two audios, a penalty term accounting for the number of frames that has to\nbe added to equal both frame numbers or to align the mel-cepstral coefficients if using Dynamic Time Warping and the\nfinal number of frames that are used to compute the mel-cepstral distance.\n\n# Parameters\n\nwav_file_1\n\n: path to the first input WAV file\n\nwav_file_2\n\n: path to the second input WAV file\n\nhop_length\n\n: specifies the number of audio samples between adjacent Short Term Fourier Transformation-columns, therefore\n  plays a role in computing the (mel-)spectrograms which are needed to compute the mel-cepstral coefficients\n  See `librosa.core.stft`\n\nn_fft\n\n: `n_fft/2+1` is the number of rows of the spectrograms. `n_fft` should be a power of two to optimize the speed of\n  the Fast Fourier Transformation\n\nwindow\n\n: - a window specification (string, tuple, or number);\n    see `scipy.signal.get_window`\n  - a window function, such as `scipy.signal.hanning`\n  - a vector or array of length `n_fft`\n\n  See `librosa.filters.get_window`\n\ncenter\n: - If `True`, the signal `audio_i` is padded so that frame `D[:, t]` with `D` being the Short-term Fourier\n    transform of the audio is centered at `audio_i[t * hop_length]` for i=1,2\n  - If `False`, then `D[:, t]` begins at `audio_i[t * hop_length]` for i=1,2\n\nn_mels\n\n: number of Mel bands to generate\n\nhtk\n\n: use HTK formula instead of Slaney when creating the mel-filter bank\n\nnorm\n\n: determines if and how the mel weights are normalized: if 1, divide the triangular mel weights by the width of\n  the mel band (area normalization). Otherwise, leave all the triangles aiming for a peak value of 1.0\n\ndtype\n\n: data type of the output\n\nn_mfcc\n\n: the number of mel-cepstral coefficients that are computed per frame, starting with the first coefficient (the\n  zeroth coefficient is omitted, as it is primarily affected by system gain rather than system distortion\n  according to Robert F. Kubichek)\n\nuse_dtw\n\n: to compute the mel-cepstral distance, the number of frames has to be the same for both audios. If `use_dtw` is\n  `True`, Dynamic Time Warping is used to align both arrays containing the respective mel-cepstral coefficients,\n  otherwise the array with less columns is filled with zeros from the right side.\n\n# Returns\n\nmcd\n\n: the mel-cepstral distance between the two input audios\n\npenalty\n\n: a term punishing for the number of frames that had to be added to align the mel-cepstral coefficient arrays\n  with Dynamic Time Warping (for `use_dtw = True`) or to equal the frame numbers via filling up one mel-cepstral\n  coefficient array with zeros (for `use_dtw = False`). The penalty is the sum of the number of added frames of\n  each of the two arrays divided by the final frame number (see below). It lies between zero and one, zero is\n  reached if no columns were added to either array.\n\nfinal_frame_number\n\n: the number of columns of one of the mel-cepstral coefficient arrays after applying Dynamic Time Warping or\n  filling up with zeros\n\n# Example\n\nComparing two audios to another audio using the sum of the mel-cepstral distance and the penalty\n\n```pycon\n>>> import librosa\n>>> mcd_12, penalty_12, _ = get_metrics_wavs(Path(\"exampleaudio_1.wav\"), Path(\"exampleaudio_2.wav\"))\n>>> mcd_13, penalty_13, _ = get_metrics_wavs(Path(\"exampleaudio_1.wav\"). Path(\"exampleaudio_3.wav\"))\n>>> mcd_with_penalty_12 = mcd_12 + penalty_12\n>>> mcd_with_penalty_13 = mcd_13 + penalty_13\n>>> if mcd_with_penalty_12 < mcd_with_penalty_13:\n>>>   print(\"Audio 2 seems to be more similar to audio 1 than audio 3.\")\n>>> elif mcd_with_penalty_13 < mcd_with_penalty_12:\n>>>   print(\"Audio 3 seems to be more similar to audio 1 than audio 2.\")\n>>> else:\n>>>   print(\"Audio 2 and audio 3 seem to share the same similarity to audio 1.\")\n```\n"]}, {"name": "mel_cepstral_distance.mcd_computation.get_metrics_mels", "asynchronous": false, "params": [{"name": "mel_1", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}, {"name": "mel_2", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}, {"name": "n_mfcc", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "take_log", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "use_dtw", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "MelCepstralDistance", "xref": {"fqname": "mel_cepstral_distance.types.MelCepstralDistance", "project": null}, "params": null}, {"name": "Penalty", "xref": {"fqname": "mel_cepstral_distance.types.Penalty", "project": null}, "params": null}, {"name": "Frames", "xref": {"fqname": "mel_cepstral_distance.types.Frames", "project": null}, "params": null}]}, "documentation": ["Compute the mel-cepstral distance between two audios, a penalty term accounting for the number of frames that has to\nbe added to equal both frame numbers or to align the mel-cepstral coefficients if using Dynamic Time Warping and the\nfinal number of frames that are used to compute the mel-cepstral distance.\n\nParameters\n----------\nmel_1           : np.ndarray [shape=(k,n)]\n    first mel spectrogram\n\nmel_2     : np.ndarray [shape=(k,m)]\n    second mel spectrogram\n\ntake_log     : bool\n    should be set to `False` if log10 already has been applied to the input mel spectrograms, otherwise `True`\n\nn_mfcc    : int > 0 [scalar]\n    the number of mel-cepstral coefficients that are computed per frame, starting with the first coefficient (the\n    zeroth coefficient is omitted, as it is primarily affected by system gain rather than system distortion\n    according to Robert F. Kubichek)\n\nuse_dtw  : bool [scalar]\n    to compute the mel-cepstral distance, the number of frames has to be the same for both audios. If `use_dtw` is\n    `True`, Dynamic Time Warping is used to align both arrays containing the respective mel-cepstral coefficients,\n    otherwise the array with less columns is filled with zeros from the right side.\n\nReturns\n-------\nmcd         : float\n    the mel-cepstral distance between the two input audios\npenalty     : float\n    a term punishing for the number of frames that had to be added to align the mel-cepstral coefficient arrays\n    with Dynamic Time Warping (for `use_dtw = True`) or to equal the frame numbers via filling up one mel-cepstral\n    coefficient array with zeros (for `use_dtw = False`). The penalty is the sum of the number of added frames of\n    each of the two arrays divided by the final frame number (see below). It lies between zero and one, zero is\n    reached if no columns were added to either array.\nfinal_frame_number : int\n    the number of columns of one of the mel-cepstral coefficient arrays after applying Dynamic Time Warping or\n    filling up with zeros"]}, {"name": "mel_cepstral_distance.mcd_computation.get_metrics_mels_pairwise", "asynchronous": false, "params": [{"name": "folder1", "type": {"name": "Path", "xref": {"fqna