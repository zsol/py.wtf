.hyp_magnitudes.key_mag", "type": null, "documentation": []}, {"name": "pz_hyperbolic_temp-0.0.data.scripts.hyp_magnitudes.key_mag_err", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "hyperbolic", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "hyperbolic.Keys", "bases": [], "methods": [], "class_variables": [{"name": "hyperbolic.Keys.filter", "type": null, "documentation": []}, {"name": "hyperbolic.Keys.field", "type": null, "documentation": []}, {"name": "hyperbolic.Keys.b", "type": null, "documentation": []}, {"name": "hyperbolic.Keys.b_abs", "type": null, "documentation": []}, {"name": "hyperbolic.Keys.ref_flux", "type": null, "documentation": []}, {"name": "hyperbolic.Keys.zp", "type": null, "documentation": []}, {"name": "hyperbolic.Keys.flux_err", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": [{"name": "hyperbolic.adapt_flux", "xref": {"fqname": "hyperbolic.magnitudes.adapt_flux", "project": null}}, {"name": "hyperbolic.compute_classic_magnitude", "xref": {"fqname": "hyperbolic.magnitudes.compute_classic_magnitude", "project": null}}, {"name": "hyperbolic.compute_classic_magnitude_error", "xref": {"fqname": "hyperbolic.magnitudes.compute_classic_magnitude_error", "project": null}}, {"name": "hyperbolic.compute_flux_error_target", "xref": {"fqname": "hyperbolic.magnitudes.compute_flux_error_target", "project": null}}, {"name": "hyperbolic.compute_flux_stats", "xref": {"fqname": "hyperbolic.magnitudes.compute_flux_stats", "project": null}}, {"name": "hyperbolic.compute_magnitude", "xref": {"fqname": "hyperbolic.magnitudes.compute_magnitude", "project": null}}, {"name": "hyperbolic.compute_magnitude_error", "xref": {"fqname": "hyperbolic.magnitudes.compute_magnitude_error", "project": null}}, {"name": "hyperbolic.convert_flux", "xref": {"fqname": "hyperbolic.magnitudes.convert_flux", "project": null}}, {"name": "hyperbolic.estimate_