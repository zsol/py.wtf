tion": ["Wait for all exclusive AND concurrent locks to release, acquire exclusive file lock, enter context, release this exclusive lock"]}, {"name": "twpl.twpl.Twpl.concurrent", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "poll_interval", "type": null, "default": "..."}, {"name": "timeout", "type": null, "default": "..."}], "returns": null, "documentation": ["Wait for all exclusive locks to release, acquire concurrent file lock, enter context, release this concurrent lock"]}, {"name": "twpl.twpl.Twpl.clean", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "min_age_seconds", "type": null, "default": null}], "returns": null, "documentation": ["Force remove lockfile if age is above `min_age_seconds` regardless of state. Useful for cleaning up stale locks after crashes etc"]}, {"name": "twpl.twpl.Twpl.__acquire_exclusive", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "poll_interval", "type": null, "default": null}, {"name": "timeout", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "twpl.twpl.Twpl.__release_exclusive", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "twpl.twpl.Twpl.__acquire_concurrent", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "poll_interval", "type": null, "default": null}, {"name": "timeout", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "twpl.twpl.Twpl.__release_concurrent", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "twpl.twpl.Twpl.__del__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "twpl.twpl.Twpl.__slots__", "type