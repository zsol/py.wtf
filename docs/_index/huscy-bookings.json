 11:30-12:30        59 - 11:30-14:00        72 - 11:30-15:30\n                         ...                     ...                     ...\n            50 - 13:30-14:30        63 - 13:30-16:00        76 - 13:30-17:30\n            51 - 14:00-15:00        64 - 14:00-16:30        77 - 14:00-18:00\n            52 - 14:30-15:30        65 - 14:30-17:00        78 - 14:30-18:30\n            53 - 15:00-16:00        66 - 15:00-17:30        79 - 15:00-19:00"]}, {"name": "tests.test_timeslot_manager.assert_overlapping_timeslots_are_inactive", "asynchronous": false, "params": [{"name": "timeslot", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "tests.test_create_timeslot", "documentation": [], "functions": [{"name": "tests.test_create_timeslot.test_admin_user_can_create_timeslots", "asynchronous": false, "params": [{"name": "admin_client", "type": null, "default": null}, {"name": "session", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_create_timeslot.test_user_with_permission_can_create_timeslots", "asynchronous": false, "params": [{"name": "client", "type": null, "default": null}, {"name": "user", "type": null, "default": null}, {"name": "session", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_create_timeslot.test_user_without_permission_cannot_create_timeslots", "asynchronous": false, "params": [{"name": "client", "type": null, "default": null}, {"name": "session", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_create_timeslot.test_anonymous_user_cannot_create_timeslots", "asynchronous": false, "params": [{"name": "client", "type": null, "default": null}, {"name": "session", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_create_timeslot.test_active_flag_when_new_timeslot_overlaps_with_booked", "asynchronous": fa