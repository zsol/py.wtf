s": false, "params": [{"name": "request", "type": {"name": "Request", "xref": {"fqname": "mitmproxy.http.Request", "project": "mitmproxy"}, "params": null}, "default": null}, {"name": "matcher_url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}, {"name": "target_url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}]}, "documentation": ["Checks if the request url matches the matcher parameter and if so rebases it into the target URL\n\n```pycon\n>>> matcher_url = urlparse('http://example.external:8080/api/v1')\n>>> target_url = urlparse('http://example.internal:8080/api/v2')\n>>> request = Request.make('GET', 'http://example.external:8080/api/v1/do/stuff')\n>>> rebased = request_rebase(request, matcher_url, target_url)\n>>> rebased and request.path == '/api/v2/do/stuff'\nTrue\n```\n\n```pycon\n>>> matcher_url = urlparse('http://example.com/')\n>>> target_url = urlparse('http://google.com/')\n>>> request = Request.make('GET', 'http://other')\n>>> request_rebase(request, matcher_url, target_url) is None\nTrue\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.redirect_rebase", "asynchronous": false, "params": [{"name": "response", "type": {"name": "Response", "xref": {"fqname": "mitmproxy.http.Response", "project": "mitmproxy"}, "params": null}, "default": null}, {"name": "matcher_url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}, {"name": "target_url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Checks if the response is a redirect and if its Location matches the matcher parameter. If so,\nrebase it into the target URL\n\n```pycon\n>>> response = Response.make(200, headers={})\n>>> redirect_rebase(response, None, None)\nFalse\n```\n\n```pycon\n>>> matcher_url = urlparse('http://internal:80/v1')\n>>> response = Response.make(301, headers={'Location': ''})\n>>> redirect_rebase(response, matcher_url, None)\nFalse\n```\n\n```pycon\n>>> matcher_url = urlparse('http://internal:80/v1')\n>>> target_url = urlparse('http://external:80/v2')\n>>> response = Response.make(307, headers={'Location': 'http://non-matching/v1/resource'})\n>>> redirect_rebase(response, matcher_url, target_url)\nFalse\n```\n\n```pycon\n>>> matcher_url = urlparse('http://internal:80/v1')\n>>> target_url = urlparse('http://external:80/v2')\n>>> response = Response.make(301, headers={'Location': 'http://internal/v1/resource'})\n>>> redirected = redirect_rebase(response, matcher_url, target_url)\n>>> redirected and response.headers[b'Location']\n'http://external/v2/resource'\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.url_rebase", "asynchronous": false, "params": [{"name": "matcher_url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}, {"name": "url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}, {"name": "target_url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}]}, "documentation": ["Checks if the url matches the matcher parameter and if so rebases it into the target URL\n\n```pycon\n>>> matcher_url = urlparse('http://example.external:8080/api/v1')\n>>> url = urlparse('http://example.external:8080/api/v1/path')\n>>> target_url = urlparse('http://internal:8081/v2')\n>>> url_rebase(matcher_url, url, target_url)\nParseResult(scheme='http', netloc='internal:8081', path='/v2/path', params='', query='', fragment='')\n```\n\n```pycon\n>>> matcher_url = urlparse('http://example.external:8080/api/v1')\n>>> url = urlparse('http://example.external:8080/api/v3/path')\n>>> target_url = urlparse('http://internal:8081/v2')\n>>> url_rebase(matcher_url, url, target_url)\n```\n\n```pycon\n>>> matcher_url = ParseResult(scheme='http', netloc='internal:80', path='/v1', params='', query='', fragment='')\n>>> url = ParseResult(scheme='http', netloc='internal', path='/v1/resource', params='', query='', fragment='')\n>>> target_url = ParseResult(scheme='http', netloc='external:80', path='/v2', params='', query='', fragment='')\n>>> url_rebase(matcher_url, url, target_url)\nParseResult(scheme='http', netloc='external', path='/v2/resource', params='', query='', fragment='')\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.path_rebase", "asynchronous": false, "params": [{"name": "matcher_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "target_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Rebase a given path onto a target path by replacing the matched portion of the path\n\n```pycon\n>>> path_rebase('/v1/', '/v1/some/stuff', '/v2/')\n'/v2/some/stuff'\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.url_parts_matches", "asynchronous": false, "params": [{"name": "matcher_url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}, {"name": "hostname", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "port", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Checks if the hostname, port and path all match the matcher_url parameter\n\n```pycon\n>>> matcher_url = urlparse('http://localhost:8080/v1')\n>>> url_parts_matches(matcher_url, 'localhost', 8080, '/v1/sub/path')\nTrue\n```\n\n```pycon\n>>> matcher_url = urlparse('http://localhost:8080/v1')\n>>> url_parts_matches(matcher_url, 'localhost', 8080, '/v2/sub/path')\nFalse\n```\n\n```pycon\n>>> matcher_url = urlparse('http://localhost:8080/v1')\n>>> url_parts_matches(matcher_url, 'test.localhost', 8080, '/v1')\nFalse\n```\n\n```pycon\n>>> matcher_url = urlparse('http://localhost:8080/v1')\n>>> url_parts_matches(matcher_url, 'localhost', 8081, '/v1')\nFalse\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.url_matches", "asynchronous": false, "params": [{"name": "matcher_url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Checks if the hostname, port and path all match the matcher_url parameter\n\n```pycon\n>>> url_matches('http://example/some', 'http://example/some/stuff')\nTrue\n```\n\n```pycon\n>>> url_matches('http://example/some', 'http://example:80/some/stuff')\nTrue\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.url_port", "asynchronous": false, "params": [{"name": "url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["Gets the url port or a default one based on the protocol.\n\nRaises:\n\n: ValueError: no port set and unrecognized protocol\n\n```pycon\n>>> url = urlparse('http://localhost:8080/v1')\n>>> url_port(url)\n8080\n```\n\n```pycon\n>>> url = urlparse('http://example.com/v1')\n>>> url_port(url)\n80\n```\n\n```pycon\n>>> url = urlparse('https://example.com')\n>>> url_port(url)\n443\n```\n\n```pycon\n>>> url = urlparse('unknown://example.com')\n>>> url_port(url)\nTraceback (most recent call last):\n    ...\nValueError: unknown scheme: 'unknown'\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.url_netloc", "asynchronous": false, "params": [{"name": "url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Gets the url netloc, removing the port if it's the default one based on the protocol\n\n```pycon\n>>> url = urlparse('http://localhost:8080/v1')\n>>> url_netloc(url)\n'localhost:8080'\n```\n\n```pycon\n>>> url = urlparse('http://example.com/v1')\n>>> url_netloc(url)\n'example.com'\n```\n\n```pycon\n>>> url = urlparse('https://example.com:443')\n>>> url_netloc(url)\n'example.com'\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.url_default_port", "asynchronous": false, "params": [{"name": "scheme", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["Gets the default url port for the given scheme\n\nRaises:\n\n: ValueError: unrecognized protocol\n\n```pycon\n>>> url_default_port('http')\n80\n```\n\n```pycon\n>>> url_default_port('https')\n443\n```\n\n```pycon\n>>> url_default_port('unknown')\nTraceback (most recent call last):\n    ...\nValueError: unknown scheme 'unknown'\n```\n"]}], "variables": [{"name": "kerberos_auth_proxy.mitm.hostutils.REDIRECT_CODES", "type": null, "documentation": []}], "classes": [{"name": "kerberos_auth_proxy.mitm.hostutils.UrlPattern", "bases": [], "methods": [{"name": "kerberos_auth_proxy.mitm.hostutils.UrlPattern.create", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "UrlPattern", "xref": {"fqname": "kerberos_auth_proxy.mitm.hostutils.UrlPattern", "project": null}, "params": null}, "documentation": ["Create a URL pattern from a URL string spec\n\n```pycon\n>>> pattern = UrlPattern.create('http://localhost:8080')\n>>> pattern\nUrlPattern(scheme='http', hostname=re.compile('(^|.)localhost$'), port=8080, path=re.compile('^/'))\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.UrlPattern.match", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Checks if the URL matches the pattern\n\n```pycon\n>>> pattern = UrlPattern.create('http://localhost')\n>>> [pattern.match(urlparse('http://localhost')),\n...  pattern.match(urlparse('http://localhost:80/')),\n...  pattern.match(urlparse('http://localhost/v1')),\n...  pattern.match(urlparse('http://other.localhost')),\n... ]\n[True, True, True, True]\n```\n\n```pycon\n>>> pattern = UrlPattern.create('http://localhost')\n>>> [pattern.match(urlparse('https://extralocalhost')),\n...  pattern.match(urlparse('http://localhost:8080/')),\n... ]\n[False, False]\n```\n"]}, {"name": "kerberos_auth_proxy.mitm.hostutils.UrlPattern.matches_any", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "patterns", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "UrlPattern", "xref": {"fqname": "kerberos_auth_proxy.mitm.hostutils.UrlPattern", "project": null}, "params": null}]}, "default": null}, {"name": "url", "type": {"name": "ParseResult", "xref": {"fqname": "urllib.parse.ParseResult", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Checks if the URL matches any of the patterns\n\n```pycon\n>>> patterns = [UrlPattern.create('http://localhost'), UrlPattern.create('https://example.com:8443')]\n>>> UrlPattern.matches_any(patterns, urlparse('http://localhost'))\nTrue\n```\n"]}], "class_variables": [{"name": "kerberos_auth_proxy.mitm.hostutils.UrlPattern.scheme", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "kerberos_auth_proxy.mitm.hostutils.UrlPattern.hostname", "type": {"name": "Pattern", "xref": {"fqname": "typing.Pattern", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "kerberos_auth_proxy.mitm.hostutils.UrlPattern.port", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "kerberos_auth_proxy.mitm.hostutils.UrlPattern.path", "type": {"name": "Pattern", "xref": {"fqname": "typing.Pattern", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}