me": "yatl.helpers.STYLE", "type": null, "documentation": []}, {"name": "yatl.helpers.STRONG", "type": null, "documentation": []}, {"name": "yatl.helpers.SELECT", "type": null, "documentation": []}, {"name": "yatl.helpers.OPTION", "type": null, "documentation": []}, {"name": "yatl.helpers.TEXTAREA", "type": null, "documentation": []}, {"name": "yatl.helpers.BUTTON", "type": null, "documentation": []}, {"name": "yatl.helpers.TITLE", "type": null, "documentation": []}, {"name": "yatl.helpers.IMG", "type": null, "documentation": []}, {"name": "yatl.helpers.INPUT", "type": null, "documentation": []}, {"name": "yatl.helpers.META", "type": null, "documentation": []}, {"name": "yatl.helpers.LINK", "type": null, "documentation": []}, {"name": "yatl.helpers.SCRIPT", "type": null, "documentation": []}], "classes": [{"name": "yatl.helpers.TAGGER", "bases": [], "methods": [{"name": "yatl.helpers.TAGGER.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "*children", "type": null, "default": null}, {"name": "**attributes", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.xml", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.__setitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.insert", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "i", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.append", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.__delitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.__len__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.amend", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*children", "type": null, "default": null}, {"name": "**attributes", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.find", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "query", "type": null, "default": "..."}, {"name": "**kargs", "type": null, "default": null}], "returns": null, "documentation": ["Find all components that match the supplied attribute dictionary,\nor None if nothing could be found\n\nAll components of the components are searched.\n\nExamples:\n\n```pycon\n>>> a = DIV(DIV(SPAN('x'),3,DIV(SPAN('y'))))\n>>> for c in a.find('span', first_only=True): c[0]='z'\n>>> print(a)\n<div><div><span>z</span>3<div><span>y</span></div></div></div>\n>>> for c in a.find('span'): c[0]='z'\n>>> print(a)\n<div><div><span>z</span>3<div><span>z</span></div></div></div>\n```\n\nIt also supports a syntax compatible with jQuery\n\nExamples:\n\n```pycon\n>>> a = DIV(SPAN(A('hello', **{'_id': '1-1', '_u:v': '$'})), P('world', _class='this is a test'))\n>>> for e in a.find('div a#1-1, p.is'): print(e)\n<a id=\"1-1\" u:v=\"$\">hello</a>\n<p class=\"this is a test\">world</p>\n>>> for e in a.find('#1-1'): print(e)\n<a id=\"1-1\" u:v=\"$\">hello</a>\n>>> a.find('a[u:v=$]')[0].xml()\n'<a id=\"1-1\" u:v=\"$\">hello</a>'\n>>> a = FORM(INPUT(_type='text'),SELECT(OPTION(0)),TEXTAREA())\n>>> for c in a.find('input, select, textarea'): c['_disabled'] = True\n>>> a.xml()\n'<form><input disabled=\"disabled\" type=\"text\"/><select disabled=\"disabled\"><option>0</option></select><textarea disabled=\"disabled\"></textarea></form>'\n>>> for c in a.find('input, select, textarea'): c['_disabled'] = False\n>>> a.xml()\n'<form><input type=\"text\"/><select><option>0</option></select><textarea></textarea></form>'\n```\n\nElements that are matched can also be replaced or removed by specifying\na \"replace\" argument (note, a list of the original matching elements\nis still returned as usual).\n\nExamples:\n\n```pycon\n>>> a = DIV(DIV(SPAN('x', _class='abc'), DIV(SPAN('y', _class='abc'), SPAN('z', _class='abc'))))\n>>> b = a.find('span.abc', replace=P('x', _class='xyz'))\n>>> print(a)  # We should .xml() here instead of print\n<div><div><p class=\"xyz\">x</p><div><p class=\"xyz\">x</p><p class=\"xyz\">x</p></div></div></div>\n```\n\n\"replace\" can be a callable, which will be passed the original element and\nshould return a new element to replace it.\n\nExamples:\n\n```pycon\n>>> a = DIV(DIV(SPAN('x', _class='abc'), DIV(SPAN('y', _class='abc'), SPAN('z', _class='abc'))))\n>>> b = a.find('span.abc', replace=lambda el: P(el[0], _class='xyz'))\n>>> print(a)\n<div><div><p class=\"xyz\">x</p><div><p class=\"xyz\">y</p><p class=\"xyz\">z</p></div></div></div>\n```\n\nIf replace=None, matching elements will be removed completely.\n\nExamples:\n\n```pycon\n>>> a = DIV(DIV(SPAN('x', _class='abc'), DIV(SPAN('y', _class='abc'), SPAN('z', _class='abc'))))\n>>> b = a.find('span', text='y', replace=None)\n>>> print(a)\n<div><div><span class=\"abc\">x</span><div><span class=\"abc\"></span><span class=\"abc\">z</span></div></div></div>\n```\n\nIf a \"text\" argument is specified, elements will be searched for text\ncomponents that match text, and any matching text components will be\nreplaced (\"text\" is ignored if \"replace\" is not also specified, use\na \"find\" argument when you only need searching for textual elements).\n\nLike the \"find\" argument, \"text\" can be a string or a compiled regex.\n\nExamples:\n\n```pycon\n>>> a = DIV(DIV(SPAN('x', _class='abc'), DIV(SPAN('y', _class='abc'), SPAN('z', _class='abc'))))\n>>> b = a.find(text=re.compile('x|y|z'), replace='hello')\n>>> print(a)\n<div><div><span class=\"abc\">hello</span><div><span class=\"abc\">hello</span><span class=\"abc\">hello</span></div></div></div>\n```\n\nIf other attributes are specified along with text, then only components\nthat match the specified attributes will be searched for text.\n\nExamples:\n\n```pycon\n>>> a = DIV(DIV(SPAN('x', _class='abc'), DIV(SPAN('y', _class='efg'), SPAN('z', _class='abc'))))\n>>> b = a.find('span.efg', text=re.compile('x|y|z'), replace='hello')\n>>> print(a)\n<div><div><span class=\"abc\">x</span><div><span class=\"efg\">hello</span><span class=\"abc\">z</span></div></div></div>\n```\n"]}], "class_variables": [{"name": "yatl.helpers.TAGGER.regex_tag", "type": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.regex_id", "type": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.regex_class", "type": null, "documentation": []}, {"name": "yatl.helpers.TAGGER.regex_attr", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "yatl.helpers.METATAG", "bases": [], "methods": [{"name": "yatl.helpers.METATAG.__getattr__", "asynchronous": false, 