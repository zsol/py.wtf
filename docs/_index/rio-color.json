, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_gamma", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_sat", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_sat_rgba_direct", "asynchronous": false, "params": [{"name": "arr_rgba", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_atmo", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_gamma", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_sigmoidal", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_multi", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_comma", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_saturation_rgb", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_rgba", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}, {"name": "arr_rgba", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_saturation_rgba", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}, {"name": "arr_rgba", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_bad_op", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_bands", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_multi_saturation_first", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_parse_multi_name", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_operations.test_simple_atmos_opstring", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "rio_color.scripts.cli", "documentation": ["Main CLI."], "functions": [{"name": "rio_color.scripts.cli.check_jobs", "asynchronous": false, "params": [{"name": "jobs", "type": null, "default": null}], "returns": null, "documentation": ["Validate number of jobs."]}, {"name": "rio_color.scripts.cli.color", "asynchronous": false, "params": [{"name": "ctx", "type": null, "default": null}, {"name": "jobs", "type": null, "default": null}, {"name": "out_dtype", "type": null, "default": null}, {"name": "src_path", "type": null, "default": null}, {"name": "dst_path", "type": null, "default": null}, {"name": "operations", "type": null, "default": null}, {"name": "creation_options", "type": null, "default": null}], "returns": null, "documentation": ["Color correction\n\nOperations will be applied to the src image in the specified order.\n\nAvailable OPERATIONS include:\n\n\b\n    \"gamma BANDS VALUE\"\n        Applies a gamma curve, brightening or darkening midtones.\n        VALUE > 1 brightens the image.\n\n\b\n    \"sigmoidal BANDS CONTRAST BIAS\"\n        Adjusts the contrast and brightness of midtones.\n        BIAS > 0.5 darkens the image.\n\n\b\n    \"saturation PROPORTION\"\n        Controls the saturation in LCH color space.\n        PROPORTION = 0 results in a grayscale image\n        PROPORTION = 1 results in an identical image\n        PROPORTION = 2 is likely way too saturated\n\nBANDS are specified as a single arg, no delimiters\n\n\b\n    `123` or `RGB` or `rgb` are all equivalent\n\nExample:\n\n\b\n    rio color -d uint8 -j 4 input.tif output.tif \\\n        gamma 3 0.95, sigmoidal rgb 35 0.13\n    "]}, {"name": "rio_color.scripts.cli.atmos", "asynchronous": false, "params": [{"name": "ctx", "type": null, "default": null}, {"name": "atmo", "type": null, "default": null}, {"name": "contrast", "type": null, "default": null}, {"name": "bias", "type": null, "default": null}, {"name": "jobs", "type": null, "default": null}, {"name": "out_dtype", "type": null, "default": null}, {"name": "src_path", "type": null, "default": null}, {"name": "dst_path", "type": null, "default": null}, {"name": "creation_options", "type": null, "default": null}, {"name": "as_color", "type": null, "default": null}], "returns": null, "documentation": ["Atmospheric correction"]}], "variables": [{"name": "rio_color.scripts.cli.jobs_opt", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "rio_color.operations", "documentation": ["Color operations."], "functions": [{"name": "rio_color.operations.sigmoidal", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}, {"name": "contrast", "type": null, "default": null}, {"name": "bias", "type": null, "default": null}], "returns": null, "documentation": ["Sigmoidal contrast is type of contrast control that\nadjusts the contrast without saturating highlights or shadows.\nIt allows control over two factors:\nthe contrast range from light to dark, and where the middle value\nof the mid-tones falls. The result is a non-linear and smooth\ncontrast change.\n\n# Parameters\n\narr\n\n: Array of color values to adjust\n\ncontrast\n\n: Enhances the intensity differences between the lighter and darker\n  elements of the image. For example, 0 is none, 3 is typical and\n  20 is a lot.\n\nbias\n\n: Threshold level for the contrast function to center on\n  (typically centered at 0.5)\n\n# Notes\n\nSigmoidal contrast is based on the sigmoidal transfer function:\n\n$$\ng(u) = ( 1/(1 + e^{- \\alpha * u + \\beta)})\n$$\n\nThis sigmoid function is scaled so that the output is bound by\nthe interval [0, 1].\n\n$$\n( 1/(1 + e^(\\beta * (\\alpha - u))) - 1/(1 + e^(\\beta * \\alpha)))/ ( 1/(1 + e^(\\beta*(\\alpha - 1))) - 1/(1 + e^(\\beta * \\alpha)) )\n$$\n\nWhere :math: `\\alpha` is the threshold level, and :math: `\\beta` the\ncontrast factor to be applied.\n\n# References\n\n[^cite_ct]: Hany Farid \"Fundamentals of Image Processing\"\n    <http://www.cs.dartmouth.edu/farid/downloads/tutorials/fip.pdf>\n", "Color manipulation functions"]}, {"name": "rio_color.operations.gamma", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}, {"name": "g", "type": null, "default": null}], "returns": null, "documentation": ["Gamma correction is a nonlinear operation that\nadjusts the image's channel values pixel-by-pixel according\nto a power-law:\n\n$$\npixel_{out} = pixel_{in} ^ {\\gamma}\n$$\n\nSetting gamma ($\\gamma$) to be less than 1.0 darkens the image and\nsetting gamma to be greater than 1.0 lightens it.\n\n# Parameters\n\ngamma ($\\gamma$): float\n\n: Reasonable values range from 0.8 to 2.4.\n"]}, {"name": "rio_color.operations.saturation", "asynchronous": false, "params": [{"name": "arr", "type": null, "default": null}, {"name": "proportion", "type": null, "default": null}], "returns": null, "documentation": ["Apply saturation to an RGB array (in LCH color space)\n\nMultiply saturation by proportion in LCH color space to adjust the intensity\nof color in the image. As saturation increases, colors appear\nmore \"pure.\" As saturation decreases, colors appear more \"washed-out.\"\n\nParameters\n----------\narr: ndarray with shape (3, ..., ...)\nproportion: number"]}, {"name": "rio_color.operations.simple_atmo_opstring", "asynchronous": false, "params": [{"name": "haze", "type": null, "default": null}, {"name": "contrast", "type": null, "default": null}, {"name": "bias", "type": null, "default": null}], "returns": null, "documentation": ["Make a simple atmospheric correction formula."]}, {"name": "rio_color.operations.simple_atmo", "asynchronous": false, "params": [{"name": "rgb", "type": null, "default": null}, {"name": "haze", "type": null, "default": null}, {"name": "contrast", "type": null, "default": null}, {"name": "bias", "type": null, "default": null}], "returns": null, "documentation": ["A simple, static (non-adaptive) atmospheric correction function.\n\nParameters\n----------\nhaze: float\n    Amount of haze to adjust for. For example, 0.03\ncontrast : integer\n    Enhances the intensity differences between the lighter and darker\n    elements of the image. For example, 0 is none, 3 is typical and\n    20 is a lot.\nbias : float, between 0 and 1\n    Threshold level for the contrast function to center on\n    (typically centered at 0.5 or 50%)"]}, {"name": "rio_color.operations._op_factory", "asynchronous": false, "params": [{"name": "func", "type": null, "default": null}, {"name": "kwargs", "type": null, "default": null}, {"name": "opname", "type": null, "default": null}, {"name": "bands", "type": null, "default": null}, {"name": "rgb_op", "type": null, "default": "..."}], "returns": null, "documentation": ["create an operation function closure\ndon't call directly, use parse_operations\nreturns a function which itself takes and returns ndarrays"]}, {"name": "rio_color.operations.parse_operations", "asynchronous": false, "params": [{"name": "ops_string", "type": null, "default": null}], "returns": null, "documentation": ["Takes a string of operations written with a handy DSL\n\n\"OPERATION-NAME BANDS ARG1 ARG2 OPERATION-NAME BANDS ARG\"\n\nAnd returns a list of functions, each of which take and return ndarrays"]}], "variables": [], "classes": [], "exports": []}]}