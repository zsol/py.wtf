"name": "total_permutations", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._compute_for_permutation", "asynchronous": false, "params": [{"name": "jx", "type": null, "default": null}, {"name": "permuted_communities_membership", "type": null, "default": null}, {"name": "scores", "type": null, "default": null}, {"name": "current_positive_class", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._compute_separability_measures", "asynchronous": false, "params": [{"name": "permuted_communities_membership", "type": null, "default": null}, {"name": "scores", "type": null, "default": null}, {"name": "current_positive_class", "type": null, "default": null}, {"name": "total_permutations", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._set_permutation_results", "asynchronous": false, "params": [{"name": "permuted_values", "type": null, "default": null}, {"name": "original_value", "type": null, "default": null}, {"name": "total_permutations", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._compute_permutations", "asynchronous": false, "params": [{"name": "previous_results", "type": null, "default": null}, {"name": "metadata", "type": null, "default": null}, {"name": "communities", "type": null, "default": null}, {"name": "positives", "type": null, "default": null}, {"name": "total_permutations", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability.compute_separability", "asynchronous": false, "params": [{"name": "embedding", "type": null, "default": null}, {"name": "communities", "type": null, "default": null}, {"name": "positives", "type": null, "default": "..."}, {"name": "variant", "type": null, "default": "..."}, {"name": "permutations", "type": null, "default": "..."}, {"name": "concorde_settings", "type": null, "default": "..."}], "returns": null, "documentation": ["Compute all community separability indices\n\n```\nparam embedding\n\nnumpy.ndarray\nData in the form of an N*M matrix where sample values are placed in the rows and\nthe feature/variable values are placed in the columns. For instance, this is the output obtained\nafter applying a network embedding algorithm.\n\nparam communities\n\nnumpy.ndarray\nList of community labels (e.g., ground truth groups/classes) of the data.\n\nparam positives\n\nnumpy.ndarray\nList of positive community labels. Depending on the study, positive classes are usually ranked as\nthe labels for which a particular prediction is desired.\nFor instance:\n\nsource:13: (ERROR/3) Unexpected indentation.\n\nsick patients (positive class) versus controls (negative class)\n\nburnout (positive class), depression (positive class), versus control (negative class)\n\nsource:15: (WARNING/2) Block quote ends without a blank line; unexpected unindent.\n\nIf not provided, then the communities with the lower number of samples will be selected as\npositive classes.\n\nparam variant\n\nSeparabilityVariant\nCommunity separability variant to use for computing the separability. This is one of:\n\nsource:19: (ERROR/3) Unexpected indentation.\n\nCPS: centroid projection separability\n\nLDPS: linear discriminant projection separability\n\nTSPS: travelling salesman projection separability\n\nparam permutations\n\nint\nNumber of iterations for the null model.\n\nparam concorde_settings\n\nConcordeSettings\nConcorde settings to use at runtime. For instance, path to temp artifacts and to\nConcorde executable. Only required when using the TSPS variant\n\nreturn\n\nindices: dict\n\nDictionary containing all the computed community separability indices.\n\nmetadata: dict\n\nDictionary containing the metadata used to compute community separability indices.\n```\n"]}], "variables": [], "classes": [], "exports": []}]}