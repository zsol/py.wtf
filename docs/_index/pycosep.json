[], "documentation": []}], "exports": []}, {"name": "pycosep", "documentation": [], "functions": [], "variables": [{"name": "pycosep.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "pycosep.PackageNotFoundError", "xref": {"fqname": "importlib.metadata.PackageNotFoundError", "project": null}}, {"name": "pycosep.version", "xref": {"fqname": "importlib.metadata.version", "project": null}}]}, {"name": "pycosep.community_separability", "documentation": [], "functions": [{"name": "pycosep.community_separability._mode_distribution", "asynchronous": false, "params": [{"name": "data_clustered", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._find_positive_classes", "asynchronous": false, "params": [{"name": "sample_labels", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._extract_positive_class", "asynchronous": false, "params": [{"name": "communities_membership", "type": null, "default": null}, {"name": "positives", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._compute_mann_whitney", "asynchronous": false, "params": [{"name": "scores_c1", "type": null, "default": null}, {"name": "scores_c2", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._compute_auc_aupr", "asynchronous": false, "params": [{"name": "labels", "type": null, "default": null}, {"name": "scores", "type": null, "default": null}, {"name": "positives", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pycosep.community_separability._compute_mcc", "asynchronous": false, "params": [{"name": "labels", "type": null, "default": null}, {"name": "scores", "type": null, "default": null}, {"name": "positives", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "py