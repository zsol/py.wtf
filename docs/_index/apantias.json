ject": "--std--"}, "params": null}, "default": null}], "returns": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "documentation": ["Combines exclude_mips_frames and exclude_bad_frames to exclude frames\nthat are above or below the median by a certain threshold.\nMIPS:\nCalculates the median of each frame and deletes frames where there is\na pixel above or below the median by a certain threshold.\nBAD FRAMES:\nCalculates the average of each frame and excludes frames that are\nabove or below the fitted mean by a certain threshold.\nArgs:\n    data: shape (nframes, column_size, nreps, row_size)\n    thres_mips: absolute threshold in adu\n    thres_bad_frames: used with the fitted sigma do exclude frames\nReturns:\n    np.array in shape (nframes-X, column_size, nreps, row_size)"]}, {"name": "apantias.analysis.get_slopes", "asynchronous": false, "params": [{"name": "data", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}], "returns": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "documentation": ["Calculates the slope over nreps for every pixel and frame.\nArgs:\n    data: np.array in shape (nframes, column_size, nreps, row_size)\nReturns:\n    slopes: np.array (nframes, column_size, row_size) with the slope values"]}, {"name": "apantias.analysis.correct_common_mode", "asynchronous": false, "params": [{"name": "data", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Calculates the median of euch row in data, and substracts it from\nthe row.\nCorrection is done inline to save memory.\nArgs:\n    np.array in shape (nframes, column_size, nreps, row_size)"]}, {"name": "apantias.analysis.group_pixels", "asynchronous": false, "params": [{"name": "data", "type": null, "default": null}, {"name": "primary_threshold", "type": null, "default": null}, {"name": "secondary_threshold", "type": null, "default": null}, {"name": "noise_map", "type": null, "default": null}, {"name": "structure", "type": null, "default": null}], "returns": null, "documentation": ["Uses the two pass labelling to group events.\nPixels over the primary threshold are connected to pixels above the\nsecondary threshold according to a structure element.\nInput is of shape (frame,row,col), calulation over the frames is\nparallized using numba's prange.\nThe output is a numpy array of shape (frame,row,col) with zeroes if there\nis no event above the primary threshold. Clustered events are labeled with\nintegers beginning at 1."]}], "variables": [{"name": "apantias.analysis._logger", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "apantias.file_io", "documentation": [], "functions": [{"name": "apantias.file_io.read_data_chunk_from_bin", "asynchronous": false, "params": [{"name": "bin_file", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "column_size", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "row_size", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "key_ints", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "nreps", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "frames_to_read", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "offset", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": 