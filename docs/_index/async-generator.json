equires", "the following notice:", "Copyright \u00a9 2001-2017 Python Software Foundation; All Rights Reserved"]}], "exports": []}, {"name": "async_generator._tests.test_util", "documentation": [], "functions": [{"name": "async_generator._tests.test_util.async_range", "asynchronous": true, "params": [{"name": "count", "type": null, "default": null}, {"name": "closed_slot", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_aclosing", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_contextmanager_do_not_unchain_non_stopiteration_exceptions", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_native_contextmanager_do_not_unchain_non_stopiteration_exceptions", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_asynccontextmanager_exception_passthrough", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_asynccontextmanager_catches_exception", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_asynccontextmanager_different_exception", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_asynccontextmanager_nice_message_on_sync_enter", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_asynccontextmanager_no_yield", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_asynccontextmanager_too_many_yields", "asynchronous": true, "params": [], "returns": null, "documentation": []}, {"name": "async_generator._tests.test_util.test_asynccontextmanager_requires_asyncgenfunction", "asynchronous": true, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "async_generator._tests.test_util.nativeasyncgenerators", "type": null, "documentation": []}, {"name": "async_generator._tests.test_util.nativeasyncgenerators", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "async_generator._impl", "documentation": [], "functions": [{"name": "async_generator._impl._wrap", "asynchronous": false, "params": [{"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl._is_wrapped", "asynchronous": false, "params": [{"name": "box", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl._unwrap", "asynchronous": false, "params": [{"name": "box", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl._yield_", "asynchronous": false, "params": [{"name": "value", "type": null, "default": null}], "returns": null, "documentation": ["This is the magic code that lets you use yield_ and yield_from_ with native", "generators.", "The old version worked great on Linux and MacOS, but not on Windows, because", "it depended on _PyAsyncGenValueWrapperNew. The new version segfaults", "everywhere, and I'm not sure why -- probably my lack of understanding", "of ctypes and refcounts.", "There are also some commented out tests that should be re-enabled if this is", "fixed:", "if sys.version_info >= (3, 6):", "# Use the same box type that the interpreter uses internally. This allows", "# yield_ and (more importantly!) yield_from_ to work in built-in", "# generators.", "import ctypes  # mua ha ha.", "# We used to call _PyAsyncGenValueWrapperNew to create and set up new", "# wrapper objects, but that symbol isn't available on Windows:", "#", "#   https://github.com/python-trio/async_generator/issues/5", "#", "# Fortunately, the type object is available, but it means we have to do", "# this the hard way.", "# We don't actually need to access this, but we need to make a ctypes", "# structure so we can call addressof.", "class _ctypes_PyTypeObject(ctypes.Structure):", "pass", "_PyAsyncGenWrappedValue_Type_ptr = ctypes.addressof(", "_ctypes_PyTypeObject.in_dll(", "ctypes.pythonapi, \"_PyAsyncGenWrappedValue_Type\"))", "_PyObject_GC_New = ctypes.pythonapi._PyObject_GC_New", "_PyObject_GC_New.restype = ctypes.py_object", "_PyObject_GC_New.argtypes = (ctypes.c_void_p,)", "_Py_IncRef = ctypes.pythonapi.Py_IncRef", "_Py_IncRef.restype = None", "_Py_IncRef.argtypes = (ctypes.py_object,)", "class _ctypes_PyAsyncGenWrappedValue(ctypes.Structure):", "_fields_ = [", "('PyObject_HEAD', ctypes.c_byte * object().__sizeof__()),", "('agw_val', ctypes.py_object),", "]", "def _wrap(value):", "box = _PyObject_GC_New(_PyAsyncGenWrappedValue_Type_ptr)", "raw = ctypes.cast(ctypes.c_void_p(id(box)),", "ctypes.POINTER(_ctypes_PyAsyncGenWrappedValue))", "raw.contents.agw_val = value", "_Py_IncRef(value)", "return box", "def _unwrap(box):", "assert _is_wrapped(box)", "raw = ctypes.cast(ctypes.c_void_p(id(box)),", "ctypes.POINTER(_ctypes_PyAsyncGenWrappedValue))", "value = raw.contents.agw_val", "_Py_IncRef(value)", "return value", "_PyAsyncGenWrappedValue_Type = type(_wrap(1))", "def _is_wrapped(box):", "return isinstance(box, _PyAsyncGenWrappedValue_Type)", "The magic @coroutine decorator is how you write the bottom level of", "coroutine stacks -- 'async def' can only use 'await' = yield from; but", "eventually we must bottom out in a @coroutine that calls plain 'yield'."]}, {"name": "async_generator._impl.yield_", "asynchronous": true, "params": [{"name": "value", "type": null, "default": "..."}], "returns": null, "documentation": ["But we wrap the bare @coroutine version in an async def, because async def", "has the magic feature that users can get warnings messages if they forget to", "use 'await'."]}, {"name": "async_generator