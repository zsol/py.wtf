lt": null}, {"name": "*first_args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl.ANextIter.__await__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl.ANextIter.__next__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl.ANextIter.send", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl.ANextIter.throw", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "type", "type": null, "default": null}, {"name": "value", "type": null, "default": "..."}, {"name": "traceback", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "async_generator._impl.ANextIter._invoke", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "fn", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["This is the awaitable / iterator that implements asynciter.__anext__() and", "friends.", "Note: we can be sloppy about the distinction between", "type(self._it).__next__(self._it)", "and", "self._it.__next__()", "because we happen to know that self._it is not a general iterator object,", "but specifically a coroutine iterator object where these are equivalent."]}, {"name": "async_generator._impl._hooks_storage", "bases": ["threading.local"], "methods": [{"name": "async_generator._impl._hooks_storage.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "async_generator._impl.AsyncGenerator", "bases": [], "methods": [{"name": "async_generator._impl.AsyncGenerator.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "coroutine", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl.AsyncGenerator.__aiter__", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl.AsyncGenerator.__aiter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl.AsyncGenerator.ag_code", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["###############################################################", "Introspection attributes", "###############################################################"]}, {"name": "async_generator._impl.AsyncGenerator.ag_frame", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "async_generator._impl.AsyncGenerator.__anext__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["###############################################################", "Core functionality", "###############################################################", "These need to return awaitables, rather than being async functions,", "to match the native behavior where the firstiter hook is called", "immediately on asend()/etc, even if the coroutine that asend()", "produces isn't awaited for a bit."]}, {"name": "async_generator._impl.AsyncGenerator.asend", "asynchronous": false, "params": [{"name": "self", "type": null, "defa