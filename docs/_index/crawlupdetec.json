{"name": "crawlupdetec", "metadata": {"name": "CrawlUpDetec", "version": "1.0.2", "classifiers": [], "home_page": null, "license": null, "documentation_url": null, "dependencies": [], "summary": "a package help detect website update or not", "upload_time": 1735636553}, "documentation": ["# Crawler Update detector\n\nThis Python package provides the following features:\n\nWebsite Content Hash Checking\nIt calculates the hash value of the entire website content using MD5 or SHA algorithms and regularly checks if the website content has changed. If the website content's hash value changes, the package detects that the website has been updated.\n\nText Change Analysis\nWhen a change in the website content is detected, the package extracts the changed text and uses the Azure GPT API to analyze whether the text change is important information. For example, it can identify whether there are new key news items, product updates, policy changes, etc.\n\nXPath for Updated Information\nFor the detected text changes, the package provides the corresponding XPath to easily locate the updated content, allowing users to further process or update their scraping logic.\n"], "modules": [{"name": "CrawlUpDetec.diff_detect", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "CrawlUpDetec.diff_detect.diff_dect", "bases": [], "methods": [{"name": "CrawlUpDetec.diff_detect.diff_dect.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "new_html_file", "type": null, "default": null}, {"name": "old_html_file", "type": null, "default": null}, {"name": "azure_endpoint", "type": null, "default": null}, {"name": "azure_model", "type": null, "default": null}, {"name": "azure_key", "type": null, "default": null}, {"name": "azure_api_version", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "CrawlUpDetec.diff_detect.diff_dect.extract_contents", "asynchronous": false, "params": [{"name": "self