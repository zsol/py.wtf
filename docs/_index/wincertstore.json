n": []}, {"name": "wincertstore.CertFile.addcerts", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "certs", "type": null, "default": null}], "returns": null, "documentation": ["Add certs to store\n        "]}, {"name": "wincertstore.CertFile.addstore", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "store", "type": null, "default": null}], "returns": null, "documentation": ["Add store to CertFile\n\n```\nparam store\n\neither a name of a store or a CertSystemStore instance\n```\n"]}, {"name": "wincertstore.CertFile.read", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Read CA.pem file and return content\n        "]}], "class_variables": [{"name": "wincertstore.CertFile.name", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Wrapper to handle a temporary file for a CA.pem\n\nNote: The object uses a temporary file because older Python versions have\n      no means to keep a tempfile after it has been closed.\n\nUsage:\n    import wincertstore\n    import atexit\n\n    certfile = wincertstore.CertFile()\n    certfile.addstore(\"CA\")\n    certfile.addstore(\"ROOT\")\n    atexit.register(certfile.close) # cleanup and remove files on shutdown)\n\n    ca_cert = certfile.name"]}], "exports": [{"name": "wincertstore.CertSystemStore", "xref": {"fqname": "wincertstore.CertSystemStore", "project": null}}]}]}