6\u4e3amp4\n\n## \u5f00\u53d1\n\n### \u5148\u5b89\u88c5rye\n\nrye\u7f51\u7ad9\uff1ahttps://rye.astral.sh/\n\n### \u4f7f\u7528rye \u5b89\u88c5\u5305\u53ca\u865a\u62df\u73af\u5883\n\n```bash\nrye sync\n```"], "modules": [{"name": "hs_m3u8", "documentation": [], "functions": [], "variables": [{"name": "hs_m3u8.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "hs_m3u8.M3u8Downloader", "xref": {"fqname": "hs_m3u8.main.M3u8Downloader", "project": null}}]}, {"name": "hs_m3u8.main", "documentation": ["M3U8 \u4e0b\u8f7d\u5668"], "functions": [{"name": "hs_m3u8.main.get_ffmpeg", "asynchronous": false, "params": [], "returns": null, "documentation": ["\u6839\u636e\u5e73\u53f0\u4e0d\u540c\u83b7\u53d6\u4e0d\u540c\u7684ffmpeg\u53ef\u6267\u884c\u6587\u4ef6\n\\:return: FFmpeg \u7684\u53ef\u6267\u884c\u6587\u4ef6\u8def\u5f84\n"]}], "variables": [], "classes": [{"name": "hs_m3u8.main.ContentType", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "hs_m3u8.main.ContentType.Text", "type": null, "documentation": []}, {"name": "hs_m3u8.main.ContentType.Json", "type": null, "documentation": []}, {"name": "hs_m3u8.main.ContentType.Bytes", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["\u83b7\u53d6URL\u6570\u636e\u7684\uff0c\u7c7b\u578b\u679a\u4e3e"]}, {"name": "hs_m3u8.main.M3u8Key", "bases": [], "methods": [{"name": "hs_m3u8.main.M3u8Key.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": {"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}, "default": null}, {"name": "iv", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["---\nparam iv: \"\\u504F\\u79FB\"\nparam key: \"\\u5BC6\\u94A5\"\n---\n"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "docum