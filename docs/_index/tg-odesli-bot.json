le", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "SongInfo", "xref": {"fqname": "tg_odesli_bot.bot.SongInfo", "project": null}, "params": null}, {"name": "...", "xref": null, "params": null}]}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Replace song URLs in message with footnotes.\n\nE.g. \"this song is awesome \\<link>\" will be transformed to \"this song\nis awesome [1]\".\n\n```\nparam message\n\noriginal message text\n\nparam song_infos\n\nlist of SongInfo metadata objects\n\nreturns\n\ntransformed message\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot._maybe_resolve_redirect", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Resolve a redirect if the URL is a short link.\n\nFor now, resolves only \".page.link\" Firebase dynamic links.\n\n```\nparam url\n\nURL\n\nreturns\n\nresolved URL\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot.extract_song_urls", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "skip_youtube", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "SongUrl", "xref": {"fqname": "tg_odesli_bot.bot.SongUrl", "project": null}, "params": null}]}, "documentation": ["Extract song URLs from text for each registered platform.\n\n```\nparam text\n\nmessage text\n\nparam skip_youtube\n\nskip YouTube platform (used for group messages)\n\nreturns\n\nlist of SongURLs\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot._merge_same_songs", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "song_infos", "type": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "SongInfo", "xref": {"fqname": "tg_odesli_bot.bot.SongInfo", "project": null}, "params": null}, {"name": "...", "xref": null, "params": null}]}, "default": null}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "SongInfo", "xref": {"fqname": "tg_odesli_bot.bot.SongInfo", "project": null}, "params": null}, {"name": "...", "xref": null, "params": null}]}, "documentation": ["Merge SongInfo objects if different links point to the same song.\n\nUse identifiers provided by Odesli API to find identical song linked\nfrom different platforms.\n\n```\nparam song_infos\n\ntuple of SongInfo objects found in a message\n\nreturns\n\ntuple of merged SongInfo objects\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot._find_songs", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "is_group_message", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "SongInfo", "xref": {"fqname": "tg_odesli_bot.bot.SongInfo", "project": null}, "params": null}, {"name": "...", "xref": null, "params": null}]}, "documentation": ["Find song info based on given text.\n\n```\nparam text\n\nmessage text\n\nparam is_group_message\n\ntext is from a group message\n\nreturns\n\ntuple of SongInfo instances\n\nraise SongNotFoundError\n\nif Odesli couldn't find any song\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot._format_urls", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "song_info", "type": {"name": "SongInfo", "xref": {"fqname": "tg_odesli_bot.bot.SongInfo", "project": null}, "params": null}, "default": null}, {"name": "separator", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["Format platform URLs into a single HTML string.\n\n```\nparam song_info\n\nSongInfo metadata\n\nparam separator\n\nseparator for platform URLs\n\nreturns\n\nHTML string e.g.\n<a href=\"1\">Deezer</a> | <a href=\"2\">SoundCloud</a> ...\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot._compose_reply", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "song_infos", "type": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "SongInfo", "xref": {"fqname": "tg_odesli_bot.bot.SongInfo", "project": null}, "params": null}, {"name": "...", "xref": null, "params": null}]}, "default": null}, {"name": "message_text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "message", "type": {"name": "Message", "xref": {"fqname": "aiogram.types.Message", "project": "aiogram"}, "params": null}, "default": null}, {"name": "append_index", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Compose a reply.\n\nFor group chats original message is included in\nreply with song URLs replaces with its indexes. If original message\nconsists only of a single link the index is omitted.\n\n\\<b>@test_user wrote:\\</b> check this one [1]\n1\\. Artist - Song\n\\<a href=\"url1\">Deezer\\</a>\n...\n\n```\nparam song_infos\n\nlist of songs metadata\n\nparam message\n\nincoming message\n\nparam message_text\n\nincoming message text with song URLs replaced\nwith its indexes\n\nparam append_index\n\nappend index\n\nreturns\n\nreply text\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot.handle_inline_query", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "inline_query", "type": {"name": "InlineQuery", "xref": {"fqname": "aiogram.types.InlineQuery", "project": "aiogram"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Handle inline query.\n\n```\nparam inline_query\n\nquery\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot.handle_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": {"name": "types.Message", "xref": {"fqname": "aiogram.types.Message", "project": "aiogram"}, "params": null}, "default": null}], "returns": null, "documentation": ["Handle incoming message.\n\n```\nparam message\n\nincoming message\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot.normalize_url", "asynchronous": false, "params": [{"name": "url", "type": null, "default": null}], "returns": null, "documentation": ["Strip \"[utm]\" parameters from URL.\n\nUsed in caching to increase cache density.\n\n```\nparam url\n\nurl\n\nreturns\n\nnormalized URL\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot.find_song_by_url", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "song_url", "type": {"name": "SongUrl", "xref": {"fqname": "tg_odesli_bot.bot.SongUrl", "project": null}, "params": null}, "default": null}], "returns": {"name": "SongInfo", "xref": {"fqname": "tg_odesli_bot.bot.SongInfo", "project": null}, "params": null}, "documentation": ["Find song info by its URL.\n\nMake an API call to Odesli service and return song data for\nsupported services.\n\n```\nparam song_url\n\nSongURL object\n\nreturns\n\nSongInfo instance for given URL\n\nraises APIError\n\nif Odesli API returned an error\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot._filter_platform_urls", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "platform_urls", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Filter and reorder platform URLs according to `PLATFORMS` registry.\n\n```\nparam platform_urls\n\ndictionary of {platform_key: platform_urls}\n\nreturns\n\ndictionary of filtered and ordered platform URLs\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot.process_api_response", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "data", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}, {"name": "url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "SongInfo", "xref": {"fqname": "tg_odesli_bot.bot.SongInfo", "project": null}, "params": null}, "documentation": ["Process Odesli API data creating SongInfo metadata object.\n\n```\nparam data\n\ndeserialized Odesli data\n\nparam url\n\noriginal URL in message text\n\nreturns\n\nsong info object\n```\n"]}, {"name": "tg_odesli_bot.bot.OdesliBot._start", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Start polling.  Retry if cannot connect to Telegram servers.\n\nMimics `aiogram.executor.start_polling` functionality."]}, {"name": "tg_odesli_bot.bot.OdesliBot.start", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Start the bot."]}, {"name": "tg_odesli_bot.bot.OdesliBot.stop", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Stop the bot."]}], "class_variables": [{"name": "tg_odesli_bot.bot.OdesliBot.SKIP_MARK", "type": null, "documentation": []}, {"name": "tg_odesli_bot.bot.OdesliBot.API_RETRY_TIME", "type": null, "documentation": []}, {"name": "tg_odesli_bot.bot.OdesliBot.API_MAX_RETRIES", "type": null, "documentation": []}, {"name": "tg_odesli_bot.bot.OdesliBot.TG_RETRY_TIME", "type": null, "documentation": []}, {"name": "tg_odesli_bot.bot.OdesliBot.TG_MAX_RETRIES", "type": null, "documentation": []}, {"name": "tg_odesli_bot.bot.OdesliBot.WELCOME_MSG_TEMPLATE", "type": null, "documentation": []}, {"name": "tg_odesli_bot.bot.OdesliBot.SPOTIFY_SEARCH_LIMIT", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Odesli Telegram bot."]}], "exports": []}]}