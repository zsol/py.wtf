as rendered\n    service_type: Type of service provided (facility type + service type = Type of Bill)\n    service_date: Date service was performed (YYYY-MM-DD)\n    place_of_service: Place of service code\n    quantity: Number of units provided\n    quantity_unit: Unit of measure for quantity\n    modifiers: List of procedure code modifiers\n    allowed_amount: Allowed amount for the service"]}], "exports": []}, {"name": "hccinfhir.extractor_837", "documentation": [], "functions": [{"name": "hccinfhir.extractor_837.parse_date", "asynchronous": false, "params": [{"name": "date_str", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["Convert 8-digit date string to ISO format YYYY-MM-DD"]}, {"name": "hccinfhir.extractor_837.parse_amount", "asynchronous": false, "params": [{"name": "amount_str", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}]}, "documentation": ["Convert string to float, return None if invalid"]}, {"name": "hccinfhir.extractor_837.get_segment_value", "asynchronous": false, "params": [{"name": "segment", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "index", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional",