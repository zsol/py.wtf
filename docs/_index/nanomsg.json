    time.sleep(0.5)\n    #pub_socket is closed\n\nSocket.bind and Socket.connect return subclass of Endpoint which allow\nyou to shutdown selected endpoints.\n\nThe constructor also allows you to wrap existing sockets by passing in the\nsocket fd instead of the protocol e.g.:\n    from nanomsg import AF_SP, PAIR, Socket\n    from nanomsg import wrapper as nn\n\n    socket_fd = nn.nn_socket(AF_SP, PAIR)\n    socket = Socket(socket_fd=socket_fd)"]}], "exports": [{"name": "nanomsg.__version__", "xref": {"fqname": "nanomsg.version.__version__", "project": null}}, {"name": "nanomsg._Struct", "xref": {"fqname": "struct.Struct", "project": null}}, {"name": "nanomsg.absolute_import", "xref": {"fqname": "__future__.absolute_import", "project": null}}, {"name": "nanomsg.division", "xref": {"fqname": "__future__.division", "project": null}}, {"name": "nanomsg.print_function", "xref": {"fqname": "__future__.print_function", "project": null}}, {"name": "nanomsg.unicode_literals", "xref": {"fqname": "__future__.unicode_literals", "project": null}}, {"name": "nanomsg.wrapper", "xref": {"fqname": "nanomsg..wrapper", "project": null}}]}]}