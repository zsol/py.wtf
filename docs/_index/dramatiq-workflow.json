, "params": null}, "default": null}, {"name": "result", "type": null, "default": "..."}, {"name": "exception", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "dramatiq_workflow.tests", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "dramatiq_workflow._barrier", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "dramatiq_workflow._barrier.AtMostOnceBarrier", "bases": ["dramatiq.rate_limits.Barrier"], "methods": [{"name": "dramatiq_workflow._barrier.AtMostOnceBarrier.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "backend", "type": null, "default": null}, {"name": "key", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "ttl", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "dramatiq_workflow._barrier.AtMostOnceBarrier.create", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parties", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "dramatiq_workflow._barrier.AtMostOnceBarrier.wait", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "block", "type": null, "default": "..."}, {"name": "timeout", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["The AtMostOnceBarrier is a barrier that ensures that it is released at most\nonce.\n\nWe use this because we want to avoid running callbacks in chains multiple\ntimes. Running callbacks more than once can have compounding effects\nespecially when groups are involved.\n\nThe downside of this is that we cannot guarantee that the barrier will be\nreleased at all. Theoretically a worker could die after releasing the\nbarrier but just before it has a chance to schedule the callbacks."]}], "exports": []}, {"name": "dramatiq_workflow._serialize", "documentation": [], "functions": [{"name": "dramatiq_workflow._serialize.serialize_workflow", "asynchronous": false, "params": [{"name": "workflow", "type": {"name": "WorkflowType | None", "xref": null, "params": null}, "default": null}], "returns": {"name": "typing.Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": ["Return a serialized version of the workflow that can be JSON-encoded."]}, {"name": "dramatiq_workflow._serialize.unserialize_workflow", "asynchronous": false, "params": [{"name": "workflow", "type": {"name": "typing.Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "WorkflowType", "xref": {"fqname": "dramatiq_workflow._serialize._models.WorkflowType", "project": null}, "params": null}, "documentation": ["Return an unserialized version of the workflow that can be used to create\na Workflow instance."]}, {"name": "dramatiq_workflow._serialize.unserialize_workflow_or_none", "asynchronous": false, "params": [{"name": "workflow", "type": {"name": "typing.Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "WorkflowType | None", "xref": null, "params": null}, "documentation": []}, {"name": "dramatiq_workflow._serialize.serialize_callbacks", "asynchronous": false, "params": [{"name": "callbacks", "type": {"name": "CompletionCallbacks", "xref": {"fqname": "dramatiq_workflow._serialize._models.CompletionCallbacks", "project": null}, "params": null}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": 