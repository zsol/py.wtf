ame": "s", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "x25519.djbec.checkvalid", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}, {"name": "m", "type": null, "default": null}, {"name": "pk", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "x25519.djbec.add", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}, {"name": "m", "type": null, "default": null}, {"name": "d", "type": null, "default": null}], "returns": null, "documentation": ["def expmod(b, e, m):", "if e == 0: return 1", "t = expmod(b, e / 2, m) ** 2 % m", "if e & 1: t = (t * b) % m", "return t", "def inv(x): return expmod(x, P - 2, P)"]}, {"name": "x25519.djbec.double", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "x25519.djbec.curve25519", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}, {"name": "base", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "x25519.djbec.genkey", "asynchronous": false, "params": [{"name": "n", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "x25519.djbec.dsa_test", "asynchronous": false, "params": [], "returns": null, "documentation": ["def str2int(s):", "return int(hexlify(s), 16)", "# return sum(ord(s[i]) << (8 * i) for i in range(32))", "def int2str(n):", "return unhexlify(\"%x\" % n)", "# return ''.join([chr((n >> (8 * i)) & 255) for i in range(32)])", "################################################"]}, {"name": "x25519.djbec.dh_test", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "x25519.djbec.PY3", "type": null, "documentation": []}, {"name": "x25519.djbec.PY3", "type": null, "documentation": []}, {"name": "x25519.djbec.asbytes", "type": null, "documentation": []}, {"name": "x25519.djbec.joinbytes", "type": n