roject": "--std--"}, "params": null}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["A test case is an instance of  test definition together with a set of Jinja variables used to render all\ntemplates that are part of the said test definition.\n\nIt is expanded to a folder called \"<test-definition>_<name_1>-<value_1>-..._<name_n>-<value_n>\" where:\n* \"test-definition\" is the name of the test\n* \"name_k\" is the name of a Jinja variable\n* \"value_k\" is the value of the Jinja variable."]}, {"name": "beku.kuttl.TestDimension", "bases": [], "methods": [{"name": "beku.kuttl.TestDimension.expand", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}]}, "documentation": ["Return a list of tuples in the form of (<dimension>, <value>)"]}], "class_variables": [{"name": "beku.kuttl.TestDimension.name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "beku.kuttl.TestDimension.values", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Test dimension."]}, {"name": "beku.kuttl.TestDefinition", "bases": [], "methods": [], "class_variables": [{"name": "beku.kuttl.TestDefinition.name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "beku.kuttl.TestDefinitio