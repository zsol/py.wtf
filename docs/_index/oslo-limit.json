aram resource_names\n\nlist of resource_name strings\n\nreturn\n\nlist of (resource_name, limit) pairs\n```\n"]}, {"name": "oslo_limit.limit._EnforcerUtils.get_project_limits", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "project_id", "type": null, "default": null}, {"name": "resource_names", "type": null, "default": null}], "returns": null, "documentation": ["Get all the limits for given project a resource_name list\n\nIf a limit is not found, it will be considered to be zero\n(i.e. no quota)\n\n```\nparam project_id\n\nproject being checked or None\n\nparam resource_names\n\nlist of resource_name strings\n\nreturn\n\nlist of (resource_name,limit) pairs\n```\n"]}, {"name": "oslo_limit.limit._EnforcerUtils._get_limit", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "project_id", "type": null, "default": null}, {"name": "resource_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "oslo_limit.limit._EnforcerUtils._get_project_limit", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "project_id", "type": null, "default": null}, {"name": "resource_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "oslo_limit.limit._EnforcerUtils._get_registered_limit", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "resource_name", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Logic common used by multiple enforcers"]}], "exports": []}]}