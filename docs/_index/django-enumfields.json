n": []}, {"name": "enumfields.fields.EnumFieldMixin.value_to_string", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "obj", "type": null, "default": null}], "returns": null, "documentation": ["This method is needed to support proper serialization. While its name is value_to_string()\nthe real meaning of the method is to convert the value to some serializable format.\nSince most of the enum values are strings or integers we WILL NOT convert it to string\nto enable integers to be serialized natively."]}, {"name": "enumfields.fields.EnumFieldMixin.get_default", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "enumfields.fields.EnumFieldMixin.deconstruct", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "enumfields.fields.EnumFieldMixin.get_choices", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "include_blank", "type": null, "default": "..."}, {"name": "blank_choice", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "enumfields.fields.EnumFieldMixin.formfield", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "form_class", "type": null, "default": "..."}, {"name": "choices_form_class", "type": null, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "enumfields.fields.EnumField", "bases": ["EnumFieldMixin", "models.CharField"], "methods": [{"name": "enumfields.fields.EnumField.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "enum", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns":