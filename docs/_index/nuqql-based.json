cumentation": ["nuqql-based socket server"], "functions": [], "variables": [{"name": "nuqql_based.server.daemon", "type": null, "documentation": []}], "classes": [{"name": "nuqql_based.server.Server", "bases": [], "methods": [{"name": "nuqql_based.server.Server.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "config", "type": {"name": "Config", "xref": {"fqname": "nuqql_based.config.Config", "project": null}, "params": null}, "default": null}, {"name": "callbacks", "type": {"name": "Callbacks", "xref": {"fqname": "nuqql_based.callback.Callbacks", "project": null}, "params": null}, "default": null}, {"name": "account_list", "type": {"name": "AccountList", "xref": {"fqname": "nuqql_based.account.AccountList", "project": null}, "params": null}, "default": null}, {"name": "queue", "type": {"name": "asyncio.Queue", "xref": {"fqname": "asyncio.Queue", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nuqql_based.server.Server._handle_incoming", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "writer", "type": {"name": "asyncio.StreamWriter", "xref": {"fqname": "asyncio.StreamWriter", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Handle messages coming from the backend connections"]}, {"name": "nuqql_based.server.Server._handle_messages", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "reader", "type": {"name": "asyncio.StreamReader", "xref": {"fqname": "asyncio.StreamReader", "project": "--std--"}, "params": null}, "default": null}, {"name": "writer", "type": {"name": "asyncio.StreamWriter", "xref": {"fqname": "asyncio.StreamWriter", "project": "--std--"}