asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "token", "type": null, "default": null}, {"name": "handler_function", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "shortcodes.Shortcode.parse_args", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "argstring", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "shortcodes.Shortcode.re_args", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Base class for atomic and block-scoped shortcodes."]}, {"name": "shortcodes.AtomicShortcode", "bases": ["Shortcode"], "methods": [{"name": "shortcodes.AtomicShortcode.render", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "context", "type": null, "default": null}], "returns": null, "documentation": ["If the shortcode handler raises an exception we intercept it and wrap it", "in a ShortcodeRenderingError. The original exception will still be", "available via the exception's __cause__ attribute."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["An atomic shortcode is a shortcode with no closing tag."]}, {"name": "shortcodes.BlockShortcode", "bases": ["Shortcode"], "methods": [{"name": "shortcodes.BlockShortcode.render", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "context", "type": null, "default": null}], "returns": null, "documentation": ["If the shortcode handler raises an exception we intercept it and wrap it", "in a ShortcodeRenderingError. The original exception will still be", "available via the exception's __cause__ attribute."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["A block-scoped shortcode is a shortcode with a closing tag."]}, {"name": "shortcodes.Parser", "bases": [], "methods": [{"name": "shortcodes.Parser.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "start", "type": null, "default": "..."}, {"name": "end", "type": null, "default": "..."}, {"name": "esc", "type": null, "default": "..."}, {"name": "inherit_globals", "type": null, "default": "..."}, {"name": "ignore_unknown", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "shortcodes.Parser.register", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "func", "type": null, "default": null}, {"name": "keyword", "type": null, "default": null}, {"name": "endword", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "shortcodes.Parser.parse", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": null, "default": null}, {"name": "context", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["-------- #", "Parser  #", "-------- #", "A Parser instance parses input text and renders shortcodes. A single Parser", "instance can parse an unlimited number of input strings. Note that the parse()", "method accepts an optional arbitrary context object which it passes on to each", "shortcode's handler function.", "If the `inherit_globals` parameter is true, the parser will inherit a copy of", "the set of globally-registered shortcodes at the moment of instantiation.", "If `ignore_unknown` is true, unknown shortcodes are ignored. If this parameter", "is false (the default), unknown shortcodes cause an error."]}, {"name": "shortcodes.Token", "bases": [], "methods": [{"name": "shortcodes.Token.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "token_type", "type": null, "default": null}, {"name": "token_text", "type": n