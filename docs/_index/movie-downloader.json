n value if the result is None\n\nReturns:\n\nExamples:\n    nested = {'A0': 'a0',\n              'B0': {'B10': 'b10', 'B11': 'b11', 'B12': {'B20': 'b20'}},\n              'C0': [{'C100': 'c100', 'C101': 'c101'}, {'C110': 'c110'}]\n              }\n    json_path_get(nested, ['B0', 'B12'])\n    json_path_get(nested, ['C0', 0, 'C100'], '')"]}, {"name": "mdl.utils.build_cookiejar_from_kvp", "asynchronous": false, "params": [{"name": "key_values", "type": null, "default": null}], "returns": null, "documentation": ["build a CookieJar from key-value pairs.\n\nArgs:\n: key_values (str): The cookies must take the form of `'cookie_key=cookie_value'`, with multiple pairs separated\n\n  : by whitespace and/or semicolon if applicable, e.g. `'key1=val1 key2=val2; key3=val3'`.\n"]}, {"name": "mdl.utils.build_logger", "asynchronous": false, "params": [{"name": "logger_name", "type": null, "default": null}, {"name": "log_file_name", "type": null, "default": null}, {"name": "logger_level", "type": null, "default": "..."}, {"name": "console_level", "type": null, "default": "..."}, {"name": "file_level", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "mdl.utils.change_logging_level", "asynchronous": false, "params": [{"name": "logger_name", "type": null, "default": null}, {"name": "logger_level", "type": null, "default": "..."}, {"name": "console_level", "type": null, "default": "..."}, {"name": "file_level", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "mdl.utils.logging_with_pipe", "asynchronous": false, "params": [{"name": "logger", "type": null, "default": null}, {"name": "level", "type": null, "default": null}, {"name": "text", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}], "returns": null, "documentation": ["From:\n https://codereview.stackexchange.com/questions/6567/redirecting-subprocesses-output-stdout-and-stderr-to-the-logging-module"]}], "variables": [{"name": "mdl.utils.ILLEGAL_FILENAME_CHARS", "type": null, "documentation": []}], "classes": [{"name": "mdl.utils.LogPipe", "bases": ["threading.Thread"], "methods": [{"name": "mdl.utils.LogPipe.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "logger", "type": null, "default": null}, {"name": "level", "type": null, "default": null}, {"name": "text", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}], "returns": null, "documentation": ["Setup the object with a logger and a loglevel\nand start the thread"]}, {"name": "mdl.utils.LogPipe.fileno", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return the write file descriptor of the pipe\n        "]}, {"name": "mdl.utils.LogPipe.run", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Run the thread, logging everything.\n        "]}, {"name": "mdl.utils.LogPipe.close", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Close the write end of the pipe.\n        "]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["From:\n https://codereview.stackexchange.com/questions/6567/redirecting-subprocesses-output-stdout-and-stderr-to-the-logging-module"]}], "exports": []}, {"name": "mdl.__main__", "documentation": [], "functions": [], "variables": [{"name": "mdl.__main__.path", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "mdl.sites", "documentation": [], "functions": [{"name": "mdl.sites.get_all_sites_vcs", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "mdl.sites._ALL_SITES_VIDEOCONFIG_CLASSES", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "mdl.sites.M1905VC", "xref": {"fqname": "mdl.sites.m19