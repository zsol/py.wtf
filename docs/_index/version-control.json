gs module as follows:\n\n```python\nMIDDLEWARE = [\n    \"version_control.middleware.VersionControlMiddleware\"\n]\n```\n\n4. Install third-party modules\n\nFor projects running under git source control:\n\n```\n$ pip install GitPython\n```\n\nFor mercurial projects:\n\n```\n$ pip install hglib  # python 3.x\n$ pip install python-hglib  # python 2.7.x\n```\n"], "modules": [{"name": "version_control.backends.dummy", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "version_control.backends.dummy.DummyVersionControlBackend", "bases": ["BaseVersionControl"], "methods": [{"name": "version_control.backends.dummy.DummyVersionControlBackend.get_current_branch_name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "version_control.utils", "documentation": [], "functions": [{"name": "version_control.utils.get_backend", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "version_control.backends.gitpython", "documentation": [], "functions": [], "variables": [{"name": "version_control.backends.gitpython.HAS_GITPYTHON", "type": null, "documentation": []}, {"name": "version_control.backends.gitpython.HAS_GITPYTHON", "type": null, "documentation": []}], "classes": [{"name": "version_control.backends.gitpython.GitPythonBackend", "bases": ["BaseVersionControl"], "methods": [{"name": "version_control.backends.gitpython.GitPythonBackend.get_current_branch_name", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "version_control", "documentation": ["# Installation\n\n## Getting the code\n\n```bash\n