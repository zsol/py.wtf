{"name": "argparsedirs", "metadata": {"name": "argparsedirs", "version": "0.1.2", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "", "license": "", "documentation_url": null, "dependencies": ["argparse"], "summary": "Readable and Writeable dir action for argparse", "upload_time": 1697723583}, "documentation": ["This is a very simple action for argparse that allows\nyou to specify a readable or a writeable directory as an `argparse` action.\nI found it on StackOverflow years ago and used it since then,\nunfortunately I cannot find the original source now.\n\nI guess it would be best to have this added directly into `argparse` anyway.\n\n### Usage\nJust import and use as an action:\n\n    import argparse\n    import argparsedirs\n\n    argparser = argparse.ArgumentParser()\n\n    argparser.add_argument('indir', action=argparsedirs.ReadableDir)\n    argparser.add_argument('outdir', action=argparsedirs.WriteableDir)\n\n    args = argparser.parse_args()\n"], "modules": [{"name": "argparsedirs", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "argparsedirs.argparsedirs", "xref": {"fqname": "argparsedirs.argparsedirs", "project": null}}, {"name": "argparsedirs.ReadableDir", "xref": {"fqname": "argparsedirs.argparsedirs.ReadableDir", "project": null}}, {"name": "argparsedirs.ReadableDirType", "xref": {"fqname": "argparsedirs.argparsedirs.ReadableDirType", "project": null}}, {"name": "argparsedirs.WriteableDir", "xref": {"fqname": "argparsedirs.argparsedirs.WriteableDir", "project": null}}, {"name": "argparsedirs.WriteableDirType", "xref": {"fqname": "argparsedirs.argparsedirs.WriteableDirType", "project": null}}]}, {"name": "argparsedirs.argparsedirs", "documentation": [], "functions": [{"name": "argparsedirs.argparsedirs.ReadableDirType", "asynchronous": false, "params": [{"name": "path", "type": {"name": "str", "xref": {"fqname":