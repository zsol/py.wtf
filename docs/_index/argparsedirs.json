{"name": "argparsedirs", "metadata": {"name": "argparsedirs", "version": "0.2.0", "classifiers": ["License :: Other/Proprietary License", "Programming Language :: Python :: 3", "Programming Language :: Python :: 3.11", "Programming Language :: Python :: 3.12"], "home_page": null, "license": "GPLv3", "documentation_url": null, "dependencies": [], "summary": "A simple extension for argparse to allow readable/writeable dir types", "upload_time": 1732540585}, "documentation": ["This is a very simple action for argparse that allows\nyou to specify a readable or a writeable directory as an `argparse` action.\nI found it on StackOverflow years ago and used it since then,\nunfortunately I cannot find the original source now.\n\nI guess it would be best to have this added directly into `argparse` anyway.\n\n### Usage\nJust import and use as an action:\n\n    import argparse\n    import argparsedirs\n\n    argparser = argparse.ArgumentParser()\n\n    argparser.add_argument('indir', type=argparsedirs.ReadableDirType)\n    argparser.add_argument('outdir', type=argparsedirs.WriteableDirType)\n\n    args = argparser.parse_args()\n"], "modules": [{"name": "argparsedirs", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "argparsedirs.argparsedirs", "xref": {"fqname": "argparsedirs.argparsedirs", "project": null}}, {"name": "argparsedirs.ReadableDir", "xref": {"fqname": "argparsedirs.argparsedirs.ReadableDir", "project": null}}, {"name": "argparsedirs.ReadableDirType", "xref": {"fqname": "argparsedirs.argparsedirs.ReadableDirType", "project": null}}, {"name": "argparsedirs.WriteableDir", "xref": {"fqname": "argparsedirs.argparsedirs.WriteableDir", "project": null}}, {"name": "argparsedirs.WriteableDirType", "xref": {"fqname": "argparsedirs.argparsedirs.WriteableDirType", "project": null}}]}, {"name": "argparsedirs.argparsedirs", "documentation": [], "functions": [{"name": "argparsedirs.argparsedirs.ReadableDirType", "asynchronous": false, "p