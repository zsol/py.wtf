ipal", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "erpbrasil.base.fiscal.codigo_municipio.formatar_codigo_municipio", "asynchronous": false, "params": [{"name": "codigo_municipal", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "erpbrasil.base.fiscal.codigo_municipio.CODIGOS_DE_ESTADO", "type": null, "documentation": []}, {"name": "erpbrasil.base.fiscal.codigo_municipio.EXCECOES", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "erpbrasil.base.__main__", "documentation": ["Entrypoint module, in case you use `python -merpbrasil.base`.\n\n\nWhy does this file exist, and why __main__? For more info, read:\n\n- https://www.python.org/dev/peps/pep-0338/\n- https://docs.python.org/2/using/cmdline.html#cmdoption-m\n- https://docs.python.org/3/using/cmdline.html#cmdoption-m"], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "erpbrasil.base.gs1", "documentation": [], "functions": [], "variables": [{"name": "erpbrasil.base.gs1.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "erpbrasil.base.gs1.gtin", "documentation": ["coding=utf-8", "Copyright (C) 2022  Renato Lima - Akretion", "License AGPL-3 - See http://www.gnu.org/licenses/agpl-3.0.html"], "functions": [{"name": "erpbrasil.base.gs1.gtin.calcula_dv", "asynchronous": false, "params": [{"name": "gs1_code", "type": null, "default": null}, {"name": "code_length", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "erpbrasil.base.gs1.gtin.validar", "asynchronous": false, "params": [{"name": "gtin", "type": null, "default": null}], "returns": null, "documentation": ["Rotina para calcular o d\u00edgito verificador dos c\u00f3digos:\n\n- GTIN-8\n- GTIN-12/UPC-A\n- GTIN-13/EAN-13\n- GTIN-13/ITF-14\n\n0   0   6   1   4   1   4   1   9   9   9   9   9   6\n-----   ---------------------   -----------------   -\n|               |                       |           |\n|               |                       |           D\u00edgito verificador\n|               |                       |\n|               |                       Refer\u00eancia do item\n|               |\n|               GS1 Pr\u00e9fixo da empresa\n|\nD\u00edgito N1\n\nComo calcular o d\u00edgito verificador:\n\n---------- ---------------------------------------------------- ---\nGTIN       D\u00edgitos do c\u00f3digo                                    DV\n---------- ---------------------------------------------------- ---\nGTIN-8                                                              N1      N2      N3      N4      N5      N6      N7      N8\nGTIN-12                             N1      N2      N3      N4      N5      N6      N7      N8      N9      N10     N11     N12\nGTIN-13                     N1      N2      N3      N4      N5      N6      N7      N8      N9      N10     N11     N12     N13\nGTIN-14             N1      N2      N3      N4      N5      N6      N7      N8      N9      N10     N11     N12     N13     N14\n-------------------------------------------------------------------\n            x3      x1      x3      x1      x3      x1      x3      x1      x3      x1      x3      x1      x3\n\nPara calcular o \u00faltimo digito (DV), caso o GTIN tenha menos do que 14 digitos\nser\u00e1 preenchido com zeros a esquerda.\n\nExemplo de calculo:\n\nPara calcular o d\u00edgito verificador do GTIN-13 629104150021-\n\n            N1      N2      N3      N4      N5      N6      N7      N8      N9      N10     N11     N12     N13\nGTIN-13     6       2       9       1       0       4       1       5       0       0       2       1       -\nMultiplica  x       x       x       x       x       x       x       x       x       x       x       x       -\npor         1       3       1       3       1       3       1       3       1       3       1       3       -\n            =       =       =       =       =       =       =       =       =       =       =       =       -\nSoma        6       6       9       3       0       12      1       15      0       0       2       3       -\n\nSoma todos os resultados:\n6 + 6 + 9 + 3 + 0 + 12 + 1 + 15 + 0 + 0 + 2 + 3 = 57\n\nSubtraia a soma do m\u00faltiplo de dez mais pr\u00f3ximo igual ou superior:\n60 - 57 = 3 D\u00edgito verificador\n\nGTIN-13: 6291041500213\n\n:param string gtin: GTIN para ser validado\n:return bool: True or False"]}, {"name": "erpbrasil.base.gs1.gtin.gerar_gs1_code", "asynchronous": false, "params": [{"name": "gs1_code_length", "type": null, "default": null}, {"name": "prefill", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [{"name": "erpbrasil.base.gs1.gtin.GS1_GTIN_LENGTH", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "erpbrasil.base.gs1.sscc", "documentation": ["coding=utf-8", "Copyright (C) 2022  Renato Lima - Akretion", "License AGPL-3 - See http://www.gnu.org/licenses/agpl-3.0.html"], "functions": [{"name": "erpbrasil.base.gs1.sscc.validar", "asynchronous": false, "params": [{"name": "sscc", "type": null, "default": null}], "returns": null, "documentation": ["C\u00f3digo serial de cont\u00eainer de remessa\n\n------- ------------------------------------------------------------------- ---\nSSCC       D\u00edgitos do c\u00f3digo                                                DV\n------- ------------------------------------------------------------------- ---\nSSCC        N1      N2      N3      N4      N5      N6      N7      N8      N9      N10     N11     N12     N13     N14     N15     N16     N17     N18\n        x3  x1      x3      x1      x3      x1      x3      x1      x3      x1      x3      x1      x3      x1      x3      x1      x3\n\n:param string sscc: SSCC para ser validado\n:return bool: True or False"]}], "variables": [{"name": "erpbrasil.base.gs1.sscc.GS1_SSCC_LENGTH", "type": null, "documentation": []}], "classes": [], "exports": [