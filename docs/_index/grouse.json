success", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "grouse.dtos.GroundedQAEvaluationReport.positive_acceptance", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "grouse.dtos.GroundedQAEvaluationReport.negative_rejection", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "grouse.dtos.GroundedQAEvaluationReport.mean", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Model that contains the average scores of the evaluations\n\nArgs:\n    answer_relevancy (float): Average relevancy score.\n    answer_relevancy_parsing_success (float): Success rate of parsing relevancy\n    JSONs.\n    completeness (float): Average completeness score.\n    completeness_parsing_success (float): Success rate of parsing completeness\n    JSONs.\n    faithfulness (float): Average faithfulness score.\n    faithfulness_parsing_success (float): Success rate of parsing faithfulness\n    JSONs.\n    usefulness (float): Average usefulness score.\n    usefulness_parse_success (float): Success rate of parsing usefulness JSONs.\n    positive_acceptance (float): Positive acceptance rate.\n    negative_rejection (float): Negative rejection rate.\n    mean (float): Average of answer_relevancy, completeness, faithfulness,\n    usefulness, positive_acceptance and negative_rejection."]}, {"name": "grouse.dtos.GroundedQAEvaluation", "bases": ["BaseModel"], "methods": [], "class_variables": [{"name": "grouse.dtos.GroundedQAEvaluation.answer_relevancy", "type": {"name": "AnswerRelevancy | Failed", "xref": null, "params": null}, "documentation": []}, {"name": "grouse.dtos.GroundedQAEvaluation.completeness",