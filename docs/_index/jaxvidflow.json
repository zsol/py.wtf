e": "JaxVidFlow.lut._lut_impl", "asynchronous": false, "params": [{"name": "lower", "type": {"name": "jnp.ndarray", "xref": {"fqname": "jax.numpy.ndarray", "project": "jax"}, "params": null}, "default": null}, {"name": "higher", "type": {"name": "jnp.ndarray", "xref": {"fqname": "jax.numpy.ndarray", "project": "jax"}, "params": null}, "default": null}, {"name": "frac", "type": {"name": "jnp.ndarray", "xref": {"fqname": "jax.numpy.ndarray", "project": "jax"}, "params": null}, "default": null}, {"name": "lut", "type": {"name": "jnp.ndarray", "xref": {"fqname": "jax.numpy.ndarray", "project": "jax"}, "params": null}, "default": null}], "returns": {"name": "jnp.ndarray", "xref": {"fqname": "jax.numpy.ndarray", "project": "jax"}, "params": null}, "documentation": []}, {"name": "JaxVidFlow.lut.apply_lut", "asynchronous": false, "params": [{"name": "frame", "type": {"name": "jnp.ndarray", "xref": {"fqname": "jax.numpy.ndarray", "project": "jax"}, "params": null}, "default": null}, {"name": "lut_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "jnp.ndarray", "xref": {"fqname": "jax.numpy.ndarray", "project": "jax"}, "params": null}, "documentation": []}], "variables": [{"name": "JaxVidFlow.lut.logger", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "JaxVidFlow.video_writer", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "JaxVidFlow.video_writer.VideoWriter", "bases": [], "methods": [{"name": "JaxVidFlow.video_writer.VideoWriter.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "filename", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "frame_rate", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}, {"name": "pixfmt", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "codec_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "codec_options", "type": {"name": "dict[str, str] | None", "xref": null, "params": null}, "default": null}, {"name": "target_bitrate", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Note: Target bitrate is usually overridden by codec-specific constant quality control. One", "exception is videotoolbox, which does support constant quality, but it uses the global quality scale", "mechanism that's not yet implemented in PyAV."]}, {"name": "JaxVidFlow.video_writer.VideoWriter.add_frame", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "frame", "type": null, "default": null}], "returns": null, "documentation": ["Add an RGB frame."]}, {"name": "JaxVidFlow.video_writer.VideoWriter.frame_format", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "JaxVidFlow.video_writer.VideoWriter.write_audio_packets", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "audio_packets", "type": null, "default": null}, {"name": "in_audio_stream", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "JaxVidFlow.video_writer.VideoWriter.__enter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "JaxVidFlow.video_writer.VideoWriter.close", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name":