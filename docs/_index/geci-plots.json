ci_plots.geci_plots.create_box_plot", "asynchronous": false, "params": [{"name": "boxplotdata", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "geci_plots.geci_plots.set_box_plot_style", "asynchronous": false, "params": [{"name": "ax", "type": null, "default": null}, {"name": "df", "type": null, "default": null}, {"name": "seasons", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "geci_plots.geci_plots.create_box_plot_data", "asynchronous": false, "params": [{"name": "data_feature", "type": null, "default": null}, {"name": "column_name", "type": null, "default": null}], "returns": null, "documentation": ["This functions takes a DataFrame and reurns array for boxplot\n\nArgs:\n    data_feature (DataFrame): DataFrame with colum \"Temporada\" and column_name\n    column_name (string): Name of the column you want to plot\n\nReturns:\n    array: array prepared for input in plt.boxplot\n    array: unique seasons"]}, {"name": "geci_plots.geci_plots.heatmap", "asynchronous": false, "params": [{"name": "data", "type": null, "default": null}, {"name": "row_labels", "type": null, "default": null}, {"name": "col_labels", "type": null, "default": null}, {"name": "labels_size", "type": null, "default": "..."}, {"name": "ax", "type": null, "default": "..."}, {"name": "cbar_kw", "type": null, "default": "..."}, {"name": "cbarlabel", "type": null, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Create a heatmap from a numpy array and two lists of labels.\n\nParameters\n----------\ndata\n    A 2D numpy array of shape (N, M).\nrow_labels\n    A list or array of length N with the labels for the rows.\ncol_labels\n    A list or array of length M with the labels for the columns.\nax\n    A `matplotlib.axes.Axes` instance to which the heatmap is plotted.  If\n    not provided, use current axes or create a new one.  Optional.\ncbar_kw\n    A dictionary with arguments to `matplotlib.Figure.colorbar`.  Optional.\ncbarlabel\n    The label for the colorbar.  Optional.\n**kwargs\n    All other arguments are forwarded to `imshow`."]}, {"name": "geci_plots.geci_plots.annotate_heatmap", "asynchronous": false, "params": [{"name": "im", "type": null, "default": null}, {"name": "data", "type": null, "default": "..."}, {"name": "valfmt", "type": null, "default": "..."}, {"name": "textcolors", "type": null, "default": "..."}, {"name": "threshold", "type": null, "default": "..."}, {"name": "**textkw", "type": null, "default": null}], "returns": null, "documentation": ["A function to annotate a heatmap.\n\nParameters\n----------\nim\n    The AxesImage to be labeled.\ndata\n    Data used to annotate.  If None, the image's data is used.  Optional.\nvalfmt\n    The format of the annotations inside the heatmap.  This should either\n    use the string format method, e.g. \"$ {x:.2f}\", or be a\n    `matplotlib.ticker.Formatter`.  Optional.\ntextcolors\n    A pair of colors.  The first is used for values below a threshold,\n    the second for those above.  Optional.\nthreshold\n    Value in data units according to which the colors from textcolors are\n    applied.  If None (the default) uses the middle of the colormap as\n    separation.  Optional.\n**kwargs\n    All other arguments are forwarded to each call to `text` used to create\n    the text labels."]}], "variables": [{"name": "geci_plots.geci_plots.cmap", "type": null, "documentation": []}, {"name": "geci_plots.geci_plots.zones_colors", "type": null, "documentation": []}, {"name": "geci_plots.geci_plots.islet_markers", "type": null, "documentation": []}, {"name": "geci_plots.geci_plots.islet_colors", "type": null, "documentation": []}], "classes": [], "exports": []}]}