": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._get_quantity_from_line", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._get_secondary_uom_qty_depends", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._compute_secondary_uom_qty", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._get_default_value_for_qty_field", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._compute_helper_target_field_qty", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Set the target qty field defined in model"]}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._onchange_helper_product_uom_for_secondary", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Helper method to be called from onchange method of uom field in\ntarget model."]}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin.default_get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "fields_list", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._name", "type": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._description", "type": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._secondary_unit_fields", "type": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin._product_uom_field", "type": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin.secondary_uom_qty", "type": null, "documentation": []}, {"name": "odoo.addons.product_secondary_unit.models.product_secondary_unit_mixin.ProductSecondaryUnitMixin.secondary_uom_id", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Mixin model that allows to compute a field from a secondary unit helper\nAn example is to extend any model in which you want to compute quantities\nbased on secondary units. You must add a dictionary `_secondary_unit_fields`\nas class variable with the following content:\n\\_secondary_unit_fields = {\n\n> \"qty_field\": \"product_uom_qty\",\n> \"uom_field\": \"product_uom\"\n\n}\n\nTo compute `qty_field` on target model, you must convert the field to computed\nwritable (computed, stored and readonly=False), and you have to define the\ncompute method adding `secondary_uom_id` and `secondary_uom_qty` fields\nas dependencies and calling inside to `self._compute_helper_target_field_qty()`.\n\nTo compute secondary units when user changes the uom field on target model,\nyou must add an onchange method on uom field and call to\n`self._onchange_helper_product_uom_for_secondary()`\n\nYou can see an example in `purchase_order_secondary_unit` on purchase-workflow\nrepository.\n"]}], "exports": []}]}