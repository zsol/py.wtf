7\u043d\u0430\u0447\u0435\u043d\u0438\u0435\u043c - \u0440\u0430\u0437\u043d\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f \u043e\n\u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u0438, \u043d\u0435 \u0438\u0433\u0440\u0430\u044e\u0449\u0430\u044f \u0440\u043e\u043b\u044c \u0432 \u044d\u0442\u043e\u043c \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u0435 "]}, {"name": "qpi.main.QPI.command_execute_queue", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "connection", "type": null, "default": null}, {"name": "command", "type": null, "default": null}], "returns": null, "documentation": ["\u0424\u0443\u043d\u043a\u0446\u0438\u044f, \u0441\u0438\u043d\u0445\u0440\u043e\u043d\u0438\u0437\u0438\u0440\u0443\u044e\u0449\u0430\u044f \u043f\u0430\u0440\u0430\u043b\u0435\u043b\u043b\u044c\u043d\u044b\u0435 \u043f\u043e\u0442\u043e\u043a\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u043c\u0435\u0442\u043e\u0434\u043e\u0432.\n(\u0412 \u043e\u0434\u043d\u043e \u0432\u0440\u0435\u043c\u044f \u043c\u043e\u0436\u0435\u0442 \u0432\u044b\u043f\u043e\u043b\u043d\u044f\u0442\u044c\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e 1 \u043c\u0435\u0442\u043e\u0434 (actA) \u043e\u0442 1 \u043a\u043b\u0438\u0435\u043d\u0442\u0430 (clientA):\n\u0435\u0441\u043b\u0438 \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u043c\u0435\u0442\u043e\u0434\u0430 actA (\u0432 \u044d\u0442\u043e \u0432\u0440\u0435\u043c\u044f \u0441\u0442\u0430\u0442\u0443\u0441 self.status_ready - \u043d\u0435\u0433\u0430\u0442\u0438\u0432\u043d\u044b\u0439),\nclientB \u043e\u0442\u043f\u0440\u0430\u0432\u0438\u0442 \u0437\u0430\u043f\u0440\u043e\u0441 \u043d\u0430 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0435 \u043a\u0430\u043a\u043e\u0439-\u043b\u0438\u0431\u043e \u043a\u043e\u043c\u0430\u043d\u0434\u044b actB, \u0442\u043e actB \u043d\u0435 \u0431\u0443\u0434\u0435\u0442 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0430,\n\u043f\u043e\u043a\u0430 \u043d\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u0441\u044f \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0435 actA, \u0438 \u0444\u043b\u0430\u0433 self.status_ready \u043d\u0435 \u0441\u0442\u0430\u043d\u0435\u0442 \u043f\u043e\u0437\u0438\u0442\u0438\u0432\u043d\u044b\u043c."]}, {"name": "qpi.main.QPI.send_response", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "conn", "type": null, "default": null}, {"name": "response", "type": null, "default": null}], "returns": null, "documentation": ["\u041e\u0442\u043f\u0440\u0430\u0432\u0438\u0442\u044c \u043e\u0442\u0432\u0435\u0442 \u043a\u043b\u0438\u0435\u043d\u0442\u0443 \u043f\u043e \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u0438\u044e \u043e\u0442 \u043d\u0435\u0433\u043e \u043a\u043e\u043c\u043c\u0430\u043d\u0434\u044b"]}, {"name": "qpi.main.QPI.operate_command", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "command", "type": null, "default": null}, {"name": "connection", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u0438 \u043d\u0430\u0434 \u043a\u043e\u043c\u0430\u043d\u0434\u043e\u0439 command \u043e\u0442 \u043a\u043b\u0438\u0435\u043d\u0442\u0430 connection "]}, {"name": "qpi.main.QPI.check_auth", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "command", "type": null, "default": null}, {"name": "connection", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u043f\u043e\u043b\u043d\u044f\u0435\u0442