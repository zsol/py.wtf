": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["OSKAR sky model array converted from the input image.\n\nColumns\n-------\nra : (J2000) right ascension (deg)\ndec : (J2000) declination (deg)\nflux : source (Stokes I) flux density (Jy)"]}, {"name": "astrokit.utils.scripts.fits2skymodel.SkyModel.write_sky_model", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "outfile", "type": null, "default": null}, {"name": "clobber", "type": null, "default": "..."}], "returns": null, "documentation": ["Write the converted sky model for simulation."]}, {"name": "astrokit.utils.scripts.fits2skymodel.SkyModel.write_fits", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "outfile", "type": null, "default": null}, {"name": "oldheader", "type": null, "default": "..."}, {"name": "clobber", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "astrokit.utils.scripts.fits2skymodel.SkyModel.write_mask", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "outfile", "type": null, "default": null}, {"name": "clobber", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["OSKAR sky model.\n\n# Parameters\n\nimage\n\n: Input image array; unit [K] (brightness temperature)\n\nfreq\n\n: Frequency of the input image slice; unit [MHz]\n\npixelsize\n\n: Pixel size of the input image;\n  Unit: [arcsec]\n\nra0, dec0\n\n: The coordinate of the image center; unit [deg]\n\nminvalue\n\n: The minimum threshold for the image absolute values\n\nmaxvalue\n\n: The maximum threshold for the image absolute values\n\nmask\n\n: Use this mask to select the sources of the output sky model,\n  instead of the above `minvalue` and `maxvalue`.\n  NOTE: Will overwrite the above `minvalue` and `maxvalue`