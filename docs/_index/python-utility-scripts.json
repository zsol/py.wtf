ommand line string or Python into\na Python list.\n\nUsage:\n    >>> @click.option(\"--param\", default=None, type=ListParamType())\n    ... def command(param):\n    ...     ...\n\n    CLI: command --param param_name 'a, b, c,'\n\nExample:\n\n    >>> param_value = '1, 2, three,'\n    >>> ListParamType().convert(param_value, None, None)\n    'param_value' = [1, 2, 'three']`", "Reference: https://gist.github.com/welel/9cf860dd3f4d3e09f9b4305878b3a04e"]}], "exports": []}, {"name": "apps.unused_code.unused_code", "documentation": [], "functions": [{"name": "apps.unused_code.unused_code.is_fixture_autouse", "asynchronous": false, "params": [{"name": "func", "type": {"name": "ast.FunctionDef", "xref": {"fqname": "ast.FunctionDef", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "apps.unused_code.unused_code._iter_functions", "asynchronous": false, "params": [{"name": "tree", "type": {"name": "ast.Module", "xref": {"fqname": "ast.Module", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Iterable", "xref": {"fqname": "typing.Iterable", "project": "--std--"}, "params": [{"name": "ast.FunctionDef", "xref": {"fqname": "ast.FunctionDef", "project": "--std--"}, "params": null}]}, "documentation": ["Get all function from python file"]}, {"name": "apps.unused_code.unused_code.is_ignore_function_list", "asynchronous": false, "params": [{"name": "ignore_prefix_list", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "function", "type": {"name": "ast.FunctionDef", "xref": {"fqname": "ast.FunctionDef", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "p