": "imf_dir", "type": null, "default": null}, {"name": "output", "type": null, "default": null}, {"name": "signal", "type": null, "default": null}, {"name": "frequency_threshold", "type": null, "default": null}], "returns": null, "documentation": ["Matches each component mode of the signal to component modes of each driver with similar frequencies\n\nIMF_DIR is the directory containing the IMF files, which should be named <column_name>_imf_<noise>.csv\n        if omitted, this defaults to ./imfs\n\nThe output will be a CSV file for each noise value, named <output>/frequencies_<noise>.csv"]}, {"name": "pySPADS.cli.fit", "asynchronous": false, "params": [{"name": "imf_dir", "type": null, "default": null}, {"name": "frequency_dir", "type": null, "default": null}, {"name": "output", "type": null, "default": null}, {"name": "signal", "type": null, "default": null}, {"name": "noises", "type": null, "default": null}, {"name": "model", "type": null, "default": null}, {"name": "fit_intercept", "type": null, "default": null}, {"name": "normalize", "type": null, "default": null}], "returns": null, "documentation": ["Fit a linear model expressing each component of the signal as a linear combination of the components of the drivers\n\nResults will be saved as a JSON file for each noise value, named <output>/coefficients_<noise>.json\n\nIMF_DIR is the directory containing the IMF files, which should be named <column_name>_imf_<noise>.csv\n        if omitted, this defaults to ./imfs\nFREQUENCY_DIR is the directory containing the frequency files, which should be named frequencies_<noise>.csv\n        if omitted, this defaults to ./frequencies"]}, {"name": "pySPADS.cli.reconstruct", "asynchronous": false, "params": [{"name": "imf_dir", "type": null, "default": null}, {"name": "frequency_dir", "type": null, "default": null}, {"name": "coeff_dir", "type": null, "default": null}, {"name": "output", "type": null, "default": null}, {"name": "signal", "type": null, "default": null}, {"name": "noises", "type": null, "default": null}], "returns": null, "documentation": ["Reconstruct signal from IMFs using linear regression coefficients\n\nResults will be saved as a CSV file for each noise value, named <output>/predictions_<noise>.csv\n and a CSV file for the total signal, named <output>/reconstructed_total.csv\n\nIMF_DIR is the directory containing the IMF files, which should be named <column_name>_imf_<noise>.csv\n        if omitted, this defaults to ./imfs\nFREQUENCY_DIR is the directory containing the frequency files, which should be named frequencies_<noise>.csv\n        if omitted, this defaults to ./frequencies\nCOEFF_DIR is the directory containing the coefficient files, which should be named coefficients_<noise>.csv\n        if omitted, this defaults to ./coefficients"]}], "variables": [], "classes": [], "exports": []}]}