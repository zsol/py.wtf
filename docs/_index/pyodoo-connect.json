s.Command.link", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "id", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Add a relation between `self` and the related record.\n\nReturn the command triple {samp}`(LINK, {id}, 0)`\n"]}, {"name": "pyodoo_connect.tools.Command.clear", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}], "returns": null, "documentation": ["Remove all records from the relation with `self`. It behaves like\nexecuting the `unlink` command on every record.\n\nReturn the command triple {samp}`(CLEAR, 0, 0)`\n"]}, {"name": "pyodoo_connect.tools.Command.set", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "ids", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Replace the current relations of `self` by the given ones. It behaves\nlike executing the `unlink` command on every removed relation then\nexecuting the `link` command on every new relation.\n\nReturn the command triple {samp}`(SET, 0, {ids})`\n"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "tests", "documentation": ["-*- coding: utf-8 -*-", "############################################################################", "Author: Fasil", "Email: fasilwdr@hotmail.com", "WhatsApp: https://wa.me/966538952934", "Facebook: https://www.facebook.com/fasilwdr", "Instagram: https://www.instagram.com/fasilwdr", "############################################################################"], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "tests.test_odoo", "documentation": ["-*- coding: utf-8 -*-", "############################################################################"