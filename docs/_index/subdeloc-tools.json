 Naruto\n\u30b5\u30af\u30e9             Sakura\n\u3044\u306e                      Ino\n\n\u305d\u308c \u548c \u30ca\u30eb\u30c8 \u3067\u3059\n\u305d\u308c\u306f\u30ca \u30eb\u30c8\u541b \u3067\u3059\u304b\uff1f\n\n\u3042\u308c\u306f \u30ca\u30eb\u30c8\u541b \u3068 \u30b5\u30af\u30e9\u3061\u3083\u3093 \u3059\n\u3042\u308c\u306f \u30ca\u30eb\u30c8\u541b \u3068 \u30b5\u30af\u30e9\u3061\u3083\u3093 \u3059\u304b\uff1f"], "functions": [{"name": "subdeloc_tools.test.get_kanji_honor_list", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "subdeloc_tools.test.get_name_list", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "subdeloc_tools.test.find_exact_name_in_string", "asynchronous": false, "params": [{"name": "name", "type": null, "default": null}, {"name": "string", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "subdeloc_tools.test.check_names", "asynchronous": false, "params": [{"name": "sentence", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "subdeloc_tools.test.search_honor", "asynchronous": false, "params": [{"name": "sentence", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "subdeloc_tools.test.replace_word", "asynchronous": false, "params": [{"name": "sentence", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "honorific", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "subdeloc_tools.test.flow", "asynchronous": false, "params": [{"name": "pair", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "subdeloc_tools.test.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "subdeloc_tools.test.names", "type": null, "documentation": []}, {"name": "subdeloc_tools.test.honorifics", "type": nul