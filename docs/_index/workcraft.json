R_INTERVAL: 10\n        This is the interval at which the database checks for dead workers.\n\nThese values are read from the workcraft.config.json file."]}], "exports": []}, {"name": "workcraft.__main__", "documentation": [], "functions": [{"name": "workcraft.__main__.signal_handler", "asynchronous": false, "params": [{"name": "signum", "type": null, "default": null}, {"name": "frame", "type": null, "default": null}, {"name": "db_config", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "workcraft.__main__.CLI", "bases": [], "methods": [{"name": "workcraft.__main__.CLI.peon", "asynchronous": true, "params": [{"name": "workcraft_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "worker_id", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "queues", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "load_db_config_from_env", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "db_host", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "db_port", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "db_user", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "db_password", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "db_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "db_use_ssl", "typ