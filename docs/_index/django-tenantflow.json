o espec\u00c3\u00adficos.\r\n    \"\"\"\r\n    restricted = models.BooleanField(default=False, help_text=\"Indica si este privilegio est\u00c3\u00a1 restringido\")\r\n\r\n"], "modules": [{"name": "tenantflow.models", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "tenantflow.models.AbstractAccount", "xref": {"fqname": "tenantflow.models.account.AbstractAccount", "project": null}}, {"name": "tenantflow.models.AbstractUserAccount", "xref": {"fqname": "tenantflow.models.user_account.AbstractUserAccount", "project": null}}]}, {"name": "tenantflow.models.user_account", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "tenantflow.models.user_account.AbstractUserAccount", "bases": ["models.Model"], "methods": [{"name": "tenantflow.models.user_account.AbstractUserAccount.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "tenantflow.models.user_account.AbstractUserAccount.user", "type": null, "documentation": []}, {"name": "tenantflow.models.user_account.AbstractUserAccount.account", "type": null, "documentation": []}, {"name": "tenantflow.models.user_account.AbstractUserAccount.created_at", "type": null, "documentation": []}, {"name": "tenantflow.models.user_account.AbstractUserAccount.updated_at", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [{"name": "tenantflow.models.user_account.AbstractUserAccount.Meta", "bases": [], "methods": [], "class_variables": [{"name": "tenantflow.models.user_account.AbstractUserAccount.Meta.abstract", "type": null, "documentation": []}, {"name": "tenantflow.models.user_account.AbstractUserAccount.Meta.unique_together", "type": null, "documentation": []}, {"name": "tenantflow.models.user_account.AbstractUserAccount.Meta.verbose_name", "type": null, "documentation": []}, {"name": "tenantflow.models.user_account.AbstractUserAccoun