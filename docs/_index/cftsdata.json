ion": []}], "classes": [], "exports": []}, {"name": "cftsdata.abr", "documentation": ["Interface for reading tone-evoked ABR data generated by psiexperiment\n\n# Example\n\n```python\nfrom psidata.api import abr\nfilename = '20220601-1200 ID1234 abr_io'\nwith abr.load(filename) as fh:\n    epochs = fh.get_epochs()\n    epochs_filtered = fh.get_epochs_filtered()\n```\n"], "functions": [{"name": "cftsdata.abr.list_abr_experiments", "asynchronous": false, "params": [{"name": "base_path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cftsdata.abr.load", "asynchronous": false, "params": [{"name": "base_path", "type": null, "default": null}, {"name": "allow_superset", "type": null, "default": "..."}], "returns": null, "documentation": ["Load ABR data\n\nParameters\n----------\nbase_path : string\n    Path to folder\nallow_superset : bool\n    If True, will merge all subfolders containing valid ABR data into a\n    single superset ABR file. If False, base_path must be a valid ABR\n    dataset.\n\nReturns\n-------\n{ABRFile, ABRSupersetFile}\n    Depending on folder, will return either an instance of `ABRFile` or\n    `ABRSupersetFile`."]}, {"name": "cftsdata.abr.is_abr_experiment", "asynchronous": false, "params": [{"name": "base_path", "type": null, "default": null}, {"name": "allow_superset", "type": null, "default": "..."}], "returns": null, "documentation": ["Checks if path contains valid ABR data\n\nParameters\n----------\nbase_path : string\n    Path to folder\n\nReturns\n-------\nbool\n    True if path contains valid ABR data, False otherwise. If path doesn't\n    exist, False is returned."]}, {"name": "cftsdata.abr.load_abr_analysis", "asynchronous": false, "params": [{"name": "filename", "type": null, "default": null}], "returns": null, "documentation": ["Load ABR analysis from file\n\nParameters\n----------\nfilename : {str, pathlib.Path}\n    Name of file to load.\n\nReturns\n-------"]}, {"name": "cftsdata.abr.format_docstring