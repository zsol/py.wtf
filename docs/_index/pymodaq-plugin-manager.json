e": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Version", "xref": {"fqname": "packaging.version.Version", "project": null}, "params": null}]}, "default": "..."}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Retrieve the metadata of a given package on pypi matching or not a specific version\n\nParameters\n----------\nname: str\n    package name\nversion: Union[str, Version]\n    package version specifier\n\n\nReturns\n-------\ndict of metadata"]}, {"name": "pymodaq_plugin_manager.validate.get_metadata_from_json", "asynchronous": false, "params": [{"name": "json_as_dict", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Transform dict of metadata from pypi to a simpler dict"]}, {"name": "pymodaq_plugin_manager.validate.get_pypi_pymodaq", "asynchronous": false, "params": [{"name": "package_name", "type": null, "default": "..."}, {"name": "pymodaq_version", "type": {"name": "Version", "xref": {"fqname": "packaging.version.Version", "project": null}, "params": null}, "default": "..."}, {"name": "pymodaq_latest", "type": {"name": "Version", "xref": {"fqname": "packaging.version.Version", "project": null}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Get the latest plugin info compatible with a given version of pymodaq\n\nParameters\n----------\npackage_name: str\npymodaq_version: Version\n\nReturns\n-------\ndict containing metadata of the latest compatible plugin"]}, {"name": "pymodaq_plugin_manager.validate.get_pypi_plugins", "asynchronous": false, "params": [{"name": "browse_pypi", "type": null, "default": "..."}, {"name": "pymodaq_versi