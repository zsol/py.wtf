{"name": "mathforuni", "metadata": {"name": "mathforuni", "version": "0.1.0", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": null, "license": null, "documentation_url": null, "dependencies": [], "summary": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0432\u0430\u0448\u0435\u0439 \u0431\u0438\u0431\u043b\u0438\u043e\u0442\u0435\u043a\u0438", "upload_time": 1734517309}, "documentation": ["# Mathforuni\n\n## \u041f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u0435\n\u0414\u0430\u043d\u043d\u0430\u044f \u0431\u0438\u0431\u043b\u0438\u043e\u0442\u0435\u043a\u0430 \u0441\u043e\u0437\u0434\u0430\u043d\u0430 \u0432 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u043c \u0434\u043b\u044f \u0441\u0442\u0443\u0434\u0435\u043d\u0442\u043e\u0432, \u0438\u0437\u0443\u0447\u0430\u044e\u0449\u0438\u0445 \u043c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u043a\u0443 \u0432 \u0432\u044b\u0441\u0448\u0438\u0445 \u0443\u0447\u0435\u0431\u043d\u044b\u0445 \u0437\u0430\u0432\u0435\u0434\u0435\u043d\u0438\u044f\u0445, \u0432 \u0447\u0430\u0441\u0442\u043d\u043e\u0441\u0442\u0438 \u0442\u0430\u043a\u0438\u0435 \u0435\u0435 \u0440\u0430\u0437\u0434\u0435\u043b\u044b \u043a\u0430\u043a \u0422\u0435\u043e\u0440\u0438\u044f \u043a\u043e\u043d\u0435\u0447\u043d\u044b\u0445 \u0433\u0440\u0430\u0444\u043e\u0432 \u0438 \u042d\u043b\u0435\u043c\u0435\u043d\u0442\u044b \u0442\u0435\u043e\u0440\u0438\u0438 \u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e\u0441\u0442\u0438\n\n## \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435\n\u0411\u0438\u0431\u043b\u0438\u043e\u0442\u0435\u043a\u0430 \u0441\u043e\u0434\u0435\u0440\u0436\u0438\u0442 **\u0434\u0432\u0430** \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u0445 \u043c\u043e\u0434\u0443\u043b\u044f - \u0433\u0440\u0430\u0444\u044b \u0438 \u0442\u0435\u043e\u0440\u0438\u044f \u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e\u