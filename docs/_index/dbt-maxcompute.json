pe": null, "default": "..."}, {"name": "condition", "type": null, "default": "..."}], "returns": null, "documentation": ["Decorator for retrying a function if it throws an exception.\n\n```\nparam max_retries\n\nMaximum number of retries before giving up.\n\nparam delay\n\nInitial delay between retries in seconds.\n\nparam backoff\n\nMultiplier applied to delay between retries.\n\nparam exceptions\n\nTuple of exceptions to catch. Defaults to base Exception.\n\nparam condition\n\nOptional function to determine if the exception should trigger a retry.\n```\n"]}], "variables": [], "classes": [], "exports": []}, {"name": "dbt.adapters.maxcompute.__version__", "documentation": [], "functions": [], "variables": [{"name": "dbt.adapters.maxcompute.__version__.version", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "dbt.adapters.maxcompute.context", "documentation": [], "functions": [], "variables": [{"name": "dbt.adapters.maxcompute.context.GLOBAL_SQL_HINTS", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "dbt.adapters.maxcompute", "documentation": [], "functions": [], "variables": [{"name": "dbt.adapters.maxcompute.Plugin", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "dbt.adapters.maxcompute.AdapterPlugin", "xref": {"fqname": "dbt.adapters.base.AdapterPlugin", "project": "dbt-adapters"}}, {"name": "dbt.adapters.maxcompute.maxcompute", "xref": {"fqname": "dbt.include.maxcompute", "project": null}}, {"name": "dbt.adapters.maxcompute.MaxComputeAdapter", "xref": {"fqname": "dbt.adapters.maxcompute.impl.MaxComputeAdapter", "project": null}}, {"name": "dbt.adapters.maxcompute.MaxComputeConnectionManager", "xref": {"fqname": "dbt.adapters.maxcompute.connections.MaxComputeConnectionManager", "project": null}}, {"name": "dbt.adapters.maxcompute.MaxComputeCredentials", "xref": {"fqname": "dbt.adapters.maxcompute.connections.MaxComputeCredentials", "project": null}}]}, {"name": "dbt.adapters.max