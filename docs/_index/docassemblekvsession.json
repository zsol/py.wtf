onous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "id", "type": null, "default": null}, {"name": "created", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "docassemblekvsession.SessionID.has_expired", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "lifetime", "type": null, "default": null}, {"name": "now", "type": null, "default": "..."}], "returns": null, "documentation": ["Report if the session key has expired.\n\n```\nparam lifetime\n\nA  that specifies the\nmaximum age this  should be checked\nagainst.\n\nparam now\n\nIf specified, use this  instance\ninstead of  as the\ncurrent time.\n```\n"]}, {"name": "docassemblekvsession.SessionID.serialize", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Serializes to the standard form of ``KEY_CREATED``"]}, {"name": "docassemblekvsession.SessionID.unserialize", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "string", "type": null, "default": null}], "returns": null, "documentation": ["Unserializes from a string.\n\n```\nparam string\n\nA string created by .\n```\n"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Helper class for parsing session ids.\n\nInternally, Flask-KVSession stores session ids that are serialized as\n`KEY_CREATED`, where `KEY` is a random number (the sessions \"true\" id)\nand `CREATED` a UNIX-timestamp of when the session was created.\n\n```\nparam id\n\nAn integer to be used as the session key.\n\nparam created\n\nA  instance or None. A value of\nNone will result in  to\nbe used.\n```\n"]}, {"name": "docassemblekvsession.KVSession", "bases": ["CallbackDict", "SessionMixin"], "methods": [{"name": "docassemblekvsession.KVSession.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "initial", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "docassemblekvsession.KVSession.destroy", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Destroys a session completely, by deleting all keys and removing it\nfrom the internal store immediately.\n\nThis allows removing a session for security reasons, e.g. a login\nstored in a session will cease to exist if the session is destroyed."]}, {"name": "docassemblekvsession.KVSession.regenerate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Generate a new session id for this session.\n\nTo avoid vulnerabilities through `session fixation attacks\n<http://en.wikipedia.org/wiki/Session_fixation>`_, this function can be\ncalled after an action like a login has taken place. The session will\nbe copied over to a new session id and the old one removed."]}], "class_variables": [{"name": "docassemblekvsession.KVSession.modified", "type": null, "documentation": ["Replacement session class.\n\nInstances of this class will replace the session (and thus be available\nthrough things like {attr}`flask.session`.\n\nThe session class will save data to the store only when necessary, empty\nsessions will not be stored at all.\n"]}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "docassemblekvsession.KVSessionInterface", "bases": ["SessionInterface"], "methods": [{"name": "docassemblekvsession.KVSessionInterface.open_session", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "app", "type": null, "default": null}, {"name": "request", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "docassemblekvsession.KVSessionInterface.manual_save_session", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "app", "type": nul