ile'},\n                        'help': 'The output file',\n                        'terms': OrderedDiot([])}},\n 'Summary': {'long': 'Long description\\n',\n             'short': 'Short description'}}\n```\n"], "modules": [{"name": "pipen_annotate.utils", "documentation": [], "functions": [{"name": "pipen_annotate.utils.is_section", "asynchronous": false, "params": [{"name": "s", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pipen_annotate.utils.dedent", "asynchronous": false, "params": [{"name": "lines", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["Dedent a list of lines."]}, {"name": "pipen_annotate.utils.indent", "asynchronous": false, "params": [{"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "indentation", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Indent a text."]}, {"name": "pipen_annotate.utils.end_of_sentence", "asynchronous": false, "params": [{"name": "line", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": [