r express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n\n[git repository]: https://github.com/hat-open/hat-asn1.git\n[hat open]: https://hat-open.com\n[kon\u010dar digital]: https://www.koncar.hr/en\n[online documentation]: https://hat-asn1.hat-open.com\n[pydoit]: https://pydoit.org\n[pypi project]: https://pypi.org/project/hat-asn1\n"], "modules": [{"name": "hat.asn1.doc", "documentation": [], "functions": [{"name": "hat.asn1.doc.generate_html", "asynchronous": false, "params": [{"name": "refs", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "common.TypeRef", "xref": {"fqname": "hat.asn1.common.TypeRef", "project": null}, "params": null}, {"name": "common.Type", "xref": {"fqname": "hat.asn1.common.Type", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Generate HTML documentation"]}, {"name": "hat.asn1.doc._generate_module_toc", "asynchronous": false, "params": [{"name": "module_name", "type": null, "default": null}, {"name": "refs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hat.asn1.doc._generate_module", "asynchronous": false, "params": [{"name": "module_name", "type": null, "default": null}, {"name": "refs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hat.asn1.doc._generate_type", "asynchronous": false, "params": [{"name": "t", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hat.asn1.doc._ref_to_href", "asynchronous": false, "params": [{"name": "ref", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hat.asn1.doc._ref_to_id", "asynchronous": false, "params": [{"name": "ref", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "hat.asn1.doc._style", "type": null, "documentation": []}, {"name": "hat.asn1.doc._optional", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "hat.asn1", "documentation": ["Abstract Syntax Notation One\n\nValue mapping\n-------------\n\n    +-----------------------+-------------------+\n    | ASN.1 type            | Python type       |\n    +=======================+===================+\n    | Boolean               | bool              |\n    +-----------------------+-------------------+\n    | Integer               | int               |\n    +-----------------------+-------------------+\n    | BitString             | List[bool]        |\n    +-----------------------+-------------------+\n    | OctetString           | Bytes             |\n    +-----------------------+-------------------+\n    | Null                  | NoneType          |\n    +-----------------------+-------------------+\n    | ObjectIdentifier      | Tuple[int, ...]   |\n    +-----------------------+-------------------+\n    | String                | str               |\n    +-----------------------+-------------------+\n    | External              | External          |\n    +-----------------------+-------------------+\n    | Real                  | float             |\n    +-----------------------+-------------------+\n    | Enumerated            | int               |\n    +-----------------------+-------------------+\n    | EmbeddedPDV           | EmbeddedPDV       |\n    +-----------------------+-------------------+\n    | Choice                | Tuple[str, Value] |\n    +-----------------------+-------------------+\n    | Set                   | Dict[str, Value]  |\n    +-----------------------+-------------------+\n    | SetOf                 | Iterable[Value]   |\n    +-----------------------+-------------------+\n    | Sequence              | Dict[str, Value]  |\n    +-----------------------+-------------------+\n    | SequenceOf            | List[Value]       |\n    +-----------------------+-------------------+\n    | ABSTRACT-SYNTAX.&Type | Entity            |\n    +-----------------------+-------------------+\n\nFor Choice, Set and Sequence, `str` represents field name."], "functions": [], "variables": [], "classes": [{"name": "hat.asn1.Encoding", "bases": ["enum.Enum"], "methods": [], "class_variables": [{"name": "hat.asn1.Encoding.BER", "type": null, "documentation": ["(joint-iso-itu-t, asn1, basic-encoding)"]}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "hat.asn1.Repository", "bases": [], "methods": [{"name": "hat.asn1.Repository.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": {"name": "typing.Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "pathlib.PurePath", "xref": {"fqname": "pathlib.PurePath", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Repository", "xref": {"fqname": "hat.asn1.Repository", "project": null}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "hat.asn1.Repository.from_json", "asynchronous": false, "params": [{"name": "data", "type": {"name": "pathlib.PurePath | json.Data", "xref": null, "params": null}, "default": null}], "returns": {"name": "Repository", "xref": {"fqname": "hat.asn1.Repository", "project": null}, "params": null}, "documentation": ["Create repository from JSON data representation"]}, {"name": "hat.asn1.Repository.to_json", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "json.Data", "xref": {"fqname": "hat.json.Data", "project": "hat-json"}, "params": null}, "documentation": ["Represent repository as JSON data"]}, {"name": "hat.asn1.Repository.generate_html_doc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "return