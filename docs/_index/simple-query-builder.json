 age, account_sum + account_sum * 0.3 AS total_sum FROM clients WHERE account_sum >= 3000;\n-----------------\nSELECT `name`, `age`, account_sum + account_sum * 0.1 AS `total_sum` FROM `clients` WHERE (`account_sum` < 3000)\nUNION\nSELECT `name`, `age`, account_sum + account_sum * 0.3 AS `total_sum` FROM `clients` WHERE (`account_sum` >= 3000)\n-----------------\nq = qb.select('clients', ['name', 'age', {'total_sum': 'account_sum + account_sum * 0.1'}]).where([['account_sum', '<', 3000]])     .union()     .select('clients', ['name', 'age', {'total_sum': 'account_sum + account_sum * 0.3'}]).where([['account_sum', '>=', 3000]])\n-----------------\n=== !TODO! ===\nSELECT * FROM `tab1` WHERE (`a` IS NOT NULL) AND (`b` = 5)\n-----------------\n\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044f \u043a\u043b\u0430\u0441\u0441 on conflict \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0430 insert, \u043c\u043e\u0436\u043d\u043e \u0434\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u043d\u043e\u0432\u0443\u044e \u0441\u0442\u0440\u043e\u043a\u0443, \u0430 \u043f\u0440\u0438 \u0443\u0436\u0435 \u0438\u043c\u0435\u044e\u0449\u0435\u0439\u0441\u044f \u0441 \u0442\u0430\u043a\u0438\u043c \u0436\u0435 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435\u043c \u043f\u043e \u043a\u043b\u044e\u0447\u0443, \u043e\u0431\u043d\u043e\u0432\u0438\u0442\u044c.\ncreate table vocabulary (word text primary key, count int default 1);\ninsert into vocabulary (word) values ('jovial') on conflict (word) do update set count = count + 1;\n\nhttps://habr.com/ru/articles/528882/\n-----------------\nq = qb.select(\"'a' || ' 123 ' || null\")\nSELECT 'a' || ' 123 ' || null\n-----------------\nq = qb.select(\"strftime('%Y-%m-%d %H:%M', 'now')\")\nSELECT strftime('%Y-%m-%d %H:%M', 'now')\n-----------------\nq = qb.select(\"strftime('%d-%m-%Y %H:%M:%S', 1605961514, 'unixepoch', 'localtime')\")\nSELECT strftime('%d-%m-%Y %H:%M:%S', 1605961514, 'unixepoch', 'localtime')\n-----------------\nq = qb.select(\"generate_series(5, 100, 5)\", ['value'])\nSELECT value FROM generate_series(5, 100, 5)"]}, {"name": "simple_query_builder.example.q", "type": null, "documentation": ["SELECT `id`, `name` FROM (SELECT * FROM `cabs` WHERE (`id` < 10)) WHERE (`id` < 5)"]}, {"name": "simple_query_builder.example.tb", "type": null, "documentation": []}, {"name": "simple_query_builder.example.printers", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "simple_query_builder.querybuilder", "documentation": [":authors: co0lc0der\n:license: MIT\n:copyright: (c) 2022-2024 co0lc0der"], "functions": [], "variables": [], "classes": [{"name": "simple_query_builder.querybuilder.QueryBuilder", "bases": [], "methods": [{"name": "simple_query_builder.querybuilder.QueryBuilder.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "database", "type": {"name": "DataBase", "xref": {"fqname": "DataBase", "project": null}, "params": null}, "default": null}, {"name": "db_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "result_dict", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "print_errors", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "uri", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "simple_query_builder.querybuilder.QueryBuilder._set_row_factory", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "result_dict", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..