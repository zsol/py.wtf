{"name": "zen-mapper", "metadata": {"name": "zen-mapper", "version": "0.2.0", "classifiers": [], "home_page": null, "license": null, "documentation_url": null, "dependencies": ["numpy"], "summary": "Mapper without the noise", "upload_time": 1735452069}, "documentation": ["# Zen Mapper\n\n> Perfection is achieved, not when there is nothing more to add, but when there\n> is nothing left to take away.\n>\n> Antoine de Saint-Exupe\u0301ry\n\nZen mapper is a minimal implementation of the TDA algorithm Mapper\n\n# Installation\n\nThere are two supported methods of installation\n\n## PyPi\n\nZen Mapper has a distribution on [PyPi](https://pypi.org/project/zen-mapper/).\nYou can install it using pip:\n```sh\npip install zen-mapper\n```\n\n## Nix\n\nZen Mapper is also packaged as a nix flake. If you have nix installed and flake\nsupport enabled. You can create a dev environment with Zen Mapper installed\neasily enough:\n```sh\nnix flake new -t github:zen-mapper/zen-mapper new_project\ncd new_project\nnix develop\n```\nWill drop you into a shell with python 3.11 and Zen Mapper configured.\n"], "modules": [{"name": "zen_mapper.adapters", "documentation": [], "functions": [{"name": "zen_mapper.adapters.to_networkx", "asynchronous": false, "params": [{"name": "komplex", "type": {"name": "Komplex", "xref": {"fqname": "zen_mapper.komplex.Komplex", "project": null}, "params": null}, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "zen_mapper", "documentation": [], "functions": [{"name": "zen_mapper.mapper", "asynchronous": false, "params": [{"name": "data", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}, {"name": "projection", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}, {"name": "cover_scheme", "type": {"name": "CoverScheme", "xref": {"fqname": "zen_mapper.cover.CoverScheme", "project": null}, "params": null}, "default": null}, {"name": "clusterer", "type": {"name": "Clusterer", "xref": {"fqname": "zen_mapper.cluster.Clusterer", "project": null}, "params": null}, "default": null}, {"name": "dim", "type": {"name": "int | None", "xref": null, "params": null}, "default": null}], "returns": {"name": "MapperResult", "xref": {"fqname": "zen_mapper.MapperResult", "project": null}, "params": null}, "documentation": []}], "variables": [{"name": "zen_mapper.logger", "type": null, "documentation": []}], "classes": [{"name": "zen_mapper.MapperResult", "bases": [], "methods": [], "class_variables": [{"name": "zen_mapper.MapperResult.nodes", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}]}, "documentation": []}, {"name": "zen_mapper.MapperResult.nerve", "type": {"name": "Komplex", "xref": {"fqname": "zen_mapper.komplex.Komplex", "project": null}, "params": null}, "documentation": []}, {"name": "zen_mapper.MapperResult.cover", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": [{"name": "zen_mapper.Clusterer", "xref": {"fqname": "zen_mapper.cluster.Clusterer", "project": null}}, {"name": "zen_mapper.compute_nerve", "xref": {"fqname": "zen_mapper.komplex.compute_nerve", "project": null}}, {"name": "zen_mapper.CoverScheme", "xref": {"fqname": "zen_mapper.cover.CoverScheme", "project": null}}, {"name": "zen_mapper.dataclass", "xref": {"fqname": "dataclasses.dataclass", "project": null}}, {"name": "zen_mapper.Komplex", "xref": {"fqname": "zen_mapper.komplex.Komplex", "projec