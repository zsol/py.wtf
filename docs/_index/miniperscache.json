ion."]}, {"name": "miniperscache.arg_hasher.DefaultArgHasher", "bases": ["MkArgHasherType"], "methods": [{"name": "miniperscache.arg_hasher.DefaultArgHasher.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "skip_args", "type": {"name": "list[str] | None", "xref": null, "params": null}, "default": "..."}], "returns": null, "documentation": ["skip_args: list of argument names of the function to skip from the hashing."]}, {"name": "miniperscache.arg_hasher.DefaultArgHasher.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "func", "type": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "...", "xref": null, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "...", "xref": null, "params": null}, {"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}]}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "miniperscache.cache", "documentation": [], "functions": [{"name": "miniperscache.cache._check_tag_uniqueness", "asynchronous": false, "params": [{"name": "tag", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "miniperscache.cache.mk_cached", "asynchronous": false, "params": [{"name": "func", "type": {"name": "Callable", "xref": {"fqname": "typing_extensions.Callable", "project": "typing-extensions"}, "params": [{"name": "P", "xref": {"fqname": "P", "project": null}, "params": null}, {"name": "R", "x