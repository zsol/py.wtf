"project": "--std--"}, "params": null}, "documentation": []}, {"name": "postgreasy.insert_df", "asynchronous": false, "params": [{"name": "df", "type": {"name": "pd.DataFrame", "xref": {"fqname": "pandas.DataFrame", "project": "pandas"}, "params": null}, "default": null}, {"name": "schema", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "table", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "connection", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Does not upload the index, so make sure to reset_index() if you need it as well", "def get_most_recent_time_value(time_column: str, schema: str, table: str) -> dt.datetime:", "\"\"\"", "Returns the most recent timestamp from the time column from the table, of the table does not exist,", "it returns 1st January 2023", "\"\"\"", "database_newest_date = dt.datetime(0, 0, 0, tzinfo=dt.timezone.utc)", "if check_if_table_exists(schema, table):", "newest_entry_date_query = sql.SQL('select {time_column_name} from {schema}.{table} order by {time_column_name} desc limit 1').format(", "schema=sql.Identifier(schema),", "table=sql.Identifier(table),", "time_column_name=sql.Identifier(time_column),", ")", "result = fetch_with_query_on_db(newest_entry_date_query)", "if len(result) > 0:", "database_newest_date = result[0][0]", "return database_newest_date"]}], "variables": [], "classes": [], "exports": [{"name": "postgreasy.Any", "xref": {"fqname": "typing.Any", "project": null}}, {"name": "postgreasy.Optional", "xref": {"fqname": "typing.Optional", "project": null}}, {"name": "postgreasy.Postg