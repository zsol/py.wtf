le queries. We tried using \"sqlparse\" to split the script into separate queries and\nexecute them individually, but it was not reliable because some queries need to be executed in\na single session. Additionally, for large scripts (e.g., 20MB), sqlparse execution was\nextremely slow. Therefore, we have no choice but to depend on the \"mysql\" command."]}, {"name": "sql_judge_utils.mysql.MysqlDatabase.run_query", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "sql_string", "type": null, "default": null}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}]}]}, "documentation": ["---\nparam sql_string: true\nreturn: |-\n  col_names\n  records\n---\n"]}, {"name": "sql_judge_utils.mysql.MysqlDatabase.get_public_table_names", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "sql_judge_utils.database", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "sql_judge_utils.database.Database", "bases": [], "methods": [{"name": "sql_judge_utils.database.Database.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "db_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "projec