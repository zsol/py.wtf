an DGPS, but not quite RTK.\n    6 = Estimated fix (dead reckoning).\n    7 = Manual input mode.\n    8 = Simulation mode.\n    9 = WAAS fix (not NMEA standard, but NovAtel receivers report this instead of a 2).", "!/usr/bin/env python3"], "functions": [{"name": "rox_septentrio.mock.sd_to_dm", "asynchronous": false, "params": [{"name": "latitude", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}, {"name": "longitude", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["convert decimals to DDDMM.SSSS format and their directions"]}, {"name": "rox_septentrio.mock.nmea_msg", "asynchronous": false, "params": [{"name": "sentence", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["add starting $ and checksum to a message"]}, {"name": "rox_septentrio.mock.message_factory", "asynchronous": false, "params": [{"name": "sentence_type", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "field_names", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}, {"name": "example_str", "type": {"name": "str", "xref": {"fqname": "functions.str