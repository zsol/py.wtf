ll, "default": null}, {"name": "date_", "type": null, "default": null}, {"name": "reference", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.account_move_cutoff.models.account_move.AccountMove._create_cutoff_entries", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "lines_to_deferred", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.account_move_cutoff.models.account_move.AccountMove._get_amounts_by_period", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "lines_to_deferred", "type": null, "default": null}, {"name": "periods", "type": null, "default": null}], "returns": null, "documentation": ["return data with amount to dispatched per account move line and per periods:\n\n```\n[\n    (\n        line1, # record of the original account.move.line,\n        { # dict of amounts per period\n            period1: amount1,\n            period2: amount2,\n        }\n    ),\n    (\n        line2,\n        {...}\n    )\n]\n```\n\nDeveloper should take care of rounding issues.\n\namount on the first period is the amount that won't be deferred\n"]}, {"name": "odoo.addons.account_move_cutoff.models.account_move.AccountMove.action_view_deferred_entries", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "odoo.addons.account_move_cutoff.models.account_move.AccountMove._name", "type": null, "documentation": []}, {"name": "odoo.addons.account_move_cutoff.models.account_move.AccountMove._inherit", "type": null, "documentation": []}, {"name": "odoo.addons.account_move_cutoff.models.account_move.AccountMove.cutoff_from_id", "type": null, "documentation": []}, {"name": "odoo.addons.account_move_cutoff.models.account_move.AccountMove.cutoff_move_count", "type": null, "documentation": []}, {"name": "odoo.addons