name": "functions.tuple", "project": "--std--"}, "params": [{"name": "_KeyT", "xref": {"fqname": "_KeyT", "project": null}, "params": null}, {"name": "...", "xref": null, "params": null}]}]}]}, "documentation": ["Reverse multimapping to map from values to keys\n\nGiven a mapping, e.g. a dictionary, from keys to an iterable of values,\nthis function reverses the mapping so it maps from values to keys. The\nkeys are collected in a collection specified by `clct`.\n\n# Examples:\n\nSimple usage using `set`:\n\\>>> reverse_multimapping(set, {1: \"abc\", 2: \"bcd\", 3: \"a\"})\n{'a': {1, 3}, 'b': {1, 2}, 'c': {1, 2}, 'd': \\{2}}\n\nUsage using `frozenset` and a cast to have the best type inference:\n\\>>> import typing as t\n\\>>> clct = t.cast(t.Type\\[frozenset[int]\\], frozenset)\n\\>>> reverse_multimapping(clct, {1: [13, 37], 2: [13, 42], 3: [42]})\n{13: frozenset({1, 2}), 37: frozenset(\\{1}), 42: frozenset({2, 3})}\n"]}], "variables": [{"name": "collectiondict._reverse_multimapping._KeyT", "type": null, "documentation": []}, {"name": "collectiondict._reverse_multimapping._HashableValueT", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "collectiondict._reverse_mapping", "documentation": [], "functions": [{"name": "collectiondict._reverse_mapping.reverse_mapping", "asynchronous": false, "params": [{"name": "clct", "type": {"name": "t.Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "Counter", "xref": {"fqname": "collections.Counter", "project": "--std--"}, "params": [{"name": "_KeyT", "xref": {"fqname": "_KeyT", "project": null}, "params": null}]}]}, "default": null}, {"name": "mapping", "type": {"name": "t.Mapping", "xref": {"fqname": "typing.Mapping", "project": "--std--"}, "params": [{"name": "_KeyT", "xref": {"fqname": "_KeyT", "project": null}, "params": null}, {"name": "_HashableValueT", "xref": {"fqname": "_HashableValueT", "project": null}, "params": null}]}, "default": null}], "returns": {"name"