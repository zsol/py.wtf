tions": [], "variables": [{"name": "pylsp_jsonrpc.endpoint.log", "type": null, "documentation": []}, {"name": "pylsp_jsonrpc.endpoint.JSONRPC_VERSION", "type": null, "documentation": []}, {"name": "pylsp_jsonrpc.endpoint.CANCEL_METHOD", "type": null, "documentation": []}], "classes": [{"name": "pylsp_jsonrpc.endpoint.Endpoint", "bases": [], "methods": [{"name": "pylsp_jsonrpc.endpoint.Endpoint.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dispatcher", "type": null, "default": null}, {"name": "consumer", "type": null, "default": null}, {"name": "id_generator", "type": null, "default": "..."}, {"name": "max_workers", "type": null, "default": "..."}], "returns": null, "documentation": ["A JSON RPC endpoint for managing messages sent to/from the client.\n\nArgs:\n\n: dispatcher (dict): A dictionary of method name to handler function.\n\n  : The handler functions should return either the result or a callable that will be used to asynchronously\n    compute the result.\n\n  consumer (fn): A function that consumes JSON RPC message dicts and sends them to the client.\n  id_generator (fn, optional): A function used to generate request IDs.\n\n  > Defaults to the string value of {func}`uuid.uuid4`.\n\n  max_workers (int, optional): The number of workers in the asynchronous executor pool.\n"]}, {"name": "pylsp_jsonrpc.endpoint.Endpoint.shutdown", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pylsp_jsonrpc.endpoint.Endpoint.notify", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "method", "type": null, "default": null}, {"name": "params", "type": null, "default": "..."}], "returns": null, "documentation": ["Send a JSON RPC notification to the client.\n\nArgs:\n    method (str): The method name of the notification to send\n    params (any): The payload of the notification"]}, {"name": "pylsp_jsonrpc.endpoint.Endpoint.request", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "method", "type": null, "default": null}, {"name": "params", "type": null, "default": "..."}], "returns": null, "documentation": ["Send a JSON RPC request to the client.\n\nArgs:\n    method (str): The method name of the message to send\n    params (any): The payload of the message\n\nReturns:\n    Future that will resolve once a response has been received"]}, {"name": "pylsp_jsonrpc.endpoint.Endpoint._cancel_callback", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "request_id", "type": null, "default": null}], "returns": null, "documentation": ["Construct a cancellation callback for the given request ID."]}, {"name": "pylsp_jsonrpc.endpoint.Endpoint.consume", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": null, "default": null}], "returns": null, "documentation": ["Consume a JSON RPC message from the client.\n\nArgs:\n    message (dict): The JSON RPC message sent by the client"]}, {"name": "pylsp_jsonrpc.endpoint.Endpoint._handle_notification", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "method", "type": null, "default": null}, {"name": "params", "type": null, "default": null}], "returns": null, "documentation": ["Handle a notification from the client."]}, {"name": "pylsp_jsonrpc.endpoint.Endpoint._notification_callback", "asynchronous": false, "params": [{"name": "method", "type": null, "default": null}, {"name": "params", "type": null, "default": null}], "returns": null, "documentation": ["Construct a notification callback for the given request ID."]}, {"name": "pylsp_jsonrpc.endpoint.Endpoint._handle_cancel_notification", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "msg_id", "type": null, "default": null}], "returns": null, "document