:\n  --version   Show the version and exit.\n  -h, --help  Show this message and exit.\n\nCommands:\n  append   Appends to the user PATH\n  prepend  Prepends to the user PATH\n  verify   Checks if locations are in the user PATH\n```\n\n## API\n\n```pycon\n>>> import userpath\n>>> location = r'C:\\Users\\Ofek\\Desktop\\test'\n>>>\n>>> userpath.in_current_path(location)\nFalse\n>>> userpath.in_new_path(location)\nFalse\n>>> userpath.append(location)\nTrue\n>>> userpath.in_new_path(location)\nTrue\n>>> userpath.need_shell_restart(location)\nTrue\n```\n\n## License\n\n`userpath` is distributed under the terms of the [MIT](https://spdx.org/licenses/MIT.html) license.\n"], "modules": [{"name": "userpath.utils", "documentation": [], "functions": [{"name": "userpath.utils.normpath", "asynchronous": false, "params": [{"name": "location", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "userpath.utils.location_in_path", "asynchronous": false, "params": [{"name": "location", "type": null, "default": null}, {"name": "path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "userpath.utils.in_current_path", "asynchronous": false, "params": [{"name": "location", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "userpath.utils.ensure_parent_dir_exists", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "userpath.utils.get_flat_output", "asynchronous": false, "params": [{"name": "command", "type": null, "default": null}, {"name": "sep", "type": null, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "userpath.utils.get_parent_process_name", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "userpath.utils.psutil", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name"