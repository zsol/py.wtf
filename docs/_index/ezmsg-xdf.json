n": []}, {"name": "ezmsg.xdf.source.XDFMultiIteratorUnit.construct_generator", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "ezmsg.xdf.source.XDFMultiIteratorUnit.pub_multi", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "typing.AsyncGenerator", "xref": {"fqname": "typing.AsyncGenerator", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [{"name": "ezmsg.xdf.source.XDFMultiIteratorUnit.STATE", "type": null, "documentation": []}, {"name": "ezmsg.xdf.source.XDFMultiIteratorUnit.SETTINGS", "type": null, "documentation": []}, {"name": "ezmsg.xdf.source.XDFMultiIteratorUnit.OUTPUT_SIGNAL", "type": null, "documentation": []}, {"name": "ezmsg.xdf.source.XDFMultiIteratorUnit.OUTPUT_TERM", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "ezmsg.xdf.iter", "documentation": [], "functions": [{"name": "ezmsg.xdf.iter.labels_from_strm", "asynchronous": false, "params": [{"name": "strm", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}], "variables": [], "classes": [{"name": "ezmsg.xdf.iter.XDFIterator", "bases": [], "methods": [{"name": "ezmsg.xdf.iter.XDFIterator.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "filepath", "type": {"name": "Path | str", "xref": null, "params": null}, "default": null}, {"name": "select", "type": {"name": "set[str]\n    | None", "xref": null, "params": null}, "default": "..."}, {"name": "chunk_dur", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "start_time", "type": {"name": "float | None", "xref": null, "params": null}, "default": "..."}, {"name": "stop_time", "type": {"name": "float | None", "xref": null, "params": null}, "default": "..."}, {"name": "rezero", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["An Iterator that yields chunks from an XDF.\nA typical offline analysis might load the entire file into memory, then perform a processing step on the entire\nrecording duration, and the next step on the entire result of the first step, and so on. This might require a\ntremendous amount of memory and, if one is not careful about memory layout, can be incredibly slow. An\nalternative procedure is to load the file into memory a chunk at a time (see Note1), then pass that chunk\nthrough the entire processing pipeline, then proceed onto the next chunk (See Note2). We create an Iterator to\nprovide our chunks.\n> Note1: I have not written a true lazy-loader for XDF because it has not yet been necessary as the files are\n  all small. Thus, I use pyxdf.load_xdf which loads the entire raw data into memory. The processing is still\n  done chunk-by-chunk.\n> Note2: It should be possible to start on chunk[ix+1] while chunk[ix] is still going through the pipeline.\n  Indeed, this is (optionally) how it works online. However, the overhead of setting this up for offline\n  analysis is not worth the gain, at least not at this stage.\n\nArgs:\n    filepath: The path to the file to load and iterate over.\n    select: (Optional) A set of stream names to select. If None, then all streams are selected.\n    chunk_dur: The duration of each chunk in seconds.\n    start_time: Start playback at this time. If rezero is True then this is relative to the file start time.\n        If rezero is False then this is relative to the original timestamps.\n    stop_time: Truncate the playback to stop at this time. If rezero is True then this is relative to the file\n        start time. If rezero is False then this is relative to the original timestamps.\n    rezero: The absolute value of timestamps in an XDF file are useful for synchronization WITHIN file, but they\n        are absolutely meaningless outside the exact XDF file like in an ezmsg application. Thus, by default we\n        rezero the timestamps to start at t=0.0 for simplicity. However, there may be rare circumstances where\n        one wants to compare the timestamps produced by ezmsg to timestamps produced by another XDF analysis\n        tool that does not rezero. In that case, set rezero=False."]}, {"name": "ezmsg.xdf.iter.XDFIterator._scan_file", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "ezmsg.xdf.iter.XDFIterator.stream_meta", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "list[dict] | dict", "xref": null, "params": null}, "documentation": []}, {"name": "ezmsg.xdf.iter.XDFIterator.n_chunks", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "ezmsg.xdf.iter.XDFIterator.__iter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "ezmsg.xdf.iter.XDFIterator.__next__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "npt.NDArray", "xref": {"fqname": "numpy.typing.NDArray", "project": "numpy"}, "params": null}, {"name": "npt.NDArray", "xref": {"fqname": "numpy.typing.NDArray", "project": "numpy"}, "params": null}]}]}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "ezmsg.xdf.iter.XDFAxisArrayIterator", "bases": ["XDFIterator"], "methods": [{"name": "ezmsg.xdf.iter.XDFAxisArrayIterator.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "select", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["This Iterator loads only a single stream and yields a single {obj}`AxisArray` object per chunk.\n\nArgs:\n\n: args:\n  select: Unlike {obj}`XDFIterator`, this must be a single string, the name of the stream to select.\n  kwargs:\n"]}, {"name": "ezmsg.xdf.iter.XDFAxisArrayIterator.__next__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "AxisArray", "xref": {"fqname": "ezmsg.util.messages.axisarray.AxisArray", "project": "ezmsg"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "ezmsg.xdf.iter.XDFMultiAxArrIterator", "bases": ["XDFIterator"], "methods": [{"name": "ezmsg.xdf.iter.XDFMultiAxArrIterator.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "force_single_sample", "type": {"name": "set", "xref": {"fqname": "functions.set", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["This Iterator loads multiple streams and yields a {obj}`AxisArray` object per iteration,\nbut the stream source might different between chunks.\n\nArgs:\n\n: args:\n  force_single_sample: Use this to identify irregular-rate streams that might conceivably have more than one\n\n  > event within the defined chunk_dur, for which {obj}`AxisArray` cannot represent timestamps properly.\n\n  kwargs:\n"]}, {"name": "ezmsg.xdf.iter.XDFMultiAxArrIterator.__next__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "AxisArray | None", "xref": null, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}