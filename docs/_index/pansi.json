nsi.codes.EOT", "type": null, "documentation": ["^D |    | end of transmission       | TC\u2084  | EOF, end of transmission"]}, {"name": "pansi.codes.ENQ", "type": null, "documentation": ["^E |    | enquiry                   | TC\u2085  |"]}, {"name": "pansi.codes.ACK", "type": null, "documentation": ["^F |    | acknowledge               | TC\u2086  |"]}, {"name": "pansi.codes.BEL", "type": null, "documentation": ["^G | \\a | bell                      |      | audio signal"]}, {"name": "pansi.codes.BS", "type": null, "documentation": ["^H | \\b | backspace                 | FE\u2080  | move cursor left 1 cell"]}, {"name": "pansi.codes.HT", "type": null, "documentation": ["^I | \\t | horizontal tab            | FE\u2081  | move cursor right to next multiple of 8"]}, {"name": "pansi.codes.LF", "type": null, "documentation": ["^J | \\n | line feed                 | FE\u2082  | newline"]}, {"name": "pansi.codes.VT", "type": null, "documentation": ["^K | \\v | vertical tab              | FE\u2083  |"]}, {"name": "pansi.codes.FF", "type": null, "documentation": ["^L | \\f | form feed                 | FE\u2084  | clear"]}, {"name": "pansi.codes.CR", "type": null, "documentation": ["^M | \\r | carriage return           | FE\u2085  | newline"]}, {"name": "pansi.codes.SO", "type": null, "documentation": ["^N |    | shift out                 | LS\u2080  |"]}, {"name": "pansi.codes.SI", "type": null, "documentation": ["^O |    | shift in                  | LS\u2081  |"]}, {"name": "pansi.codes.DLE", "type": null, "documentation": ["^P |    | data link escape          | TC\u2087  |"]}, {"name": "pansi.codes.DC1", "type": null, "documentation": ["^Q |    | device control 1          | DC\u2081  | XON, resume transmission (e.g. buffer ready)"]}, {"name": "pansi.codes.DC2", "type": null, "documentation": ["^R |    | device control 2          | DC\u2082  |"]}, {"name": "pansi.codes.DC3", "type": null, "documentation": ["^S |    | device control 3          | DC\u2083  | XOFF, pause t