r@gmail.com>>\n\n### Maintainer\n\n```{image} https://simetri-sinergi.id/logo.png\n:alt: PT. Simetri Sinergi Indonesia\n:target: https://simetri-sinergi.id.com\n```\n\nThis module is maintained by the PT. Simetri Sinergi Indonesia.\n"], "modules": [{"name": "odoo.addons.base_public_holiday.models", "documentation": ["Copyright 2022 OpenSynergy Indonesia", "Copyright 2022 PT. Simetri Sinergi Indonesia", "License LGPL-3.0 or later (http://www.gnu.org/licenses/lgpl)."], "functions": [], "variables": [], "classes": [], "exports": [{"name": "odoo.addons.base_public_holiday.models.base_public_holiday", "xref": {"fqname": "odoo.addons.base_public_holiday.models..base_public_holiday", "project": null}}, {"name": "odoo.addons.base_public_holiday.models.base_public_holiday_line", "xref": {"fqname": "odoo.addons.base_public_holiday.models..base_public_holiday_line", "project": null}}]}, {"name": "odoo.addons.base_public_holiday.models.base_public_holiday_line", "documentation": ["Copyright 2022 OpenSynergy Indonesia", "Copyright 2022 PT. Simetri Sinergi Indonesia", "License LGPL-3.0 or later (http://www.gnu.org/licenses/lgpl)."], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.base_public_holiday.models.base_public_holiday_line.BasePublicHolidayLine", "bases": ["models.Model"], "methods": [{"name": "odoo.addons.base_public_holiday.models.base_public_holiday_line.BasePublicHolidayLine._check_date_header", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.base_public_holiday.models.base_public_holiday_line.BasePublicHolidayLine._check_date_line_no_state", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.base_public_holiday.models.base_public_holiday_line.BasePublicHolidayLine._check_date_line_with_state", "asynchronous": false, "params": [{"name": "self", "type": null, "d