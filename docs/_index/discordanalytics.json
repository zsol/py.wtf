YOUR_API_TOKEN\")\nanalytics.track_events()\n\nclient.run('TOKEN')\n```\n"], "modules": [{"name": "discordanalytics", "documentation": [], "functions": [], "variables": [{"name": "discordanalytics.__title__", "type": null, "documentation": []}, {"name": "discordanalytics.__author__", "type": null, "documentation": []}, {"name": "discordanalytics.__license__", "type": null, "documentation": []}, {"name": "discordanalytics.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "discordanalytics.client", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "discordanalytics.client.ApiEndpoints", "bases": [], "methods": [], "class_variables": [{"name": "discordanalytics.client.ApiEndpoints.BASE_URL", "type": null, "documentation": []}, {"name": "discordanalytics.client.ApiEndpoints.BOT_URL", "type": null, "documentation": []}, {"name": "discordanalytics.client.ApiEndpoints.STATS_URL", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "discordanalytics.client.ErrorCodes", "bases": [], "methods": [], "class_variables": [{"name": "discordanalytics.client.ErrorCodes.INVALID_CLIENT_TYPE", "type": null, "documentation": []}, {"name": "discordanalytics.client.ErrorCodes.CLIENT_NOT_READY", "type": null, "documentation": []}, {"name": "discordanalytics.client.ErrorCodes.INVALID_RESPONSE", "type": null, "documentation": []}, {"name": "discordanalytics.client.ErrorCodes.INVALID_API_TOKEN", "type": null, "documentation": []}, {"name": "discordanalytics.client.ErrorCodes.DATA_NOT_SENT", "type": null, "documentation": []}, {"name": "discordanalytics.client.ErrorCodes.SUSPENDED_BOT", "type": null, "documentation": []}, {"name": "discordanalytics.client.ErrorCodes.INVALID_EVENTS_COUNT", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "discordanalytics.client.DiscordAnalytics", "bases": [], "methods