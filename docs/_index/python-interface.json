nctions": [{"name": "interface.typecheck.compatible", "asynchronous": false, "params": [{"name": "impl_sig", "type": null, "default": null}, {"name": "iface_sig", "type": null, "default": null}], "returns": null, "documentation": ["Check whether `impl_sig` is compatible with `iface_sig`.\n\n# Parameters\n\nimpl_sig\n\n: The signature of the implementation function.\n\niface_sig\n\n: The signature of the interface function.\n\nIn general, an implementation is compatible with an interface if any valid\nway of passing parameters to the interface method is also valid for the\nimplementation.\n\nConsequently, the following differences are allowed between the signature\nof an implementation method and the signature of its interface definition:\n\n1. An implementation may add new arguments to an interface iff:\n   a. All new arguments have default values.\n   b. All new arguments accepted positionally (i.e. all non-keyword-only\n\n   > arguments) occur after any arguments declared by the interface.\n\n   3. Keyword-only arguments may be reordered by the implementation.\n\n2. For type-annotated interfaces, type annotations my differ as follows:\n   a. Arguments to implementations of an interface may be annotated with\n\n   > a **superclass** of the type specified by the interface.\n\n   2. The return type of an implementation may be annotated with a\n      **subclass** of the type specified by the interface.\n"]}, {"name": "interface.typecheck.is_positional", "asynchronous": false, "params": [{"name": "arg", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "interface.typecheck.has_default", "asynchronous": false, "params": [{"name": "arg", "type": null, "default": null}], "returns": null, "documentation": ["Does `arg` provide a default?\n"]}, {"name": "interface.typecheck.params_compatible", "asynchronous": false, "params": [{"name": "impl", "type": null, "default": null}, {"name": "iface", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "interface.typecheck.positionals_compatible", "asynchronous": false, "params": [{"name": "impl_positionals", "type": null, "default": null}, {"name": "iface_positionals", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "interface.typecheck.keywords_compatible", "asynchronous": false, "params": [{"name": "impl_keywords", "type": null, "default": null}, {"name": "iface_keywords", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "interface.typecheck.annotations_compatible", "asynchronous": false, "params": [{"name": "impl", "type": null, "default": null}, {"name": "iface", "type": null, "default": null}], "returns": null, "documentation": ["Check whether the type annotations of an implementation are compatible with\nthe annotations of the interface it implements."]}], "variables": [{"name": "interface.typecheck._POSITIONALS", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "interface.tests.test_interface", "documentation": [], "functions": [{"name": "interface.tests.test_interface.test_valid_implementation", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "interface.tests.test_interface.test_implement_multiple_interfaces_correctly", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "interface.tests.test_interface.generative_fixture", "asynchronous": false, "params": [{"name": "g", "type": null, "default": null}], "returns": null, "documentation": ["Decorator for turning a generator into a \"parameterized\" fixture that emits\nthe generated values."]}, {"name": "interface.tests.test_interface.combine_interfaces", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "interface.tests.test_interface.test_require_implement_all_interfaces", "asynchronous": false, "params": [{"name": "combine_interfaces", "type": null, "default": null}], "returns": null