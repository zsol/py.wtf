e__<field_name>`"]}, {"name": "salinic.schema.Schema.needs_transform", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "field_name", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "salinic.schema.Schema.model_config", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "salinic.schema.SearchResultItem", "bases": ["BaseModel"], "methods": [], "class_variables": [{"name": "salinic.schema.SearchResultItem.id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "salinic.schema.SearchResultItem.title", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "salinic.schema.SearchResultItem.lang", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "salinic.schema.SearchResultItem.tags", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "salinic.schema.DocumentPage", "bases": ["SearchResultItem"], "methods": [{"name": "salinic.schema.DocumentPage.__hash__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "salinic.schema.DocumentPage.page_number", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "salinic.schema.DocumentPage.document_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name"