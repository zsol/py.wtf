tion.\n  month: The month part of the cron definition.\n  day_of_week: The day of week part of the cron definition.\n  name: Name of the task, defaults to the function name.\n"]}, {"name": "quart_tasks.extension.QuartTasks.add_cron_task", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "task", "type": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}, "default": null}, {"name": "cron_expression", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "seconds", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "minutes", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "hours", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "day_of_month", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "month", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "day_of_week", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "name", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Add a cron task.\n\nIf the task is a synchronous function, the function will be\nwrapped in {func}`~quart.utils.run_sync` and run in a thread\nexecutor (with the wrapped function returned).\n\nThe cron definition can either be given in the cron format, or\nas individual arguments. See for example\n<https://crontab.guru/>. An example usage,\n\n```python\nasync def infrequent_task():\n    ...\n\ntasks.add_cron_task(infrequent_task, \"*/5 * * * *)\n```\n\nArguments:\n\n: cron_expression: The cron defintion.\n  task: The callable to execute as the task.\n  seconds: The seconds part of the cron definition.\n  minutes: The minutes part of the cron definition.\n  hours: The hours part of the cron definition.\n  day_of_month: The day of month part of the cron definition.\n  month: The month part of the cron definition.\n  day_of_week: The day of week part of the cron definition.\n  name: Name of the task, defaults to the function name.\n"]}, {"name": "quart_tasks.extension.QuartTasks.periodic", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "period", "type": {"name": "timedelta", "xref": {"fqname": "datetime.timedelta", "project": "--std--"}, "params": null}, "default": null}, {"name": "name", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "", "xref": null, "params": [{"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "P", "xref": null, "params": null}, {"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}]}, {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "P", "xref": null, "params": null}, {"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}]}, "documentation": ["Add a periodic task.\n\nThis is designed to be used as a decorator, if used to\ndecorate a synchronous function, the function will be wrapped\nin {func}`~quart.utils.run_sync` and run in a thread executor\n(with the wrapped function returned).\n\n```python\n@tasks.periodic(timedelta(seconds=5))\nasync def frequent_task():\n    ...\n```\n\nArguments:\n\n: period: The period between task invocations.\n  name: Name of the task, defaults to the function name.\n"]}, {"name": "quart_tasks.extension.QuartTasks.add_periodic_task", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "task", "type": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}, "default": null}, {"name": "period", "type": {"name": "timedelta", "xref": {"fqname": "datetime.timedelta", "project": "--std--"}, "params": null}, "default": null}, {"name": "name", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Add a periodic task.\n\nIf the task is a synchronous function, the function will be\nwrapped in {func}`~quart.utils.run_sync` and run in a thread\nexecutor (with the wrapped function returned).\n\n```python\nasync def frequent_task():\n    ...\n\ntasks.add_periodic_task(timedelta(seconds=5), frequent_task)\n```\n\nArguments:\n\n: period: The period between task invocations.\n  task: The callable to execute as the task.\n  name: Name of the task, defaults to the function name.\n"]}, {"name": "quart_tasks.extension.QuartTasks.before_task", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "func", "type": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "", "xref": null, "params": []}, {"name": "Awaitable", "xref": {"fqname": "typing.Awaitable", "project": "--std--"}, "params": [{"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}]}]}, "default": null}], "returns": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "", "xref": null, "params": []}, {"name": "Awaitable", "xref": {"fqname": "typing.Awaitable", "project": "--std--"}, "params": [{"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}]}]}, "documentation": ["Add a before task function.\n\nThis will allow the function provided to be called once before\nany invocation of a task. This runs within the same app\ncontext as the task invocation.\n\nThis is designed to be used as a decorator, if used to\ndecorate a synchronous function, the function will be wrapped\nin {func}`~quart.utils.run_sync` and run in a thread executor\n(with the wrapped function returned). An example usage,\n\n```python\n@app.before_task\nasync def func():\n    ...\n```\n\nArguments:\n\n: func: The function itself.\n"]}, {"name": "quart_tasks.extension.QuartTasks.after_task", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "func", "type": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "", "xref": null, "params": []}, {"name": "Awaitabl