n": ["Limit float precision "]}, {"name": "djgeojson.views.GeoJSONResponseMixin.precision", "type": null, "documentation": ["Simplify geometries "]}, {"name": "djgeojson.views.GeoJSONResponseMixin.simplify", "type": null, "documentation": ["Change projection of geometries "]}, {"name": "djgeojson.views.GeoJSONResponseMixin.srid", "type": null, "documentation": ["Geometry field to serialize "]}, {"name": "djgeojson.views.GeoJSONResponseMixin.geometry_field", "type": null, "documentation": ["Force 2D "]}, {"name": "djgeojson.views.GeoJSONResponseMixin.force2d", "type": null, "documentation": ["bbox "]}, {"name": "djgeojson.views.GeoJSONResponseMixin.bbox", "type": null, "documentation": ["bbox auto "]}, {"name": "djgeojson.views.GeoJSONResponseMixin.bbox_auto", "type": null, "documentation": []}, {"name": "djgeojson.views.GeoJSONResponseMixin.use_natural_keys", "type": null, "documentation": []}, {"name": "djgeojson.views.GeoJSONResponseMixin.with_modelname", "type": null, "documentation": []}, {"name": "djgeojson.views.GeoJSONResponseMixin.crs_type", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["A mixin that can be used to render a GeoJSON response."]}, {"name": "djgeojson.views.GeoJSONLayerView", "bases": ["GeoJSONResponseMixin", "ListView"], "methods": [{"name": "djgeojson.views.GeoJSONLayerView.dispatch", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["A generic view to serve a model as a layer."]}, {"name": "djgeojson.views.TiledGeoJSONLayerView", "bases": ["GeoJSONLayerView"], "methods": [{"name": "djgeojson.views.TiledGeoJSONLayerView.tile_coord", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "xtile", "type": null, "default": null}, {"name": "ytile", "type": null, "default": null}, {"name": "zoom", "type": null, "default": null}], "returns": null, "documentation": ["This returns the NW-corner of the square. Use the function\nwith xtile+1 and/or ytile+1 to get the other corners.\nWith xtile+0.5 & ytile+0.5 it will return the center of the tile.\nhttp://wiki.openstreetmap.org/wiki/Slippy_map_tilenames#Tile_numbers_to_lon..2Flat._2"]}, {"name": "djgeojson.views.TiledGeoJSONLayerView._parse_args", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "djgeojson.views.TiledGeoJSONLayerView.get_queryset", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Inspired by Glen Roberton's django-geojson-tiles view"]}], "class_variables": [{"name": "djgeojson.views.TiledGeoJSONLayerView.width", "type": null, "documentation": []}, {"name": "djgeojson.views.TiledGeoJSONLayerView.height", "type": null, "documentation": []}, {"name": "djgeojson.views.TiledGeoJSONLayerView.tile_srid", "type": null, "documentation": []}, {"name": "djgeojson.views.TiledGeoJSONLayerView.trim_to_boundary", "type": null, "documentation": ["Simplify geometries by zoom level (dict <int:float>)"]}, {"name": "djgeojson.views.TiledGeoJSONLayerView.simplifications", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "djgeojson.serializers", "documentation": ["This code mainly comes from @glenrobertson's django-geoson-tiles at:\nhttps://github.com/glenrobertson/django-geojson-tiles/\n\nItself, adapted from @jeffkistler's geojson serializer at: https://gist.github.com/967274"], "functions": [{"name": "djgeojson.serializers.hasattr_lazy", "asynchronous": false, "params": [{"name": "obj", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": nul