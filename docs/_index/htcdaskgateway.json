options.worker_cores  # doctest: +SKIP\n2\n```\n\nAccessing invalid options error appropriately:\n\n```pycon\n>>> options.not_a_valid_option = 'myvalue'  # doctest: +SKIP\nTraceback (most recent call last):\n    ...\nAttributeError: No option 'not_a_valid_option' available\n```\n\nErrors are also raised if values being set are invalid (e.g. wrong type,\nout-of-bounds, etc...).\n"]}, {"name": "htcdaskgateway.options.Field", "bases": [], "methods": [{"name": "htcdaskgateway.options.Field.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "field", "type": null, "default": null}, {"name": "default", "type": null, "default": null}, {"name": "label", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "htcdaskgateway.options.Field._from_spec", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "spec", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "htcdaskgateway.options.Field.validate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "htcdaskgateway.options.Field.set", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "htcdaskgateway.options.Field.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "htcdaskgateway.options.Field.widget", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "htcdaskgateway.options.Field._field_types", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["A single option field"]}, {"name": "htcdaskga