ts."], "functions": [], "variables": [], "classes": [{"name": "comfyui_types.inputs.builtin.ModelInput", "bases": ["InputBase"], "methods": [], "class_variables": [{"name": "comfyui_types.inputs.builtin.ModelInput.type_name", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["ComfyUI Model input."]}, {"name": "comfyui_types.inputs.builtin.VAEInput", "bases": ["InputBase"], "methods": [], "class_variables": [{"name": "comfyui_types.inputs.builtin.VAEInput.type_name", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["ComfyUI VAE input."]}, {"name": "comfyui_types.inputs.builtin.CLIPInput", "bases": ["InputBase"], "methods": [], "class_variables": [{"name": "comfyui_types.inputs.builtin.CLIPInput.type_name", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["ComfyUI CLIP input."]}, {"name": "comfyui_types.inputs.builtin.ConditioningInput", "bases": ["InputBase"], "methods": [], "class_variables": [{"name": "comfyui_types.inputs.builtin.ConditioningInput.type_name", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["ComfyUI Conditioning input."]}, {"name": "comfyui_types.inputs.builtin.LatentInput", "bases": ["InputBase"], "methods": [], "class_variables": [{"name": "comfyui_types.inputs.builtin.LatentInput.type_name", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["ComfyUI Latent input."]}, {"name": "comfyui_types.inputs.builtin.ImageInput", "bases": ["InputBase"], "methods": [], "class_variables": [{"name": "comfyui_types.inputs.builtin.ImageInput.type_name", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["ComfyUI Image input."]}, {"name": "comfyui_types.inputs.builtin.MaskInput", "bases": ["InputBase"], "methods": [], "class_variables": [{"name": "comfyu