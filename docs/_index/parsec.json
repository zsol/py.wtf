8 -*-"], "functions": [{"name": "parsec.expected_arguments", "asynchronous": false, "params": [{"name": "callable", "type": null, "default": null}], "returns": null, "documentation": ["#########################################################################", "Text.Parsec.Error", "#########################################################################"]}, {"name": "parsec.parse", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "text", "type": null, "default": null}, {"name": "index", "type": null, "default": "..."}], "returns": null, "documentation": ["Parse a string and return the result or raise a ParseError."]}, {"name": "parsec.bind", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "fn", "type": null, "default": null}], "returns": null, "documentation": ["Bind two parsers, implements the operator of `(>=)`."]}, {"name": "parsec.compose", "asynchronous": false, "params": [{"name": "pa", "type": null, "default": null}, {"name": "pb", "type": null, "default": null}], "returns": null, "documentation": ["Compose two parsers, implements the operator of `(>>)`, or `(>)`."]}, {"name": "parsec.joint", "asynchronous": false, "params": [{"name": "*parsers", "type": null, "default": null}], "returns": null, "documentation": ["Joint two or more parsers, implements the operator of `(+)`."]}, {"name": "parsec.choice", "asynchronous": false, "params": [{"name": "pa", "type": null, "default": null}, {"name": "pb", "type": null, "default": null}], "returns": null, "documentation": ["Choice one from two parsers, implements the operator of `(|)`."]}, {"name": "parsec.try_choice", "asynchronous": false, "params": [{"name": "pa", "type": null, "default": null}, {"name": "pb", "type": null, "default": null}], "returns": null, "documentation": ["Choose one from two parsers with backtrack, implements the operator of `(^)`."]}, {"name": "parsec.try_choices", "asynchronous": false, "params": [{"name": "*choices", "type": null, "default": null}], "returns": null, "documentation": ["Choose one from the choices"]}, {"name": "parsec.try_choices_longest", "asynchronous": false, "params": [{"name": "*choices", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "parsec.skip", "asynchronous": false, "params": [{"name": "pa", "type": null, "default": null}, {"name": "pb", "type": null, "default": null}], "returns": null, "documentation": ["Ends with a specified parser, and at the end parser consumed the end flag.\nImplements the operator of `(<<)`."]}, {"name": "parsec.ends_with", "asynchronous": false, "params": [{"name": "pa", "type": null, "default": null}, {"name": "pb", "type": null, "default": null}], "returns": null, "documentation": ["Ends with a specified parser, and at the end parser hasn't consumed any input.\nImplements the operator of `(<)`."]}, {"name": "parsec.excepts", "asynchronous": false, "params": [{"name": "pa", "type": null, "default": null}, {"name": "pb", "type": null, "default": null}], "returns": null, "documentation": ["Fail `pa` though matched when the consecutive parser `pb` success for the rest text."]}, {"name": "parsec.parsecmap", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "fn", "type": null, "default": null}], "returns": null, "documentation": ["Returns a parser that transforms the produced value of parser with `fn`."]}, {"name": "parsec.parsecapp", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": ["Returns a parser that applies the produced value of this parser to the produced\nvalue of `other`.\n\nThere should be an operator `(<*>)`, but that is impossible in Python."]}, {"name": "parsec.result", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "res", "type": null, "default": null}], "returns": null, "documentation": ["Return a value according to the parameter `res` when parse successfully."]}, {"name": "parsec.mark", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}], "returns": null, "documentation": ["Mark the line and column information of the result of the parser `p`."]}, {"name": "parsec.desc", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "description", "type": null, "default": null}], "returns": null, "documentation": ["Describe a parser, when it failed, print out the description text."]}, {"name": "parsec.generate", "asynchronous": false, "params": [{"name": "fn", "type": null, "default": null}], "returns": null, "documentation": ["Parser generator. (combinator syntax).", "#########################################################################", "Parser Generator", "The most powerful way to construct a parser is to use the generate decorator.", "the `generate` creates a parser from a generator that should yield parsers.", "These parsers are applied successively and their results are sent back to the", "generator using `.send()` protocol. The generator should return the result or", "another parser, which is equivalent to applying it and returning its result.", "Note that `return` with arguments inside generator is not supported in Python 2.", "Instead, we can raise a `StopIteration` to return the result in Python 2.", "See #15 and `test_generate_raise` in tests/test_parsec.py", "#########################################################################"]}, {"name": "parsec.times", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "mint", "type": null, "default": null}, {"name": "maxt", "type": null, "default": "..."}], "returns": null, "documentation": ["Repeat a parser between `mint` and `maxt` times. DO AS MUCH MATCH AS IT CAN.\nReturn a list of values.", "#########################################################################", "Text.Parsec.Combinator", "#########################################################################"]}, {"name": "parsec.count", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "n", "type": null, "default": null}], "returns": null, "documentation": ["`count p n` parses n occurrences of p. If n is smaller or equal to zero,\nthe parser equals to return []. Returns a list of n values returned by p."]}, {"name": "parsec.optional", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "default_value", "type": null, "default": "..."}], "returns": null, "documentation": ["`Make a parser as optional. If success, return the result, otherwise return\ndefault_value silently, without raising any exception. If default_value is not\nprovided None is returned instead."]}, {"name": "parsec.many", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}], "returns": null, "documentation": ["Repeat a parser 0 to infinity times. DO AS MUCH MATCH AS IT CAN.\nReturn a list of values."]}, {"name": "parsec.many1", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}], "returns": null, "documentation": ["Repeat a parser 1 to infinity times. DO AS MUCH MATCH AS IT CAN.\nReturn a list of values."]}, {"name": "parsec.separated", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "sep", "type": null, "default": null}, {"name": "mint", "type": null, "default": null}, {"name": "maxt", "type": null, "default": "..."}, {"name": "end", "type": null, "default": "..."}], "returns": null, "documentation": ["Repeat a parser `p` separated by `s` between `mint` and `maxt` times.\n\n- When `end` is None, a trailing separator is optional.\n- When `end` is True, a trailing separator is required.\n- When `end` is False, a trailing separator will not be parsed.\n\nMATCHES AS MUCH AS POSSIBLE.\n\nReturn list of values returned by `p`."]}, {"name": "parsec.sepBy", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "sep", "type": null, "default": null}], "returns": null, "documentation": ["`sepBy(p, sep)` parses zero or more occurrences of p, separated by `sep`.\nReturns a list of values returned by `p`."]}, {"name": "parsec.sepBy1", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "sep", "type": null, "default": null}], "returns": null, "documentation": ["`sepBy1(p, sep)` parses one or more occurrences of `p`, separated by\n`sep`. Returns a list of values returned by `p`."]}, {"name": "parsec.endBy", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "sep", "type": null, "default": null}], "returns": null, "documentation": ["`endBy(p, sep)` parses zero or more occurrences of `p`, separated and\nended by `sep`. Returns a list of values returned by `p`."]}, {"name": "parsec.endBy1", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "sep", "type": null, "default": null}], "returns": null, "documentation": ["`endBy1(p, sep) parses one or more occurrences of `p`, separated and\nended by `sep`. Returns a list of values returned by `p`."]}, {"name": "parsec.sepEndBy", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "sep", "type": null, "default": null}], "returns": null, "documentation": ["`sepEndBy(p, sep)` parses zero or more occurrences of `p`, separated and\noptionally ended by `sep`. Returns a list of\nvalues returned by `p`."]}, {"name": "parsec.sepEndBy1", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "sep", "type": null, "default": null}], "returns": null, "documentation": ["`sepEndBy1(p, sep)` parses one or more occurrences of `p`, separated and\noptionally ended by `sep`. Returns a list of values returned by `p`."]}, {"name": "parsec.satisfy", "asynchronous": false, "params": [{"name": "predicate", "type": null, "default": null}, {"name": "failure", "type": null, "default": "..."}], "returns": null, "documentation": ["#########################################################################", "Text.Parsec.Char", "#########################################################################"]}, {"name": "parsec.any", "asynchronous": false, "params": [], "returns": null, "documentation": ["Parses a arbitrary character."]}, {"name": "parsec.one_of", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": ["Parses a char from specified string."]}, {"name": "parsec.none_of", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": ["Parses a char NOT from specified string."]}, {"name": "parsec.space", "asynchronous": false, "params": [], "returns": null, "documentation": ["Parses a whitespace character."]}, {"name": "parsec.spaces", "asynchronous": false, "params": [], "returns": null, "documentation": ["Parses zero or more whitespace characters."]}, {"name": "parsec.letter", "asynchronous": false, "params": [], "returns": null, "documentation": ["Parse a letter in alphabet."]}, {"name": "parsec.digit", "asynchronous": false, "params": [], "returns": null, "documentation": ["Parse a digit."]}, {"name": "parsec.eof", "asynchronous": false, "params": [], "returns": null, "documentation": ["Parses EOF flag of a string."]}, {"name": "parsec.string", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": ["Parses a string."]}, {"name": "parsec.regex", "asynchronous": false, "params": [{"name": "exp", "type": null, "default": null}, {"name": "flags", "type": null, "default": "..."}], "returns": null, "documentation": ["Parses according to a regular expression."]}, {"name": "parsec.newline", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "parsec.crlf", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "parsec.end_of_line", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "parsec.success_with", "asynchronous": false, "params": [{"name": "value", "type": null, "default": null}, {"name": "advance", "type": null, "default": "..."}], "returns": null, "documentation": ["#########################################################################", "Useful utility parsers", "#########################################################################"]}, {"name": "parsec.fail_with", "asynchronous": false, "params": [{"name": "message", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "parsec.exclude", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}, {"name": "exclude", "type": null, "default": null}], "returns": null, "documentation": ["Fails parser p if parser `exclude` matches"]}, {"name": "parsec.lookahead", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}], "returns": null, "documentation": ["Parses without consuming"]}, {"name": "parsec.unit", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}], "returns": null, "documentation": ["Converts a parser into a single unit. Only consumes input if the parser succeeds"]}, {"name": "parsec.between", "asynchronous": false, "params": [{"name": "open", "type": null, "default": null}, {"name": "close", "type": null, "default": null}, {"name": "parser", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "parsec.fix", "asynchronous": false, "params": [{"name": "fn", "type": null, "default": null}], "returns": null, "documentation": ["Allow recursive parser using the Y combinator trick.\n\nNote that this version still yields the stack overflow problem, and will be fixed\nin later version.\n\nSee also: https://github.com/sighingnow/parsec.py/issues/39."]}, {"name": "parsec.validat