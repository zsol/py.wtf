  self._ubl_add_supplier_party(partner, False, ...)\n2) if it is our company, call the method that way:\n    self._ubl_add_supplier_party(False, company, ...)"]}, {"name": "odoo.addons.base_ubl.models.ubl.BaseUbl._ubl_add_delivery", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "delivery_partner", "type": null, "default": null}, {"name": "parent_node", "type": null, "default": null}, {"name": "ns", "type": null, "default": null}, {"name": "version", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "odoo.addons.base_ubl.models.ubl.BaseUbl._ubl_add_delivery_terms", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "incoterm", "type": null, "default": null}, {"name": "parent_node", "type": null, "default": null}, {"name": "ns", "type": null, "default": null}, {"name": "version", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "odoo.addons.base_ubl.models.ubl.BaseUbl._ubl_add_payment_terms", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "payment_term", "type": null, "default": null}, {"name": "parent_node", "type": null, "default": null}, {"name": "ns", "type": null, "default": null}, {"name": "version", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "odoo.addons.base_ubl.models.ubl.BaseUbl._ubl_add_line_item", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "line_number", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "product", "type": null, "default": null}, {"name": "type_", "type": null, "default": null}, {"name": "quantity", "type": null, "default": null}, {"name": "uom", "type": null, "default": null}, {"name": "parent_node", "type": null, "default": null}, {"name": "ns", "type": null, "default": null}, {"name": "seller", "type": null, "default":