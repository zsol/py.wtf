: null, "default": null}], "returns": null, "documentation": ["Return homogeneous rotation matrix from quaternion.\n\n```pycon\n>>> M = quaternion_matrix([1, 0, 0, 0])\n>>> numpy.allclose(M, numpy.identity(4))\nTrue\n>>> M = quaternion_matrix([0, 1, 0, 0])\n>>> numpy.allclose(M, numpy.diag([1, -1, -1, 1]))\nTrue\n```\n", "Downloaded on 6 August, 2013 from", "http://www.lfd.uci.edu/~gohlke/code/transformations.py", "Author: Christoph Gohlke", "License: BSD"]}, {"name": "pymvg.quaternions.quaternion_from_matrix", "asynchronous": false, "params": [{"name": "matrix", "type": null, "default": null}, {"name": "isprecise", "type": null, "default": "..."}], "returns": null, "documentation": ["Return quaternion from rotation matrix.\n\nIf isprecise is True, the input matrix is assumed to be a precise rotation\nmatrix and a faster algorithm is used.\n\n```pycon\n>>> q = quaternion_from_matrix(numpy.identity(4), True)\n>>> numpy.allclose(q, [1, 0, 0, 0])\nTrue\n>>> q = quaternion_from_matrix(numpy.diag([1, -1, -1, 1]))\n>>> numpy.allclose(q, [0, 1, 0, 0]) or numpy.allclose(q, [0, -1, 0, 0])\nTrue\n>>> R = [[-0.545, 0.797, 0.260, 0], [0.733, 0.603, -0.313, 0],\n...      [-0.407, 0.021, -0.913, 0], [0, 0, 0, 1]]\n>>> q = quaternion_from_matrix(R)\n>>> numpy.allclose(q, [0.19069, 0.43736, 0.87485, -0.083611])\nTrue\n>>> R = [[0.395, 0.362, 0.843, 0], [-0.626, 0.796, -0.056, 0],\n...      [-0.677, -0.498, 0.529, 0], [0, 0, 0, 1]]\n>>> q = quaternion_from_matrix(R)\n>>> numpy.allclose(q, [0.82336615, -0.13610694, 0.46344705, -0.29792603])\nTrue\n```\n"]}], "variables": [{"name": "pymvg.quaternions._EPS", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "pymvg.util", "documentation": ["!/usr/bin/env python"], "functions": [{"name": "pymvg.util.is_string", "asynchronous": false, "params": [{"name": "value", "type": null, "default": null}], "returns": null, "documentation": ["helper functions ---------------"]}, {"name": "pymvg.util.point_msg_to_tuple", "as