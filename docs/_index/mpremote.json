al script\n    mpremote fs <command> <args...>  -- execute filesystem commands on the device\n    mpremote repl                    -- enter REPL"], "functions": [{"name": "mpremote.main.do_sleep", "asynchronous": false, "params": [{"name": "state", "type": null, "default": null}, {"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mpremote.main.do_help", "asynchronous": false, "params": [{"name": "state", "type": null, "default": null}, {"name": "_args", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "mpremote.main.do_version", "asynchronous": false, "params": [{"name": "state", "type": null, "default": null}, {"name": "_args", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "mpremote.main._bool_flag", "asynchronous": false, "params": [{"name": "cmd_parser", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "short_name", "type": null, "default": null}, {"name": "default", "type": null, "default": null}, {"name": "description", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mpremote.main.argparse_connect", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "mpremote.main.argparse_sleep", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "mpremote.main.argparse_edit", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "mpremote.main.argparse_mount", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "mpremote.main.argparse_repl", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "mpremote.main.argparse_eval", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "mpremote.main.argparse_exec", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "mpre