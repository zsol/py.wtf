cumentation": ["Controller loop\nThe controller is run as a deployment and repeatedly polls the logging backend\nfor GPU related error logs. When a GPU, CUDA, NCCL error is detected,\nwe check against a set of known patterns(regexes) to see if the error is\nirrecoverable making the node unfit for more work. We can then label/taint\nthe node to prevent more pods from being scheduled onto the node.\n\nSometimes an NCCL error can be raised due to all-reduce style workloads causing\nall workers to fail even though only one is actually faulty. To place workers,\nback into the working pool, we run a health check which just consists of doing NCCL\ntest on the tainted nodes"], "functions": [{"name": "konduktor.controller.launch.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "konduktor.controller.launch.KONDUKTOR_CONTROLLER_LOG_POLL_SECONDS", "type": null, "documentation": []}, {"name": "konduktor.controller.launch.KONDUKTOR_CONTROLLER_HEALTH_CHECK_FREQ", "type": null, "documentation": []}, {"name": "konduktor.controller.launch.logger", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "konduktor.controller.node", "documentation": [], "functions": [{"name": "konduktor.controller.node.nccl_single_test", "asynchronous": false, "params": [{"name": "node", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "thresh", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Runs NCCL test within a node. Tests NVLINK BW\n\nArgs:\n    node (str): k8s node name\n    thresh (int, optional): minimum busbw to be considered healthy\n    H100SXM should report 450GB/s max theoretically. Default 400"]}, {"name": "konduktor.controller.node.nccl_pair_test", "asynchronous": false, "params": [{"name": "nodeA", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "nodeB", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "thresh", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Runs NCCL test between a pair of nodes. Tests\ninternode bandwidth\n\nArgs:\n    nodeA (str): k8s node name\n    nodeB (str): k8s node name\n    thresh (int, optional): minimum busbw to be considered healthy\n    ConnectX-7 cards have a theoretical max BW of 400GB/s\n    Defaults to 350GB/s."]}, {"name": "konduktor.controller.node.health_check", "asynchronous": false, "params": [], "returns": null, "documentation": ["Gathers nodes with label/taint `trainy.konduktor.ai/faulty=true:NoSchedule`\nand attempts to run NCCL test on them. Nodes that pass\nhave their label/taint removed."]}, {"name": "konduktor.controller.node.untaint", "asynchronous": false, "params": [{"name": "node_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Removes label/taint of `trainy.konduktor.ai/faulty=true:NoSchedule`\n\nArgs:\n    node (str): k8s node name"]}, {"name": "konduktor.controller.node.taint", "asynchronous": false, "params": [{"name": "node_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Labels/Taints node with `trainy.konduktor.ai/faulty=true:NoSchedule`\n\nArgs:\n    node (str): k8s node name"]}, {"name": "konduktor.controller.node.list_nodes", "asynchronous": false, "params": [], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["returns a list of k8s node names\n\nReturns:\n    List[str]: List of k8s node names"]}], "variables": [{"name": "konduktor.controller.node.NODE_HEALTH_LABEL", "type": null, "documentation": []}, {"name": "konduktor.controller.node.logger", "type": null, "documentation": []}], "classes": [], "exports": []}]}