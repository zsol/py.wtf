xplode/blob/master/pwexplode.py", "#######################", "pwexplode.py - implementation of the PKWARE Data Compression Library ", "format (imploding) for byte streams", "Copyright (C) 2022 by Sven Kochmann", "This program is free software: you can redistribute it and/or modify", "it under the terms of the GNU General Public License as published by", "the  Free Software Foundation,  either version 3  of the License, or", "(at your option) any later version.", "This program  is distributed  in the hope  that it will  be  useful,", "but  WITHOUT  ANY  WARRANTY;  without even  the implied warranty  of", "MERCHANTABILITY  or  FITNESS  FOR  A  PARTICULAR  PURPOSE.  See  the", "GNU General Public License for more details.", "You  should  have  received a copy of the GNU General Public License", "along with this program. If not, see <http://www.gnu.org/licenses/>.", "Note: this program is mostly based on the description of Ben Rudiak-", "Gould in the comp.compression group:", "https://groups.google.com/forum/#!msg/comp.compression/M5P064or93o/W1ca1-ad6kgJ", "and zlib's blast.c:", "https://github.com/madler/zlib/blob/master/contrib/blast/blast.c#L150", "It should be noted that  there is  a small mistake in Ben's example. ", "He uses  00 04 82 24 25 c7 80 7f as example, which should decompress ", "to 'AIAIAIAIAIAIA'.  However,  testing  this with  my implementation ", "failed.  When  I created it  with  the official pkware ziptool  (see ", "below  for  tests),  the   sequence  turned  out   to  be   actually ", "00 04 82 24 25 8f 80 7f (notice the difference at byte 6). This will", "successfully decompress to 'AIAIAIAIAIAIA'.", "Instead of pure dictionaries, this package uses functions to provide ", "the data of  the tables necessary  to decompress streams. Advantage: ", "functions are 'read-only' and can provide error feedback. ", "Disadvantage: overhead, runtime. But it is considered to be minimal. ", "In order  to reduce  the extra time   a little bit,  all tables  are ", "'complete',  i.e.  each entry  just needs  to be extracted  but  not ", "calculated.  The difference  is minimal  and  practical non-existant ", "when accessing a function one time only;  but these functions can be ", "called hundred or thousand times per stream.", "Import stuff"], "functions": [{"name": "sfextract.pwexplode.debug_print", "asynchronous": false, "params": [{"name": "text", "type": null, "default": null}], "returns": null, "documentation": ["Quick & dirty debug printing function; prints only if debugflag is True; gets line number and everything from", "the currentframes _parent_ (f_back!)"]}, {"name": "sfextract.pwexplode.is_bitstring", "asynchronous": false, "params": [{"name": "bitstring", "type": null, "default": null}], "returns": null, "documentation": ["Checks if a string just consists of 0 and 1"]}, {"name": "sfextract.pwexplode.get_literals", "asynchronous": false, "params": [{"name": "bitstring", "type": null, "default": null}], "returns": null, "documentation": ["This gives back the literals; returns a tuple of code and error; error is -1 if nothing is found"]}, {"name": "sfextract.pwexplode.get_copylength", "asynchronous": false, "params": [{"name": "bitstring", "type": null, "default": null}], "returns": null, "documentation": ["This gives back the copy-length; returns a tuple of length and error; error is -1 if nothing is found"]}, {"name": "sfextract.pwexplode.get_copyoffset", "asynchronous": false, "params": [{"name": "bitstring", "type": null, "default": null}], "returns": null, "documentation": ["This gives back the copy-offset; returns a tuple of offset and error; error is -1 if nothing is found"]}, {"name": "sfextract.pwexplode.explode", "asynchronous": false, "params": [{"name": "compressedstring", "type": null, "default": null}], "returns": null, "documentation": ["This function takes a compressed bytestring and decompresses it; returns the uncompressed data if successful"]}, {"name": "sfextract.pwexplode.runtest", "asynchronous": false, "params": [{"name": "inputdata", "type": null, "default": null}, {"name": "expectedoutput", "type": null, "default": null}, {"name": "positivecounter", "type": null, "default": null}, {"name": "number", "type": null, "default": null}], "returns": null, "documentation": ["Only for this use we define this test function"]}], "variables": [{"name": "sfextract.pwexplode.debugflag", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "sfextract.setupfactory7", "documentation": [], "functions": [{"name": "sfextract.setupfactory7.valid_signature", "asynchronous": false, "params": [{"name": "overlay", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "sfextract.setupfactory7.get_extractor", "asynchronous": false, "params": [{"name": "pe", "type": {"name": "pefile", "xref": {"fqname": "pefile", "project": "pefile"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "sfextract.setupfactory7.SkipString", "asynchronous": false, "params": [{"name": "script_data", "type": {"name": "BytesIO", "xref": {"fqname": "io.BytesIO", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "sfextract.setupfactory7.ReadString", "asynchronous": false, "params": [{"name": "script_data", "type": {"name": "BytesIO", "xref": {"fqname": "io.BytesIO", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "sfextract.setupfactory7.ReadSpecialFile", "asynchronous": false, "params": [{"name": "overlay", "type": null, "default": null}, {"name": "output_location", "type": null, "default": null}, {"name": "filename", "type": null, "default": null}, {"name": "is_xored", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "sfextract.setupfactory7.SIGNATURE", "type": null, "documentation": []}, {"name": "sfextract.setupfactory7.FILENAME_EMBEDDED_INSTALLER", "type