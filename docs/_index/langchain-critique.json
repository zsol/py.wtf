_critique.toolkits.CritiqueToolkit", "bases": ["BaseToolkit"], "methods": [{"name": "langchain_critique.toolkits.CritiqueToolkit.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "api_key", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "base_url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "include_apis", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Initialize the toolkit."]}, {"name": "langchain_critique.toolkits.CritiqueToolkit._get_dynamic_api_tools", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "BaseTool", "xref": {"fqname": "langchain_core.tools.BaseTool", "project": "langchain-core"}, "params": null}]}, "documentation": ["Get tools for all created APIs."]}, {"name": "langchain_critique.toolkits.CritiqueToolkit.get_tools", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "BaseTool", "xref": {"fqname": "langchain_core.tools.BaseTool", "project": "langchain-core"}, "params": null}]}, "documentation": ["Get the tools in the toolkit."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Critique toolkit for agentic search and API design.\n\nSetup:\n\n: Install `langchain-critique` and set environment variable `CRITIQUE_API_KEY`.\n  Get your API key at <https://critiquebrowser.app/en/flow-api?view=keys>\n\n  ```bash\n  pip install -U langchain-critique\n  export CRITIQUE_API_KEY=\"your-api-key\"\n  ```\n\nFor detailed API documentation, visit: <https://critiquebrowser.app/en/flow-api?view=usage>\n\nKey init args:\n: api_key: Optional[str]\n\n  : Critique API key. If not provided, will look for CRITIQUE_API_KEY env var.\n\n  base_url: str\n\n  : Base URL for Critique API. Defaults to <https://api.critiquebrowser.app>\n\n  include_apis: bool\n\n  : Whether to include dynamically created APIs as tools. Defaults to True.\n\nInstantiate:\n: ```python\n  from langchain_critique import CritiqueToolkit\n\n  toolkit = CritiqueToolkit(\n      api_key=\"your-api-key\",  # Optional if env var is set\n      include_apis=True  # Include dynamic API tools\n  )\n  ```\n\nTools:\n\n: ```python\n  toolkit.get_tools()\n  ```\n\n  Returns a list containing:\n  \\- CritiqueSearchTool: For performing grounded searches with optional image input\n  \\- CritiqueAPIDesignTool: For creating and managing APIs through natural language\n  \\- Dynamic API tools: If include_apis=True, includes tools for all created APIs\n"]}], "exports": []}]}