": "..."}], "returns": null, "documentation": ["Generalized method to send a request to the server and retrieve the response.\n\n```\nparam command\n\nThe type of command (e.g., GET or GET_TABLES).\n\nparam value\n\nThe optional key for the command.\n\nparam TIMEOUT\n\nTimeout in milliseconds to wait for the response (default is 3000).\n\nreturn\n\nThe response value or None if the request times out.\n```\n"]}, {"name": "XTABLES.SocketClient.SocketClient._process_update", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parts", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "XTABLES.SocketClient.SocketClient._process_buffered_messages", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "XTABLES.SocketClient.SocketClient._message_listener", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "XTABLES.XTablesClient", "documentation": [], "functions": [{"name": "XTABLES.XTablesClient.a", "asynchronous": false, "params": [{"name": "key", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "XTABLES.XTablesClient.c", "type": null, "documentation": []}], "classes": [{"name": "XTABLES.XTablesClient.Status", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "XTABLES.XTablesClient.Status.FAIL", "type": null, "documentation": []}, {"name": "XTABLES.XTablesClient.Status.OK", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "XTABLES.XTablesClient.XTablesClient", "bases": [], "methods": [{"name": "XTABLES.XTablesClient.XTablesClient.__init__", "asynchronous": false, 