riter.dialect", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["```pycon\n>>> import unicodecsv\n>>> from cStringIO import StringIO\n>>> f = StringIO()\n>>> w = unicodecsv.writer(f, encoding='utf-8')\n>>> w.writerow((u'\u00e9', u'\u00f1'))\n>>> f.seek(0)\n>>> r = unicodecsv.reader(f, encoding='utf-8')\n>>> row = r.next()\n>>> row[0] == u'\u00e9'\nTrue\n>>> row[1] == u'\u00f1'\nTrue\n```\n"]}, {"name": "unicodecsv.py2.UnicodeReader", "bases": ["object"], "methods": [{"name": "unicodecsv.py2.UnicodeReader.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "f", "type": null, "default": null}, {"name": "dialect", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}, {"name": "errors", "type": null, "default": "..."}, {"name": "**kwds", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unicodecsv.py2.UnicodeReader.next", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unicodecsv.py2.UnicodeReader.__iter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unicodecsv.py2.UnicodeReader.dialect", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unicodecsv.py2.UnicodeReader.line_num", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "unicodecsv.py2.DictWriter", "bases": ["csv.DictWriter"], "methods": [{"name": "unicodecsv.py2.DictWriter.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "csvfile", "type": null, "default": null}, {"name": "fieldnames", "type": null, "default": null}, {"name": "restval", "type": null, "default": "..."}, {"name": "extrasaction", "type": null, "default": "..."}, {"name": "dialect", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}, {"name": "errors", "type": null, "default": "..."}, {"name": "*args", "type": null, "default": null}, {"name": "**kwds", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unicodecsv.py2.DictWriter.writeheader", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["```pycon\n>>> from cStringIO import StringIO\n>>> f = StringIO()\n>>> w = DictWriter(f, ['a', u'\u00f1', 'b'], restval=u'\u00ee')\n>>> w.writerow({'a':'1', u'\u00f1':'2'})\n>>> w.writerow({'a':'1', u'\u00f1':'2', 'b':u'\u00f8'})\n>>> w.writerow({'a':u'\u00e9', u'\u00f1':'2'})\n>>> f.seek(0)\n>>> r = DictReader(f, fieldnames=['a', u'\u00f1'], restkey='r')\n>>> r.next() == {'a': u'1', u'\u00f1':'2', 'r': [u'\u00ee']}\nTrue\n>>> r.next() == {'a': u'1', u'\u00f1':'2', 'r': [u'\u00c3\u00b8']}\nTrue\n>>> r.next() == {'a': u'\u00c3\u00a9', u'\u00f1':'2', 'r': [u'\u00c3\u00ae']}\nTrue\n```\n"]}, {"name": "unicodecsv.py2.DictReader", "bases": ["csv.DictReader"], "methods": [{"name": "unicodecsv.py2.DictReader.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "csvfile", "type": null, "default": null}, {"name": "fieldnames", "type": null, "default": "..."}, {"name": "restkey", "type": null, "default": "..."}, {"name": "restval", "type": null, "default": "..."}, {"name": "dialect", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}, {"name": "errors", "type": null, "default": "..."}, {"name": "*args", "type": null, "default": null}, {"name": "**kwds", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unicodecsv.py2.DictReader.next", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["```pycon\n>>> from cStringIO import StringIO\n>>> f = StringIO()\n>>> w = DictWriter(f, fieldnames=['name', 'place'])\n>>> w.writerow({'name': 'Cary Grant', 'place': 'hollywood'})\n>>> w.writerow({'name': 'Nathan Brillstone', 'place': u'\u00f8Land'})\n>>> w.writerow({'name': u'Will \u00f8. Unicoder', 'place': u'\u00e9Spandland'})\n>>> f.seek(0)\n>>> r = DictReader(f, fieldnames=['name', 'place'])\n>>> print r.next() == {'name': 'Cary Grant', 'place': 'hollywood'}\nTrue\n>>> print r.next() == {'name': 'Nathan Brillstone', 'place': u'\u00f8Land'}\nTrue\n>>> print r.next() == {'name': u'Will \u00f8. Unicoder', 'place': u'\u00e9Spandland'}\nTrue\n```\n"]}], "exports": []}, {"name": "unicodecsv.test", "documentation": ["-*- coding: utf-8 -*-", "Copyright (C) 2001,2002 Python Software Foundation", "csv package unit tests"], "functions": [], "variables": [{"name": "unicodecsv.test.chr", "type": null, "documentation": []}, {"name": "unicodecsv.test.py_compat_exc", "type": null, "documentation": []}], "classes": [{"name": "unicodecsv.test.Test_Csv", "bases": ["unittest.TestCase"], "methods": [{"name": "unicodecsv.test.Test_Csv._test_arg_valid", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "ctor", "type": null, "default": null}, {"name": "arg", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unicodecsv.test.Test_Csv.test_reader_arg_valid", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unicodecsv.test.Test_Csv.t