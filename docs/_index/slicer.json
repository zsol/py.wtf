l}], "returns": null, "documentation": []}, {"name": "slicer.slicer.Slicer._iter_tracked", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "include_aliases", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "slicer.slicer.Slicer._recompute_max_dim", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Provides unified slicing to tensor-like objects. "]}], "exports": []}, {"name": "slicer.slicer_internal", "documentation": ["Lower level layer for slicer.\nMom's spaghetti."], "functions": [{"name": "slicer.slicer_internal.unify_slice", "asynchronous": false, "params": [{"name": "item", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}, {"name": "max_dim", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "alias_lookup", "type": null, "default": "..."}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "documentation": ["Resolves aliases and ellipses in a slice item.\n\nArgs:\n    item: Slicing key that is passed to __getitem__.\n    max_dim: Max dimension of object to be sliced.\n    alias_lookup: AliasLookup structure.\n\nReturns:\n    A tuple representation of the item."]}, {"name": "slicer.slicer_internal._normalize_subkey_types", "asynchronous": false, "params": [{"name": "index_tup", "type": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "documentation": ["Casts subkeys into basic types such as int.\n\nArgs:\n    key: Slicing key that is passed within __getitem__.\n\nReturns:\n    Tuple with subkeys casted to basic types."]}, {"name": "slicer.slicer_internal._normalize_slice_key", "asynchronous": false, "params": [{"name": "key", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "documentation": ["Normalizes slice key into always being a top-level tuple.\n\nArgs:\n    key: Slicing key that is passed within __getitem__.\n\nReturns:\n    Expanded slice as a tuple."]}, {"name": "slicer.slicer_internal._handle_newaxis_ellipses", "asynchronous": false, "params": [{"name": "index_tup", "type": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "default": null}, {"name": "max_dim", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "documentation": ["Expands newaxis and ellipses within a slice for simplification.\nThis code is mostly adapted from: https://github.com/clbarnes/h5py_like/blob/master/h5py_like/shape_utils.py#L111\n\nArgs:\n    index_tup: Slicing key as a tuple.\n    max_dim: Maximum number of dimensions in the respective sliceable object.\n\nReturns:\n    Expanded slice as a tuple."]}, {"name": "slicer.slicer_internal._handle_aliases", "asynchronous": false, "params": [{"name": "index_tup", "type": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "default": null}, {"name": "alias_lookup", "type": null, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "slicer.slicer_internal.resolve_dim", "asynchronous": false, "params": [{"name": "slicer_index", "type": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "default": null}, {"name": "slicer_dim", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": null}, "documentation": ["Extracts new dim after applying slicing index and maps it back to the original index list. "]}, {"name": "slicer.slicer_internal.reduced_o", "asynchronous": false, "params": [{"name": "tracked", "type": {"name": "Tracked", "xref": {"fqname": "slicer.slicer_internal.Tracked", "project": null}, "params": null}, "default": null}], "returns": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "slicer.slicer_internal._type_name", "asynchronous": false, "params": [{"name": "o", "type": {"name": "object", "xref": {"fqname": "functions.object", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "slicer.slicer_internal._safe_isinstance", "asynchronous": false, "params": [{"name": "o", "type": {"name": "object", "xref": {"fqname": "functions.object", "project": "--std--"}, "params": null}, "default": null}, {"name": "module_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "type_name", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "set", "xref": {"fqname": "functions.set", "project": "--std--"}, "params": null}, {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "slicer.slicer_internal._handle_module_aliases", "asynchronous": false, "params": [{"name": "module_name", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "slicer.slicer_internal.AtomicSlicer", "bases": [], "methods": [{"name": "slicer.slicer_internal.AtomicSlicer.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "o", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}, {"name": "max_dim", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, {"name": "AnyStr", "xref": {"fqname": "typing.AnyStr", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": null, "documentation": ["Provides a consistent slicing API to the object provided.\n\nArgs:\n    o: Object to enable consistent slicing.\n        Currently supports numpy dense arrays, recursive lists ending with list or numpy.\n    max_dim: Max number of dimensions the wrapped object has.\n        If set to \"auto\", max dimensions will be inferred. This comes at compute cost."]}, {"name": "slicer.slicer_internal.AtomicSlicer.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "AnyStr", "xref": {"fqname": "typing.AnyStr", "project": "--std--"}, "params": null}, "documentation": ["Override default repr for human readability.\n\nReturns:\n    String to display."]}, {"name": "slicer.slicer_internal.AtomicSlicer.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "item", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": ["Consistent slicing into wrapped object.\n\nArgs:\n    item: Slicing key of type integer or slice.\n\nReturns:\n    Sliced object.\n\nRaises:\n    ValueError: If slicing is not compatible with wrapped object."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Wrapping object that will unify slicing across data structures.\n\nWhat we support:\n    Basic indexing (return references):\n    - (start:stop:step) slicing\n    - support ellipses\n    Advanced indexing (return references):\n    - integer array indexing\n\nNumpy Reference:\n    Basic indexing (return views):\n    - (start:stop:step) slicing\n    - support ellipses and newaxis (alias for None)\n    Advanced indexing (return copy):\n    - integer array indexing, i.e. X[[1,2], [3,4]]\n    - boolean array indexing\n    - mixed array indexing (has integer array, ellipses, newaxis in same slice)"]}, {"name": "slicer.slicer_internal.Tracked", "bases": ["AtomicSlicer"], "methods": [{"name": "slicer.slicer_internal.Tracked.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "o", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}, {"name": "dim", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, {"name": "List", "xref": {"fqname": "