dful use \"result\" instead.\n"]}, {"name": "swiftly_api_client.SwiftlyAPIClient.get_runtimes_for_route_by_trip", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "route_short_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "start_date", "type": {"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}, "default": null}, {"name": "end_date", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "days_of_week", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}]}, "default": "..."}, {"name": "exclude_dates", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}]}]}, "default": "..."}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Get runtimes for a route by trip.\n\n<https://dashboard.goswift.ly/nctd/api-guide/reference>\nGET /run-times/\\{agencyKey}/route/\\{routeKey}/by-trip\n\n```\nparam route_short_name\n\nThe route short name.\n\nparam start_date\n\nThe start date.\n\nparam end_date\n\nThe end date. If omitted, the end date is the start date so a single date is returned.\n\nparam days_of_week\n\nThe days of the week to return. If omitted, all days of the week are returned. Formatted\nas a list of isoweekdays, where 1 is Monday and 7 is Sunday.\n\nparam exclude_dates\n\nThe dates to exclude.\n\nreturn\n\nA dictionary of runtimes keyed by trip.\n```\n"]}, {"name": "swiftly_api_client.SwiftlyAPIClient.get_on_time_performance_export", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "start_date", "type": {"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}, "default": null}, {"name": "end_date", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "days_of_week", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}]}, "default": "..."}, {"name": "exclude_dates", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}]}]}, "default": "..."}, {"name": "use_service_dates", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "only_first_stop_of_trip", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "pd.DataFrame", "xref": {"fqname": "pandas.DataFrame", "project": "pandas"}, "p