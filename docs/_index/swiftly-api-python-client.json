": "--std--"}, "params": null}]}]}, "default": "..."}], "returns": {"name": "pd.DataFrame", "xref": {"fqname": "pandas.DataFrame", "project": "pandas"}, "params": null}, "documentation": ["Get trip observations aka what actually happened on the ground\n\n<https://dashboard.goswift.ly/nctd/api-guide/reference>\nGET /run-times/\\{agencyKey}/trip-observations\n\n```\nparam start_date\n\nThe start date.\n\nparam end_date\n\nThe end date. If omitted, the end date is the start date so a single date is returned.\n\nparam days_of_week\n\nThe days of the week to return. If omitted, all days of the week are returned. Formatted\nas a list of isoweekdays, where 1 is Monday and 7 is Sunday.\n\nparam exclude_dates\n\nThe dates to exclude.\n\nparam use_service_dates\n\nIf true, the service dates are used trips/stops which occur after mightnight will\nbe returned with a time > 24:00.\n\nreturn\n\nA pandas dataframe of the export.\n```\n"]}, {"name": "swiftly_api_client.SwiftlyAPIClient.get_arrivals_departures_observations", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "start_date", "type": {"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}, "default": null}, {"name": "end_date", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "days_of_week", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}]}, "default": "..."}, {"name": "exclude_dates", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}]}]}, "default": "..."}], "returns": {"name": "pd.DataFrame", "xref": {"fqname": "pandas.DataFrame", "project": "pandas"}, "params": null}, "documentation": ["Provides information about scheduled and observed arrivals and departures for specified route(s).\nThe returned data is an array of arrival and departure observations that include scheduled times,\nand, if available, observed timing.\n\n<https://dashboard.goswift.ly/nctd/api-guide/reference>\nGET /run-times/\\{agencyKey}/trip-observations\n\n```\nparam start_date\n\nThe start date.\n\nparam end_date\n\nThe end date. If omitted, the end date is the start date so a single date is returned.\n\nparam days_of_week\n\nThe days of the week to return. If omitted, all days of the week are returned. Formatted\nas a list of isoweekdays, where 1 is Monday and 7 is Sunday.\n\nparam exclude_dates\n\nThe dates to exclude.\n\nreturn\n\nA pandas dataframe of the export.\n```\n"]}, {"name": "swiftly_api_client.SwiftlyAPIClient.get_raw_apc_events", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "date_to_fetch", "type": {"name": "datetime.date", "xref": {"fqname": "datetime.date", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}]}, "documentation": ["Provides unprocessed APC data points (door open/close events), complemented with the inferred\nlatitude/longitude of the vehicle. Returns data for one calendar date at a time, i.e. it does not\nfollow the GTFS service-dates concept, but instead goes from midnight to midnight on the specified\ncalendar date.\n\n<https://dashboard.goswift.ly/nctd/api-guide/reference>\nGET /ridership/\\{agencyKey}/apc-raw-events\n\n```\nparam date_to_fetch\n\nThe calendar date to fetch.\n\nreturn\n\nA list of dictionaries of the raw APC events.\n```\n"]}], "class_variables": [{"name": "swiftly_api_client.SwiftlyAPIClient.PROD_BASE_URL", "type": null, "documentation": []}, {"name": "swiftly_api_client.SwiftlyAPIClient.RUN_TIMES_BY_ROUTE", "type": null, "documentation": []}, {"name": "swiftly_api_client.SwiftlyAPIClient.OTP_EXPORT", "type": null, "documentation": []}, {"name": "swiftly_api_client.SwiftlyAPIClient.TRIP_OBSERVATIONS", "type": null, "documentation": []}, {"name": "swiftly_api_client.SwiftlyAPIClient.ARRIVAL_DEPARTURE_OBSERVATIONS", "type": null, "documentation": []}, {"name": "swiftly_api_client.SwiftlyAPIClient.RAW_APC_EVENTS", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": [{"name": "swiftly_api_client.configure_requests_session", "xref": {"fqname": "swiftly_api_client.network.configure_requests_session", "project": null}}, {"name": "swiftly_api_client.Optional", "xref": {"fqname": "typing.Optional", "project": null}}, {"name": "swiftly_api_client.RetryError", "xref": {"fqname": "requests.exceptions.RetryError", "project": "requests"}}, {"name": "swiftly_api_client.Session", "xref": {"fqname": "requests.Session", "project": "requests"}}, {"name": "swiftly_api_client.Union", "xref": {"fqname": "typing.Union", "project": null}}]}]}