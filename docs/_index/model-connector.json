r.common.STRING_ENCODING", "type": null, "documentation": ["\"utf-8\""]}, {"name": "model_connector.common.DELETE_FLAG", "type": null, "documentation": []}, {"name": "model_connector.common.MIN_DELETE_LENGTH", "type": null, "documentation": []}, {"name": "model_connector.common.NULL_INT", "type": null, "documentation": []}, {"name": "model_connector.common.NULL_DOUBLE", "type": null, "documentation": []}, {"name": "model_connector.common.NULL_FLOAT", "type": null, "documentation": []}, {"name": "model_connector.common.NULL_SHORT", "type": null, "documentation": []}, {"name": "model_connector.common.NULL_TINY", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "model_connector.read_ffb", "documentation": ["This file provides a function to read TransCAD FFB tables."], "functions": [{"name": "model_connector.read_ffb.read_ffb", "asynchronous": false, "params": [{"name": "ffb_file", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "null_to_zero", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "pd.DataFrame", "xref": {"fqname": "pandas.DataFrame", "project": "pandas"}, "params": null}, "documentation": ["Read a FFB file and return a pandas DataFrame.\n\nParameters\n----------\nffb_file : str\n    The path to the FFB file to read.\nnull_to_zero : bool, optional\n    Whether to replace null values with zeros, by default False\n\nReturns\n-------\npd.DataFrame\n    A pandas DataFrame containing the data from the FFB file.\n\nThe `null_to_zero` parameter determines whether null values are replaced\nwith zeros. When `null_to_zero` is `False`, null values from TransCAD are\nconverted to `NaN`, or `NaT` for dates and times. When `null_to_zero` is\n`True`, null values in numeric columns areconverted to zeros, null values\nin string columns are left as empty strings, and null values 