cumentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Printer is where Poncho's user-visible output is defined. A Printer\ninstance receives typed messages and prints them to its output (usually\nSTDOUT) in the Poncho format."]}], "exports": []}, {"name": "plain.dev.utils", "documentation": [], "functions": [{"name": "plain.dev.utils.has_pyproject_toml", "asynchronous": false, "params": [{"name": "target_path", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "plain.dev.default_settings", "documentation": [], "functions": [], "variables": [{"name": "plain.dev.default_settings.DEV_REQUESTS_IGNORE_PATHS", "type": null, "documentation": []}, {"name": "plain.dev.default_settings.DEV_REQUESTS_MAX", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "plain.dev.debug", "documentation": [], "functions": [{"name": "plain.dev.debug.attach", "asynchronous": false, "params": [{"name": "endpoint", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "plain.dev.poncho.manager", "documentation": [], "functions": [], "variables": [{"name": "plain.dev.poncho.manager.KILL_WAIT", "type": null, "documentation": []}, {"name": "plain.dev.poncho.manager.SIGNALS", "type": null, "documentation": []}, {"name": "plain.dev.poncho.manager.SYSTEM_PRINTER_NAME", "type": null, "documentation": []}], "classes": [{"name": "plain.dev.poncho.manager.Manager", "bases": [], "methods": [{"name": "plain.dev.poncho.manager.Manager.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "printer", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "plain.dev.poncho.manager.Manager.add_process", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "cmd", "type": null, "default": null}, {"name": "quiet", "type": null, "default": "..."}, {"name": "env", "type": null, "default": "..."}, {"name": "cwd", "type": null, "default": "..."}], "returns": null, "documentation": ["Add a process to this manager instance. The process will not be started\nuntil {func}`~poncho.manager.Manager.loop` is called.\n"]}, {"name": "plain.dev.poncho.manager.Manager.loop", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Start all the added processes and multiplex their output onto the bound\nprinter (which by default will print to STDOUT).\n\nIf one process terminates, all the others will be terminated by\nPoncho, and {func}`~poncho.manager.Manager.loop` will return.\n\nThis method will block until all the processes have terminated.\n"]}, {"name": "plain.dev.poncho.manager.Manager.terminate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Terminate all processes managed by this ProcessManager."]}, {"name": "plain.dev.poncho.manager.Manager.kill", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Kill all processes managed by this ProcessManager."]}, {"name": "plain.dev.poncho.manager.Manager._killall", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "force", "type": null, "default": "..."}], "returns": null, "documentation": ["Kill all remaining processes, forcefully if requested."]}, {"name": "plain.dev.poncho.manager.Manager._start", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "plain.dev.poncho.manager.Manager._all_started", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name":