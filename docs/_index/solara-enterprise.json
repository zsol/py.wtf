 not auth.user.value:\n        solara.Info(\"Login to see your avatar (see the button in the app bar)\")\n        with solara.AppBar():\n            solara.Button(icon_name=\"mdi-login\", href=auth.get_login_url(), icon=True)\n    else:\n        with solara.AppBar(): # this shows the user's picture in the app bar\n            with auth.AvatarMenu():\n                solara.Button(\"Logout\", icon_name=\"mdi-logout\", href=auth.get_logout_url(), text=True)\n                solara.Button(\"Fake user settings\", icon_name=\"mdi-account-cog\", text=True)\n        solara.Info(\"Logout via the appbar\")\n```\n\n## Arguments\n\n * image_url: if not given, the picture from the user's profile will be used (OAuth only)\n * size: size of the avatar (in pixels)\n * color: color of the avatar (if no picture is available)\n * children: list of elements to show in the menu"]}, {"name": "solara_enterprise.auth.components.Avatar", "asynchronous": false, "params": [{"name": "image_url", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "size", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "color", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Display an avatar with the user's picture or a default icon.\n\n## Example\n\n```solara\nimport solara\nfrom solara_enterprise import auth\n\n@solara.component\ndef Page():\n    if not auth.user.value:\n        solara.Info(\"Login to see your avatar\")\n        solara.Button(\"Login\", icon_name=\"mdi-login\", href=auth.get_login_url())\n    else:\n        auth.Avatar()  # this shows the user's picture\n        solara.Button(\"Logout\", icon_name=\"mdi-logout\", href=auth.get_logout_url())\n```\n\n## Arguments\n\n * image_url: if not given, the picture from the user's profile will be used (OAuth only)\n * size: size of the avatar (in pixels)\n * color: color of the avatar (if no picture is available)"]}], "variables": [], "classes": [], "exports": []}, {"name": "solara_enterprise.auth", "documentation": [], "functions": [], "variables": [{"name": "solara_enterprise.auth.user", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "solara_enterprise.auth.Avatar", "xref": {"fqname": "solara_enterprise.auth.components.Avatar", "project": null}}, {"name": "solara_enterprise.auth.AvatarMenu", "xref": {"fqname": "solara_enterprise.auth.components.AvatarMenu", "project": null}}, {"name": "solara_enterprise.auth.get_login_url", "xref": {"fqname": "solara_enterprise.auth.utils.get_login_url", "project": null}}, {"name": "solara_enterprise.auth.get_logout_url", "xref": {"fqname": "solara_enterprise.auth.utils.get_logout_url", "project": null}}, {"name": "solara_enterprise.auth.user", "xref": {"fqname": "solara_enterprise.auth.user", "project": null}}]}, {"name": "solara_enterprise.auth.flask", "documentation": [], "functions": [{"name": "solara_enterprise.auth.flask.init_flask", "asynchronous": false, "params": [{"name": "app", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "solara_enterprise.auth.flask.init", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "solara_enterprise.auth.flask.check_oauth", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "solara_enterprise.auth.flask.authorize", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "solara_enterprise.auth.flask.logout", "asynchronous": false, "params": [], "returns"