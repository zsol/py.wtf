60e\u51b3\u7b56\u53d8\u91cf x\nmodel.y = Var(within=NonNegativeReals) # \u58f0\u660e\u51b3\u7b56\u53d8\u91cf y\nmodel.obj = Objective(expr=model.x + model.y, sense = minimize) # \u58f0\u660e\u76ee\u6807\u51fd\u6570\u4e3a x+y, minimize \u8868\u793a\u6781\u5c0f\u5316\nmodel.constrs = Constraint(expr=model.x + model.y <= 1) # \u6dfb\u52a0\u7ea6\u675f x+y <= 1\nmodel.write('model.lp') # \u8f93\u51fa\u6a21\u578b\u6587\u4ef6\nmodel.pprint() # \u6253\u5370\u6a21\u578b\u4fe1\u606f\nopt = SolverFactory('gurobi') # \u6307\u5b9aGurobi\u4e3a\u6c42\u89e3\u5668\nsolution = opt.solve(model) # \u8c03\u7528\u6c42\u89e3\u5668\u6c42\u89e3\n```\n"], "modules": [{"name": "eopt.utils", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "eopt.objective", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "eopt.objective.Objective", "bases": [], "methods": [{"name": "eopt.objective.Objective.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "rule", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "sense", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}, {"name": "eopt.objective.Objective.rule", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "eopt.objective.Objective.rule", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "eopt.objective.Objective.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}