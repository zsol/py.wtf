ions)...\n\nparam reset_handlers\n\nIn case we want to remove all handlers and create a new one\nwith the new stream...\n\nreturn\n\nThe logger.\n```\n"]}], "variables": [], "classes": [], "exports": []}, {"name": "core_mixins.managers", "documentation": ["-*- coding: utf-8 -*-"], "functions": [], "variables": [], "classes": [], "exports": [{"name": "core_mixins.managers.TasksManager", "xref": {"fqname": "core_mixins.managers.tasks_manager.TasksManager", "project": null}}]}, {"name": "core_mixins.managers.tasks_manager", "documentation": ["-*- coding: utf-8 -*-"], "functions": [{"name": "core_mixins.managers.tasks_manager.execute", "asynchronous": false, "params": [{"name": "task", "type": {"name": "ITask", "xref": {"fqname": "core_mixins.interfaces.task.ITask", "project": null}, "params": null}, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "core_mixins.managers.tasks_manager.TasksManager", "bases": [], "methods": [{"name": "core_mixins.managers.tasks_manager.TasksManager.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "tasks", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "ITask", "xref": {"fqname": "core_mixins.interfaces.task.ITask", "project": null}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "core_mixins.managers.tasks_manager.TasksManager.execute", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "task_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "parallelize", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "processes", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns