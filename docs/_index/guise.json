equent_english' or 'wordnet_lemmas'"]}, {"name": "guise.nlp.html_tokens", "asynchronous": false, "params": [{"name": "html", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "include", "type": null, "default": "..."}, {"name": "exclude", "type": null, "default": "..."}], "returns": {"name": "Words", "xref": {"fqname": "Words", "project": null}, "params": null}, "documentation": []}, {"name": "guise.nlp.term_filtered_html2text", "asynchronous": false, "params": [{"name": "html", "type": null, "default": null}, {"name": "include", "type": null, "default": "..."}, {"name": "exclude", "type": null, "default": "..."}, {"name": "sep", "type": null, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["allowed_terms = 'most_frequent_english' or 'wordnet_lemmas'"]}, {"name": "guise.nlp.stem_based_word_mapping", "asynchronous": false, "params": [{"name": "words", "type": {"name": "Words", "xref": {"fqname": "Words", "project": null}, "params": null}, "default": null}, {"name": "stemmer", "type": {"name": "StemmerSpec", "xref": {"fqname": "StemmerSpec", "project": null}, "params": null}, "default": "..."}], "returns": {"name": "WordMap", "xref": {"fqname": "WordMap", "project": null}, "params": null}, "documentation": ["Returns a dict of {word: replace_with_word, ...} mapping based on stemming.\n\nstemming is great to reduce the number of words by replacing several\n\nThe words (or word counts) are stemmed, then for each stem, the word with the\nhighest count gets to represent the others.\n\n```pycon\n>>> _words = ['happy', 'happier', 'happiest', 'happily', 'sad', 'sadly']\n>>> word_count = Counter(_words)\n>>> stem_based_word_mapping(word_count)  # doctest: +NORMALIZE_WHITESPACE\n{'happy': 'happy',\n 'happier': 'happy',\n 'happiest': 'happiest',\n 'happily': 'happy',\n 'sad': 'sad',\n 'sadly': 'sad'}\n```\n"]}, {"name": "guise.nlp.map_words_of_word_count", "asynchronous": false, "params": [{"name": "word_count", "type": {"name": "WordCount", "xref": {"fqname": "WordCount", "project": null}, "params": null}, "default": null}, {"name": "word_map", "type": {"name": "WordMap", "xref": {"fqname": "WordMap", "project": null}, "params": null}, "default": null}], "returns": {"name": "WordCount", "xref": {"fqname": "WordCount", "project": null}, "params": null}, "documentation": ["Recompute a word count based on a (complete) mapping of it's words (keys)\n\n```pycon\n>>> assert (dict(\n... map_words_of_word_count(\n...     {'one': 1, 'ones': 2, '1': 3, 'two': 4},\n...     {'one': 'one', 'ones': 'one', '1': 'one', 'two': 'two'}))\n... == {'one': 6, 'two': 4}\n... )\n```\n"]}, {"name": "guise.nlp.stem_based_word_count", "asynchronous": false, "params": [{"name": "words", "type": {"name": "Words", "xref": {"fqname": "Words", "project": null}, "params": null}, "default": null}, {"name": "stemmer", "type": {"name": "StemmerSpec", "xref": {"fqname": "StemmerSpec", "project": null}, "params": null}, "default": "..."}], "returns": {"name": "WordCount", "xref": {"fqname": "WordCount", "project": null}, "params": null}, "documentation": ["From an iterable of words, get a WordCount mapping which uses a stem-based map\n\n```pycon\n>>> words = ['happy', 'happier', 'happiest', 'happily', 'sad', 'sadly']\n>>> assert (dict(stem_based_word_count(words))\n... == {'happy': 3, 'happiest': 1, 'sad': 2})\n```\n"]}], "variables": [{"name": "guise.nlp.Word", "type": null, "documentation": []}, {"name": "guise.nlp.Words", "type": null, "documentation": []}, {"name": "guise.nlp.WordCount", "type": null, "documentation": []}, {"name": "guise.nlp.WordStats", "type": null, "documentation": []}, {"name": "guise.nlp.WordMap", "type": null, "documentation": []}, {"name": "guise.nlp.StemmerSpec", "type": null, "documentation": []}, {"name": "guise.nlp._cache", "type": null, "documentation": []}, {"name": "guise.nlp.DFLT_INCLUDE_TERMS", "type": null, "documentation": []}, {"name": "guise.nlp.DFLT_EXCLUDE_TERMS", "type": null, "documentation": []}], "classes": [{"name": "guise.nlp.TFIDFCalculator", "bases": [], "methods": [{"name": "guise.nlp.TFIDFCalculator.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "corpus_counts", "type": null, "default": null}, {"name": "idf_type", "type": null, "default": "..."}, {"name": "stop_words", "type": null, "default": "..."}, {"name": "custom_idf", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "guise.nlp.TFIDFCalculator._compute_idf", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "guise.nlp.TFIDFCalculator.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "doc_counts", "type": null, "default": null}], "returns": null, "documentation": ["Computes the TF-IDF scores for a document based on word counts.\n\nParameters\n----------\ndoc_counts : pandas.Series\n    Series with index as words and values as counts in the document.\n\nReturns\n-------\ntfidf : pandas.Series\n    TF-IDF scores for each word in the document."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["A TF-IDF calculator that computes TF-IDF scores for documents based on a corpus.\n\n# Parameters\n\ncorpus_counts\n\n: Series with index as words and values as counts in the corpus.\n\nidf_type\n\n: The type of IDF calculation to use. Options are:\n  \\- 'standard': IDF = log(N / (df))\n  \\- 'smooth': IDF = log(1 + N / (df))\n  \\- 'probabilistic': IDF = log((N - df) / df)\n  \\- 'frequency': IDF = log((total_counts_corpus + 1) / (corpus_counts + 1))\n  Default is 'frequency'.\n\nstop_words\n\n: A set or list of stop words to exclude from calculations.\n\ncustom_idf\n\n: A mapping from words to custom IDF values.\n\n# Attributes\n\n[idf]\n\n: Inverse Document Frequency (IDF) values computed from the corpus.\n\n[default_idf]\n\n: Default IDF value for words not found in the corpus.\n\n# Examples\n\n```pycon\n>>> import pandas as pd\n>>> # Sample corpus word counts\n>>> corpus_counts = pd.Series({\n...     'word1': 300,\n...     'word2': 200,\n...     'word4': 500,\n...     'trump': 100\n... })\n>>> stop_words = {'the', 'and', 'is'}\n>>> custom_idf = {'trump': 5.0}\n>>> tfidf_calculator = TFIDFCalculator(corpus_counts,\n...                                    idf_type='standard',\n...                                    stop_words=stop_words,\n...                                    custom_idf=custom_idf)\n>>> # Sample document word counts\n>>> doc_counts = pd.Series({\n...     'word1': 3,\n...     'word2': 2,\n...     'trump': 4,\n...     'harris': 2,\n...     'the': 10\n... })\n>>> tfidf_scores = tfidf_calculator(doc_counts)\n>>> print(tfidf_scores)  # doctest: +ELLIPSIS\nword1    -1.17...\nword2    -0.71...\ntrump     1.81...\nharris    0.90...\ndtype: float64\n```\n"]}], "exports": []}]}