  <start_of_file docname=\"part1/sec1\">\n                            <section>\n                                <title>\n                                ...\n            <start_of_file docname=\"part1/chap2\">\n                <section>\n                    <title>\n                    ...\n        <compound classes=\"toctree-wrapper\">\n            <start_of_file docname=\"part2/chap1\">\n                <section>\n                    <title>\n                    ...\n```\n"]}, {"name": "sphinx_jupyterbook_latex.transforms.LatexToctreeNodeInterpret", "bases": ["SphinxTransform"], "methods": [{"name": "sphinx_jupyterbook_latex.transforms.LatexToctreeNodeInterpret.apply", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "**kwargs", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [{"name": "sphinx_jupyterbook_latex.transforms.LatexToctreeNodeInterpret.default_priority", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Creates a HiddenCellNode for each toctree node, copies its attributes and inserts\nit in the doctree adjacent to the toctree node, to be used by a post-transform later."]}, {"name": "sphinx_jupyterbook_latex.transforms.ListTableOfContents", "bases": ["SphinxPostTransform"], "methods": [{"name": "sphinx_jupyterbook_latex.transforms.ListTableOfContents._create_item_node", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "item", "type": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "nodes.list_item", "xref": {"fqname": "docutils.nodes.list_item", "project": null}, "params": null}, "documentation": ["Creating a list item doc