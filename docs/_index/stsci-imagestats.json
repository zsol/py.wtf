": [], "returns": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_histogram1d.test_bad_input_small_bin", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "stsci.imagestats.tests.test_histogram1d._FINFO32", "type": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_histogram1d._EPS32", "type": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_histogram1d._TINY32", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "setup", "documentation": ["!/usr/bin/env python"], "functions": [], "variables": [{"name": "setup.include_dirs", "type": null, "documentation": []}, {"name": "setup.define_macros", "type": null, "documentation": []}, {"name": "setup.cflags", "type": null, "documentation": []}, {"name": "setup.extra_compile_args", "type": null, "documentation": []}, {"name": "setup.extra_compile_args", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "stsci.imagestats", "documentation": ["Compute desired statistics values for input array objects."], "functions": [], "variables": [], "classes": [{"name": "stsci.imagestats.ImageStats", "bases": [], "methods": [{"name": "stsci.imagestats.ImageStats.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "image", "type": null, "default": null}, {"name": "fields", "type": null, "default": "..."}, {"name": "lower", "type": null, "default": "..."}, {"name": "upper", "type": null, "default": "..."}, {"name": "nclip", "type": null, "default": "..."}, {"name": "lsig", "type": null, "default": "..."}, {"name": "usig", "type": null, "default": "..."}, {"name": "binwidth", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "stsci.imagestats.ImageStats._error_no_valid_pixels", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "clipiter", "type": null, "default": null}, {"name": "minval", "type": null, "default": null}, {"name": "maxval", "type": null, "default": null}, {"name": "minclip", "type": null, "default": null}, {"name": "maxclip", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "stsci.imagestats.ImageStats._computeStats", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Compute all the basic statistics from the array object. "]}, {"name": "stsci.imagestats.ImageStats.getCenters", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Compute the array of bin center positions."]}, {"name": "stsci.imagestats.ImageStats.printStats", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Print the requested statistics values for those fields specified\non input."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Class to compute desired statistics from array objects.\n\n# Examples\n\nThis class can can be instantiated using the following syntax:\n\n```\n>>> import stsci.imagestats as imagestats\n>>> i = imagestats.ImageStats(image,\n            fields=\"npix,min,max,mean,stddev\",\n            nclip=3,\n            lsig=3.0,\n            usig=3.0,\n            binwidth=0.1\n            )\n>>> i.printStats()\n>>> i.mean\n```\n\nThe statistical quantities specified by the parameter *fields* are\ncomputed and printed for the input *image* array. The results are available\nas attributes of the class object as well.\n\n# Parameters\n\nimage\n\n: input image data array.\n\nfields\n\n: comma-separated list of values to be computed. The following\n  are the available fields:\n\n  |        |                                                  |\n  | ------ | ------------------------------------------------ |\n  | image  | image data array                                 |\n  | npix   | the number of pixels used to do the statistics   |\n  | mean   | the mean of the pixel distribution               |\n  | midpt  | estimate of the median of the pixel distribution |\n  | mode   | the mode of the pixel distribution               |\n  | stddev | the standard deviation of the pixel distribution |\n  | min    | the minimum pixel value                          |\n  | max    | the maximum pixel value                          |\n\n  **WARNING**\n\n  : Only those fields specified upon instantiation will be computed\n    and available as an output value.\n\nlower\n\n: Lowest valid value in the input array to be used for computing the\n  statistical values\n\nupper\n\n: Largest valid value in the input array to be used in computing the\n  statistical values\n\nnclip\n\n: Number of clipping iterations to apply in computing the results\n\nlsig\n\n: Lower sigma clipping limit (in sigma)\n\nusig\n\n: Upper sigma clipping limit (in sigma)\n\nbinwidth\n\n: Width of bins (in sigma) to use in generating histograms for computing\n  median-related values\n\n# NOTES\n\nThe mean, standard deviation, min and max are computed in a\nsingle pass through the image using the expressions listed below.\nOnly the quantities selected by the fields parameter are actually computed.\n\n```\n    mean = sum (x1,...,xN) / N\n       y = x - mean\nvariance = sum (y1 ** 2,...,yN ** 2) / (N-1)\n  stddev = sqrt (variance)\n```\n\nThe midpoint and mode are computed in two passes through the image. In the\nfirst pass the standard deviation of the pixels is calculated and used\nwith the *binwidth* parameter to compute the resolution of the data\nhistogram. The midpoint is estimated by integrating the histogram and\ncomputing by interpolation the data value at which exactly half the\npixels are below that data value and half are above it. The mode is\ncomputed by locating the maximum of the data histogram and fitting the\npeak by parabolic interpolation.\n\n**Warning**\n\n: This data will be promoted down to float32 if provided as 64-bit\n  datatype.\n"]}], "exports": [{"name": "stsci.imagestats.computeMean", "xref": {"fqname": "stsci.imagestats.computeMean.computeMean", "project": null}}, {"name": "stsci.imagestats.histogram1d", "xref": {"fqname": "stsci.imagestats.histogram1d.histogram1d", "project": null}}, {"name": "stsci.imagestats.ImageStats", "xref": {"fqname": "stsci.imagestats.ImageStats", "project": null}}]}, {"name": "stsci.imagestats.tests.test_imagestats", "documentation": [], "functions": [{"name": "stsci.imagestats.tests.test_imagestats.test_imagestats", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_imagestats.test_gaussian", "asynchronous": false, "params": [{"name": "gaussian_image", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_imagestats.test_uniform", "asynchronous": false, "params": [{"name": "uniform_image", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_imagestats.test_gaussian_clipping", "asynchronous": false, "params": [{"name": "gaussian_image", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_imagestats.test_all_values_in_one_bin", "asynchronous": false, "params": [{"name": "constant_image", "type": null, "default": null}, {"name": "nclip", "type": null, "default": null}, {"name": "capsys", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_imagestats.test_limits", "asynchronous": false, "params": [{"name": "gaussian_image", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "stsci.imagestats.tests.test_imagestats.test_print", "asynchronous": false, "params": [{"name": "gaussian_image", "type": null, "default": null}, {"name": "capsys", "type": null, "default": null}], "