to trigger this with context"]}], "variables": [{"name": "dynamicalsystem.halogen.logging.config", "type": null, "documentation": []}], "classes": [{"name": "dynamicalsystem.halogen.logging.SignalHandler", "bases": ["Handler"], "methods": [{"name": "dynamicalsystem.halogen.logging.SignalHandler.emit", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "record", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "dynamicalsystem.halogen.logging.SignalFormatter", "bases": ["Formatter"], "methods": [{"name": "dynamicalsystem.halogen.logging.SignalFormatter.format", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "record", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "dynamicalsystem.halogen.config", "documentation": [], "functions": [{"name": "dynamicalsystem.halogen.config.config_instance", "asynchronous": false, "params": [{"name": "context", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "dynamicalsystem.halogen.config.singleton", "type": null, "documentation": []}], "classes": [{"name": "dynamicalsystem.halogen.config._Config", "bases": [], "methods": [{"name": "dynamicalsystem.halogen.config._Config.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "context", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["context: str - is assumed to be <namespace>.<package>.<module>\nIn normal use just pass __name__ as the context so that you\ncan assume that the config file is located at:\n        ${<namespace>_FOLDER}/<namespace>/config/${ENVIRONMENT}[.package].env\n\nconfig will try to load a names file called ${ENVIRONMENT}.env before progressing\nto [.package].env. Values in the package file will override those in the\nnamespace file where the variable is duplicated.\n\nThen, within the dotenv file, you can prefix each variable with the module name and\nget a Config object which is scoped to the module.\n\nAssumptions include that the environment variables are uppercase and underscore separated.\n\nThe config object's attributes are lowercased and underscore separated."]}, {"name": "dynamicalsystem.halogen.config._Config._package_attributes", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "root_folder", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "dynamicalsystem.halogen.config._Config._parse_context", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "context", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "dynamicalsystem.halogen.config._Config.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "dynamicalsystem.halogen.config._Config.environment", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "dynamicalsystem.halogen.config._Config.data_folder", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "dynamicalsystem.halogen.config._Config._namespace_file", "type": {"name": "str", "xref": {"fqname": "func