ion": []}], "instance_variables": [], "inner_classes": [], "documentation": ["For storing snapshots of postgres index stats"]}, {"name": "pgstats.models.TableStatsManager", "bases": ["models.Manager"], "methods": [{"name": "pgstats.models.TableStatsManager.create_snapshot", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pgstats.models.TableStatsManager.get_stats", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pgstats.models.TableStats", "bases": ["models.Model"], "methods": [], "class_variables": [{"name": "pgstats.models.TableStats.created_at", "type": null, "documentation": []}, {"name": "pgstats.models.TableStats.stats", "type": null, "documentation": []}, {"name": "pgstats.models.TableStats.objects", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["For storing snapshots of postgres table stats"]}], "exports": []}]}