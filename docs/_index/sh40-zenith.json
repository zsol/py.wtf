olor", "project": "sh40-slate"}, "params": null}, {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}]}, "documentation": ["Returns a complementary triangle including base and the base's complement.\n\nOn a colorwheel:\n\n       . 0 .\n     .  /|\\  .\n    .  / | \\  .\n    . /  |  \\ .\n     2---+---1\n       . 3 ."]}, {"name": "zenith.palette.analogous", "asynchronous": false, "params": [{"name": "base", "type": {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, "default": null}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}]}, "documentation": ["Returns three colors next to eachother, including base.\n\nOn a colorwheel:\n\n       . 0 1\n     .       2\n    .         .\n     .       .\n       . 3 ."]}, {"name": "zenith.palette.tetradic", "asynchronous": false, "params": [{"name": "base", "type": {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, "default": null}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}]}, "documentation": ["Returns a complementary square including base.\n\nOn a colorwheel:\n\n       . 0 .\n     .       .\n    3         1\n     .       .\n       . 2 ."]}], "variables": [{"name": "zenith.palette.PalettingFunction", "type": null, "documentation": []}, {"name": "zenith.palette.DEFAULT_PANEL", "type": null, "documentation": []}, {"name": "zenith.palette.PANEL_BLEND_ALPHA", "type": null, "documentation": []}, {"name": "zenith.palette.DEFAULT_TEXT", "type": null, "documentation": []}, {"name": "zenith.palette.DEFAULT_SUCCESS", "type": null, "documentation": []}, {"name": "zenith.palette.DEFAULT_ERROR", "type": null, "documentation": []}, {"name": "zenith.palette.DEFAULT_WARNING", "type": null, "documentation": []}, {"name": "zenith.palette.SEMANTIC_BLEND_ALPHA", "type": null, "documentation": []}], "classes": [{"name": "zenith.palette.Palette", "bases": [], "methods": [{"name": "zenith.palette.Palette.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "primary", "type": {"name": "Color | str | int", "xref": null, "params": null}, "default": null}, {"name": "namespace", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "strategy", "type": {"name": "PalettingFunction", "xref": {"fqname": "PalettingFunction", "project": null}, "params": null}, "default": "..."}, {"name": "shade_count", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "shade_step", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "text", "type": {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, "default": "..."}, {"name": "secondary", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "tertiary", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "quaternary", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "success", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "warning", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "error", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "panel1", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "panel2", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "panel3", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "panel4", "type": {"name": "Color | None", "xref": null, "params": null}, "default": "..."}, {"name": "panel_base", "type": {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, "default": "..."}, {"name": "success_base", "type": {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, "default": "..."}, {"name": "warning_base", "type": {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, "default": "..."}, {"name": "error_base", "type": {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "zenith.palette.Palette.__getattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "attr", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Color", "xref": {"fqname": "slate.color.Color", "project": "sh40-slate"}, "params": null}, "documenta