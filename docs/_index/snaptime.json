{"name": "snaptime", "metadata": {"name": "snaptime", "version": "0.2.4", "classifiers": [], "home_page": "https://github.com/zartstrom/snaptime", "license": "UNKNOWN", "documentation_url": null, "dependencies": [], "summary": "Transform timestamps with a simple DSL", "upload_time": 1497540124}, "documentation": ["UNKNOWN"], "modules": [{"name": "setup", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "snaptime", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "snaptime.snap", "xref": {"fqname": "snaptime.main.snap", "project": null}}, {"name": "snaptime.snap_tz", "xref": {"fqname": "snaptime.main.snap_tz", "project": null}}]}, {"name": "snaptime.main", "documentation": [], "functions": [{"name": "snaptime.main.get_unit", "asynchronous": false, "params": [{"name": "string", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.get_weekday", "asynchronous": false, "params": [{"name": "string", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.get_num", "asynchronous": false, "params": [{"name": "string", "type": null, "default": null}, {"name": "default", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "snaptime.main.get_mult", "asynchronous": false, "params": [{"name": "string", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.truncate", "asynchronous": false, "params": [{"name": "datetime_", "type": null, "default": null}, {"name": "unit", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.parse", "asynchronous": false, "params": [{"name": "instruction", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.snap", "asynchronous": false, "params": [{"name": "dttm", "type": null, "default": null}, {"name": "instruction", "type": null, "default": null}], "returns": null, "documentation": ["Args:\n    instruction (string): a string that encodes 0 to n transformations of a time, i.e. \"-1h@h\", \"@mon+2d+4h\", ...\n    dttm (datetime):\nReturns:\n    datetime: The datetime resulting from applying all transformations to the input datetime.\n\nExample:\n    >>> snap(datetime(2016, 1, 1, 15, 30), \"-1h@h\")\n    datetime(2016, 1, 1, 14)"]}, {"name": "snaptime.main.snap_tz", "asynchronous": false, "params": [{"name": "dttm", "type": null, "default": null}, {"name": "instruction", "type": null, "default": null}, {"name": "timezone", "type": null, "default": null}], "returns": null, "documentation": ["This function handles timezone aware datetimes.\nSometimes it is necessary to keep daylight saving time switches in mind.\n\nArgs:\n    instruction (string): a string that encodes 0 to n transformations of a time, i.e. \"-1h@h\", \"@mon+2d+4h\", ...\n    dttm (datetime): a datetime with timezone\n    timezone: a pytz timezone\nReturns:\n    datetime: The datetime resulting from applying all transformations to the input datetime.\n\nExample:\n    >>> import pytz\n    >>> CET = pytz.timezone(\"Europe/Berlin\")\n    >>> dttm = CET.localize(datetime(2017, 3, 26, 3, 44)\n    >>> dttm\n    datetime.datetime(2017, 3, 26, 3, 44, tzinfo=<DstTzInfo 'Europe/Berlin' CEST+2:00:00 DST>)\n\n    >>> snap_tz(dttm, \"-2h@h\", CET)\n    datetime.datetime(2017, 3, 26, 0, 0, tzinfo=<DstTzInfo 'Europe/Berlin' CET+1:00:00 STD>)\n    >>> # switch from winter to summer time!"]}], "variables": [{"name": "snaptime.main.UTC", "type": null, "documentation": []}, {"name": "snaptime.main.SECONDS", "type": null, "documentation": []}, {"name": "snaptime.main.MINUTES", "type": null, "documentation": []}, {"name": "snaptime.main.HOURS", "type": null, "documentation": []}, {"name": "snaptime.main.DAYS", "type": null, "documentation": []}, {"name": "snaptime.main.WEEKS", "type": null, "documentation": []}, {"name": "snaptime.main.MONTHS", "type": null, "documentation": []}, {"name": "snaptime.main.YEARS", "type": null, "documentation": []}, {"name": "snaptime.main.UNIT_LISTS", "type": null, "documentation": []}, {"name": "snaptime.main.D_GENERAL", "type": null, "documentation": []}, {"name": "snaptime.main.D_DETAILS", "type": null, "documentation": []}, {"name": "snaptime.main.D_PATTERN", "type": null, "documentation": []}, {"name": "snaptime.main.S_GENERAL", "type": null, "documentation": []}, {"name": "snaptime.main.S_DETAILS", "type": null, "documentation": []}, {"name": "snaptime.main.S_PATTERN", "type": null, "documentation": []}, {"name": "snaptime.main.HEAD_PATTERN", "type": null, "documentation": []}], "classes": [{"name": "snaptime.main.SnapParseError", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "snaptime.main.SnapUnitError", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "snaptime.main.SnapTransformation", "bases": ["object"], "methods": [{"name": "snaptime.main.SnapTransformation.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "group", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.SnapTransformation.apply_to", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dttm", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.SnapTransformation.apply_to_with_tz", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dttm", "type": null, "default": null}, {"name": "timezone", "type": null, "default": null}], "returns": null, "documentation": ["We make sure that after truncating we use the correct timezone,\neven if we 'jump' over a daylight saving time switch.\n\nI.e. if we apply \"@d\" to `Sun Oct 30 04:30:00 CET 2016` (1477798200)\nwe want to have `Sun Oct 30 00:00:00 CEST 2016` (1477778400)\nbut not `Sun Oct 30 00:00:00 CET 2016` (1477782000)"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "snaptime.main.DeltaTransformation", "bases": ["object"], "methods": [{"name": "snaptime.main.DeltaTransformation.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "group", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.DeltaTransformation.apply_to", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dttm", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "snaptime.main.DeltaTransformation.apply_to_with_tz", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dttm", "type": null, "default": null}, {"name": "timezone", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}