_analytic_distribution_manual.tests.common.DistributionManualCommon", "bases": ["BaseCommon"], "methods": [{"name": "odoo.addons.account_analytic_distribution_manual.tests.common.DistributionManualCommon.setUpClass", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "odoo.addons.account_analytic_distribution_manual.models.base", "documentation": ["Copyright 2024 Tecnativa - Carlos Lopez", "License AGPL-3.0 or later (https://www.gnu.org/licenses/agpl)."], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.account_analytic_distribution_manual.models.base.AnalyticMixin", "bases": ["models.AbstractModel"], "methods": [{"name": "odoo.addons.account_analytic_distribution_manual.models.base.AnalyticMixin.get_view", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "view_id", "type": null, "default": "..."}, {"name": "view_type", "type": null, "default": "..."}, {"name": "**options", "type": null, "default": null}], "returns": null, "documentation": ["The purpose of inheriting this method is to\nadd a specific field, 'manual_distribution_id',\nto the tree/form views if the model has this field defined.\n\nAdditionally, if a one2many field exists\nand the related model has the 'manual_distribution_id' field,\nthe method will add the 'manual_distribution_id' field to the sub-view.\n\nFinally, the method returns the modified view.\n\nNote: This method should be inherited in the base model,\nnot in the analytic.mixin model,\nto ensure it executes correctly for models\nthat do not inherit from the mixin but have one2many fields.\nFor example, when rendering account.move,\nit does not inherit from analytic.mixin,\nbut it has one2many fields that inherit from analytic.mixin."]}], "class_variables": [{"name": "odoo.addons.account_analyt