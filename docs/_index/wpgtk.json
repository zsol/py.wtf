arest-neighbor interpolation. For other image formats, it\nscales the image to the same dimensions while preserving the aspect ratio.\n\nParameters:\n- image_name (str): The path to the image file.\n\nReturns:\nGdkPixbuf.Pixbuf or None: The GdkPixbuf preview if successful, or None if\nthe file does not exist."]}, {"name": "wpgtk.gui.util.get_sample_pixbuf", "asynchronous": false, "params": [{"name": "sample_name", "type": null, "default": null}], "returns": null, "documentation": ["Get a GdkPixbuf sample for an image file.\n\nThis function takes the name of an image file as input, checks if the file\nexists, and creates a GdkPixbuf sample for display. The image is scaled to\n500x500 pixels.\n\nParameters:\n- sample_name (str): The path to the image file.\n\nReturns:\nGdkPixbuf.Pixbuf or None: The GdkPixbuf sample if successful, or None if\nthe file does not exist"]}], "variables": [], "classes": [], "exports": []}, {"name": "wpgtk.gui.template_grid", "documentation": [], "functions": [], "variables": [{"name": "wpgtk.gui.template_grid.PAD", "type": null, "documentation": []}, {"name": "wpgtk.gui.template_grid.icon", "type": null, "documentation": []}], "classes": [{"name": "wpgtk.gui.template_grid.TemplateGrid", "bases": ["Gtk.Grid"], "methods": [{"name": "wpgtk.gui.template_grid.TemplateGrid.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parent", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "wpgtk.gui.template_grid.TemplateGrid.on_add_clicked", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "widget", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "wpgtk.gui.template_grid.TemplateGrid.on_open_clicked", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "widget", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "wpgtk.gui.temp