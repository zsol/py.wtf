ll}, {"name": "theme", "type": null, "default": null}], "returns": null, "documentation": ["removes a pair of keyword value for a wallpaper"]}], "variables": [{"name": "wpgtk.data.keywords.KEY_LENGTH", "type": null, "documentation": []}, {"name": "wpgtk.data.keywords.VAL_LENGTH", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "wpgtk.gui.keyword_dialog", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "wpgtk.gui.keyword_dialog.KeywordDialog", "bases": ["Gtk.Dialog"], "methods": [{"name": "wpgtk.gui.keyword_dialog.KeywordDialog.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parent", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "wpgtk.gui.keyword_dialog.KeywordDialog.get_section_name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "wpgtk.data.files", "documentation": [], "functions": [{"name": "wpgtk.data.files.get_file_list", "asynchronous": false, "params": [{"name": "path", "type": null, "default": "..."}, {"name": "regex", "type": null, "default": "..."}], "returns": null, "documentation": ["gets file names in a given directory, optional regex\nparameter to filter the list of files by."]}, {"name": "wpgtk.data.files.write_script", "asynchronous": false, "params": [{"name": "wallpaper", "type": null, "default": null}, {"name": "colorscheme", "type": null, "default": null}], "returns": null, "documentation": ["writes the script that should be called on startup\nto restore the theme."]}, {"name": "wpgtk.data.files.get_cache_path", "asynchronous": false, "params": [{"name": "wallpaper", "type": null, "default": null}, {"name": "backend", "type": null, "default": "..."}], "returns": null, "documentation": ["get a colorscheme cach