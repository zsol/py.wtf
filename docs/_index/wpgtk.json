dard xterm colors"]}, {"name": "wpgtk.data.color.auto_adjust", "asynchronous": false, "params": [{"name": "colors", "type": null, "default": null}], "returns": null, "documentation": ["create a clear foreground and background set of colors"]}, {"name": "wpgtk.data.color.change_templates", "asynchronous": false, "params": [{"name": "colors", "type": null, "default": null}], "returns": null, "documentation": ["call change_colors on each custom template\ninstalled or defined by the user"]}, {"name": "wpgtk.data.color.add_icon_colors", "asynchronous": false, "params": [{"name": "colors", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "wpgtk.data.color.keyword_colors", "asynchronous": false, "params": [{"name": "hexc", "type": null, "default": null}, {"name": "is_dark_theme", "type": null, "default": "..."}], "returns": null, "documentation": ["extract active and inactive colors from a given\nhex color value"]}, {"name": "wpgtk.data.color.get_color_dict", "asynchronous": false, "params": [{"name": "pywal_colors", "type": null, "default": null}, {"name": "colorscheme", "type": null, "default": null}], "returns": null, "documentation": ["ensamble wpgtk color dictionary from pywal color dictionary"]}, {"name": "wpgtk.data.color.apply_colorscheme", "asynchronous": false, "params": [{"name": "color_dict", "type": null, "default": null}], "returns": null, "documentation": ["Receives a colorscheme dict ensambled by\ncolor.get_color_dict as argument and applies it\nsystem-wide."]}], "variables": [], "classes": [], "exports": []}, {"name": "wpgtk.data.config", "documentation": [], "functions": [{"name": "wpgtk.data.config.write_conf", "asynchronous": false, "params": [{"name": "config_path", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "wpgtk.data.config.write_keywords", "asynchronous": false, "params": [{"name": "keywords_path", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name":