a sequence input.\n\ntype text\n\nUTF-8 ; ; string sequence (list, tuple, iterator, generator)\n\nrtype\n\nDetected\n\nrtype\n\n (when a list is passed)\n```\n\nBasic usage:\n: ```pycon\n  >>> from googletrans import Translator\n  >>> translator = Translator()\n  >>> translator.detect('\uc774 \ubb38\uc7a5\uc740 \ud55c\uae00\ub85c \uc4f0\uc5ec\uc84c\uc2b5\ub2c8\ub2e4.')\n  <Detected lang=ko confidence=0.27041003>\n  >>> translator.detect('\u3053\u306e\u6587\u7ae0\u306f\u65e5\u672c\u8a9e\u3067\u66f8\u304b\u308c\u307e\u3057\u305f\u3002')\n  <Detected lang=ja confidence=0.64889508>\n  >>> translator.detect('This sentence is written in English.')\n  <Detected lang=en confidence=0.22348526>\n  >>> translator.detect('Tiu frazo estas skribita en Esperanto.')\n  <Detected lang=eo confidence=0.10538048>\n  ```\n\nAdvanced usage:\n: ```pycon\n  >>> langs = translator.detect(['\ud55c\uad6d\uc5b4', '\u65e5\u672c\u8a9e', 'English', 'le fran\u00e7ais'])\n  >>> for lang in langs:\n  ...    print(lang.lang, lang.confidence)\n  ko 1\n  ja 0.92929292\n  en 0.96954316\n  fr 0.043500196\n  ```\n"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Google Translate ajax API implementation class\n\nYou have to create an instance of Translator to use this API\n\n```\nparam service_urls\n\ngoogle translate url list. URLs will be used randomly.\nFor example ['translate.google.com', 'translate.google.co.kr']\nTo preferably use the non webapp api, service url should be translate.googleapis.com\n\ntype service_urls\n\na sequence of strings\n\nparam user_agent\n\nthe User-Agent header to send when making requests.\n\ntype user_agent\n\n\n\nparam proxies\n\nproxies configuration.\nDictionary mapping protocol or protocol and host to the URL of the proxy\nFor example {'http': 'foo.bar:3128', 'http://host.name': 'foo.bar:4012'}\n\ntype proxies\n\ndictionary\n\nparam timeout\n\nDefinition of timeout for httpx library.\nWill be used for every request.\n\ntype timeout\n\nnumber or a double of numbers\n\nparam proxies\n\nproxies configuration.\nDictionary mapping protocol or protocol and host to the URL of the proxy\nFor example {'http': 'foo.bar:3128', 'http://host.name': 'foo.bar:4012'}\n\nparam raise_exception\n\nif  then raise exception if smth will go wrong\n\ntype raise_exception\n\nboolean\n```\n"]}], "exports": []}, {"name": "googletrans.models", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "googletrans.models.Base", "bases": [], "methods": [{"name": "googletrans.models.Base.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "response", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Response", "xref": {"fqname": "httpx.Response", "project": null}, "params": null}]}, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "googletrans.models.Translated", "bases": ["Base"], "methods": [{"name": "googletrans.models.Translated.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "src", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "dest", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "origin", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "pronunciation", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "extra_data", "type": {"name": "Optional", "xref": {"fqname": "typing.Opti