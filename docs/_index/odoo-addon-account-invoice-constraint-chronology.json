entation": []}, {"name": "odoo.addons.account_invoice_constraint_chronology.tests.test_account_invoice_constraint_chronology.TestAccountInvoiceConstraintChronology.test_invoice_higher_number", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.account_invoice_constraint_chronology.tests.test_account_invoice_constraint_chronology.TestAccountInvoiceConstraintChronology.test_modify_validated_past_invoice", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["We've got an invoice from yesterday that we need to modify but new ones\nhave been posted since. As the invoice already has a name, we should be able\nto validate it"]}, {"name": "odoo.addons.account_invoice_constraint_chronology.tests.test_account_invoice_constraint_chronology.TestAccountInvoiceConstraintChronology.test_modify_invoice_date_validated_past_invoice", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["in order to avoid a raise caused by the sequence mixin we must ensure", "that all dates are in the same year, hence we freeze the date", "in the middle of the year"]}], "exports": []}]}