umentation": []}, {"name": "ess.imaging.io.AllImageStacks", "type": null, "documentation": []}, {"name": "ess.imaging.io.DEFAULT_IMAGE_NAME_PREFIX_MAP", "type": null, "documentation": []}], "classes": [{"name": "ess.imaging.io.ImageKey", "bases": ["Enum"], "methods": [{"name": "ess.imaging.io.ImageKey.as_index", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "key", "type": {"name": "ImageKey", "xref": {"fqname": "ess.imaging.io.ImageKey", "project": null}, "params": null}, "default": null}, {"name": "target_da", "type": {"name": "sc.DataArray | None", "xref": null, "params": null}, "default": null}], "returns": {"name": "sc.Variable", "xref": {"fqname": "scipp.Variable", "project": "scipp"}, "params": null}, "documentation": []}], "class_variables": [{"name": "ess.imaging.io.ImageKey.SAMPLE", "type": null, "documentation": []}, {"name": "ess.imaging.io.ImageKey.OPEN_BEAM", "type": null, "documentation": []}, {"name": "ess.imaging.io.ImageKey.DARK_CURRENT", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Image key values."]}], "exports": []}, {"name": "ess.imaging.normalize", "documentation": ["SPDX-License-Identifier: BSD-3-Clause", "Copyright (c) 2024 Scipp contributors (https://github.com/scipp)"], "functions": [{"name": "ess.imaging.normalize._warn_constant_exposure_time", "asynchronous": false, "params": [{"name": "target", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "ess.imaging.normalize._mean_all_dims", "asynchronous": false, "params": [{"name": "data", "type": {"name": "sc.Variable", "xref": {"fqname": "scipp.Variable", "project": "scipp"}, "params": null}, "default": null}], "returns": {"name": "sc.Variable", "xref": {"fqname": "scipp.Variable", "project": "scipp"}, "params": null}, "documentation": ["Calculate the mean of all dimensions one by one to avoid overflow."]}, {"name": "ess.imaging.normalize.average_open_beam_images", "asynchronous": false, "params": [{"name": "open_beam", "type": {"name": "OpenBeamImageStacks", "xref": {"fqname": "ess.imaging.normalize.io.OpenBeamImageStacks", "project": null}, "params": null}, "default": null}], "returns": {"name": "OpenBeamImage", "xref": {"fqname": "OpenBeamImage", "project": null}, "params": null}, "documentation": ["Average the open beam image stack.\n\n$$\nOpenBeam = mean(OpenBeam, dim=\\text{'time'})\n$$\n"]}, {"name": "ess.imaging.normalize.average_dark_current_images", "asynchronous": false, "params": [{"name": "dark_current", "type": {"name": "DarkCurrentImageStacks", "xref": {"fqname": "ess.imaging.normalize.io.DarkCurrentImageStacks", "project": null}, "params": null}, "default": null}], "returns": {"name": "DarkCurrentImage", "xref": {"fqname": "DarkCurrentImage", "project": null}, "params": null}, "documentation": ["Average the dark current image stack.\n\n$$\nDarkCurrent = mean(DarkCurrent, dim=\\text{'time'})\n$$\n"]}, {"name": "ess.imaging.normalize.cleanse_open_beam_image", "asynchronous": false, "params": [{"name": "open_beam", "type": {"name": "OpenBeamImage", "xref": {"fqname": "OpenBeamImage", "project": null}, "params": null}, "default": null}, {"name": "dark_current", "type": {"name": "DarkCurrentImage", "xref": {"fqname": "DarkCurrentImage", "project": null}, "params": null}, "default": null}], "returns": {"name": "CleansedOpenBeamImage", "xref": {"fqname": "CleansedOpenBeamImage", "project": null}, "params": null}, "documentation": ["Calculate the background image stack.\n\n$$\nBackground = OpenBeam - DarkCurrent\n$$\n\n# Parameters\n\nopen_beam:\n\n: Open beam image.\n\ndark_current:\n\n: Dark current image.\n"]}, {"name": "ess.imaging.normalize.cleanse_sample_images", "asynchronous": false, "params": [{"name": "sample_images", "type": {"name": "SampleImageStacksWithLogs", "xref": {"fqname": "ess.imaging.normalize.io.SampleImageStacksWithLogs", "project": null}, "params": null}, "default": null}, {"name": "dark_current", "type": {"name": "DarkCurrentImage", "xref": {"fqname": "DarkCurrentImage", "project": null}, "params": null}, "default": null}], "returns": {"name": "CleansedSampleImages", "xref": {"fqname": "CleansedSampleImages", "project": null}, "params": null}, "documentation": ["Cleanse the sample image stack.\n\nWe subtract the averaged dark current image from the sample image stack.\n\n$$\nCleansedSample_{i} = Sample_{i} - mean(DarkCurrent, dim=\\text{'time'})\n\n\\text{where } i \\text{ is an index of an image.}\n$$\n\n# Parameters\n\nsample_images:\n\n: Sample image stack.\n\ndark_current:\n\n: Dark current image.\n"]}, {"name": "ess.imaging.normalize.average_background_pixel_counts", "asynchronous": false, "params": [{"name": "background", "type": {"name": "BackgroundImage", "xref": {"fqname": "BackgroundImage", "project": null}, "params": null}, "default": null}], "returns": {"name": "AverageBackgroundPixelCounts", "xref": {"fqname": "AverageBackgroundPixelCounts", "project": null}, "params": null}, "documentation": ["Calculate the average background pixel counts."]}, {"name": "ess.imaging.normalize.average_sample_pixel_counts", "asynchronous": false, "params": [{"name": "sample_images", "type": {"name": "SampleImageStacks", "xref": {"fqname": "SampleImageStacks", "project": null}, "params": null}, "default": null}], "returns": {"name": "AverageSamplePixelCounts", "xref": {"fqname": "AverageSamplePixelCounts", "project": null}, "params": null}, "documentation": ["Calculate the average sample pixel counts.\n\n# Notes\n\nFor performance reason, we tried calculating\nthe mean of sample images and dark current images\nfirst and subtract them afterwards,\ninstead of using the subtracted image stack directly.\nIt was to utilize that the integer operation is faster than\nthe floating point operation.\n\nHowever, we are ceiling negative values to zero\nafter cleansing the sample images with dark current images.\n\nTherefore we need to calculate the mean of the cleansed sample images\nto avoid negative values in the average calculation.\n\nWe don't calculate `mean(cleansed_sample_images)` at once\nsince it is a large array and it may cause memory issues.\n\nThere was an example of 361 images of 2048x2048 pixels with 32-bit integer data\nexceeded the limit of the maximum integer so the average calculation failed\nand returned negative values.\n"]}, {"name": "ess.imaging.normalize.calculate_scale_factor", "asynchronous": false, "params": [{"name": "average_bg", "type": {"name": "AverageBackgroundPixelCounts", "xref": {"fqname": "AverageBackgroundPixelCounts", "project": null}, "params": null}, "default": null}, {"name": "average_sample", "type": {"name": "AverageSamplePixelCounts", "xref": {"fqname": "AverageSamplePixelCounts", "project": null}, "params": null}, "default": null}], "returns": {"name": "ScaleFactor", "xref": {"fqname": "ScaleFactor", "project": null}, "params": null}, "documentation": ["Calculate the scale factor from average background and sample pixel counts.\n\n$$\nScaleFactor = AverageBackgroundPixelCounts / AverageSamplePixelCounts\n$$\n"]}, {"name": "ess.imaging.normalize.apply_threshold_to_sample_images", "asynchronous": false, "params": [{"name": "samples", "type": {"name": "CleansedSampleImages", "xref": {"fqname": "CleansedSampleImages", "project": null}, "params": null}, "default": null}, {"name": "sample_threshold", "type": {"name": "SamplePixelThreshold", "xref": {"fqname": "SamplePixelThreshold", "project": null}, "params": null}, "default": null}], "returns": {"name": "SampleImageStacks", "xref": {"fqname": "SampleImageStacks", "project": null}, "params": null}, "documentation": ["Apply the threshold to the sample image stack.\n\n# Parameters\n\nsamples:\n\n: Sample image stack.\n\nsample_threshold:\n\n: Threshold for the sample pixel values.\n  Any pixel values less than `sample_threshold`\n  are replaced with `sample_threshold`.\n"]}, {"name": "ess.imaging.normalize.apply_threshold_to_background_image", "asynchronous": false, "params": [{"name": "background", "type": {"name": "CleansedOpenBeamImage", "xref": {"fqname": "CleansedOpenBeamImage", "project": null}, "params": null}, "default": null}, {"name": "background_threshold", "type": {"name": "BackgroundPixelThreshold", "xref": {"fqname": "BackgroundPixelThreshold", "project": null}, "params": null}, "default": null}], "returns": {"name": "BackgroundImage", "xref": {"fqname": "BackgroundImage", "project": null}, "params": null}, "documentation": ["Apply the threshold to the background image.\n\n# Parameters\n\nbackground:\n\n: Background image.\n\nbackground_threshold:\n\n: Threshold for the background pixel values.\n  Any pixel values less than `background_threshold`\n  are replaced with `background_threshold`.\n"]}, {"name": "ess.imaging.normalize.normalize_sample_images", "asynchronous": false, "params": [{"name": "samples", "type": {"name": "SampleImageStacks", "xref": {"fqname": "SampleImageStacks", "project": null}, "params": null}, "default": null}, {"name": "background", "type": {"name": "BackgroundImage", "xref": {"fqname": "BackgroundImage", "project": null}, "params": null}, "default": null}, {"name": "factor", "type": {"name": "ScaleFactor", "xref": {"fqname": "ScaleFactor", "project": null}, "params": null}, "default": null}], "returns": {"name": "NormalizedSampleImages", "xref": {"fqname": "NormalizedSampleImages", "project": null}, "params": null}, "documentation": ["Normalize the sample image stack.\n\n$$\nNormalizedImages = SampleImages / Background * ScaleFactor\n$$\n\n# Parameters\n\nsamples:\n\n: Sample image stack to be normalized.\n\nbackground:\n\n: Background image to be used for normalization.\n\nfactor:\n\n: Scale factor for the normalization.\n\n# Raises\n\nValueError:\n\n: If the scale factor is negative.\n  It is for the safety of the calculation on short data type.\n  Depending on how you calculate the scale factor,\n  the operation might fail and return negative values.\n"]}], "variables": [{"name": "ess.imaging.normalize.AverageBackgroundPixelCounts", "type": null, "documentation": ["mean(background)."]}, {"name": "ess.imaging.normalize.AverageSamplePixelCounts", "type": null, "documentation": ["mean(sample)."]}, {"name": "ess.imaging.normalize.ScaleFactor", "type": null, "documentation": ["AverageBackgroundPixelCounts / AverageSamplePixelCounts."]}, {"name": "ess.imaging.normalize.OpenBeamImage", "type": null, "documentation": ["Open beam image. mean(OpenBeam)"]}, {"name": "ess.imaging.normalize.DarkCurrentImage", "type": null, "documentation": ["Dark current image. mean(DarkCurrentImages)"]}, {"name": "ess.imaging.normalize.CleansedOpenBeamImage", "type": null, "documentation": ["OpenBeam - DarkCrrent"]}, {"name": "ess.imaging.normalize.CleansedSampleImages", "type": null, "documentation": ["SampleImageStack - DarkCurrent"]}, {"name": "ess.imaging.normalize.SampleImageStacks", "type": null, "documentation": ["Sample image stack ready to be used for normalization."]}, {"name": "ess.imaging.normalize.BackgroundImage", "type": null, "documentation": ["Background image ready to be used for normalization."]}, {"name": "ess.imaging.normalize.NormalizedSampleImages", "type": null, "documentation": ["Normalized sample image stack. SampleImages / Background * ScaleFactor"]}, {"name": "ess.imaging.normalize.BackgroundPixelThreshold", "type": null, "documentation": ["Threshold of the background pixel values."]}, {"name": "ess.imaging.normalize.SamplePixelThreshold", "type": null, "documentation": ["Threshold of the sample pixel values."]}], "classes": [], "exports": []}, {"name": "ess.imaging.data", "documentation": ["SPDX-License-Identifier: BSD-3-Clause", "Copyright (c) 2024 Scipp contributors (https://github.com/scipp)"], "functions": [{"name": "ess.imaging.data._make_pooch", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "ess.imaging.data.get_path", "asynchronous": false, "params": [{"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "pathlib.Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "documentation": ["Return the path to a data file bundled with ess.imaging test helpers.\n\nThis function only works with example data and cannot handle\npaths to custom files."]}, {"name": "ess.imaging.data.get_ymir_images_path", "asynchronous": false, "params": [], "returns": {"name": "pathlib.Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "documentation": ["Return the path to the small YMIR images HDF5 file."]}, {"name": "ess.imaging.data.get_mcstas_ob_images_path", "asynchronous": false, "params": [], "returns": {"name": "pathlib.Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "documentation": ["Return the path to the small McStas OB images HDF5 file."]}, {"name": "ess.imaging.data.get_mcstas_sample_images_path", "asynchronous": false, "params": [], "returns": {"name": "pathlib.Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "documentation": ["Return the path to the small McStas sample images HDF5 file."]}], "variables": [{"name": "ess.imaging.data._version", "type": null, "documentation": []}, {"name": "ess.imaging.data._pooch", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "ess.imaging", "documentation": ["SPDX-License-Identifier: BSD-3-Clause", "Copyright (c) 2024 Scipp contributors (https://github.com/scipp)", "ruff: noqa: E402, F401"], "functions": [], "variables": [{"name": "ess.imaging.__version__", "type": null, "documentation": []}, {"name": "ess.imaging.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "ess.imaging.workflow", "documentation": ["SPDX-License-Identifier: BSD-3-Clause", "Copyright (c) 2024 Scipp contributors (https://github.com/scipp)"], "functions": [{"name": "ess.imaging.workflow.YmirImageNormalizationWorkflow", "asynchronous": false, "params": [], "returns": {"name": "sl.Pipeline", "xref": {"fqname": "sciline.Pipeline", "project": "sciline"}, "params": null}, "documentation": ["Ymir histogram mode imaging normalization workflow.\n\n# Default Normalization Formula\n\n$$\nNormalizedSample_{i} = SampleImageStacks_{i} / BackgroundImage * ScaleFactor\n$$\n\n$$\nScaleFactor = AverageBackgroundPixelCounts / AverageSamplePixelCounts\n$$\n\n$$\nSampleImageStacks_{i} = Sample_{i} - mean(DarkCurrent, dim=\\text{'time'})\n\n\\text{where } i \\text{ is an index of an image.}\n\n\\text{Pixel values less than sample_threshold}\n\n\\text{ are replaced with sample_threshold}.\n$$\n\n$$\nBackgroundImage = mean(OpenBeam, dim=\\text{'time'})\n- mean(DarkCurrent, dim=\\text{'time'})\n\n\\text{Pixel values less than } \\text{background_threshold}\n\n\\text{ are replaced with } \\text{background_threshold}.\n$$\n"]}], "variables": [{"name": "ess.imaging.workflow._IO_PROVIDERS", "type": null, "documentation": []}, {"name": "ess.imaging.workflow._NORMALIZATION_PROVIDERS", "type": null, "documentation": []}, {"name": "ess.imaging.workflow._DEFAULT_BACKGROUND_THRESHOLD", "type": null, "documentation": []}, {"name": "ess.imaging.workflow._DEFAULT_SAMPLE_THRESHOLD", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "ess.imaging.types", "documentation": ["SPDX-License-Identifier: BSD-3-Clause", "Copyright (c) 2024 Scipp contributors (https://github.com/scipp)"], "functions": [], "variables": [{"name": "ess.imaging.types.ImageDetectorName", "type": null, "documentation": ["Histogram mode detector name."]}, {"name": "ess.imaging.types.ImageKeyLogs", "type": null, "documentation": ["Image key logs."]}, {"name": "ess.imaging.types.RotationMotionSensorName", "type": null, "documentation": ["Rotation sensor name."]}, {"name": "ess.imaging.types.RotationLogs", "type": null, "documentation": ["Rotation logs data."]}, {"name": "ess.imaging.types.HistogramModeDetectorsPath", "type": null, "documentation": ["Path to the histogram mode detectors in a nexus file."]}, {"name": "ess.imaging.types.DEFAULT_HISTOGRAM_PATH", "type": null, "documentation": []}], "classes": [], "exports": []}]}