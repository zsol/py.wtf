me": "rnx_bytes", "type": null, "default": null}, {"name": "crx_bytes", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hatanaka.test.test_hatanaka.test_rnx2crx_extra_args_good", "asynchronous": false, "params": [{"name": "rnx_str", "type": null, "default": null}, {"name": "crx_str", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hatanaka.test.test_hatanaka.test_rnx2crx_extra_args_warning", "asynchronous": false, "params": [{"name": "rnx_str", "type": null, "default": null}, {"name": "crx_str", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hatanaka.test.test_hatanaka.test_crx2rnx_extra_args_good", "asynchronous": false, "params": [{"name": "rnx_str", "type": null, "default": null}, {"name": "crx_str", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hatanaka.test.test_hatanaka.test_non_ascii_is_tolerated", "asynchronous": false, "params": [{"name": "rnx_bytes", "type": null, "default": null}, {"name": "crx_bytes", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hatanaka.test.test_hatanaka.test_stderr_bad_encoding", "asynchronous": false, "params": [{"name": "crx_bytes", "type": null, "default": null}], "returns": null, "documentation": ["The errors and warnings can include cited garbage from invalid files\nand we should handle that gracefully."]}], "variables": [], "classes": [], "exports": []}, {"name": "hatanaka.cli", "documentation": [], "functions": [{"name": "hatanaka.cli.decompress_cli", "asynchronous": false, "params": [{"name": "args", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "hatanaka.cli.compr