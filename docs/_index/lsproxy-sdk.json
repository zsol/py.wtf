context:\n        print(ref.code_context)\n```\n\n\n\n"], "modules": [{"name": "lsproxy", "documentation": [], "functions": [], "variables": [{"name": "lsproxy.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "lsproxy.CodeContext", "xref": {"fqname": "lsproxy.models.CodeContext", "project": null}}, {"name": "lsproxy.DefinitionResponse", "xref": {"fqname": "lsproxy.models.DefinitionResponse", "project": null}}, {"name": "lsproxy.FilePosition", "xref": {"fqname": "lsproxy.models.FilePosition", "project": null}}, {"name": "lsproxy.FileRange", "xref": {"fqname": "lsproxy.models.FileRange", "project": null}}, {"name": "lsproxy.GetDefinitionRequest", "xref": {"fqname": "lsproxy.models.GetDefinitionRequest", "project": null}}, {"name": "lsproxy.GetReferencesRequest", "xref": {"fqname": "lsproxy.models.GetReferencesRequest", "project": null}}, {"name": "lsproxy.Lsproxy", "xref": {"fqname": "lsproxy.client.Lsproxy", "project": null}}, {"name": "lsproxy.Position", "xref": {"fqname": "lsproxy.models.Position", "project": null}}, {"name": "lsproxy.ReferencesResponse", "xref": {"fqname": "lsproxy.models.ReferencesResponse", "project": null}}, {"name": "lsproxy.SupportedLanguages", "xref": {"fqname": "lsproxy.models.SupportedLanguages", "project": null}}, {"name": "lsproxy.Symbol", "xref": {"fqname": "lsproxy.models.Symbol", "project": null}}]}, {"name": "lsproxy.client", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "lsproxy.client.Lsproxy", "bases": [], "methods": [{"name": "lsproxy.client.Lsproxy.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "base_url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "timeout", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}, {"na