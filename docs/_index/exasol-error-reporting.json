g\nparameters, handling quotation of placeholder."]}], "exports": []}, {"name": "exasol_error_reporting_python.parameters_mapper", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "exasol_error_reporting_python.parameters_mapper.ParametersMapper", "bases": [], "methods": [{"name": "exasol_error_reporting_python.parameters_mapper.ParametersMapper.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "arguments", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "exasol_error_reporting_python.parameters_mapper.ParametersMapper.get_params_dict", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "text", "type": null, "default": null}, {"name": "arguments", "type": null, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Create ParametersMapper object and return the generated dictionary\nthat maps the placeholders and parameters.\n\n```\nparam text\n\nmessage or mitigation that may contain placeholders\n\nparam arguments\n\narguments to replace with  the placeholders\n\nreturn\n\na dictionary that maps the placeholders and parameters\n```\n"]}, {"name": "exasol_error_reporting_python.parameters_mapper.ParametersMapper._map_parameters", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Parse the given text containing placeholders, look up the positional\nparameters and set the correct parameter mapping."]}, {"name": "exasol_error_reporting_python.parameters_mapper.ParametersMapper._get_current_parameter", "asynchronous": false, "params": [{"name": "se