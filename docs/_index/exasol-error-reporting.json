OR", "type": null, "documentation": []}, {"name": "exasol.error.version.PATCH", "type": null, "documentation": []}, {"name": "exasol.error.version.VERSION", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "exasol_error_reporting_python.error_message_builder", "documentation": [], "functions": [], "variables": [{"name": "exasol_error_reporting_python.error_message_builder.ERROR_CODE_FORMAT", "type": null, "documentation": []}], "classes": [{"name": "exasol_error_reporting_python.error_message_builder.InvalidErrorCode", "bases": ["ValueError"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Indicates that the error code does not comply with the commonly defined error code format."]}, {"name": "exasol_error_reporting_python.error_message_builder.ErrorMessageBuilder", "bases": [], "methods": [{"name": "exasol_error_reporting_python.error_message_builder.ErrorMessageBuilder.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "error_code", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "exasol_error_reporting_python.error_message_builder.ErrorMessageBuilder.message", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "*arguments", "type": null, "default": null}], "returns": null, "documentation": ["Add the given error message to the error builder list and invokes\nthe method that performs mapping of the given parameters with the\nplaceholders in the message. This class allows multiple calls for\nmessage or mitigation methods, in this case the text given in\nmessage or mitigation is appended to the list of the corresponding\nmethod.\n\n```\npara