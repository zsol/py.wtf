FCT EVENTUALLY (ONLY NEEDED TO TRANSITION LEGACY CODE MORE EASILY) ------"]}], "variables": [{"name": "bq.metadoc.formats.etree_result_types", "type": null, "documentation": []}, {"name": "bq.metadoc.formats.etree_result_types", "type": null, "documentation": []}, {"name": "bq.metadoc.formats.log", "type": null, "documentation": []}, {"name": "bq.metadoc.formats.metadoc_everywhere", "type": null, "documentation": ["Assume internal tree structure:\n\n<RESERVED_TAGNAME uniq=\"00-xyz\" name=\"...\" type=\"image\" usertype=\"cell image\" unit=\"...\"\n id=\"img1\" path=\"...\" owner=\"...\" permission=\"...\" storage=\"...\" >    ...VALUE...\n      <tag _id=\"09\" name=\"NOT_RESERVED_TYPE\" type=\"datetime\" usertype=\"...\" unit=\"...\" id=\"...\" >   ...VALUE...  </tag>\n      ...\n      <RESERVED_TAGNAME> ...VALUE... </RESERVED_TAGNAME>\n      ...\n</RESERVED_TAGNAME>\n\n\nAssume external natural XML:\n\n<VALID_XMLTAG .... >    ...value...\n    <tag name=\"INVALID_XMLTAG\" .... > ...VALUE... </tag>\n    ...\n    <VALID_XMLTAG .... > ...VALUE... </VALID_XMLTAG>\n    ...\n    <tag name=\"INVALID_XMLTAG\" .... value=\"VALUE WITH SURROUNDING SPACES\" />\n    ...\n</VALID_XMLTAG>\n\n\nAssume external \"tag-XML\":\n\n<RESERVED_TAGNAME ...  value=\"VALUE\" >\n    <tag name=\"NOT_RESERVED_TYPE\" ...   value=\"VALUE\" />\n    ...\n    <RESERVED_TAGNAME ...  value=\"VALUE\" />\n    ...\n</RESERVED_TAGNAME>\n\n\n\n\n\nThe different converters work together as follows:\n\nConvert from/to naturalxml:\n\nNATURALXML str --> fromstring/deserialize --> NATURALXML etree* -->   naturalxml_to_tree  --> INTERNAL etree*\n                   (resolves any empty                               (deals with leading/     (used in all internal ops;\n                    string escapes)                                   trailing spaces in       ALL values in text nodes!)\n                                                                      text nodes)\n\nINTERNAL etree* -->   tree_to_naturalxml  -->  NATURALXML etree* -->  tostring/serialize  -->  NATURALXML str\n                     (deals with leading/                             (escapes any empty\n                      trailing spaces in                               text strings)\n                      text nodes)\n\n\nConvert from/to tagxml:\n\nTAGXML str  -->  fromstring/deserialize  -->  TAGXML etree* -->  tagxml_to_tree  -->  INTERNAL etree*\n                 (no special handling                            (moves values to\n                  in this case)                                   text nodes)\n\nINTERNAL etree* -->  tree_to_tagxml  -->  TAGXML etree* -->   tostring/serialize  -->  TAGXML str\n                     (moves text nodes                        (no special handling\n                      to value attr)                           in this case)\n\n\nConvert from/to naturaljson:\n\nNATURALJSON str  -->  json.load  -->  NATURALJSON struct  -->  d2xml  -->  NATURALXML etree*  -->  naturalxml_to_tree  -->  INTERNAL etree*\n                                                              (\"simulate\"  (same as above ------> )\n                                                               leading/\n                                                               trailing space\n                                                               escape)\n\nINTERNAL etree*  -->  tree_to_naturalxml  -->  NATURALXML etree* -->  xml2d  -->  NATURALJSON struct  -->  json.dumps  -->  NATURALJSON str\n                                      (<--------- same as above)     (resolve\n                                                                      leading/\n                                                                      trailing space\n                                                                      escape)\n\nSerialize/deserialize (for task communication):\n\nINTERNAL etree* -->  tostring/serialize  -->  INTERNAL str\n                     (escapes any empty\n                      text strings)\n\nINTERNAL str  -->  fromstring/deserialize -->  INTERNAL etree*\n                   (resolves any empty\n                    string escapes)\n\n\n(* these etrees will be replaced with Metadoc eventually)"]}, {"name": "bq.metadoc.formats.RESERVED_TAGNAMES", "type": null, "documentation": []}, {"name": "bq.metadoc.formats.XML_PARSER", "type": null, "documentation": []}], "classes": [{"name": "bq.metadoc.formats.InvalidFormat", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "bq.metadoc.formats.Metadoc", "bases": [], "methods": [{"name": "bq.metadoc.formats.Metadoc.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "et", "type": null, "default": "..."}, {"name": "parent", "type": null, "default": "..."}, {"name": "tag", "type": null, "default": "..."}, {"name": "**attrs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "bq.metadoc.formats.Metadoc.__getstate__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "bq.metadoc.formats.Metadoc.__setstate__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "bq.metadoc.formats.Metadoc.convert", "asynchronous": false, "params": [{"name": "internal", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "bq.metadoc.formats.Metadoc.convert_back", "asynchronous": false, "params": [{"name": "metadoc", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "bq.metadoc.formats.Metadoc.convert_to_etree", "asynchronous": false, "params": [{"name": "metadoc", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "bq.metadoc.formats.Metadoc.from_tagxml", "asynchronous": false, 