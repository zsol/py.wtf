oo-community.org/page/Contribute>.\n"], "modules": [{"name": "odoo.addons.mrp_lot_number_propagation.models.product_product", "documentation": ["Copyright 2022 Camptocamp SA", "License AGPL-3.0 or later (http://www.gnu.org/licenses/agpl)"], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.mrp_lot_number_propagation.models.product_product.ProductProduct", "bases": ["models.Model"], "methods": [{"name": "odoo.addons.mrp_lot_number_propagation.models.product_product.ProductProduct._check_bom_propagate_lot_number", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "odoo.addons.mrp_lot_number_propagation.models.product_product.ProductProduct._inherit", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "odoo.addons.mrp_lot_number_propagation.models.mrp_bom", "documentation": ["Copyright 2022 Camptocamp SA", "License AGPL-3.0 or later (http://www.gnu.org/licenses/agpl)"], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.mrp_lot_number_propagation.models.mrp_bom.MrpBom", "bases": ["models.Model"], "methods": [{"name": "odoo.addons.mrp_lot_number_propagation.models.mrp_bom.MrpBom._compute_display_lot_number_propagation", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Check if a lot number can be propagated.\n\nA lot number can be propagated from a component to the finished product if:\n- the type of the BoM is normal (Manufacture this product)\n- the finished product is tracked by serial number\n- the quantity of the finished product is 1 and its UoM is unit\n- there is at least one bom line, with a component tracked by serial,\n  having a quantity of 1 and its UoM is unit"]}, {"name": "odoo.addons.mrp_lot_number_propagation.models.mrp_bom.MrpBom._get_lot_number_propagation_bom_types"