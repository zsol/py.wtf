hResult.UNKNOWN_ERROR", "type": null, "documentation": ["\u672a\u77e5\u9519\u8bef"]}], "instance_variables": [], "inner_classes": [], "documentation": ["\u8865\u4e01\u64cd\u4f5c\u7ed3\u679c\u679a\u4e3e"]}, {"name": "patcher1337.Patcher1337", "bases": [], "methods": [{"name": "patcher1337.Patcher1337.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "debug", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["\u521d\u59cb\u5316\u8865\u4e01\u5904\u7406\u5668\n\nArgs:\n    debug: \u662f\u5426\u542f\u7528\u8c03\u8bd5\u6a21\u5f0f"]}, {"name": "patcher1337.Patcher1337.parse_patch_file", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "patch_file", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "target_file", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "PatchEntry", "xref": {"fqname": "patcher1337.PatchEntry", "project": null}, "params": null}]}]}, "documentation": ["\u89e3\u67901337\u683c\u5f0f\u8865\u4e01\u6587\u4ef6\n\nArgs:\n    patch_file: \u8865\u4e01\u6587\u4ef6\u8def\u5f84\n    target_file: \u76ee\u6807\u6587\u4ef6\u540d\uff08\u53ef\u9009\uff09\uff0c\u7528\u4e8e\u53ea\u89e3\u6790\u7279\u5b9a\u6587\u4ef6\u7684\u8865\u4e01\n    \nReturns:\n    Tuple[str, List[PatchEntry]]: \u8fd4\u56de\u76ee\u6807\u6587\u4ef6\u540d\u548c\u8865\u4e01\u6761\u76ee\u5217\u8868\n    \nRaises:\n    InvalidPatchFile: \u8865\u4e01\u6587\u4ef6\u683c\u5f0f\u65e0\