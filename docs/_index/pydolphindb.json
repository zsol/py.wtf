b.exceptions.BlobException", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pydolphindb.exceptions.DigestNotFoundException", "bases": ["BlobException"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pydolphindb.exceptions.BlobLocationNotFoundException", "bases": ["BlobException"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pydolphindb.exceptions.TimezoneUnawareException", "bases": ["Error"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "pydolphindb", "documentation": [], "functions": [], "variables": [{"name": "pydolphindb.__version__", "type": null, "documentation": ["pydolphindb version"]}, {"name": "pydolphindb.apilevel", "type": null, "documentation": ["DBapi2.0"]}, {"name": "pydolphindb.threadsafety", "type": null, "documentation": ["thread safety level, need to check & modify"]}, {"name": "pydolphindb.paramstyle", "type": null, "documentation": ["param style for Engine URL"]}], "classes": [], "exports": [{"name": "pydolphindb.connect", "xref": {"fqname": "pydolphindb.connection.Connection", "project": null}}, {"name": "pydolphindb.DolphinDBDialect", "xref": {"fqname": "pydolphindb.sqlalchemy.DolphinDBDialect", "project": null}}, {"name": "pydolphindb.Error", "xref": {"fqname": "pydolphindb.exceptions.Error", "project": null}}]}, {"name": "pydolphindb.sqlalchemy", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "pydolphindb.sqlalchemy.DolphinDBDialect", "xref": {"fqname": "pydolphindb.sqlalchemy.dialect.DolphinDBDialect", "project": null}}]}, {"name": "pydolphindb.cursor", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "pydolphindb.cursor.Cursor", "bases": ["object"], "