s.Parameters.Data.path_mask", "type": null, "documentation": []}, {"name": "dpivsoft.Classes.Parameters.Data.path_stereo", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Extra data needed in some cases"]}, {"name": "dpivsoft.Classes.Parameters.Stereo_Calibration", "bases": [], "methods": [{"name": "dpivsoft.Classes.Parameters.Stereo_Calibration.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "npz_file", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "dpivsoft.Classes.Parameters.Stereo_Calibration.load_variables", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "npz_file", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "documentation": ["Contains all parameters options to perform PIV\n\nDefault values are defined here. There are two options to change the\nvalues for a specific DPIV run:\n\n- Change the specific value manually on python shell or on the running\n  script.\n\n        Example:  Parameters.box_size_1_x = 128\n\n- Load all the parameters included in a yaml file by using readPArameters\n  classmethod.\n\n        Example: Parameters.readParameters('folder/filename')"]}, {"name": "dpivsoft.Classes.grid", "bases": [], "methods": [{"name": "dpivsoft.Classes.grid.generate_mesh", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "width", "type": null, "default": null}, {"name": "height", "type": null, "default": null}], "returns": null, "documentation": ["Generates the meshgrid of x and y position for the correlation\nwindows in the two passes, according to the piv parameters selected."]}, {"name": "dpivsoft.Classes.grid.read_mesh", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name