params": null}, "documentation": ["`FramesRecorded` in info.json plus 1 (for metadata frame)."]}, {"name": "npc_mvr.mvr.remove_lost_frame_idx", "asynchronous": false, "params": [{"name": "frame_times", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": [{"name": "NumericT", "xref": {"fqname": "NumericT", "project": null}, "params": null}]}, "default": null}, {"name": "lost_frame_idx", "type": {"name": "Container", "xref": {"fqname": "collections.abc.Container", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "npt.NDArray", "xref": {"fqname": "numpy.typing.NDArray", "project": null}, "params": [{"name": "NumericT", "xref": {"fqname": "NumericT", "project": null}, "params": null}]}, "documentation": ["```pycon\n>>> remove_lost_frame_idx([1., 2., 3., 4., 5.], [1, 3])\narray([1., 3., 5.])\n```\n"]}, {"name": "npc_mvr.mvr.get_video_file_paths", "asynchronous": false, "params": [{"name": "*paths", "type": {"name": "npc_io.PathLike", "xref": {"fqname": "npc_io.PathLike", "project": "npc-io"}, "params": null}, "default": null}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "upath.UPath", "xref": {"fqname": "upath.UPath", "project": null}, "params": null}, {"name": "...", "xref": null, "params": null}]}, "documentation": []}, {"name": "npc_mvr.mvr.get_video_info_file_paths", "asynchronous": false, "params": [{"name": "*paths", "type": {"name": "npc_io.PathLike", "xref": {"fqname": "npc_io.PathLike", "project": "npc-io"}, "params": null}, "default": null}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "upath.UPath", "xref": {"fqname": "upath.UPath", "project": null}, "params": null}, {"name": "...", "xref": null, "params": null}]}, "documentation": []}, {"name": "npc_mvr.mvr.get_video_info_data", "asynchronous": false, "params": [{"name": "path_or_info_data", "type": {"name": "npc_io.PathLike | Mapping", "xref": null, "params": null}, "default": null}], "returns": {"name": "MVRInfoData", "xref": {"fqname": "MVRInfoData", "project": null}, "params": null}, "documentation": []}, {"name": "npc_mvr.mvr.get_video_data", "asynchronous": false, "params": [{"name": "video_or_video_path", "type": {"name": "cv2.VideoCapture | npc_io.PathLike", "xref": null, "params": null}, "default": null}], "returns": {"name": "cv2.VideoCapture", "xref": {"fqname": "cv2.VideoCapture", "project": "opencv-python-headless"}, "params": null}, "documentation": ["```pycon\n>>> path = 's3://aind-ephys-data/ecephys_660023_2023-08-08_07-58-13/behavior_videos/Behavior_20230808T130057.mp4'\n>>> v = get_video_data(path)\n>>> assert isinstance(v, cv2.VideoCapture)\n>>> assert v.get(cv2.CAP_PROP_FRAME_COUNT) != 0\n```\n"]}, {"name": "npc_mvr.mvr.get_barcode_image", "asynchronous": false, "params": [{"name": "frame", "type": {"name": "npt.NDArray", "xref": {"fqname": "numpy.typing.NDArray", "project": null}, "params": [{"name": "np.uint8", "xref": {"fqname": "numpy.uint8", "project": null}, "params": null}]}, "default": null}, {"name": "coordinates", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "Literal", "xref": {"fqname": "typing.Literal", "project": "--std--"}, "params": [{"name": "\"xOffset\"", "xref": null, "params": null}, {"name": "\"yOffset\"", "xref": null, "params": null}, {"name": "\"width\"", "xref": null, "params": null}, {"name": "\"height\"", "xref": null, "params": null}]}, {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "npt.NDArray", "xref": {"fqname": "numpy.typing.NDArray", "project": null}, "params": [{"name": "np.uint8", "xref": {"fqname": "numpy.uint8", "project": null}, "params": null}]}, "documentation": ["Image box contains a series of grey vertical divider lines (1 per exponent; 1-pix wide):\nthe binary value for each exponent is the value to the right of the grey\nline - either black (0) or white (1)"]}, {"name": "npc_mvr.mvr.get_barcode_value", "asynchronous": false, "params": [{"name": "barcode_image", "type": {"name": "npt.NDArray", "xref": {"fqname": "numpy.typing.NDArray", "project": null}, "params": [{"name": "np.uint8", "xref": {"fqname": "numpy.uint8", "project": null}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "npc_mvr.mvr.get_barcode_value_from_frame", "asynchronous": false, "params": [{"name": "video_data", "type": {"name": "cv2.VideoCapture", "xref": {"fqname": "cv2.VideoCapture", "project": "opencv-python-headless"}, "params": null}, "default": null}, {"name": "frame_number", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "barcode_image_coordinates", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "Literal", "xref": {"fqname": "typing.Literal", "project": "--std--"}, "params": [{"name": "\"xOffset\"", "xref": null, "params": null}, {"name": "\"yOffset\"", "xref": null, "params": null}, {"name": "\"width\"", "xref": null, "params": null}, {"name": "\"height\"", "xref": null, "params": null}]}, {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["value is the binary value extracted from the barcode in the corner of the\nimage\n- there's no barcode on the metadata frame (frame 0)\n- the first proper barcode starts with a value of 1"]}, {"name": "npc_mvr.mvr.get_barcode_image_coordinates", "asynchronous": false, "params": [{"name": "video_info", "type": {"name": "MVRInfoData", "xref": {"fqname": "MVRInfoData", "project": null}, "params": null}, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "Literal", "xref": {"fqname": "typing.Literal", "project": "--std--"}, "params": [{"name": "\"xOffset\"", "xref": null, "params": null}, {"name": "\"yOffset\"", "xref": null, "params": null}, {"name": "\"width\"", "xref": null, "params": null}, {"name": "\"height\"", "xref": null, "params": null}]}, {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "npc_mvr.mvr.get_frame_number_from_barcode", "asynchronous": false, "params": [{"name": "video_or_video_path", "type": {"name": "cv2.VideoCapture | npc_io.PathLike", "xref": null, "params": null}, "default": null}, {"name": "info_path_or_data", "type": {"name": "MVRInfoData | npc_io.PathLike", "xref": null, "params": null}, "default": null}, {"name": "frame_number", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["Extract barcode from encoded ID in image frame.\n\n- barcodes start at 1: presumably to account for metadata frame at 0\n\n```pycon\n>>> path = 's3://aind-private-data-prod-o5171v/ecephys_703333_2024-04-09_13-06-44'\n>>> m = MVRDataset(path)\n>>> video_data = m.video_data['behavior']\n>>> video_info = m.info_data['behavior']\n>>> frame_number = 0\n>>> get_frame_number_from_barcode(video_data, info_path_or_data=video_info, frame_number=0) # metadata frame\n0\n>>> get_frame_number_from_barcode(video_data, info_path_or_data=video_info, frame_number=1)\n1\n```\n"]}, {"name": "npc_mvr.mvr.get_total_frames_in_video", "asynchronous": false, "params": [{"name": "video_path", "type": {"name": "npc_io.PathLike", "xref": {"fqname": "npc_io.PathLike", "project": "npc-io"}, "params": null}, "de