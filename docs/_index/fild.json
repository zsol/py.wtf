 "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fild.sdk.field.Field.full_value", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fild.sdk.field.Field.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "is_full", "type": null, "default": null}, {"name": "with_data", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "fild.sdk.field.Field.with_values", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "values", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fild.sdk.field.Field._generate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "is_full", "type": null, "default": "..."}, {"name": "with_data", "type": null, "default": "..."}, {"name": "required", "type": null, "default": "..."}, {"name": "use_default", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "fild.sdk.field.Field.generate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "use_default", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "fild.sdk.field.Field.generate_value", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Valid value generator based on type"]}, {"name": "fild.sdk.field.Field.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "fild.process.dictionary", "documentation": [], "functions": [{"name": "fild.process.dictionary.merge_with_updates", "asynchronous": false, "params": [{"name": "initial_dict", "type": null, "default": null}, {"name": "updates", "type": null, "default": null}, {"name": "extend_only", "type": null, "default": "..."}, {"name": "merge_lists", "type": null, "default": "..."}], "returns": null, "documentation": ["Creates copy of initial_dict with updates applied\n\n**Parameters**\n\ninitial_dict : dictionary used as base for updates\nupdates : dictionary with changes to be applied\nextend_only: boolean flag that prohibits to overwrite values, only add new\n\n**Returns**\n\nA copy of initial dict with all updates applied\n\n**Examples**\n\ninitial_dict is None:\n  >>> merge_with_updates(None, {2: 2})\n  {2: 2}\n\nAdd new value in dict:\n  >>> merge_with_updates({1: 1}, {2: 2})\n  {1: 1, 2: 2}\n\nUpdate value in dict:\n  >>> merge_with_updates({1: 1, 2: 2}, {2: 'two', 3: 3} )\n  {1: 1, 2: 'two', 3: 3}\n\nUpdate value in inner dict:\n  >>> merge_with_updates({1: 1, 2: {21: 21}}, {2: {21: 'twenty-one'}})\n  {1: 1, 2: {21: 'twenty-one'}}\n\nOverride list:\n  >>> merge_with_updates({1: [{2: 2, 3: 3}]}, {1: [{2: 'two'}]})\n  {1: [{2: 'two'}]}\n\nUpdate value in list:\n  >>> merge_with_updates(\n  ...   {1: [{2: 2, 3: 3}]}, {1: [{2: 'two'}]},\n  ...   merge_lists=True)\n  {1: [{2: 'two', 3: 3}]}\n\nUpdate value in inner list:\n  >>> merge_with_updates(\n  ...   {1: {2: [{3: [{4: 4}]}]}},\n  ...   {1: {2: [{3: [{4: 'four'}]}]}},\n  ...   merge_lists=True)\n  {1: {2: [{3: [{4: 'four'}]}]}}\n\nExtend dict:\n  >>> merge_with_updates({1: 1}, {2: 2}, extend_only=True)\n  {1: 1, 2: 2}\n\nExtend list:\n  >>> merge_with_updates({1: [2]}, {1: [2, 3]}, merge_lists=True)\n  {1: [2, 2, 3]}\n\nExtend list of dicts:\n  >>> merge_with_updates({1: [{2: 2}]}, {1: [{3: 3}]}, merge_lists=True)\n  {1: [{2: 2, 3: 3}]}\n\nExtend empty list with list of dicts:\n  >>> merge_with_updates({1: []}, {1: [{2: 2}]}, merge_lists=True)\n  {1: [{2: 2}]}\n\nExtend list of dicts with empty inner dict:\n  >>> merge_with_updates({1: [{2: 2}]}, {1: [{}]}, merge_lists=True)\n  {1: [{2: 2}, {}]}\n\nExtend inner dict:\n  >>> merge_with_updates({1: 1, 2: {21: 21}}, {2: {22: 22}})\n  {1: 1, 2: {21: 21, 22: 22}}\n\nOverwrite value with dict:\n  >>> merge_with_updates({1: 1}, {1: {2: 2}})\n  {1: {2: 2}}\n\nDo not modify initial dict:\n  >>> initial_dict = {1: 1, 2: {21: 21}}\n  >>> merge_with_updates(initial_dict, {1: 'one', 2: {21: 'two'}})\n  {1: 'one', 2: {21: 'two'}}\n  >>> print(initial_dict)\n  {1: 1, 2: {21: 21}}\n\nDo not override value in extend mode:\n  >>> merge_with_updates({1: 1}, {1: 'one'}, extend_only=True)\n  Traceback (most recent call last):\n      ...\n  ValueError: Can not overwrite \"1\" value in extend mode\n\nDo not override inner value in extend mode:\n  >>> merge_with_updates({1: {2: 2}}, {1: {2: 0}}, extend_only=True)\n  Traceback (most recent call last):\n      ...\n  ValueError: Can not overwrite \"2\" value in extend mode\n\nDo not override list value in extend mode:\n  >>> merge_with_updates(\n  ...   {1: [{2: 2}]}, {1: [{2: 0}]}, merge_lists=True, extend_only=True)\n  Traceback (most recent call last):\n      ...\n  ValueError: Can not overwrite \"2\" value in extend mode"]}, {"name": "fild.process.dictionary.dict_predicate", "asynchronous": false, "params": [{"name": "func", "type": null, "default": "..."}, {"name": "name", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "fild.process.dictionary.matches_pattern", "asynchronous": false, "params": [{"name": "initial_dict", "type": null, "default": null}, {"name": "pattern_dict", "type": null, "default": null}], "returns": null, "documentation": ["Checks whether dict matches value/filter pattern\n\n**Parameters**\n\ninitial_dict : dictionary to verify\npattern_dict: dictionary pattern to apply for verification. Filter function\nis allowed as value: takes one actual arg and returns True or False.\nDecorate filter functions with @dict_predicate to add names on logging.\n\n**Returns**\n\nTrue/False if the dict matches pattern.\n\n**Examples**\n\nFull match:\n  >>> matches_pattern({1: 1}, {1: 1})\n  True\n\nExtra value in initial dict:\n  >>> matches_pattern({1: 1, 2: 2}, {2: 2})\n  True\n\nExtra value in pattern:\n  >>> matches_pattern({1: 1}, {1: 1, 2: 2})\n  False\n\nInner dict doesn't match filter pattern:\n  >>> matches_pattern({1: {2: 2}}, {1: {2: lambda x: x != 2}})\n  False\n\nInner dict matches filter pattern:\n  >>> matches_pattern({1: {2: 2}}, {1: {2: lambda x: x == 2}})\n  True"]}, {"name": "fild.process.dictionary.apply_modifier", "asynchronous": false, "params": [{"name": "initial_dict", "type": null, "default": null}, {"name": "modifier", "type": null, "default": null}], "returns": null, "documentation": ["Returns a copy of an initial dictionary with modified values.\n\n```\nparam initial_dict\n\nany dictionary to create a copy from and modify\n\nparam modifier\n\neither a callable that modifies the dictionary or a\n```\n\ndictionary that contains other modifiers under corresponding keys.\n\\:return: a copy of the dictionary\n\\:rtype: dict\n\nExamples:\n: ```pycon\n  >>> apply_modifier({'a': 7}, lambda _: {})\n  {}\n  ```\n\n  ```pycon\n  >>> apply_modifier({'b': 7}, {'b': float})\n  {'b': 7.0}\n  ```\n\n  ```pycon\n  >>> apply_modifier({'c': {'x': 1}, 'd': 2}, {'c': {'x': float}})\n  {'c': {'x': 1.0}, 'd': 2}\n  ```\n\n  ```pycon\n  >>> apply_modifier({'c': {'x': 1}}, {'d': float})\n  {'c': {'x': 1}}\n  ```\n\n  ```pycon\n  >>> apply_modifier({'c': {'x': 1}}, {'c': lambda _: 'test'})\n  {'c': 'test'}\n  ```\n\n  ```pycon\n  >>> apply_modifier({'c': [1, 2, 3]}, {'c': [float]})\n  {'c': [1.0, 2.0, 3.0]}\n  ```\n\n  ```pycon\n  >>> apply_modifier({'c': []}, {'c': [float]})\n  {'c': []}\n  ```\n\n  ```pycon\n  >>> apply_modifier(\n  ...   {'c': [{'x': [1]}, {'y': 4}]}, {'c': [{'x': [float]}]})\n  {'c': [{'x': [1.0]}, {'y': 4}]}\n  ```\n\n  ```pycon\n  >>> apply_modifier(\n  ...   {'c': [{'x': [1], 'y': 2}]}, {'c': [{'x': [float], 'y': float}]})\n  {'c': [{'x': [1.0], 'y': 2.0}]}\n  ```\n"]}, {"name": "fild.process.dictionary.normalize", "asynchronous": false, "params": [{"name": "actual", "type": null, "default": null}, {"name": "expected", "type": null, "default": null}, {"name": "keys", "type": null, "default": "..."}], "returns": null, "documentation": ["Applies same structure as expected, based on id for ordered structures.\n\nExamples:\n  >>> normalize(['c', 'b', 'a'], ['b'])\n  ['b', 'c', 'a']\n\n  >>> normalize({'a': [1, 2, 5, 6], 'b': 0}, {'a': [1, 3, 6 ], 'b': None})\n  {'a': [1, 6, 2, 5], 'b': 0}\n\n  >>> normalize(\n  ...   {'a': {'c': 'test', 'd': ['a', 1]}, 'b': 123},\n  ...   {'a': {'d': ['b', 'c', 1]}})\n  {'a': {'c': 'test', 'd': [1, 'a']}, 'b': 123}\n\n  >>> normalize(\n  ... {'a': [{'id': 1, 'val': 'test'}, {'id': 2, 'val': 'test2'}]},\n  ... {'a': [{'id': 2}, {'id': 3}]})\n  {'a': [{'id': 2, 'val': 'test2'}, {'id': 1, 'val': 'test'}]}\n\n  >>> normalize(\n  ...   {'a': [{'id': 1, 'val': 'test'}, {'id': 2, 'val': 'test2'}]},\n  ...   {'a': [{'id': 4, 'val': 'test2'}, {'id': 5, 'val': 'v'}]},\n  ...   keys=['fake', 'val'])\n  {'a': [{'id': 2, 'val': 'test2'}, {'id': 1, 'val': 'test'}]}\n\n  >>> normalize(\n  ...   {'a': [\n  ...       {'id': 'b1', 'b': [{'id': 2}, {'id': 1}]},\n  ...       {'id': 'b0', 'b': [{'id': 3}, {'id': 4}]}\n  ...   ]},\n  ...   {'a': [\n  ...       {'id': 'b0', 'b': [{'id': 4}]},\n  ...       {'id': 'b1', 'b': [{'id': 1}, {'id': 2}]}\n  ...   ]})\n  {'a': [{'id': 'b0', 'b': [{'id': 4}, {'id': 3}]}, {'id': 'b1', 'b': [{'id': 1}, {'id': 2}]}]}"]}], "variables": [], "classes": [], "exports": []}, {"name": "fild.sdk", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "fild.sdk.Array", "xref": {"fqname": "fild.sdk.array.Array", "project": null}}, {"name": "fild.sdk.Bool", "xref": {"fqname": "fild.sdk.types.Bool", "project": null}}, {"name": "fild.sdk.DateTime", "xref": {"fqname": "fild.sdk.types.DateTime", "project": null}}, 