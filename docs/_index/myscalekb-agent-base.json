 "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Annotate on the source node to establish a unidirectional edge to the target node.\n. code-block:: python\n\n    @node\n    @edge(target_node=\"summary_contexts\")\n    async def retrieve_contexts(self, data):\n        # code logic\n\n    @node\n    @edge(target_node=GraphBuilder.END)\n    async def summary_contexts(self, data):\n        # code logic"]}, {"name": "myscalekb_agent.base.graph_builder.conditional_edge", "asynchronous": false, "params": [{"name": "path", "type": {"name": "RunnableLike", "xref": {"fqname": "langchain_core.runnables.base.RunnableLike", "project": null}, "params": null}, "default": null}, {"name": "path_map", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Annotate on the source node and define different conditions to reach different nodes.\n. code-block:: python\n\n    @conditional_edge(source_node=\"run_query\", path_map={\"continue\": \"retrieve_contexts\", \"end\": GraphBuilder.END})\n    def should_continue(self, data):\n        if isinstance(data[\"outcome\"], AgentFinish):\n            return  \"continue\"\n        return \"continue\""]}, {"name": "myscalekb_agent.base.graph_builder.entry", "asynchronous": false, "params": [{"name": "func", "type": null, "default": null}], "returns": null, "documentation": ["Mark a node as entry point in Graph.\nA Graph can only have one entry. This annotation cannot be used with @conditional_entry\n. code-block:: python\n\n    @node\n    @entry\n    async def run_query(self, data):\n        # code logic"]}, {"name": "myscalekb_agent.base.graph_builder.conditional_entry", "asynchronous": false, "params": [{"name": "path_map", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Mark an edge as entry point in Graph.\nSome special graphs need to determine which node to branch to at the entrance.\n. code-block:: python\n\n    @conditional_entry(path_map={\"form\": \"init_form\", \"query\": \"run_query\"})\n    async def entry(self, data):\n        # code logic"]}], "variables": [{"name": "myscalekb_agent.base.graph_builder.logger", "type": null, "documentation": []}], "classes": [{"name": "myscalekb_agent.base.graph_builder.GraphBuilder", "bases": [], "methods": [{"name": "myscalekb_agent.base.graph_builder.GraphBuilder._build_graph", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "state_definition", "type": {"name": "TypedDict", "xref": {"fqname": "typing.TypedDict", "project": "--std--"}, "params": null}, "default": null}, {"name": "compiled", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [{"name": "myscalekb_agent.base.graph_builder.GraphBuilder.END", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "myscalekb_agent.base.schemas", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "myscalekb_agent.base.schemas.agent_metadata", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "myscalekb_agent.base.schemas.agent_metadata.AgentMetadata", "bases": ["BaseModel"], "methods": [], "class_variables": [{"name": "myscalekb_agent.base.schemas.agent_metadata.AgentMetadata.name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "myscalekb_agent.base.schemas.agent_metadata.AgentMetadata.step", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "do