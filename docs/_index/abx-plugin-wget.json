ath of someone else's attempt to do so..."]}], "variables": [{"name": "abx_plugin_wget.wget_util.__package__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "abx_plugin_wget.wget", "documentation": [], "functions": [{"name": "abx_plugin_wget.wget.get_output_path", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "abx_plugin_wget.wget.get_embed_path", "asynchronous": false, "params": [{"name": "archiveresult", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "abx_plugin_wget.wget.should_save_wget", "asynchronous": false, "params": [{"name": "link", "type": {"name": "Link", "xref": {"fqname": "archivebox.index.schema.Link", "project": null}, "params": null}, "default": null}, {"name": "out_dir", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "overwrite", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "abx_plugin_wget.wget.save_wget", "asynchronous": false, "params": [{"name": "link", "type": {"name": "Link", "xref": {"fqname": "archivebox.index.schema.Link", "project": null}, "params": null}, "default": null}, {"name": "out_dir", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "timeout", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": 