\"my_library.module1\", # test scope is the module1.py\n        root_dir=\"/path/to/dir_git_repo\",\n        htmlcov_dir=\"/path/to/dir_git_repo/htmlcov\",\n    )\n```\n\nIn your all modules unit test script, you can do this:\n\n```python\nif __name__ == \"__main__\":\n    from fixa.pytest_cov_helper import run_cov_test\n\n    run_cov_test(\n        script=__file__,\n        module=\"my_library\", # test scope is the my_library/\n        root_dir=\"/path/to/dir_git_repo\",\n        htmlcov_dir=\"/path/to/dir_git_repo/htmlcov\",\n        is_folder=True, # my_library is a folder\n    )\n```\n\n```\nparam script\n\nthe test script absolute path\n\nparam module\n\nthe dot notation to the python module you want to calculate\ncoverage\n\nparam root_dir\n\nthe dir to dump coverage results binary file\n\nparam htmlcov_dir\n\nthe dir to dump HTML output\n\nparam preview\n\nwhether to open the HTML output in web browser after the test\n\nparam is_folder\n\nwhether the module is a folder\n```\n\nReference:\n\n- <https://pypi.org/project/pytest-cov/>\n"]}], "variables": [{"name": "pyatlassian.vendor.pytest_cov_helper.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}]}