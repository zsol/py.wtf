(seq.sequence))\n\n# or\n\nwith open(\"sequences.fasta\") as f:\n    r = FASTAReader(f)\n    for seq in r:\n        print(seq.id, len(seq.sequence))\n```\n\nWriting FASTA files:\n\n```python\nfrom biofiles.fasta import FASTAWriter\nfrom biofiles.types.sequence import Sequence\n\nseq = Sequence(id=\"SEQ\", description=\"Important sequence\", sequence=\"GAGAGA\")\n\nwith FASTAWriter(\"output.fasta\") as w:\n    w.write(seq)\n```\n\nReading GFF genome annotations:\n\n```python\nfrom biofiles.gff import GFFReader\nfrom biofiles.types.feature import Gene\n\nwith GFFReader(\"GCF_009914755.1_T2T-CHM13v2.0_genomic.gff\") as r:\n    for feature in r:\n        if isinstance(feature, Gene):\n            print(feature.name, len(feature.exons))\n```\n\n## License \n\nMIT license, see [License](LICENSE).\n"], "modules": [{"name": "biofiles.types", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "biofiles.types.sequence", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "biofiles.types.sequence.Sequence", "bases": [], "methods": [], "class_variables": [{"name": "biofiles.types.sequence.Sequence.id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "biofiles.types.sequence.Sequence.description", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "biofiles.types.sequence.Sequence.sequence", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": [{"name": "biofiles.types.sequence.Sequence", "xref": {"fqname": "biofiles.types.sequence.Sequence", "project": null}}]}, {"name": "biofiles.types.feature", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "biofiles.types.feature.Feature"