roject": "--std--"}, "params": [{"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}]}, "default": null}, {"name": "source_ids", "type": null, "default": "..."}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "LabelSet", "xref": {"fqname": "labeling.Labeling.LabelSet", "project": null}, "params": null}]}]}, "documentation": ["Convenience function to add multiple original segmentations to an image.\nSegmentations need to be of the same size.\n\\:param images:\n\\:param source_ids:\n\\:return:\n"]}, {"name": "labeling.Labeling.Labeling.add_image", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "image", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}, {"name": "source_id", "type": null, "default": "..."}], "returns": {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "LabelSet", "xref": {"fqname": "labeling.Labeling.LabelSet", "project": null}, "params": null}]}, "documentation": ["Add a single segmentation image to the Labeling.\n\\:param image:\n\\:param source_id:\n\\:return:\n"]}, {"name": "labeling.Labeling.Labeling.add_segments", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "patch", "type": {"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": "numpy"}, "params": null}, "default": null}, {"name": "position", "type": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": null}, "default": null}, {"name": "merge", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "source_id", "type": null, "default": "..."}], "returns": {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "LabelSet", "xref": {"fqname": "labeling.Labeling.LabelSet", "project": null}, "params": null}]}, "documentation": ["The main function of the library.\nIntegrates a patch at the specified position.\nIt iterates over each pixel of the patch and updates\nthe Labeling accordingly, adding a new segment and creating fragments\non demand.\n\\:param patch: a nD labeling patch. a patch can also be a full image in this case\n\\:param position: the nD position the patch is being inserted in. the\nposition is \"upperleft corner\" i.e. it corresponds to (0,0) in the patch\n\\:param merge: unused. meant to hold additional information that refer to each\npatch pixels value\n\\:param source_id: a reference value for all segments that are added for future\ntracking\n\\:return: the mapping of fragment id to segment id\n"]}, {"name": "labeling.Labeling.Labeling.add_metadata", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "data", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Optional\nAdd any additional metadata to the Labeling that might be necessary.\n\\:param data:\n\\:return: None\n"]}, {"name": "labeling.Labeling.Labeling.add_segmentation_source", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "source_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "label_value", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Optional\nAdds a mapping of user-defined source_id to a value(should be either segment or fragment id)\n\\:param source_id:\n\\:param label_value:\n\\:return: None\n"]}, {"name": "labeling.Labeling.Labeling.save_result", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "cleanup", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["---\nparam cleanup: if the metadata should be cleaned up of all no longer valid data\nparam path: the path to save the Labeling to\nreturn: the merged image, a LabelingData object\n---\n"]}, {"name": "labeling.Labeling.Labeling.get_result", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cleanup", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "(np.array, LabelingData)", "xref": null, "params": null}, "documentation": ["This returns the current state of the Labeling image.\nand it's corresponding metadata.\n\\:param cleanup:\n\\:return: the merged image, a LabelingData object\n"]}, {"name": "labeling.Labeling.Labeling.__cleanup_labelsets", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Removes all fragments that are in the dict but no longer in\nthe containing image. It also removes all segments\nthat have no associated fragments from the list.\n:return:"]}, {"name": "labeling.Labeling.Labeling.__segment_fragment_mapping", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Returns the current representation of a segment-fragments mapping.\nThis is not a copy of the values.\n\\:return: a dict[int,set(int)]\n"]}, {"name": "labeling.Labeling.Labeling.remove_segment", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "segment_number", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Removes a single segment from the Labeling object,\nrearranging all involved fragments.\n\\:param segment_number: the segment to remove from the Labeling.\n\\:return:\n"]}, {"name": "labeling.Labeling.Labeling.__eq__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}