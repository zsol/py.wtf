{"name": "ed25519-blake2b", "metadata": {"name": "ed25519-blake2b", "version": "1.4.1", "classifiers": ["Development Status :: 5 - Production/Stable", "Intended Audience :: Developers", "License :: OSI Approved :: MIT License", "Programming Language :: Python", "Programming Language :: Python :: 2.7", "Programming Language :: Python :: 3.4", "Programming Language :: Python :: 3.5", "Programming Language :: Python :: 3.6", "Programming Language :: Python :: 3.7", "Topic :: Security :: Cryptography"], "home_page": "https://github.com/Matoking/python-ed25519-blake2b", "license": "MIT", "documentation_url": null, "dependencies": [], "summary": "Ed25519 public-key signatures (BLAKE2b fork)", "upload_time": 1705946982}, "documentation": ["A fork of python-ed25519 that uses BLAKE2b instead of SHA512 as a hash function\nas used in the NANO cryptocurrency.\nOriginal code written by @warner on GitHub:\ngithub.com/warner/python-ed25519\n\nPython bindings to the Ed25519 public-key signature system.\n\nThis offers a comfortable python interface to a C implementation of the\nEd25519 public-key signature system (http://ed25519.cr.yp.to/), using the\nportable 'ref' code from the 'SUPERCOP' benchmarking suite.\n\nThis system provides high (128-bit) security, short (32-byte) keys, short\n(64-byte) signatures, and fast (2-6ms) operation. Please see the README for\nmore details.\n"], "modules": [{"name": "ed25519.keys", "documentation": [], "functions": [{"name": "ed25519.keys.create_keypair", "asynchronous": false, "params": [{"name": "entropy", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "ed25519.keys.remove_prefix", "asynchronous": false, "params": [{"name": "s_bytes", "type": null, "default": null}, {"name": "prefix", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "ed25519.keys.to_ascii", "asynchronous": false, "params": [{"name": "s_bytes", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}], "returns": null, "documentation": ["Return a version-prefixed ASCII representation of the given binary\nstring. 'encoding' indicates how to do the encoding, and can be one of:\n * base64\n * base32\n * base16 (or hex)\n\nThis function handles bytes, not bits, so it does not append any trailing\n'=' (unlike standard base64.b64encode). It also lowercases the base32\noutput.\n\n'prefix' will be prepended to the encoded form, and is useful for\ndistinguishing the purpose and version of the binary string. E.g. you\ncould prepend 'pub0-' to a VerifyingKey string to allow the receiving\ncode to raise a useful error if someone pasted in a signature string by\nmistake."]}, {"name": "ed25519.keys.from_ascii", "asynchronous": false, "params": [{"name": "s_ascii", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}], "returns": null, "documentation": ["This is the opposite of to_ascii. It will throw BadPrefixError if\nthe prefix is not found."]}, {"name": "ed25519.keys.selftest", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "ed25519.keys.BadSignatureError", "type": null, "documentation": []}], "classes": [{"name": "ed25519.keys.BadPrefixError", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "ed25519.keys.SigningKey", "bases": ["object"], "methods": [{"name": "ed25519.keys.SigningKey.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "sk_s", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}], "returns": null, "documentation": ["this can only be used to reconstruct a key created by create_keypair()."]}, {"name": "ed25519.keys.SigningKey.to_bytes", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "ed25519.keys.SigningKey.to_ascii", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "ed25519.keys.SigningKey.to_seed", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "ed25519.keys.SigningKey.__eq__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "them", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "ed25519.keys.SigningKey.get_verifying_key", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "ed25519.keys.SigningKey.sign", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "msg", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "ed25519.keys.VerifyingKey", "bases": ["object"], "methods": [{"name": "ed25519.keys.VerifyingKey.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "vk_s", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "ed25519.keys.VerifyingKey.to_bytes", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"