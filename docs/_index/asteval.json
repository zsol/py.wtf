method."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Find all symbol names used by a parsed node."]}, {"name": "asteval.astutils.Group", "bases": ["dict"], "methods": [{"name": "asteval.astutils.Group.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": "..."}, {"name": "searchgroups", "type": null, "default": "..."}, {"name": "**kws", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Group.__setattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Group.__getattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "default", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Group.__setitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Group.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}, {"name": "default", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Group.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Group._repr_html_", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["HTML representation for Jupyter notebook"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Group: a container of objects that can be accessed either as an object attributes\nor dictionary  key/value.  Attribute names must follow Python naming conventions."]}, {"name": "asteval.astutils.Procedure", "bases": [], "methods": [{"name": "asteval.astutils.Procedure.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "interp", "type": null, "default": null}, {"name": "doc", "type": null, "default": "..."}, {"name": "lineno", "type": null, "default": "..."}, {"name": "body", "type": null, "default": "..."}, {"name": "args", "type": null, "default": "..."}, {"name": "kwargs", "type": null, "default": "..."}, {"name": "vararg", "type": null, "default": "..."}, {"name": "varkws", "type": null, "default": "..."}], "returns": null, "documentation": ["TODO: docstring in public method."]}, {"name": "asteval.astutils.Procedure.__setattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "attr", "type": null, "default": null}, {"name": "val", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Procedure.__dir__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Procedure._getdoc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Procedure.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["TODO: docstring in magic method."]}, {"name": "asteval.astutils.Procedure._signature", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.astutils.Procedure.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["TODO: docstring in public method."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Procedure: user-defined function for asteval.\n\nThis stores the parsed ast nodes as from the 'functiondef' ast node\nfor later evaluation."]}], "exports": []}, {"name": "asteval.asteval", "documentation": ["Safe(ish) evaluation of minimal Python code using Python's ast module.\n\nThis module provides an Interpreter class that compiles a restricted set of\nPython expressions and statements to Python's AST representation, and then\nexecutes that representation using values held in a symbol table.\n\nThe symbol table is a simple dictionary, giving a flat namespace.  This comes\npre-loaded with many functions from Python's builtin and math module.  If numpy\nis installed, many numpy functions are also included.  Additional symbols can\nbe added when an Interpreter is created, but the user of that interpreter will\nnot be able to import additional modules.\n\nExpressions, including loops, conditionals, and function definitions can be\ncompiled into ast node and then evaluated later, using the current values\nin the symbol table.\n\nThe result is a restricted, simplified version of Python meant for numerical\ncalculations that is somewhat safer than 'eval' because many unsafe operations\n(such as 'eval') are simply not allowed, and others (such as 'import') are\ndisabled by default, but can be explicitly enabled.\n\nMany parts of Python syntax are supported, including:\n     for loops, while loops, if-then-elif-else conditionals, with,\n     try-except-finally\n     function definitions with def\n     advanced slicing:    a[::-1], array[-3:, :, ::2]\n     if-expressions:      out = one_thing if TEST else other\n     list, dict, and set comprehension\n\nThe following Python syntax elements are not supported:\n     Import, Exec, Lambda, Class, Global, Generators,\n     Yield, Decorators\n\nIn addition, while many builtin functions are supported, several builtin\nfunctions that are considered unsafe are missing ('eval', 'exec', and\n'getattr' for example) are missing.", "!/usr/bin/env python"], "functions": [], "variables": [{"name": "asteval.asteval.ALL_NODES", "type": null, "documentation": []}, {"name": "asteval.asteval.MINIMAL_CONFIG", "type": null, "documentation": []}, {"name": "asteval.asteval.DEFAULT_CONFIG", "type": null, "documentation": []}], "classes": [{"name": "asteval.asteval.Interpreter", "bases": [], "methods": [{"name": "asteval.asteval.Interpreter.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "symtable", "type": null, "default": "..."}, {"name": "nested_symtable", "type": null, "default": "..."}, {"name": "user_symbols", "type": null, "default": "..."}, {"name": "writer", "type": null, "default": "..."}, {"name": "err_writer", "type": null, "default": "..."}, {"name": "use_numpy", "type": null, "default": "..."}, {"name": "max_statement_length", "type": null, "default": "..."}, {"name": "minimal", "type": null, "default": "..."}, {"name": "readonly_symbols", "type": null, "default": "..."}, {"name": "builtins_readonly", "type": null, "default": "..."}, {"name": "config", "type": null, "default": "..."}, {"name": "**kws", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "asteval.asteval.Interpreter.remove_nodehandler", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": null, "default": null}], "returns": null, "documentation": ["remove support for a node\nreturns current node handler, so that it\nmight be re-added with add_nodehandler()"]}, {"name": "asteval.asteval.Interpreter.set_nodehandler", "asynchronous": f