tation": []}, {"name": "owocr.run.engine_change_handler", "asynchronous": false, "params": [{"name": "user_input", "type": null, "default": "..."}, {"name": "is_combo", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "owocr.run.user_input_thread_run", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "owocr.run.on_key_press", "asynchronous": false, "params": [{"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.on_key_release", "asynchronous": false, "params": [{"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.on_screenshot_combo", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "owocr.run.signal_handler", "asynchronous": false, "params": [{"name": "sig", "type": null, "default": null}, {"name": "frame", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.on_window_closed", "asynchronous": false, "params": [{"name": "alive", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.on_window_activated", "asynchronous": false, "params": [{"name": "active", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.on_window_minimized", "asynchronous": false, "params": [{"name": "minimized", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.on_window_resized", "asynchronous": false, "params": [{"name": "size", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.on_window_moved", "asynchronous": false, "params": [{"name": "pos", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.normalize_macos_clipboard", "asynchronous": false, "params": [{"name": "img", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.are_images_identical", "asynchronous": false, "params": [{"name": "img1", "type": null, "default": null}, {"name": "img2", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.process_and_write_results", "asynchronous": false, "params": [{"name": "img_or_path", "type": null, "default": null}, {"name": "write_to", "type": null, "default": null}, {"name": "notifications", "type": null, "default": null}, {"name": "last_result", "type": null, "default": null}, {"name": "filtering", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.get_path_key", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.init_config", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "owocr.run.run", "asynchronous": false, "params": [{"name": "read_from", "type": null, "default": "..."}, {"name": "write_to", "type": null, "default": "..."}, {"name": "engine", "type": null, "default": "..."}, {"name": "pause_at_startup", "type": null, "default": "..."}, {"name": "ignore_flag", "type": null, "default": "..."}, {"name": "delete_images", "type": null, "default": "..."}, {"name": "notifications", "type": null, "default": "..."}, {"name": "auto_pause", "type": null, "default": "..."}, {"name": "combo_pause", "type": null, "default": "..."}, {"name": "combo_engine_switch", "type": null, "default": "..."}, {"name": "screen_capture_monitor", "type": null, "default": "..."}, {"name": "screen_capture_coords", "type": null, "default": "..."}, {"name": "screen_capture_delay_secs", "type": null, "default": "..."}, {"name": "screen_capture_only_active_windows", "type": null, "default": "..."}, {"name": "screen_capture_combo", "type": null, "default": "..."}], "returns": null, "documentation": ["Japanese OCR client\n\nRuns OCR in the background.\nIt can read images copied to the system clipboard or placed in a directory, images sent via a websocket or a Unix domain socket, or directly capture a screen (or a portion of it) or a window.\nRecognized texts can be either saved to system clipboard, appended to a text file or sent via a websocket.\n\n```\nparam read_from\n\nSpecifies where to read input images from. Can be either \"clipboard\", \"websocket\", \"unixsocket\" (on macOS/Linux), \"screencapture\", or a path to a directory.\n\nparam write_to\n\nSpecifies where to save recognized texts to. Can be either \"clipboard\", \"websocket\", or a path to a text file.\n\nparam delay_secs\n\nHow often to check for new images, in seconds.\n\nparam engine\n\nOCR engine to use. Available: \"mangaocr\", \"glens\", \"gvision\", \"avision\", \"alivetext\", \"azure\", \"winrtocr\", \"easyocr\", \"rapidocr\".\n\nparam pause_at_startup\n\nPause at startup.\n\nparam ignore_flag\n\nProcess flagged clipboard images (images that are copied to the clipboard with the ocr_ignore string).\n\nparam delete_images\n\nDelete image files after processing when reading from a directory.\n\nparam notifications\n\nShow an operating system notification with the detected text.\n\nparam auto_pause\n\nAutomatically pause the program after the specified amount of seconds since the last successful text recognition. Will be ignored when reading with screen capture. 0 to disable.\n\nparam combo_pause\n\nSpecifies a combo to wait on for pausing the program. As an example: \"<ctrl>+<shift>+p\". The list of keys can be found here: https://pynput.readthedocs.io/en/latest/keyboard.html#pynput.keyboard.Key\n\nparam combo_engine_switch\n\nSpecifies a combo to wait on for switching the OCR engine. As an example: \"<ctrl>+<shift>+a\". To be used with combo_pause. The list of keys can be found here: https://pynput.readthedocs.io/en/latest/keyboard.html#pynput.keyboard.Key\n\nparam screen_capture_monitor\n\nSpecifies monitor to target when reading with screen capture. Will be ignored when screen_capture_coords is a window name.\n\nparam screen_capture_coords\n\nSpecifies area to target when reading with screen capture. Can be either empty (whole screen), a set of coordinates (x,y,width,height) or a window name (the first matching window title will be used).\n\nparam screen_capture_delay_secs\n\nSpecifies the delay (in seconds) between screenshots when reading with screen capture.\n\nparam screen_capture_only_active_windows\n\nWhen reading with screen capture and screen_capture_coords is a window name, specifies whether to only target the window while it's active.\n\nparam screen_capture_combo\n\nWhen reading with screen capture, specifies a combo to wait on for taking a screenshot instead of using the delay. As an example: \"<ctrl>+<shift>+s\". The list of keys can be found here: https://pynput.readthedocs.io/en/latest/keyboard.html#pynput.keyboard.Key\n```\n"]}], "variables": [{"name": "owocr.run.config", "type": null, "documentation": []}], "classes": [{"name": "owocr.run.WindowsClipboardThread", "bases": ["threading.Thread"], "methods": [{"name": "owocr.run.WindowsClipboardThread.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.WindowsClipboardThread.process_message", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "hwnd", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "msg", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "wparam", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "lparam", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "owocr.run.WindowsClipboar