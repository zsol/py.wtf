ble._to_key", "asynchronous": false, "params": [{"name": "key", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "Key", "xref": {"fqname": "pynput.keyboard.Key", "project": "pynput"}, "params": null}, {"name": "KeyCode", "xref": {"fqname": "pynput.keyboard.KeyCode", "project": "pynput"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "botable.botable.record", "asynchronous": false, "params": [{"name": "exit_key", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "pause_key", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Iterator", "xref": {"fqname": "typing.Iterator", "project": "--std--"}, "params": [{"name": "ButtonEvent", "xref": {"fqname": "botable.button_event.ButtonEvent", "project": null}, "params": null}]}, "documentation": ["Launch the recording, yielding the keyboard and mouse click events as they occur.\nPressing the `exit_key` will terminate the recording.\nPressing the `pause_key` will pause/resume the recording."]}, {"name": "botable.botable.play", "asynchronous": false, "params": [{"name": "button_events", "type": {"name": "Iterable", "xref": {"fqname": "typing.Iterable", "project": "--std--"}, "params": [{"name": "ButtonEvent", "xref": {"fqname": "botable.button_event.ButtonEvent", "project": null}, "params": null}]}, "default": null}, {"name": "exit_key", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "pause_key", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "loops", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "rate", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "delay", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "offset", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "verbose", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Waits `delay` and then iterates on `events` to play them,\n  optionally playing them at a modified speed `rate`,\n  optionally skipping the first `offset` events,\n  optionally logging the played events if `verbose`.\nOnce `button_events` is exhausted the entire collected set of event will optionally be replayed additional times if `loops` > 1.\nPressing the `exit_key` will terminate the recording.\nPressing the `pause_key` will pause/resume the recording."]}], "variables": [{"name": "botable.botable.RECORDING", "type": null, "documentation": []}, {"name": "botable.botable.PLAYING", "type": null, "documentation": []}], "classes": [], "exports": []}]}