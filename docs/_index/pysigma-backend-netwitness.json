", "project": "--std--"}, "params": null}, {"name": "DeferredQueryExpression", "xref": {"fqname": "sigma.conversion.deferred.DeferredQueryExpression", "project": "pysigma"}, "params": null}]}, "documentation": ["Conversion of NOT conditions\n\nArgs:\n    cond (ConditionNOT): NOT Condition object that should be converted\n    state (ConversionState): State of the conversion\n\nRaises:\n    NotImplementedError: If something isn't supported by the backend\n\nReturns:\n    Union[str, DeferredQueryExpression]: Generated query"]}, {"name": "sigma.backends.netwitness.netwitness.NetWitnessBackend.convert_condition_field_eq_expansion", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cond", "type": {"name": "ConditionFieldEqualsValueExpression", "xref": {"fqname": "sigma.conditions.ConditionFieldEqualsValueExpression", "project": "pysigma"}, "params": null}, "default": null}, {"name": "state", "type": {"name": "ConversionState", "xref": {"fqname": "sigma.conversion.state.ConversionState", "project": "pysigma"}, "params": null}, "default": null}], "returns": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": ["Converting expansion conditions like windash, contains, base64 e.g.\n\nArgs:\n    cond (ConditionFieldEqualsValueExpression): Condition that should be converted\n    state (ConversionState): State of the conversion\n\nRaises:\n    ValueError: If the method will be called with a condition that isn't a 'SigmaExpansion'\n\nReturns:\n    Any: Query as string or DeferredQueryExpression"]}, {"name": "sigma.backends.netwitness.netwitness.NetWitnessBackend.decide_convert_condition_as_in_expression", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cond", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "ConditionOR", "xref": {"fqname": "sigma.conditions.ConditionOR", "project": "pysigma"}, "params": null}, {"name": "ConditionAND", "xref": {"fqname": "sigma.conditions.ConditionAND", "project": "pysigma"}, "params": null}]}, "default": null}, {"name": "state", "type": {"name": "ConversionState", "xref": {"fqname": "sigma.conversion.state.ConversionState", "project": "pysigma"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Decide if an OR or AND expression should be converted as \"field in (value list)\" or as plain expression.\n\nArgs:\n    cond (Union[ConditionOR, ConditionAND]): Condition that is converted for which the decision has to be made\n    state (ConversionState): Current conversion state\n\nReturns:\n    bool: True if in-expression should be generated, else False"]}, {"name": "sigma.backends.netwitness.netwitness.NetWitnessBackend.is_contains", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "arg", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "ConditionFieldEqualsValueExpression", "xref": {"fqname": "sigma.conditions.ConditionFieldEqualsValueExpression", "project": "pysigma"}, "params": null}, {"name": "ConditionValueExpression", "xref": {"fqname": "sigma.conditions.ConditionValueExpression", "project": "pysigma"}, "params": null}]}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Checks if an given argument is a contains expression\n\nArgs:\n    arg (Union[ConditionFieldEqualsValueExpression, ConditionValueExpression]): Argument to check\n\nReturns:\n    bool: True if contains statement, False otherwise"]}, {"name": "sigma.backends.netwitness.netwitness.NetWitnessBackend.is_begins", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "arg", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "ConditionFieldEqualsValueExpression", "xref": {"fqname": "sigma.conditions.ConditionFieldEqualsValueExpression", "project": "pysigma"}, "params": null}, {"name": "ConditionValueExpression", "xref": {"fqname": "sigma.conditions.ConditionValueExpression", "project": "pysigma"}, "params": null}]}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Checks if an given argument is a begins expression\n\nArgs:\n    arg (Union[ConditionFieldEqualsValueExpression, ConditionValueExpression]): Argument to check\n\nReturns:\n    bool: True if begins statement, False otherwise"]}, {"name": "sigma.backends.netwitness.netwitness.NetWitnessBackend.is_ends", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "arg", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "ConditionFieldEqualsValueExpression", "xref": {"fqname": "sigma.conditions.ConditionFieldEqualsValueExpression", "project": "pysigma"}, "params": null}, {"name": "ConditionValueExpression", "xref": {"fqname": "sigma.conditions.ConditionValueExpression", "project": "pysigma"}, "params": null}]}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Checks if an given argument is an ends expression\n\nArgs:\n    arg (Union[ConditionFieldEqualsValueExpression, ConditionValueExpression]): Argument to check\n\nReturns:\n    bool: True if ends statement, False otherwise"]}, {"name": "sigma.backends.netwitness.netwitness.NetWitnessBackend.unpack_condition_if_necessary", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cond", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "ConditionOR", "xref": {"fqname": "sigma.conditions.ConditionOR", "project": "pysigma"}, "params": null}, {"name": "ConditionAND", "xref": {"fqname": "sigma.conditions.ConditionAND", "project": "pysigma"}, "params": null}]}, "default": null}], "returns": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "ConditionOR", "xref": {"fqname": "sigma.conditions.ConditionOR", "project": "pysigma"}, "params": null}, {"name": "ConditionAND", "xref": {"fqname": "sigma.conditions.ConditionAND", "project": "pysigma"}, "params": null}]}, "documentation": ["This method checks if a condition needs unpacking. If the condition contains arguments with values\nthat have the SigmaExpansion type unpacking is necessary for NetWitness. This will convert the SigmaExpansion\nvalue into normal ConditionFieldEqualsValueExpression which then can be used to turn into a list. Therefore\nqueries will get shorter.\n\nArgs:\n    cond (Union[ConditionOR, ConditionAND]): Condition that should be unpacked if necessary\n\nReturns:\n    Union[ConditionOR, ConditionAND]: Updated condition or unchanged if not necessary"]}, {"name": "sigma.backends.netwitness.netwitness.NetWitnessBackend.convert_or_expressions_into_sub_expressions", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cond", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "ConditionOR", "xref": {"fqname": "sigma.conditions.ConditionOR", "project": "pysigma"}, "params": null}, {"name": "ConditionAND", "xref": {"fqname": "sigma.conditions.ConditionAND", "project": "pysigma"}, "params": null}]}, "default": null}, {"name": "state", "type": {"name": "ConversionState", "xref": {"fqname": "sigma.conversion.state.ConversionState", "project": "pysigma"}, "params": null}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "DeferredQueryExpression", "xref": {"fqname": "sigma.conversion.deferred.DeferredQueryExpression", "project": "pysigma"}, "params": null}]}]}, "documentation": ["Converts a condition into sub expressions. This is used to generate smaller expressions\nfor NetWitness. Generally expressions like fieldA = 'foo' || fieldA = 'bar' can be summarized\nas fieldA = 'foo','bar'. This also works for modifiers like contains, begins, ends e.g. but for\nthem the standard implementation of pySigma doesn't generates lists. So this is the implementation\nfor that. The implementation also supports multiple modifiers in the condition which will then\nget seperatly summarized.\n\nArgs:\n    cond (Union[ConditionOR, ConditionAND]): Conditions that should be used for the conversion\n    state (ConversionState): Conversion state that is passed to sub methods\n\nRaises:\n    SigmaConversionError: If field_in_list_expression is not set\n    SigmaConversionError: If or_in_operator is not set\n\nReturns:\n    list[Union[str, DeferredQueryExpression]]: List of generated sub expressions"]}, {"name": "sigma.backends.netwitness.netwitness.NetWitnessBackend.convert_condition_as_in_expression", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cond", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "ConditionOR", "xref": {"fqname": "sigma.conditions.ConditionOR", "project": "pysigma"}, "params": null}, {"name": "ConditionAND", "xref": {"fqname": "sigma.conditions.ConditionAND", "project": "pysigma"}, "params": null}]}, "default": null}, {"name": "state", "type": {"name": "ConversionState", "xref": {"fqname": "sigma.conversion.state.ConversionState", "project": "pysigma"}, "params": null}, "default": null}], "returns": {"name": "Union", "xref": {"fqname": "typing.Union", "