ame": "app.server.ApplyChangesRequest.diff", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "app.server.ApplyChangesRequest.filePath", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "app.server.TokenCountRequest", "bases": ["BaseModel"], "methods": [], "class_variables": [{"name": "app.server.TokenCountRequest.text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "app.utils.version_util", "documentation": [], "functions": [{"name": "app.utils.version_util.get_latest_version", "asynchronous": false, "params": [], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}, {"name": "app.utils.version_util.update_package", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "app.utils.version_util.get_current_version", "asynchronous": false, "params": [], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "app.utils", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "app.utils.code_util", "documentation": [], "functions": [{"name": "app.utils.code_util.use_git_to_apply_code_diff", "asynchronous": false, "params": [{"name": "git_diff", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Apply a git diff to the user's codebase.\n\nThis function takes a git diff as a string and applies it to the user's codebase\nspecified by the ZIYA_USER_CODEBASE_DIR environment variable. It creates a temporary\nfile with the diff content and uses the 'git apply' command to apply the changes.\n\nArgs:\n    git_diff (str): A string containing the git diff to be applied.\n\nNote:\n    This function assumes that the git command-line tool is available in the system path.\n    It uses the --ignore-whitespace and --ignore-space-change options with 'git apply'\n    to handle potential whitespace issues."]}, {"name": "app.utils.code_util.correct_git_diff", "asynchronous": false, "params": [{"name": "git_diff", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "original_file_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Corrects the hunk headers in a git diff string by recalculating the line counts and\nadjusting the starting line numbers in the new file, considering the cumulative effect of\nprevious hunks.\n\nThe function assumes that the `start_line_old` values in the hunk headers are correct,\nbut the line counts and `start_line_new` may be incorrect due to manual edits or errors.\n\nParameters:\n    git_diff (str): The git diff string to be corrected. It may contain multiple hunks\n    original_file_path (str): Path to the original file to calculate correct start_line_old\n                    and incorrect hunk headers.\n\nReturns:\n    str: The git diff string with corrected hunk headers.\n\nThe function works by parsing the diff, recalculating the line counts for each hunk,\nadjusting the `start_line_new` values based on the cumulative changes from previous hunks,\nand reconstructing the diff with corrected hunk headers.\n\nNotes:\n    - The diff is expected to be in unified diff format.\n    - Lines starting with '+++', '---', or other file headers are not treated as additions or deletions.\n    - Context lines are lines that do not start with '+', '-', or '@@'.\n    - All lines in the hunk (including empty lines) are considered in the counts."]}, {"name": "app.utils.code_util._find_correct_old_start_line", "asynchronous": false, "params": [{"name": "original_content", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}, {"name": "hunk_lines", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["Finds the correct starting line number in the original file by matching context and deleted lines.\n\nParameters:\n    original_content (list): List of lines from the original file\n    hunk_lines (list): List of lines in the current hunk\n\nReturns:\n    int: The correct 1-based line number where the hunk should start in the original file\n\nThe function works by:\n1. Extracting context and deleted lines from the hunk (ignoring added lines)\n2. Creating a pattern from these lines\n3. Finding where this pattern matches in the original file\n4. Converting the matching position to a 1-based line number"]}, {"name": "app.utils.code_util._process_hunk_with_original_content", "asynchronous": false, "params": [{"name": "lines", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}, {"name": "start_index", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "cumulative_line_offset", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "original_content", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Processes a single hunk starting at start_index in lines, recalculates the line counts,\nand returns the corrected hunk header, hunk lines, and the updated index after the hunk.\n\nParameters:\n    lines (list): The list of lines from the diff.\n    start_index (int): The index in lines where the hunk header is located.\n    cumulative_line_offset (int): The cumulative line offset from previous hunks.\n    original_content (list): List of lines from the original file.\n\nReturns:\n    tuple:\n        - corrected_hunk_header (str): The corrected hunk header.\n        - hunk_lines (list): The list of lines in the hunk (excluding the hunk header).\n        - end_index (int): The index in lines after the hunk.\n        - line_offset (int): The line offset caused by this hunk (to adjust future hunks).\n\nThe function reads the hunk lines, counts the number of lines in the original and new files,\nand adjusts the starting line number in the new file based on cumulative changes."]}, {"name": "app.utils.code_util._format_hunk_header", "asynchronous": false, "params": [{"name": "start_old", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "count_old", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "start_new", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "count_new", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Formats the hunk header according to git diff syntax, omitting counts when they are 1.\n\nParameters:\n    start_old (int): Starting line number in the original file.\n    count_old (int): Number of lines in the hunk in the original file.\n    start_new (int): Starting line number in the new file.\n    count_new (int): Number of lines in the hunk in the new file.\n\nReturns:\n    str: The formatted hunk header.\n\nThe hunk header format is:\n    @@ -start_old[,count_old] +start_new[,count_new] @@\n\nIf count_old or count_new is 1, the count is omitted."]}], "variables": [{"name": "app.utils.code_util.HUNK_HEADER_REGEX", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "app.utils.sanitizer_util", "documentation": ["lets move sanitizers here to clean up code flow and make them reusable"], "functions": [{"name": "app.utils.sanitizer_util.clean_backtick_sequences", "asynchronous": false, "params": [{"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Cleans up problematic backtick sequences while preserving content within code blocks.\nEnsures all code blocks are properly closed.\n\nArgs:\n    text (str): The input text containing potential backtick sequences\n    \nReturns:\n    str: Text with properly closed code blocks and preserved content"]}], "variables": [], "classes": [], "exports": []}, {"name": "app.utils.directory_util", "documentation": [], "functions": [{"name": "app.utils.directory_util.get_ignored_patterns", "asynchronous": false, "params": [{"name": "directory", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Tuple",