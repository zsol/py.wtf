{"name": "executor-invest-helper", "metadata": {"name": "executor-invest-helper", "version": "0.1", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/sazonovvladimir/invest_helper_bot", "license": null, "documentation_url": null, "dependencies": [], "summary": "Database Executor for Invest Helper", "upload_time": 1732863567}, "documentation": ["# Database executor\n\n**\u0422\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0435 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435:** executor_invest_helper\n\n## \u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435\n\nDatabase executor \u2014 \u044d\u0442\u043e \u043c\u043e\u0449\u043d\u044b\u0439 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442 \u0434\u043b\u044f \u0432\u0437\u0430\u0438\u043c\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f \u0441 \u0431\u0430\u0437\u043e\u0439 \u0434\u0430\u043d\u043d\u044b\u0445 \u043c\u0435\u0433\u0430-\u043a\u0440\u0443\u0442\u043e\u0433\u043e \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c-\u0431\u043e\u0442\u0430 \u043f\u0440\u043e \u0438\u043d\u0432\u0435\u0441\u0442\u0438\u0446\u0438\u0438. \u042d\u0442\u043e\u0442 \u043f\u0430\u043a\u0435\u0442 \u0443\u043f\u0440\u043e\u0449\u0430\u0435\u0442 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0435 \u0437\u0430\u043f\u0440\u043e\u0441\u043e\u0432 \u043a \u0431\u0430\u0437\u0435 \u0434\u0430\u043d\u043d\u044b\u0445 \u0438 \u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0434\u0430\u043d\u043d\u044b\u043c\u0438, \u0447\u0442\u043e \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0447\u0438\u043a\u0430\u043c \u0441\u043e\u0441\u0440\u0435\u0434\u043e\u0442\u043e\u0447\u0438\u0442\u044c\u0441\u044f \u043d\u0430 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u0438 \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u0430 \u0431\u043e\u0442\u0430.\n\n## \u0423\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0430\n\n\u0414\u043b\u044f \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0438 \u043f\u0430\u043a\u0435\u0442\u0430 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 pip:\n\n```bash\npip install executor_invest_helper\n"], "modules": [{"name": "executor.duckdb_executor", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "executor.duckdb_executor.DuckDBManager", "bases": [], "methods": [{"name": "executor.duckdb_executor.DuckDBManager.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "db_name", "type": null, "default": "..."}], "returns": null, "documentation": ["Initialize the DuckDB connection."]}, {"name": "executor.duckdb_executor.DuckDBManager.insert_data", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "table_name", "type": null, "default": null}, {"name": "data", "type": null, "default": null}], "returns": null, "documentation": ["Insert a list of dictionaries into a specified DuckDB table.\n\nParameters:\n- table_name (str): The name of the table to insert data into.\n- data (list): A list of dictionaries containing the data to insert."]}, {"name": "executor.duckdb_executor.DuckDBManager.execute_query", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "query", "type": null, "default": null}], "returns": null, "documentation": ["Execute an arbitrary SQL query against DuckDB.\n\nParameters:\n- query (str): The SQL query to execute.\n\nReturns:\n- result: The result of the query execution."]}, {"name": "executor.duckdb_executor.DuckDBManager.close", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Close the DuckDB connection."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "e