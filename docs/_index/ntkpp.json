{"name": "ntkpp", "metadata": {"name": "NTkpp", "version": "0.0.2.5", "classifiers": [], "home_page": null, "license": null, "documentation_url": null, "dependencies": ["numpy"], "summary": "\u041f\u0440\u043e\u0441\u0442\u0430\u044f \u0431\u0438\u0431\u043b\u0438\u043e\u0442\u0435\u043a\u0430 \u0434\u043b\u044f \u043f\u043e\u043b\u043d\u043e\u0441\u0432\u044f\u0437\u043d\u044b\u0445 \u043d\u0435\u0439\u0440\u043e\u043d\u043d\u044b\u0445 \u0441\u0435\u0442\u0435\u0439", "upload_time": 1733149166}, "documentation": [""], "modules": [{"name": "NTPKKP.activations", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "NTPKKP.activations.ReLU", "bases": [], "methods": [{"name": "NTPKKP.activations.ReLU.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "z", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 ReLU \u0434\u043b\u044f \u0432\u0445\u043e\u0434\u043d\u043e\u0433\u043e \u043c\u0430\u0441\u0441\u0438\u0432\u0430 z.\nReLU(z) = max(0, z)\n\n\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b:\nz (ndarray): \u0412\u0445\u043e\u0434\u043d\u043e\u0439 \u043c\u0430\u0441\u0441\u0438\u0432.\n\n\u0412\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442:\nndarray: \u041c\u0430\u0441\u0441\u0438\u0432 \u043f\u043e\u0441\u043b\u0435 \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0444\u0443\u043d\u043a\u0446\u0438\u0438 ReLU."]}, {"name": "NTPKKP.activations.ReLU.derivative", "asynchronous": false, "params": [{"name": "z", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u0443\u044e \u0444\u0443\u043d\u043a\u0446\u0438\u0438 ReLU \u043f\u043e \u0432\u0445\u043e\u0434\u0443 z.\n\u041f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u0430\u044f \u0440\u0430\u0432\u043d\u0430 1 \u0434\u043b\u044f z > 0 \u0438 0 \u0434\u043b\u044f z <= 0.\n\n\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b:\nz (ndarray): \u0412\u0445\u043e\u0434\u043d\u043e\u0439 \u043c\u0430\u0441\u0441\u0438\u0432.\n\n\u0412\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442:\nndarray: \u041c\u0430\u0441\u0441\u0438\u0432 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0439 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u043e\u0439 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 ReLU."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["\u041a\u043b\u0430\u0441\u0441 \u0434\u043b\u044f \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0430\u043a\u0442\u0438\u0432\u0430\u0446\u0438\u0438 ReLU (Rectified Linear Unit)."]}, {"name": "NTPKKP.activations.Sigmoid", "bases": [], "methods": [{"name": "NTPKKP.activations.Sigmoid.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "z", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435 \u0441\u0438\u0433\u043c\u043e\u0438\u0434\u043d\u043e\u0439 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0434\u043b\u044f \u0432\u0445\u043e\u0434\u043d\u043e\u0433\u043e \u043c\u0430\u0441\u0441\u0438\u0432\u0430 z.\nSigmoid(z) = 1 / (1 + exp(-z))\n\n\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b:\nz (ndarray): \u0412\u0445\u043e\u0434\u043d\u043e\u0439 \u043c\u0430\u0441\u0441\u0438\u0432.\n\n\u0412\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442:\nndarray: \u041c\u0430\u0441\u0441\u0438\u0432 \u043f\u043e\u0441\u043b\u0435 \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0441\u0438\u0433\u043c\u043e\u0438\u0434\u044b."]}, {"name": "NTPKKP.activations.Sigmoid.derivative", "asynchronous": false, "params": [{"name": "z", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u0443\u044e \u0441\u0438\u0433\u043c\u043e\u0438\u0434\u043d\u043e\u0439 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u043f\u043e \u0432\u0445\u043e\u0434\u0443 z.\n\u041f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u0430\u044f: sigmoid(z) * (1 - sigmoid(z))\n\n\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b:\nz (ndarray): \u0412\u0445\u043e\u0434\u043d\u043e\u0439 \u043c\u0430\u0441\u0441\u0438\u0432.\n\n\u0412\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442:\nndarray: \u041c\u0430\u0441\u0441\u0438\u0432 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0439 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u043e\u0439 \u0441\u0438\u0433\u043c\u043e\u0438\u0434\u044b."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["\u041a\u043b\u0430\u0441\u0441 \u0434\u043b\u044f \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0430\u043a\u0442\u0438\u0432\u0430\u0446\u0438\u0438 \u0441\u0438\u0433\u043c\u043e\u0438\u0434\u044b"]}, {"name": "NTPKKP.activations.Tanh", "bases": [], "methods": [{"name": "NTPKKP.activations.Tanh.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "z", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0433\u0438\u043f\u0435\u0440\u0431\u043e\u043b\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0442\u0430\u043d\u0433\u0435\u043d\u0441\u0430 \u0434\u043b\u044f z.\nTanh(z) = tanh(z)\n\n\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b:\nz (ndarray): \u0412\u0445\u043e\u0434\u043d\u043e\u0439 \u043c\u0430\u0441\u0441\u0438\u0432.\n\n\u0412\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442:\nndarray: \u041c\u0430\u0441\u0441\u0438\u0432 \u043f\u043e\u0441\u043b\u0435 \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f tanh."]}, {"name": "NTPKKP.activations.Tanh.derivative", "asynchronous": false, "params": [{"name": "z", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u0443\u044e \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0433\u0438\u043f\u0435\u0440\u0431\u043e\u043b\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0442\u0430\u043d\u0433\u0435\u043d\u0441\u0430 \u043f\u043e \u0432\u0445\u043e\u0434\u0443 z.\n\u041f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u0430\u044f: 1 - tanh(z)^2\n\n\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b:\nz (ndarray): \u0412\u0445\u043e\u0434\u043d\u043e\u0439 \u043c\u0430\u0441\u0441\u0438\u0432.\n\n\u0412\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442:\nndarray: \u041c\u0430\u0441\u0441\u0438\u0432 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0439 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u043e\u0439 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 tanh."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["\u041a\u043b\u0430\u0441\u0441 \u0434\u043b\u044f \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0430\u043a\u0442\u0438\u0432\u0430\u0446\u0438\u0438 Tanh (\u0433\u0438\u043f\u0435\u0440\u0431\u043e\u043b\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0442\u0430\u043d\u0433\u0435\u043d\u0441).", "\u041a\u043b\u0430\u0441\u0441 \u0434\u043b\u044f \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0430\u043a\u0442\u0438\u0432\u0430\u0446\u0438\u0438 \u0433\u0438\u043f\u0435\u0440\u0431\u043e\u043b\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0442\u0430\u043d\u0433\u0435\u043d\u0441\u0430"]}, {"name": "NTPKKP.activations.Softmax", "bases": [], "methods": [{"name": "NTPKKP.activations.Softmax.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "z", "type": null, "default": null}], "returns": null, "documentation": ["\u0412\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435 \u0444\u0443\u043d\u043a\u0446\u0438\u0438 Softmax \u0434\u043b\u044f \u0432\u0445\u043e\u0434\u043d\u043e\u0433\u043e \u043c\u0430\u0441\u0441\u0438\u0432\u0430 z.\nSoftmax(z) = exp(z) / sum(exp(z))\n\n\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b:\nz (ndarray): \u0412\u0445\u043e\u0434\u043d\u043e\u0439 \u043c\u0430\u0441\u0441\u0438\u0432.\n\n\u0412\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442:\nndarray: \u041c\u0430\u0441\u0441\u0438\u0432 \u043f\u043e\u0441\u043b\u0435 \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u044f Softmax."]}, {"name": "NTPKKP.activations.Softmax.derivative", "asynchronous": false, "params": [{"name": "z", "type": null, "default": null}], "returns": null, "documentation": ["\u0417\u0430\u0433\u043b\u0443\u0448\u043a\u0430 \u0434\u043b\u044f \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u043e\u0439 Softmax.\n\u041f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u043d\u0430\u044f Softmax \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0431\u043e\u043b\u0435\u0435 \u0441\u043b\u043e\u0436\u043d\u043e\u0439, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u0437\u0434\u0435\u0441\u044c \u043e\u043d\u0430 \u0443\u043f\u0440\u043e\u0449\u0435\u043d\u0430."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["\u041a\u043b\u0430\u0441\u0441 \u0434\u043b\u044f \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0430\u043a\u0442\u0438\u0432\u0430\u0446\u0438\u0438 Softmax.", "\u041a\u043b\u0430\u0441\u0441 \u0434\u043b\u044f \u0444\u0443\u043d\u043a\u0446\u0438\u0438 \u0430\u043a\u0442\u0438\u0432\u0430\u0446\u0438\u0438 Softmax"]}], "exports": []}, {"name": "NTPKKP", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [