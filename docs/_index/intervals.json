argument:\n\n   ```\n   >>> range = IntInterval(34)\n   >>> range.lower == range.upper == 34\n   True\n   ```\n\n4. Object argument:\n\n   ```\n   >>> range = IntInterval(IntInterval((20, 30)))\n   >>> range.lower\n   20\n   >>> range.upper\n   30\n   ```\n"]}, {"name": "intervals.interval.AbstractInterval.open", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "lower_bound", "type": null, "default": null}, {"name": "upper_bound", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "intervals.interval.AbstractInterval.closed", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "lower_bound", "type": null, "default": null}, {"name": "upper_bound", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "intervals.interval.AbstractInterval.open_closed", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "lower_bound", "type": null, "default": null}, {"name": "upper_bound", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "intervals.interval.AbstractInterval.closed_open", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "lower_bound", "type": null, "default": null}, {"name": "upper_bound", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "intervals.interval.AbstractInterval.greater_than", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "lower_bound", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "intervals.interval.AbstractInterval.at_least", "asynchronous