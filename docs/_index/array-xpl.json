json file\n* `--saveas_dat`: save the data as a text file\n* `--log_dir`: log directory\n\n### Evaluations\n\n* `--r2_score`: R^2 score of two arrays\n"], "modules": [{"name": "array_xpl.eval_metrics", "documentation": [], "functions": [{"name": "array_xpl.eval_metrics.r2_score", "asynchronous": false, "params": [{"name": "y_p", "type": null, "default": null}, {"name": "y_t", "type": null, "default": null}, {"name": "opt", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "array_xpl.utils", "documentation": [], "functions": [{"name": "array_xpl.utils.validate_length", "asynchronous": false, "params": [{"name": "opt", "type": null, "default": null}, {"name": "min_length", "type": null, "default": "..."}, {"name": "err_msg", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "array_xpl.utils.get_keys_ids", "asynchronous": false, "params": [{"name": "tags", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "array_xpl.utils.print_stats", "asynchronous": false, "params": [{"name": "arrays", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "array_xpl.utils.pretty_print", "asynchronous": false, "params": [{"name": "row", "type": null, "default": null}, {"name": "cell_width", "type": null, "default": null}, {"name": "sep", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "array_xpl.utils.print_table", "asynchronous": false, "params": [{"name": "contents", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "header", "type": {"name": "