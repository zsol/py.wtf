uent training/analysis procedures unless manually indicated.\n```\n"]}, {"name": "type_infer.base.BaseEngine", "bases": [], "methods": [{"name": "type_infer.base.BaseEngine.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "stable", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "type_infer.base.BaseEngine.infer", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "df", "type": null, "default": null}], "returns": {"name": "TypeInformation", "xref": {"fqname": "type_infer.base.TypeInformation", "project": null}, "params": null}, "documentation": ["Given a dataframe, infer the types of each column and return a TypeInformation object."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "type_infer.base.ENGINES", "bases": [], "methods": [], "class_variables": [{"name": "type_infer.base.ENGINES.RULE_BASED", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "type_infer.rule_based", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "type_infer.bert", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "type_infer.bert.core", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "type_infer.bert.core.BERType", "bases": ["BaseEngine"], "methods": [{"name": "type_infer.bert.core.BERType.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "stable", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "type_infer.bert.core.BERType.infer", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "df", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "i