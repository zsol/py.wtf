ist of alphanumeric characters\n  including _ and -.", "Copyright (c) 2020-2022, Adam Karpierz", "Licensed under the BSD license", "https://opensource.org/licenses/BSD-3-Clause"], "functions": [{"name": "lcov.gendesc.gen_description", "asynchronous": false, "params": [{"name": "input_filename", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}, {"name": "output_filename", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "default": null}], "returns": null, "documentation": ["Read text file INPUT_FILENAME and convert the contained description\nto a format as understood by genhtml, i.e.\n\n   TN:<test name>\n   TD:<test description>\n\nIf defined, write output to OUTPUT_FILENAME, otherwise to stdout.\n\nDie on error."]}, {"name": "lcov.gendesc.main", "asynchronous": false, "params": [{"name": "argv", "type": null, "default": "..."}], "returns": null, "documentation": ["Convert a test case description file into a format as understood\nby genhtml."]}], "variables": [{"name": "lcov.gendesc.tool_name", "type": null, "documentation": []}, {"name": "lcov.gendesc.lcov_version", "type": null, "documentation": ["+ `${abs_path(dirname($0))}/get_version.sh --full`"]}, {"name": "lcov.gendesc.lcov_url", "type": null, "documentation": []}], "classes": [], "exports": []}]}