sis.burst_interaction_overall_plot_low", "asynchronous": false, "params": [{"name": "burstinfo", "type": null, "default": null}, {"name": "fig_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._downstream_analysis.burst_interaction_overall_plot_high", "asynchronous": false, "params": [{"name": "burstinfo", "type": null, "default": null}, {"name": "fig_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._downstream_analysis.burst_info_summarize", "asynchronous": false, "params": [{"name": "infer_result_filename", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._downstream_analysis.affinity_burst", "asynchronous": false, "params": [{"name": "burst_info", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._downstream_analysis.burst_interactionlevel_positive", "asynchronous": false, "params": [{"name": "readfile_name", "type": null, "default": null}, {"name": "burst_info", "type": null, "default": null}, {"name": "cv2_info", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "burstlink.tools._burst_interactions", "documentation": ["-*- coding: utf-8 -*-"], "functions": [{"name": "burstlink.tools._burst_interactions.global_burst_link", "asynchronous": false, "params": [{"name": "grn_filename", "type": null, "default": null}, {"name": "counts_filename", "type": null, "default": null}, {"name": "save_filename", "type": null, "default": null}, {"name": "verbose1", "type": null, "default": null}, {"name": "verbose2", "type": null, "default": null}, {"name": "verbose3", "type": null, "default": null}, {"name": "test", "type": null, "default": null}, {"name": "verbose4", "type": null, "default": null}], "returns": null, "documentation": ["Inferface for inferring dynamic information including gene regulatory interaction and bursting kinetics from scRNA-seq data of two genes.\n\nParameters\n----------\ngrn_filename\n    The optional input for base-GRN based on scATAC-seq.\ncounts_filename\n    The input for scRNA-seq data file.\nsave_filename\n    The saved inferred file name.\nverbose1\n    Whether to output images.\n    If False, only the inferred results are outputed. If True, the inferred results with visualization images are outputed.\nverbose2\n    Whether to save images.\n    If False, the images are only shown in the runtime screen. If True, the images are saved as pdf format in a folder under the default path.\nverbose3\n    Whether to exhibit all images.\n    If 0, all images are exhibited. If 1, only visualization images are exhibited.\ntest\n    Whether to perform distributional test.\n    If False, distribution test is not performed. If True, gibbs samples are generated and distribution test is performed.\nverbose4\n    Whether to save the inferred results.\n    If False, the inferred results are not saved. If True, the inferred results are saved as csv format in a folder under the default path.\n\nReturns\n-------\nnp.array(['gene1', 'gene2', 'feedback1', 'feedback2', 'kon1', 'kon2', 'koff1', 'koff2', 'ksyn1', 'ksyn2', 'w', 'bs1', 'bs2', 'bf1', 'bf2', 'cv1', 'cv2', 'convergence', 'corr', 'NMI', 'cmi_given_x1', 'cmi_given_x2', 'sign_givenx1', 'sign_givenx2'])"]}, {"name": "burstlink.tools._burst_interactions.global_uni_burst_link", "asynchronous": false, "params": [{"name": "grn_filename", "type": null, "default": null}, {"name": "counts_filename", "type": null, "default": null}, {"name": "genename1", "type": null, "default": null}, {"name": "genename2", "type": null, "default": null}, {"name": "verbose1", "type": null, "default": null}, {"name": "verbose2", "type": null, "default": null}, {"name": "verbose3", "type": null, "default": null}, {"name": "test", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._burst_interactions._global_uni_burst_link", "asynchronous": false, "params": [{"name": "grn_filename", "type": null, "default": null}, {"name": "counts_filename", "type": null, "default": null}, {"name": "index", "type": null, "default": null}, {"name": "verbose1", "type": null, "default": null}, {"name": "verbose2", "type": null, "default": null}, {"name": "verbose3", "type": null, "default": null}, {"name": "test", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._burst_interactions.genepair_info", "asynchronous": false, "params": [{"name": "grn", "type": null, "default": null}, {"name": "counts", "type": null, "default": null}, {"name": "index", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._burst_interactions.genepair_inference", "asynchronous": false, "params": [{"name": "vals", "type": null, "default": null}, {"name": "geneinfo", "type": null, "default": null}, {"name": "figflag", "type": null, "default": null}, {"name": "verbose1", "type": null, "default": null}, {"name": "verbose2", "type": null, "default": null}, {"name": "verbose3", "type": null, "default": null}, {"name": "test", "type": null, "default": null}], "returns": null, "documentation": ["Infer dynamic information including gene regulatory interaction and bursting kinetics from scRNA-seq data of two genes.\n\nParameters\n----------\nvals\n    The data matrix of shape 2 \u00d7 columns.\n    Rows correspond to genes or spots and columns to cells.\ngeneinfo\n    The priori information from the base-GRN built from scATAC-seq data, containing names and regulatory types of two genes.\nfigflag\n    The index of the outputed images name.\n    If choose not to output the images, the default value is 0.\nverbose1\n    Whether to output images.\n    If False, only the inferred results are outputed. If True, the inferred results with visualization images are outputed.\nverbose2\n    Whether to save images.\n    If False, the images are only shown in the runtime screen. If True, the images are saved as pdf format in a folder under the default path.\nverbose3\n    Whether to exhibit all images.\n    If 0, all images are exhibited. If 1, only visualization images are exhibited.\ntest\n    Whether to perform distributional test.\n    If False, distribution test is not performed. If True, gibbs samples are generated and distribution test is performed.\n\nReturns\n-------\nnp.array(['gene1', 'gene2', 'feedback1', 'feedback2', 'kon1', 'kon2', 'koff1', 'koff2', 'ksyn1', 'ksyn2', 'w', 'bf1', 'bf2', 'bs1', 'bs2', 'cv1', 'cv2', 'convergence', 'corr', 'NMI', 'cmi_given_x1', 'cmi_given_x2', 'sign_givenx1', 'sign_givenx2'])"]}, {"name": "burstlink.tools._burst_interactions.pre_truncation", "asynchronous": false, "params": [{"name": "vals", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._burst_interactions.select_hdr", "asynchronous": false, "params": [{"name": "data", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._burst_interactions.genepair_burstinference", "asynchronous": false, "params": [{"name": "data", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._burst_interactions.uni_poisson", "asynchronous": false, "params": [{"name": "vals", "type": null, "default": null}, {"name": "m", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._burst_interactions.uni_pobe", "asynchronous": false, "params": [{"name": "vals", "type": null, "default": null}, {"name": "alpha_", "type": null, "default": null}, {"name": "beta_", "type": null, "default": null}, {"name": "phi_", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "burstlink.tools._burst_interactions.uni_moment_inference", "asynchronous": false, "params": [{"name": "vals", "type": null, "default": null}