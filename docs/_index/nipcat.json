ace.\n    netmask: Network mask of the interface.\n    broadcast: Broadcast address of the interface."]}, {"name": "nipcat.types.SubnetInfo", "bases": [], "methods": [], "class_variables": [{"name": "nipcat.types.SubnetInfo.network_address", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.broadcast_address", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.first_host", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.last_host", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.num_hosts", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.netmask", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.wildcard_mask", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.cidr_notation", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.network_class", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nipcat.types.SubnetInfo.is_private", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Represents detailed information abo