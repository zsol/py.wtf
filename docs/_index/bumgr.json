ude_caches: Pass the '--exclude-caches' to restic.\nparam exclude_file: true\nparam hostname: Set a hostname explicitly.\nparam macos_exclude_item: |-\n  Use `mdutil` command to determine\n  exclude items for macOS backups. Enabled by default.\nparam mount: Mount point\nparam pass_env_all: |-\n  Whether all environment variables that are\n  set when running this program are passed to restic.\n  Defaults is `False`.\nparam pass_env_home: |-\n  Whether the 'HOME' environment is passed\n  to restic. Needed for using cache. Default is `True`.\n  Ignored if {param}`pass_env_all` is `True`.\nparam pass_env_path: |-\n  Whether the 'PATH' environment is passed\n  to restic. Needed for password commands.\n  Default is `True`. Ignored if {param}`pass_env_all`\n  is `True`.\nparam password_command: true\nparam password_file: true\nparam repository: true\nparam source: true\nparam use_static_hostname: |-\n  Determine the static hostname. Works\n  on macOS and Linux. This hostname usually never changes\n  when connecting to different networks. Ignored if\n  hostname\\`\\`is set. Enabled by default.\n---\n"]}, {"name": "bumgr.backup.Backup.__enter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "Self", "xref": {"fqname": "typing.Self", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "bumgr.backup.Backup.__exit__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "exc_type", "type": null, "default": null}, {"name": "exc_value", "type": null, "default": null}, {"name": "traceback", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "bumgr.backup.Backup.hostname", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str | None", "xref": null, "params": null}, "documentation": []}, {"name": "bumgr.backup.Backup._hostname_args", "asynchronous": false, "params": [{"name": "self", "