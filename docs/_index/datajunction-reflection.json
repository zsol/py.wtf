{"name": "datajunction-reflection", "metadata": {"name": "datajunction-reflection", "version": "0.0.1a75", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3.10", "Programming Language :: Python :: 3.11", "Programming Language :: Python :: 3.12", "Programming Language :: Python :: 3.8", "Programming Language :: Python :: 3.9"], "home_page": null, "license": "MIT", "documentation_url": null, "dependencies": ["importlib-metadata", "pydantic", "python-dotenv", "requests"], "summary": "OSS Implementation of a DataJunction Reflection Service", "upload_time": 1733213341}, "documentation": ["# DJ Reflection Service\n\nThe reflection service polls the DJ core service for all nodes with associated tables, whether source\ntables or materialized tables. For each node, it refreshes the node's schema based on the associated\ntable's schema that it retrieves from the query service. It also retrieves the available partitions and\nthe valid through timestamp of these tables and reflects them accordingly to DJ core.\n\nThis service uses a celery beat scheduler, with a configurable polling interval that defaults to once per\nhour and async tasks for each node's reflection.\n"], "modules": [{"name": "datajunction_reflection", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "datajunction_reflection.worker.app", "documentation": ["Celery app that does the polling of nodes in DJ and then subsequent\nqueueing of reflection tasks."], "functions": [], "variables": [{"name": "datajunction_reflection.worker.app.celery_app", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "datajunction_reflection.worker", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "datajunction_reflection.__about__", "documentation": ["Version for Hatch"], "functions": [], "variables": [{"name": "datajunction_reflection.