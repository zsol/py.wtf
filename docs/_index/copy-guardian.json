{"name": "copy-guardian", "metadata": {"name": "copy-guardian", "version": "0.2.1", "classifiers": ["Intended Audience :: Developers", "Intended Audience :: Science/Research", "License :: OSI Approved :: MIT License", "Natural Language :: English", "Operating System :: OS Independent", "Programming Language :: Python :: 3", "Programming Language :: Python :: 3.10", "Programming Language :: Python :: 3.9"], "home_page": null, "license": "MIT License", "documentation_url": null, "dependencies": ["portalocker"], "summary": "File system based semaphore + rsync", "upload_time": 1721809076}, "documentation": ["# copy_guardian\n\nFile system based semaphore + rsync.\n\n\n## Features\n\n`copy_guardian` implements a file system based seamaphore to limit execution of\ncritical operations. The default mode binds the semaphore to the script which\nowns it, such that operations can be also limitted over parallel executions within\na HPC batch system.\n"], "modules": [{"name": "copy_guardian", "documentation": [], "functions": [], "variables": [{"name": "copy_guardian.__author__", "type": null, "documentation": []}, {"name": "copy_guardian.__email__", "type": null, "documentation": []}, {"name": "copy_guardian.__credits__", "type": null, "documentation": []}, {"name": "copy_guardian.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "copy_guardian.BoundedSemaphore", "xref": {"fqname": "copy_guardian.copy_guardian.BoundedSemaphore", "project": null}}, {"name": "copy_guardian.Connection", "xref": {"fqname": "copy_guardian.copy_guardian.Connection", "project": null}}, {"name": "copy_guardian.copy_local_folder", "xref": {"fqname": "copy_guardian.copy_utils.copy_local_folder", "project": null}}]}, {"name": "copy_guardian.copy_utils", "documentation": [], "functions": [{"name": "copy_guardian.copy_utils._expand_key", "asynchronous": false, "params": [{"name": "private_key", "type": null, "default": null}], "returns": null, "documentation": []}, {"nam