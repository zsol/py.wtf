"type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fildapi.deepdiff.deepdiff.DeepDiff.__create_hashtable", "asynchronous": false, "params": [{"name": "t", "type": null, "default": null}, {"name": "parent", "type": null, "default": null}], "returns": null, "documentation": ["Create hashtable of {item_hash: item}"]}, {"name": "fildapi.deepdiff.deepdiff.DeepDiff.__diff_unhashable_iterable", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "t1", "type": null, "default": null}, {"name": "t2", "type": null, "default": null}, {"name": "parent", "type": null, "default": null}], "returns": null, "documentation": ["Diff of unhashable iterables. Only used when ignoring the order."]}, {"name": "fildapi.deepdiff.deepdiff.DeepDiff.__diff", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "t1", "type": null, "default": null}, {"name": "t2", "type": null, "default": null}, {"name": "parent", "type": null, "default": "..."}, {"name": "parents_ids", "type": null, "default": "..."}, {"name": "rules", "type": null, "default": "..."}], "returns": null, "documentation": ["The main diff method"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["**DeepDiff v 1.1.0**\n\nDeep Difference of dictionaries, iterables, strings and almost any other\nobject.\nIt will recursively look for all the changes.\n\n**Parameters**\n\nt1 : A dictionary, list, string or any python object that has __dict__\n    or __slots__\n    This is the first item to be compared to the second item\n\nt2 : dictionary, list, string or almost any python object that has\n    __dict__ or __slots__\n    The second item is to be compared to the first one\n\nignore_order : Boolean, defalt=False ignores orders for iterables.\n    Note that if you have iterables contatining any unhashable,\n    ignoring order can be expensive.\n    Ignoring order for an iterable containing any unhashable\n    will include duplicates if there are any in the iterable.\n    Ignoring order for an iterable containing only hashables\n    will not include duplicates in the iterable.\n\n**Returns**\n\n    A DeepDiff object that has already calculated the difference of the 2\n    items.\n\n**Supported data types**\n\nint, string, unicode, dictionary, list, tuple, set, frozenset, OrderedDict,\nNamedTuple and custom objects!\n\n**Examples**\n\nImporting\n    >>> from deepdiff import DeepDiff\n    >>> from pprint import pprint\n\nSame object returns empty\n    >>> t1 = {1:1, 2:2, 3:3}\n    >>> t2 = t1\n    >>> print(DeepDiff(t1, t2))\n    {}\n\nType of an item has changed\n    >>> t1 = {1:1, 2:2, 3:3}\n    >>> t2 = {1:1, 2:\"2\", 3:3}\n    >>> pprint(DeepDiff(t1, t2), indent=2)\n    { 'type_changes': { 'root[2]': { 'new_type': <class 'str'>,\n                                     'new_value': '2',\n                                     'old_type': <class 'int'>,\n                                     'old_value': 2}}}\n\nValue of an item has changed\n    >>> t1 = {1:1, 2:2, 3:3}\n    >>> t2 = {1:1, 2:4, 3:3}\n    >>> pprint(DeepDiff(t1, t2), indent=2)\n    {'values_changed': {'root[2]': {'new_value': 4, 'old_value': 2}}}\n\nItem added and/or removed\n    >>> t1 = {1:1, 2:2, 3:3, 4:4}\n    >>> t2 = {1:1, 2:4, 3:3, 5:5, 6:6}\n    >>> ddiff = DeepDiff(t1, t2)\n    >>> pprint (ddiff)\n    {'dictionary_item_added': ['root[5]', 'root[6]'],\n     'dictionary_item_removed': ['root[4]'],\n     'values_changed': {'root[2]': {'new_value': 4, 'old_value': 2}}}\n\nString difference\n    >>> t1 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":\"world\"}}\n    >>> t2 = {1:1, 2:4, 3:3, 4:{\"a\":\"hello\", \"b\":\"world!\"}}\n    >>> ddiff = DeepDiff(t1, t2)\n    >>> pprint (ddiff, indent = 2)\n    { 'values_changed': { 'root[2]': {'new_value': 4, 'old_value': 2},\n                          \"root[4]['b']\": { 'new_value': 'world!',\n                                            'old_value': 'world'}}}\n\nList difference\n    >>> t1 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":[1, 2, 3, 4]}}\n    >>> t2 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":[1, 2]}}\n    >>> ddiff = DeepDiff(t1, t2)\n    >>> pprint (ddiff, indent = 2)\n    {'iterable_item_removed': {\"root[4]['b'][2]\": 3, \"root[4]['b'][3]\": 4}}\n\nList difference 2:\n    >>> t1 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":[1, 2, 3]}}\n    >>> t2 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":[1, 3, 2, 3]}}\n    >>> ddiff = DeepDiff(t1, t2)\n    >>> pprint (ddiff, indent = 2)\n    {'iterable_item_added': {\"root[4]['b'][1]\": 3}}\n\nList difference ignoring order or duplicates: (with the same dictionaries as above)\n    >>> t1 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":[1, 2, 3]}}\n    >>> t2 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":[1, 3, 2, 3]}}\n    >>> ddiff = DeepDiff(t1, t2, ignore_order=True)\n    >>> print (ddiff)\n    {}\n\nList that contains dictionary:\n    >>> t1 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":[1, 2, {1:1, 2:2}]}}\n    >>> t2 = {1:1, 2:2, 3:3, 4:{\"a\":\"hello\", \"b\":[1, 2, {1:3}]}}\n    >>> ddiff = DeepDiff(t1, t2)\n    >>> pprint (ddiff, indent = 2)\n    { 'dictionary_item_removed': [\"root[4]['b'][2][2]\"],\n      'values_changed': {\"root[4]['b'][2][1]\": {'new_value': 3, 'old_value': 1}}}\n\n\nDictionary extended:\n    >>> t1 = {1:1, 2:2}\n    >>> t2 = {1:1, 2:2, 3:3}\n    >>> ddiff = DeepDiff(t1, t2)\n    >>> pprint (ddiff, indent = 2)\n    {'dictionary_item_added': ['root[3]']}\n\n\nNamed Tuples:\n    >>> from collections import namedtuple\n    >>> Point = namedtuple('Point', ['x', 'y'])\n    >>> t1 = Point(x=11, y=22)\n    >>> t2 = Point(x=11, y=23)\n    >>> pprint (DeepDiff(t1, t2))\n    {'values_changed': {'root.y': {'new_value': 23, 'old_value': 22}}}\n\nCustom objects:\n    >>> class ClassA(object):\n    ...     a = 1\n    ...     def __init__(self, b):\n    ...         self.b = b\n    ...\n    >>> t1 = ClassA(1)\n    >>> t2 = ClassA(2)\n    >>>\n    >>> pprint(DeepDiff(t1, t2))\n    {'values_changed': {'root.b': {'new_value': 2, 'old_value': 1}}}\n\nObject attribute added:\n    >>> t2.c = \"new attribute\"\n    >>> pprint(DeepDiff(t1, t2))\n    {'attribute_added': ['root.c'],\n     'values_changed': {'root.b': {'new_value': 2, 'old_value': 1}}}"]}], "exports": []}, {"name": "fildapi.mock.data", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "fildapi.mock.data.JsonMatcher", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "fildapi.mock.data.JsonMatcher.IGNORE_KEY", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "fildapi.mock.data.HttpRequest", "bases": ["Dictionary"], "methods": [], "class_variables": [{"name": "fildapi.mock.data.HttpRequest.Method", "type": null, "documentation": []}, {"name": "fildapi.mock.data.HttpRequest.Path", "type": null, "documentation": []}, {"name": "fildapi.mock.data.HttpRequest.Params", "type": null, "documentation": []}, {"name": "fildapi.mock.data.HttpRequest.Body", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "fildapi.mock.data.HttpResponse", "bases": ["Dictionary"], "methods": [], "class_variables": [{"name": "fildapi.mock.data.HttpResponse.StatusCode", "type": null, "documentation": []}, {"name": "fildapi.mock.data.HttpResponse.Headers", "type": null, "documentation": []}, {"name": "fildapi.mock.data.HttpResponse.Cookies", "type": null, "documentation": []}, {"name": "fildapi.mock.data.HttpResponse.Body", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "fildapi.mock.data.Command", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "fildapi.mock.data.Command.Expectation", "type": null, "documentation": []}, {"name": "fildapi.mock.data.Command.Reset", "type": null, "documentation": []}, {"name": "fildapi.mock.data.Command.Retrieve",