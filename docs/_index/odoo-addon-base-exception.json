aise_exception=False in context. They will still be detected\nand updated on the related record, though.\n"]}], "class_variables": [{"name": "odoo.addons.base_exception.models.base_exception.BaseExceptionModel._inherit", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.base_exception.BaseExceptionModel._name", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.base_exception.BaseExceptionModel._order", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.base_exception.BaseExceptionModel._description", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.base_exception.BaseExceptionModel.main_exception_id", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.base_exception.BaseExceptionModel.exceptions_summary", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.base_exception.BaseExceptionModel.exception_ids", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.base_exception.BaseExceptionModel.ignore_exception", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "odoo.addons.base_exception.models", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "odoo.addons.base_exception.models.base_exception", "xref": {"fqname": "odoo.addons.base_exception.models..base_exception", "project": null}}, {"name": "odoo.addons.base_exception.models.base_exception_method", "xref": {"fqname": "odoo.addons.base_exception.models..base_exception_method", "project": null}}, {"name": "odoo.addons.base_exception.models.exception_rule", "xref": {"fqname": "odoo.addons.base_exception.models..exception_rule", "project": null}}]}, {"name": "odoo.addons.base_exception.models.exception_rule", "documentation": ["Copyright 2011 Rapha\u00ebl Valyi, Renato Lima, Guewen Baconnier, Sodexis", "Copyright 2017 Akretion (http://www.akretion.com)", "Mourad EL HADJ MIMOUNE <mourad.elhadj.mimoune@akretion.com>", "Copyright 2020 Hibou Corp.", "Copyright 2023 ACSONE SA/NV (http://acsone.eu)", "License AGPL-3.0 or later (https://www.gnu.org/licenses/agpl.html)."], "functions": [], "variables": [{"name": "odoo.addons.base_exception.models.exception_rule._logger", "type": null, "documentation": []}], "classes": [{"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule", "bases": ["models.Model"], "methods": [{"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule.check_exception_type_consistency", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule._get_domain", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["override me to customize domains according exceptions cases"]}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule._get_rules_info_for_domain", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "domain", "type": null, "default": null}], "returns": null, "documentation": ["returns the rules that match the domain\n\nThis method will call _get_cached_rules_for_domain to get the rules\nthat match the domain. This is required to transform the domain\ninto a tuple to be used as a key in the cache."]}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule._get_cached_rules_for_domain", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "domain", "type": null, "default": null}], "returns": null, "documentation": ["This method is used to get the rules that match the domain.\n\nThe result is cached to avoid to have to loockup the database every\ntime the method is called for rules that never change.\n\nRecordset are transformed into a dict and then into an object that have\nthe same attributes as the exception.rule model. If you need to add\nnew attributes to the exception.rule model, you need to add them to\nthe dict returned by _to_cache_entry method."]}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule._to_cache_entry", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["This method is used to extract information from the rule to be put\nin cache. It's used by _get_cached_rules_for_domain to avoid to put\nthe recordset in cache. The goal is to avoid to have to loockup\nthe database to get the information required to apply the rule\neach time the rule is applied."]}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule.create", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "vals_list", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule.write", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "vals", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule.unlink", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule._name", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule._description", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule._order", "type": null, "documentation": []}, {"name": "odoo.addons.base_exception.models.exception_rule.ExceptionRule.name", "type": null, "documentation": []}, {"name": "