g succeeded,\n  otherwise `None`.\n\nExample:\n\n```\nproc, mpy = mpy_cross_compile(\"example.py\", \"print('hello mpy')\")\n\n# be sure to check the return code for failure\ntry:\n    proc.check_returncode()\nexcept subprocess.CalledProcessError:\n    # stderr should contain more information about the failure\n    print(proc.stderr)\n    ...\n\n...\n```\n"]}, {"name": "mpy_cross_v5.mpy_cross_version", "asynchronous": false, "params": [], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Gets the version string from the `mpy-cross` executable.\n"]}, {"name": "mpy_cross_v5._run", "asynchronous": false, "params": [], "returns": null, "documentation": ["Run mpy-cross directly."]}], "variables": [{"name": "mpy_cross_v5.MPY_CROSS_PATH", "type": null, "documentation": []}], "classes": [{"name": "mpy_cross_v5.Arch", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "mpy_cross_v5.Arch.X86", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Arch.X64", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Arch.ARMV6", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Arch.ARMV7M", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Arch.ARMV7EM", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Arch.ARMV7EMSP", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Arch.ARMV7EMDP", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Arch.XTENSA", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Arch.XTENSAWIN", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "mpy_cross_v5.Emitter", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "mpy_cross_v5.Emitter.BYTECODE", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Emitter.NATIVE", "type": null, "documentation": []}, {"name": "mpy_cross_v5.Emitter.VIPER", "type": null, "documentation": []}], "insta