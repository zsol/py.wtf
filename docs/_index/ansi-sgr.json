 N O P Q R S T U V W X Y Z\n[ \\ ] ^ _ ` a b c d e f g h i j k l m n o p q r s t u v w x y z {.\nThis part matches that ending character. This character typically indicates what action\nshould be taken (e.g., change color, move cursor, clear screen, etc.)."]}, {"name": "ansi_sgr.sgr.has_sequence", "asynchronous": false, "params": [{"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "ansi_sgr.sgr.reset_sequence", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "ansi_sgr.sgr.text_style_code", "asynchronous": false, "params": [{"name": "text_style", "type": {"name": "Stringable | int", "xref": null, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "ansi_sgr.sgr.color_code", "asynchronous": false, "params": [{"name": "color", "type": {"name": "int | Stringable | tuple[int, int, int]", "xref": null, "params": null}, "default": null}, {"name": "bg", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "ansi_sgr.element", "documentation": [], "functions": [{"name": "ansi_sgr.element.code_block", "asynchronous": false, "params": [{"name": "code", "type": {"name": "Stringable", "xref": {"fqname": "protocolman.Stringable", "project": "protocolman"}, "params": null}, "default": null}, {"name": "title", "type": {"name": "Stringable", "xref": {"fqname": "protocolman.Stringable", "project": "protocolman"}, "params": null}, "default": "..."}, {"name": "emoji", "type": {"name": "Stringable | None", "xref": null, "params": null}, "default": "..."}, 