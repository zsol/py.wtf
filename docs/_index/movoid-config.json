3\u5165\u4e86\u8fd9\u4e9b\u547d\u4ee4\u540e\uff0c\u4f1a\u628a\u8be5\u503c\u8bbe\u7f6e\u4e3aTrue\n> > sub\uff1a\u5b50\u7c7b\u578b\uff0c\u9488\u5bf9enum\u3001kv\u7b49\u7c7b\u578b\uff0c\u7528\u4e8e\u786e\u5b9a\u8fd9\u4e9b\u7c7b\u578b\u4e0b\u7684\u53d6\u503c\u8303\u56f4\n\n\\:param \\_file:\u6587\u4ef6\u76ee\u5f55\uff0c\u5982\u679c\u4e0d\u5199\u5c31\u4e0d\u4f1a\u5c1d\u8bd5\u8bfb\u5199\u914d\u7f6e\u6587\u4ef6\n\\:param \\_file_write:\u662f\u5426\u81ea\u52a8\u5199\u5165\u6587\u4ef6\n"]}, {"name": "movoid_config.config.Config.file", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "movoid_config.config.Config.file", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "movoid_config.config.Config.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "item", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "movoid_config.config.Config.__setitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "item", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "movoid_config.config.Config.__getattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "item", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "movoid_config.config.Config.__len__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "movoid_config.config.Config.items", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "movoid_config.config.Config.keys", "asynchronous": fals