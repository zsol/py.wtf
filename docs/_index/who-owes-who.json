the user's debt/credit balance using matplotlib."]}, {"name": "expense_tracker.reporting_tools.test_report_generation.TestReportGeneration.initialize_db", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "db", "type": null, "default": null}], "returns": null, "documentation": ["Ensure required tables exist in the database."]}, {"name": "expense_tracker.reporting_tools.test_report_generation.TestReportGeneration.test_visualize_balances", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Main test function to visualize Alice's balances and run simple assertions."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "expense_tracker.reporting_tools", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "expense_tracker.reporting_tools.balance_calculation", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "expense_tracker.reporting_tools.balance_calculation.BalanceManager", "bases": [], "methods": [{"name": "expense_tracker.reporting_tools.balance_calculation.BalanceManager.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "expense_tracker.reporting_tools.balance_calculation.BalanceManager.calculate_debts", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Calculate detailed debts between users."]}, {"name": "expense_tracker.reporting_tools.balance_calculation.BalanceManager.get_user_debts", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": null}], "returns": null, "documentation": ["Retrieve detailed debt information for a specific user.", "def simplify_debts(self):", "\"\"\"", "Suggest debt simplifications where transfers can happen between users who already have a debt relationship.", "Returns:", "list: Human-readable suggestions for debt transfers and instructions for unresolved relationships.", "\"\"\"", "# Fetch all debts from the database", "debts = self.db.cursor.execute(", "\"SELECT creditor, debtor, amount FROM debts\"", ").fetchall()", "# Build a debt map to track relationships", "debt_map = {}  # {debtor: {creditor: amount}}", "for creditor, debtor, amount in debts:", "debt_map.setdefault(debtor, {})[creditor] = amount", "# Prepare suggestions for simplification", "suggestions = []", "# Iterate through each debtor and their creditors", "for debtor, creditors in debt_map.items():", "for creditor, amount in creditors.items():", "# Check if the creditor also owes someone", "if creditor in debt_map:", "for next_creditor, next_amount in debt_map[creditor].items():", "# Suggest a transfer if there's a known relationship", "if next_creditor == debtor or next_creditor in creditors:", "suggested_amount = min(amount, next_amount)", "suggestions.append((creditor, next_creditor, suggested_amount))", "# Create human-readable output", "readable_suggestions = []", "for debtor, creditor, amount in suggestions:", "readable_suggestions.append(", "f\"{debtor} should directly transfer ${amount:.2f} to {creditor} to simplify debts.\"", ")", "# Provide instructions for unresolved relationships", "unresolved = []", "for creditor, debtor, amount in debts:", "if (creditor, debtor, amount) not in suggestions:", "unresolved.append(", "f\"No simplification possible for {debtor} owing ${amount:.2f} to {creditor}. Please settle this directly.\"", ")", "return {\"simplifications\": readable_suggestions, \"instructions\": unresolved}"]}, {"name": "expense_tracker.reporting_tools.balance_calculation.BalanceManager.update_negative_debts", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Interchange the creditor and debtor if the debt amount is negative.", "def update_negative_debts(self):", "\"\"\"Interchange the creditor and debtor if the debt amount is negative.\"\"\"", "neg_debt = self.db.cursor.execute(", "\"SELECT creditor,debtor,amount FROM debts WHERE amount < 0\"", ").fetchall()", "if neg_debt:", "print(\"### Amounts Owed to You (Creditors):\",)", "for creditor,debtor,amount in neg_debt:", "print(creditor,debtor,amount)", "self.db.cursor.execute(\"INSERT INTO debts (creditor, debtor, amount) VALUES (?, ?, ?)\", (debtor, creditor, amount*-1))", "self.db.conn.commit()", "self.db.cursor.execute(\"delete from debts where creditor = ? and debtor = ?\", (creditor,debtor,))", "self.db.conn.commit()", "print(\"\\n### Converted negative debts successfully\")", "else:", "print(\"### No negative debts found\")", "return"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "expense_tracker.reporting_tools.report_generation", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "expense_tracker.reporting_tools.report_generation.ReportGeneration", "bases": [], "methods": [{"name": "expense_tracker.reporting_tools.report_generation.ReportGeneration.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "expense_tracker.reporting_tools.report_generation.ReportGeneration.generate_summary", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": null}], "returns": null, "documentation": ["Generate a well-formatted text summary of the user's expense history and debt situation.\n\nParameters:\n    user (str): The username for which the summary is generated.\n\nReturns:\n    str: The formatted summary as a string."]}, {"name": "expense_tracker.reporting_tools.report_generation.ReportGeneration.export_report", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": null}, {"name": "file_format", "type": null, "default": "..."}], "returns": null, "documentation": ["Export the summary report for a specific user to a file.\n\nParameters:\n    user (str): The username for which the report is generated.\n    file_format (str): File format to export (\"txt\", \"csv\", or \"xlsx\")."]}, {"name": "expense_tracker.reporting_tools.report_generation.ReportGeneration.visualize_balances", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": null}], "returns": null, "documentation": ["Create a pie chart summarizing:\n- Total amount the user owes (negative balances).\n- Total amount owed to the user (positive balances).\n\nParameters:\n    user (str): The username for whom to generate the visualization."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "expense_tracker", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "expense_tracker.reporting_tools.test_graph_draft", "documentation": [], "functions": [], "variables": [{"name": "expense_tracker.reporting_tools.test_graph_draft.db", "type": null, "documentation": []}, {"name": "expense_tracker.reporting_tools.test_graph_draft.sample_expenses", "type": null, "documentation": []}, {"name": "expense_tracker.reporting_tools.test_graph_draft.balance_manager", "type": null, "documentation": []}, {"name": "expense_tracker.reporting_tools.test_graph_draft.new", "type": null, "documentation": []}, {"name": "expense_tracker.reporting_tools.test_graph_draft.report_gen", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "expense_tracker.expense_management.test_manager", "documentation": [], "func