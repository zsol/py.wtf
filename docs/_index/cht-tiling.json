ull}, {"name": "lon_deg", "type": null, "default": null}, {"name": "zoom", "type": null, "default": null}], "returns": null, "documentation": ["Returns column and row index of slippy tile", "### Index to degree (and vice versa) functions"]}, {"name": "cht_tiling.tiling.num2deg", "asynchronous": false, "params": [{"name": "xtile", "type": null, "default": null}, {"name": "ytile", "type": null, "default": null}, {"name": "zoom", "type": null, "default": null}], "returns": null, "documentation": ["Returns upper left latitude and longitude of slippy tile"]}, {"name": "cht_tiling.tiling.num2deg_ll", "asynchronous": false, "params": [{"name": "xtile", "type": null, "default": null}, {"name": "ytile", "type": null, "default": null}, {"name": "zoom", "type": null, "default": null}], "returns": null, "documentation": ["## Old index to degrees functions"]}, {"name": "cht_tiling.tiling.num2deg_ur", "asynchronous": false, "params": [{"name": "xtile", "type": null, "default": null}, {"name": "ytile", "type": null, "default": null}, {"name": "zoom", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cht_tiling.tiling.png2elevation", "asynchronous": false, "params": [{"name": "png_file", "type": null, "default": null}], "returns": null, "documentation": ["Convert png to elevation array based on terrarium interpretation", "def rgba2int(rgba):", "\"\"\"Convert rgba tuple to int\"\"\"", "r, g, b, a = rgba", "return (r * 256**3) + (g * 256**2) + (b * 256) + a", "## Conversion between elevation and png and vice versa", "Note: we only use the RGB channels for this (and not the alpha channel)"]}, {"name": "cht_tiling.tiling.elevation2png", "asynchronous": false, "params": [{"name": "val", "type": null, "default": null}, {"name": "png_file", "type": null, "default": null}], "returns": null, "documentation": ["Convert elevation array to png using terrarium interpretation"]}, {"name": "cht_tiling.tiling.png2int", "asynchronous": false, "params": [{"name": "png_file", "type": null, "default": null}], "returns": null, "documentation": ["Convert png to int array", "def elevation2rgb(val):", "\"\"\"Convert elevation to rgb tuple\"\"\"", "val += 32768", "r = np.floor(val / 256)", "g = np.floor(val % 256)", "b = np.floor((val - np.floor(val)) * 256)", "return (r, g, b)", "def rgb2elevation(r, g, b):", "\"\"\"Convert rgb tuple to elevation\"\"\"", "val = (r * 256 + g + b / 256) - 32768", "return val", "def rgb2elevation(rgb):", "\"\"\"Convert rgb tuple to elevation\"\"\"", "val = (rgb[:,:,0] * 256 + rgb[:,:,1] + rgb[:,:,2] / 256) - 32768.0", "# where val is less than -32767, set to NaN", "val[val<-32767.0] = np.NaN", "return val", "## Conversion between int and png and vice versa"]}, {"name": "cht_tiling.tiling.int2png", "asynchronous": false, "params": [{"name": "val", "type": null, "default": null}, {"name": "png_file", "type": null, "default": null}], "returns": null, "documentation": ["Convert int array to png"]}, {"name": "cht_tiling.tiling.makedir", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}], "returns": null, "documentation": ["def int2rgba(int_val):", "\"\"\"Convert int to rgba tuple\"\"\"", "r = (int_val // 256**3) % 256", "g = (int_val // 256**2) % 256", "b = (int_val // 256) % 256", "a = int_val % 256", "return (r, g, b, a)", "## Util functions"]}, {"name": "cht_tiling.tiling.list_files", "asynchronous": false, "params": [{"name": "src", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cht_tiling.tiling.list_folders", "asynchronous": false, "params": [{"name": "src", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cht_tiling.tiling.interp2", "asynchronous": false, "params": [{"name": "x0", "type": null, "default": null}, {"name": "y0", "type": null, "default": null}, {"name": "z0", "type": null, "default": null}, {"name": "x1", "type": null, "default": null}, {"name": "y1", "type": null, "default": null}], "retur