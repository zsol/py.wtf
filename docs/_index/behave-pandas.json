hronous": false, "params": [{"name": "table", "type": null, "default": null}, {"name": "column_levels", "type": null, "default": "..."}, {"name": "index_levels", "type": null, "default": "..."}, {"name": "collapse_empty_index_levels", "type": null, "default": "..."}], "returns": null, "documentation": ["Given a behave table, convert it to a pandas data frame using the following rules:\n\\- valid column types must be specified in the table heading\n\\- 0 or more rows can be used to label columns (a multi index will be created if column_levels > 1)\n\\- 0 or more columns can be used to label columns (a multi index will be created if index_levels > 1)\n\\- For tables with multi indexed columns, row index level names will be flattened to a string by default\ninstead of a tuple if needed, unless `collapse_empty_index_levels` is set to False.\n\n```\nparam table\n\nbehave.Table\n\nparam column_levels\n\nint\n\nparam index_levels\n\nint\n\nparam collapse_empty_index_levels\n\nbool\n\nreturn\n\npd.DataFrame\n```\n"]}, {"name": "behave_pandas.parser._flatten_index_names_if_needed", "asynchronous": false, "params": [{"name": "collapse_empty_index_levels", "type": null, "default": null}, {"name": "column_levels", "type": null, "default": null}, {"name": "index_cols", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "behave_pandas.parser._get_column_types", "asynchronous": false, "params": [{"name": "headings", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "behave_pandas.parser._convert_row_to_correct_type", "asynchronous": false, "params": [{"name": "row", "type": null, "default": null}, {"name": "column_types", "type": {"name": "Iterable", "xref": {"fqname": "typing.Iterable", "project": "--std--"}, "params": [{"name": "ColumnParser", "xref": {"fqname": "behave_pandas.column_types.ColumnParser", "project": null}, "params": null}]}, "default": null}], "returns": null, "documentation": []}], "variables": [], "cl