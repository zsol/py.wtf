 rates.\ntime_series = client.time_series(dt.date(2021, 1, 1), dt.date(2021, 1, 31))\n\n# Get OHLC exchange rates.\nohlc = client.ohlc(dt.date(2021, 1, 1), dt.date(2021, 1, 31))\n\n# Convert currency.\nconversion = client.convert(\"USD\", \"EUR\", 100)\n```"], "functions": [], "variables": [], "classes": [], "exports": [{"name": "oxr.Client", "xref": {"fqname": "oxr.client.Client", "project": null}}]}, {"name": "oxr.tests.test_integration", "documentation": ["Test endpoints that don't require a paid plan."], "functions": [{"name": "oxr.tests.test_integration.client", "asynchronous": false, "params": [], "returns": {"name": "oxr.Client", "xref": {"fqname": "oxr.Client", "project": null}, "params": null}, "documentation": []}, {"name": "oxr.tests.test_integration.test_latest", "asynchronous": false, "params": [{"name": "client", "type": {"name": "oxr.Client", "xref": {"fqname": "oxr.Client", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "oxr.tests.test_integration.test_historical", "asynchronous": false, "params": [{"name": "client", "type": {"name": "oxr.Client", "xref": {"fqname": "oxr.Client", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "oxr.tests.test_integration.test_currencies", "asynchronous": false, "params": [{"name": "client", "type": {"name": "oxr.Client", "xref": {"fqname": "oxr.Client", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "oxr.tests.test_integration.test_usage", "asynchronous": false, "params": [{"name": "client", "type": {"name": "oxr.Client", "xref": {"fqname": "oxr.Client", "project": null}, "params": null}, "default