 that contains the theoretical arrival times by\n\n  : key.\n\n  default_limits: A sequence of instances of RateLimit, these become\n\n  : the default rate limits for all routes in addition to those set\n    manually using the rate_limit decorator. They will also use the\n    RateLimiter's key_function if none is supplied.\n\n  enabled: Set to False to disable rate limiting entirely.\n"]}], "exports": [{"name": "quart_rate_limiter.Any", "xref": {"fqname": "typing.Any", "project": null}}, {"name": "quart_rate_limiter.Awaitable", "xref": {"fqname": "typing.Awaitable", "project": null}}, {"name": "quart_rate_limiter.Blueprint", "xref": {"fqname": "flask.sansio.blueprints.Blueprint", "project": null}}, {"name": "quart_rate_limiter.Callable", "xref": {"fqname": "typing.Callable", "project": null}}, {"name": "quart_rate_limiter.current_app", "xref": {"fqname": "quart.current_app", "project": "quart"}}, {"name": "quart_rate_limiter.dataclass", "xref": {"fqname": "dataclasses.dataclass", "project": null}}, {"name": "quart_rate_limiter.datetime", "xref": {"fqname": "datetime.datetime", "project": null}}, {"name": "quart_rate_limiter.defaultdict", "xref": {"fqname": "collections.defaultdict", "project": null}}, {"name": "quart_rate_limiter.Dict", "xref": {"fqname": "typing.Dict", "project": null}}, {"name": "quart_rate_limiter.List", "xref": {"fqname": "typing.List", "project": null}}, {"name": "quart_rate_limiter.MemoryStore", "xref": {"fqname": "quart_rate_limiter.store.MemoryStore", "project": null}}, {"name": "quart_rate_limiter.Optional", "xref": {"fqname": "typing.Optional", "project": null}}, {"name": "quart_rate_limiter.Quart", "xref": {"fqname": "quart.Quart", "project": "quart"}}, {"name": "quart_rate_limiter.RateLimiterStoreABC", "xref": {"fqname": "quart_rate_limiter.store.RateLimiterStoreABC", "project": null}}, {"name": "quart_rate_limiter.request", "xref": {"fqname": "quart.request", "project": "quart"}}, {"name": "quart_rate_limiter.Response", "xref": {"fqname