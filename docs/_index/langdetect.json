, "type": null, "default": null}, {"name": "max_text_length", "type": null, "default": null}], "returns": null, "documentation": ["Specify max size of target text to use for language detection.\nThe default value is 10000(10KB)."]}, {"name": "langdetect.detector.Detector.append", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": null, "default": null}], "returns": null, "documentation": ["Append the target text for language detection.\nIf the total size of target text exceeds the limit size specified by\nDetector.set_max_text_length(int), the rest is cut down."]}, {"name": "langdetect.detector.Detector.cleaning_text", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Cleaning text to detect\n(eliminate URL, e-mail address and Latin sentence if it is not written in Latin alphabet)."]}, {"name": "langdetect.detector.Detector.detect", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Detect language of the target text and return the language name\nwhich has the highest probability."]}, {"name": "langdetect.detector.Detector.get_probabilities", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "langdetect.detector.Detector._detect_block", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "langdetect.detector.Detector._init_probability", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Initialize the map of language probabilities.\nIf there is the specified prior map, use it as initial map."]}, {"name": "langdetect.detector.Detector._extract_ngrams", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Extract n-grams from target text."]}, {"name": "langdetect.detector.Detector._update_lang_prob", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prob", "type": null, "default": null}, {"name": "word", "type": null, "default": null}, {"name": "alpha", "type": null, "default": null}], "returns": null, "documentation": ["Update language probabilities with N-gram string(N=1,2,3)."]}, {"name": "langdetect.detector.Detector._word_prob_to_string", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prob", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "langdetect.detector.Detector._normalize_prob", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prob", "type": null, "default": null}], "returns": null, "documentation": ["Normalize probabilities and check convergence by the maximun probability.\n        "]}, {"name": "langdetect.detector.Detector._sort_probability", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prob", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "langdetect.detector.Detector._unicode_encode", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "word", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "langdetect.detector.Detector.ALPHA_DEFAULT", "type": null, "documentation": []}, {"name": "langdetect.detector.Detector.ALPHA_WIDTH", "type": null, "documentation": []}, {"name": "langdetect.detector.Detector.ITERATION_LIMIT", "type": null, "documentation": []}, {"name": "langdetect.detector.Detector.PROB_THRESHOLD", "type": null, "documentation": []}, {"name": "langdetect.detector.Detector.CONV_THRESHOLD", "type": null, "documentation": []}, {"name": "langdetect.detector.Detector.BASE_FREQ", "type": null, "documentation": []}, {"name": "langdetect.detector.Detector.UNKNOWN_LANG", "type": null, "documentation": []}, {"name": "langdetect.detector.Detector.URL_RE", "type": null, "documentation": []}, {"name": "langdetect.detector.Detector.MAIL_RE", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Detector class is to detect language from specified text.\nIts instance is able to be constructed via the factory class DetectorFactory.\n\nAfter appending a target text to the Detector instance with .append(string),\nthe detector provides the language detection results for target text via .detect() or .get_probabilities().\n\n.detect() method returns a single language name which has the highest probability.\n.get_probabilities() methods returns a list of multiple languages and their probabilities.\n\nThe detector has some parameters for language detection.\nSee set_alpha(double), .set_max_text_length(int) .set_prior_map(dict).\n\nExample:\n\n    from langdetect.detector_factory import DetectorFactory\n    factory = DetectorFactory()\n    factory.load_profile('/path/to/profile/directory')\n\n    def detect(text):\n        detector = factory.create()\n        detector.append(text)\n        return detector.detect()\n\n    def detect_langs(text):\n        detector = factory.create()\n        detector.append(text)\n        return detector.get_probabilities()"]}], "exports": []}, {"name": "langdetect.utils.ngram", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "langdetect.utils.ngram.NGram", "bases": ["object"], "methods": [{"name": "langdetect.utils.ngram.NGram.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "langdetect.utils.ngram.NGram.add_char", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "ch", "type": null, "default": null}], "returns": null, "documentat