l}], "returns": null, "documentation": []}, {"name": "langdetect.detector_factory.DetectorFactory.clear", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "langdetect.detector_factory.DetectorFactory.create", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "alpha", "type": null, "default": "..."}], "returns": null, "documentation": ["Construct Detector instance with smoothing parameter."]}, {"name": "langdetect.detector_factory.DetectorFactory._create_detector", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "langdetect.detector_factory.DetectorFactory.set_seed", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "seed", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "langdetect.detector_factory.DetectorFactory.get_lang_list", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "langdetect.detector_factory.DetectorFactory.seed", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Language Detector Factory Class.\n\nThis class manages an initialization and constructions of Detector.\n\nBefore using language detection library,\nload profiles with DetectorFactory.load_profile(str)\nand set initialization parameters.\n\nWhen the language detection,\nconstruct Detector instance via DetectorFactory.create().\nSee also Detector's sample code."]}], "exports": []}, {"name": "langdetect.tests.test_detector", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "langdetect.tests.test_detector.DetectorTest", "bases": ["unittest.TestCase"], "methods": [{"name": "langdetect.tests.test_detector.DetectorTest.setUp", "asynchronou