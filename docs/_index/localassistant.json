\n\r\nBefore doing anything, we should download a model first.\r\n\r\n```\r\nlocas download -n Qwen Qwen/Qwen2.5-1.5B-Instruct 3\r\n```\r\n\r\n## Running\r\n\r\n```\r\nlocas ...\r\n```\r\n\r\nUse `locas -h` for more.\r\n\r\n## Disclaimer\r\n\r\nThis AI was designed to communicating with Hugging Face models in CLI. Please do not use this AI for any unethical reasons. Any damages from abusing this application will not be the responsibility of the author.\r\n"], "modules": [{"name": "LocalAssistant", "documentation": [], "functions": [], "variables": [{"name": "LocalAssistant.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "LocalAssistant.models", "xref": {"fqname": "LocalAssistant.models", "project": null}}, {"name": "LocalAssistant.parser", "xref": {"fqname": "LocalAssistant.parser", "project": null}}, {"name": "LocalAssistant.utils", "xref": {"fqname": "LocalAssistant.utils", "project": null}}]}, {"name": "LocalAssistant.utils", "documentation": [], "functions": [{"name": "LocalAssistant.utils._clean_cache", "asynchronous": false, "params": [{"name": "path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["delete choosen .cache dir (Too dangerous to be used)"]}, {"name": "LocalAssistant.utils.clean_all_cache", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["delete all .cache dir"]}, {"name": "LocalAssistant.utils._print_dict", "asynchronous": false, "params": [{"name": "data", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}, {"name": "level", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."