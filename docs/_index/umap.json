{"name": "umap", "metadata": {"name": "umap", "version": "0.1.1", "classifiers": ["Development Status :: 2 - Pre-Alpha", "Programming Language :: Python"], "home_page": "http://amath.unist.ac.kr", "license": "UNKNOWN", "documentation_url": null, "dependencies": [], "summary": "UNIST synthesis MAP solution", "upload_time": 1453307591}, "documentation": ["UNKNOWN"], "modules": [{"name": "setup", "documentation": ["-*- coding: utf8 -*-"], "functions": [], "variables": [{"name": "setup.config", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "umap.get", "documentation": ["-*- coding: utf-8 -*-"], "functions": [{"name": "umap.get.distance", "asynchronous": false, "params": [{"name": "source", "type": null, "default": null}, {"name": "target", "type": null, "default": null}], "returns": null, "documentation": ["1 = 1km\n\\:param source:\n\\:param target:\n\\:return:\n"]}, {"name": "umap.get.nearest", "asynchronous": false, "params": [{"name": "database", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "location", "type": null, "default": null}, {"name": "maxkm", "type": null, "default": null}], "returns": null, "documentation": ["MongoDB GeoSpatial Search\n\\:param database: db.test\n\\:param name: field name 'gps'\n\\:param location: [lat, lon]\n\"All documents must store location data in the same order.\nIf you use latitude and longitude as your coordinate system,\nalways store longitude first.\nMongoDB\u2019s 2d spherical index operators only recognize\n[longitude, latitude] ordering.\"\n\\:param maxkm: limit of distance\n\\:return: count, database\n"]}, {"name": "umap.get.inline_map", "asynchronous": false, "params": [{"name": "map", "type": null, "default": null}], "returns": null, "documentation": ["Embeds the HTML source of the map directly into the IPython notebook.\n\nThis method will not work if the map depends on any files (json data). Also this uses\nthe HTML5 srcdoc attribute, which may not be supported in all browsers.", "def nearest(data, location, dist=10):", "for d in data:", "cand = vincenty(location, d['loc'])", "#         print dist, cand", "if dist > cand:", "dist = cand", "#             result = d", "return dist", "\uc2dc\uc7a5_\uc1fc\ud551\uc13c\ud130", "one degree is approximately 111.12 kilometers", "for m in MB:", "maps = db.maps.find({'cat': m})", "for mm in maps:", "location = mm['loc']", "query = {\"loc\": SON([(\"$near\", location), (\"$maxDistance\", 0.001/111.12)]), \"cat\": \"\uc2dc\uc7a5_\uc1fc\ud551\uc13c\ud130\"}", "data = db.maps.find(query)", "count = data.count()", "ite = 1", "while count < 1:", "query = {\"loc\": SON([(\"$near\", location), (\"$maxDistance\", (0.001+0.1*ite)/111.12)]), \"cat\": \"\uc2dc\uc7a5_\uc1fc\ud551\uc13c\ud130\"}", "data = db.maps.find(query)", "count = data.count()", "ite += 1", "#         print data.count(),", "dist = nearest(data, location)", "db.maps.update({'_id':mm['_id']}, {'$set': {'market': dist}})", "print m"]}, {"name": "umap.get.embed_map", "asynchronous": false, "params": [{"name": "map", "type": null, "default": null}, {"name": "path", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "umap.get.Map", "bases": [], "methods": [{"name": "umap.get.Map.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["lat, lon, zoom_start"]}, {"name": "umap.get.Map.reset", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["reset circles, map\n:return:"]}, {"name": "umap.get.Map.drawing", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Map drawing\n\\:return: iframe map\n"]}, {"name": "umap.get.Map.add_circle", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "location", "type": null, "default": null}, {"name": "radius", "type": null, "default": "..."}, {"name": "fill_opacity", "type": null, "default": "..."}, {"name": "popup", "type": null, "default": "..."}, {"name": "fill_color", "type": null, "default": "..."}, {"name": "line_color", "type": null, "default": "..."}], "returns": null, "documentation": ["Add a circle in the map\n\\:param location: [lat, lon]\n\\:param radius: circle radius\n\\:param fill_opacity: transparency\n\\:param popup: text\n\\:param fill_color:\n\\:param line_color: circle line color\n\\:return:\n"]}, {"name": "umap.get.Map.get_circles", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Get a list of circles\n\\:return: list\n"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Map with folium", "def export_map(map, path=\"export_data.html\", js=\"test.js\"):", "path = path", "map.create_map(path=path)", "# Open the HTML file", "f = open(path, 'r')", "text = f.read()", "f.close()", "# Parsing HTML for circles", "pos = text.find('var circle_1')", "if len(splited) > 1:", "circles = text[pos:]", "else:", "print 'Length is 1'", "circles = circles.replace('</script>','').replace('</body>','')", "cv = ''", "vs = []", "for i in circles.split('\\n'):", "if 'map' not in i:", "cv += i.replace('  ','')+'\\n'", "if 'var ' in i:", "i = i.replace('  ','')", "vs.append(i.split(' ')[1])", "# Making a new JS file", "head = \"\"\"var circle_group = L.layerGroup(\"\"\"", "vs = str(vs).replace(\"'\", '')", "tail = \"\"\");\"\"\"", "java_1 = cv", "java_2 = head+vs+tail", "f = open(js, 'w')", "filename = js.split('.')[0]+'_'", "f.write(java_1.replace('circle_', filename))", "f.write(java_2.replace('circle_', filename))", "f.close()", "return js"]}], "exports": []}, {"name": "umap", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}]}