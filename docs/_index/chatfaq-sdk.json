nsition, in case 'source' is not set then\n    the 'dest' state on this transition would be considered 'ubiquitous state', meaning it can be accesses from\n    any other state\nconditions: function\n    The functions that has to pass in order to satisfy the transition\nunless: function\n    The functions that doesn't have to pass in order to satisfy the transition"]}, {"name": "chatfaq_sdk.fsm.Transition.to_dict_repr", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["The transition between 2 states of the FSM"]}], "exports": [{"name": "chatfaq_sdk.fsm.annotations", "xref": {"fqname": "__future__.annotations", "project": null}}, {"name": "chatfaq_sdk.fsm.Callable", "xref": {"fqname": "typing.Callable", "project": null}}, {"name": "chatfaq_sdk.fsm.ChatFAQSDK", "xref": {"fqname": "chatfaq_sdk.ChatFAQSDK", "project": null}}, {"name": "chatfaq_sdk.fsm.List", "xref": {"fqname": "typing.List", "project": null}}, {"name": "chatfaq_sdk.fsm.TYPE_CHECKING", "xref": {"fqname": "typing.TYPE_CHECKING", "project": null}}]}, {"name": "chatfaq_sdk.data_source_parsers", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "chatfaq_sdk.data_source_parsers.DataSourceParser", "bases": [], "methods": [{"name": "chatfaq_sdk.data_source_parsers.DataSourceParser.parse", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "data_source", "type": {"name": "DataSource", "xref": {"fqname": "chatfaq_sdk.types.DataSource", "project": null}, "params": null}, "default": null}], "returns": {"name": "Iterator", "xref": {"fqname": "typing.Iterator", "project": "--std--"}, "params": [{"name": "KnowledgeItem", "xref": {"fqname": "chatfaq_sdk.types.KnowledgeItem", "project": null}, "params": null}]}, "documentation": []}, {"name": "chatfaq_sdk.data_source_parsers.DataSourceParser.__