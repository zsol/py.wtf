aded_rating", "project": null}}]}, {"name": "easy_inspect.scorer.model_graded_rating", "documentation": [], "functions": [{"name": "easy_inspect.scorer.model_graded_rating.model_graded_rating", "asynchronous": false, "params": [{"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "criterion", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "template", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "instructions", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "rating_pattern", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "include_history", "type": {"name": "bool | Callable[[TaskState], str]", "xref": null, "params": null}, "default": "..."}, {"name": "model", "type": {"name": "list[str | Model] | str | Model | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "Scorer", "xref": {"fqname": "inspect_ai.scorer._scorer.Scorer", "project": "inspect-ai"}, "params": null}, "documentation": ["Score a question/answer task using a model to assign a numerical rating.\n\nNotable design differences from the inspect_ai `model_graded_qa` scorer:\n- Specifies the 'criterion' through the 'criterion' argument (not the target.text).\n\nArgs:\n    name (str): Name of the scorer.\n    criterion (str): The judge prompt to use for scoring.\n    template (str | None): Template for grading prompt. This template has\n        four variables: `question`, `answer`, `criterion`, and `instructions`.\n        Variables from sample `metadata` are also available in the template.\n        Defaults to DEFAULT_MODEL_GRADED_RATING_TEMPLATE.\n    instructions (str | None): Grading instructions for the model. Should guide\n        the model to provide a numerical rating and reasoning that matches the\n        specified `rating_pattern`. Defaults to DEFAULT_MODEL_GRADED_RATING_INSTRUCTIONS.\n    rating_pattern (str | None): Regex to extract the numerical rating from the\n        model response. Should have a single capture group that extracts a number\n        between 0-100. Defaults to DEFAULT_MODEL_GRADED_RATING_PATTERN.\n    include_history (bool | Callable[[TaskState], str]): Whether to include the\n        full chat history in the presented question. If False (default), presents\n        only the original sample input. Can provide a function to customize how\n        the chat history is presented.\n    model (list[str | Model] | str | Model | None): Model(s) to use for grading.\n        If multiple models are passed, their ratings will be averaged. If None,\n        uses the model being evaluated.\n\nReturns:\n    Scorer: A scoring function that returns normalized scores between 0 and 1.", "TODO: Change 'criterion' to 'judge_prompt'"]}, {"name": "easy_inspect.scorer.model_graded_rating._model_graded_rating_single", "asynchronous": false, "params": [{"name": "criterion", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "template", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "instructions", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "rating_pattern", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "include_history", "type": {"name": "bool | Callable[[TaskState], str]", "xref": null, "params": null}, "default": "..."}, {"name": "model", "type": {"name": "str | Model | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "Scorer", "xref": {"fqname": "inspect_ai.scorer._scorer.Scorer", "project": "inspe