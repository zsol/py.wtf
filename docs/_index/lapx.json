"default": null}, {"name": "cc", "type": null, "default": null}, {"name": "ii", "type": null, "default": null}, {"name": "kk", "type": null, "default": null}, {"name": "n_free_rows", "type": null, "default": null}, {"name": "free_rows", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "v", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lap.lapmod.check_cost", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}, {"name": "cc", "type": null, "default": null}, {"name": "ii", "type": null, "default": null}, {"name": "kk", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lap.lapmod.get_cost", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}, {"name": "cc", "type": null, "default": null}, {"name": "ii", "type": null, "default": null}, {"name": "kk", "type": null, "default": null}, {"name": "x0", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lap.lapmod.lapmod", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}, {"name": "cc", "type": null, "default": null}, {"name": "ii", "type": null, "default": null}, {"name": "kk", "type": null, "default": null}, {"name": "fast", "type": null, "default": "..."}, {"name": "return_cost", "type": null, "default": "..."}, {"name": "fp_version", "type": null, "default": "..."}], "returns": null, "documentation": ["Solve sparse linear assignment problem using Jonker-Volgenant algorithm.\n\nn: number of rows of the assignment cost matrix\ncc: 1D array of all finite elements of the assignement cost matrix\nii: 1D array of indices of the row starts in cc. The following must hold:\n        ii[0] = 0 and ii[n+1] = len(cc).\nkk: 1D array of the column indices so that:\n        cost[i, kk[ii[i] + k]] == cc[ii[i] + k].\n    Indices within one row must be sorted.\nextend_cost: whether or not extend a non-square matrix [default: False]\ncost_limit: an upper limit for a cost of a single assignment\n            [default: np.inf]\nreturn_cost: whether or not to return the assignment cost\n\nReturns (opt, x, y) where:\n  opt: cost of the assignment\n  x: vector of columns assigned to rows\n  y: vector of rows assigned to columns\nor (x, y) if return_cost is not True.\n\nWhen extend_cost and/or cost_limit is set, all unmatched entries will be\nmarked by -1 in x/y."]}], "variables": [], "classes": [], "exports": []}, {"name": "lap.tests.test_utils", "documentation": [], "functions": [{"name": "lap.tests.test_utils.make_hard", "asynchronous": false, "params": [{"name": "cost", "type": null, "default": null}, {"name": "lo", "type": null, "default": null}, {"name": "hi", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lap.tests.test_utils.get_dense_8x8_int", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "lap.tests.test_utils.get_dense_int", "asynchronous": false, "params": [{"name": "sz", "type": null, "default": null}, {"name": "rng", "type": null, "default": null}, {"name": "hard", "type": null, "default": "..."}, {"name": "seed", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "lap.tests.test_utils.get_sparse_int", "asynchronous": false, "params": [{"name": "sz", "type": null, "default": null}, {"name": "rng", "type": null, "default": null}, {"name": "sparsity", "type": null, "default": null}, {"name": "hard", "type": null, "default": "..."}, {"name": "seed", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "lap.tests.test_utils.get_nnz_int", "asynchronous": false, "params": [{"name": "sz", "type": null, "default": null}, {"name": "nnz", "type": null, "default": null}, {"name": "rng", "type": null, "default": "..."}, {"name": "seed", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name"