ull, "documentation": []}, {"name": "lap.tests.test_utils.get_cost_CS", "asynchronous": false, "params": [{"name": "cost", "type": null, "default": null}, {"name": "x", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lap.tests.test_utils.get_platform_maxint", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "lap.tests", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "lap", "documentation": ["LAP\n`lap` is a linear assignment problem solver using Jonker-Volgenant\nalgorithm for dense (LAPJV) or sparse (LAPMOD) matrices.\n\n# Functions\n\nlapjv\n\n: Find optimal (minimum-cost) assignment for a dense cost matrix.\n\nlapmod\n\n: Find optimal (minimum-cost) assignment for a sparse cost matrix.\n"], "functions": [], "variables": [{"name": "lap.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "lap.FP_1", "xref": {"fqname": "lap._lapjv.FP_1_", "project": null}}, {"name": "lap.FP_2", "xref": {"fqname": "lap._lapjv.FP_2_", "project": null}}, {"name": "lap.FP_DYNAMIC", "xref": {"fqname": "lap._lapjv.FP_DYNAMIC_", "project": null}}, {"name": "lap.lapjv", "xref": {"fqname": "lap._lapjv.lapjv", "project": null}}, {"name": "lap.lapmod", "xref": {"fqname": "lap.lapmod.lapmod", "project": null}}, {"name": "lap.LARGE", "xref": {"fqname": "lap._lapjv.LARGE_", "project": null}}]}, {"name": "lap.tests.test_lapmod", "documentation": [], "functions": [{"name": "lap.tests.test_lapmod.test_square", "asynchronous": false, "params": [{"name": "cost", "type": null, "default": null}, {"name": "expected", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lap.tests.test_lapmod.test_sparse_square", "asynchronous": false, "params": [{"name": "cost", "type": null, "default": null}, {"name": "expected", "type": null, "default": null}], "returns": null, "documentation"