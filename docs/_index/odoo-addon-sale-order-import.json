ny by mistake", "'date': '2016-08-16',  # order date", "'order_ref': 'PO1242',  # Customer PO number", "'currency': {'iso': 'EUR', 'symbol': u'\u20ac'},", "'incoterm': 'EXW',", "'note': 'order notes of the customer',", "'chatter_msg': ['msg1', 'msg2']", "'lines': [{", "'product': {", "'code': 'EA7821',", "'ean13': '2100002000003',", "},", "'qty': 2.5,", "'uom': {'unece_code': 'C62'},", "'price_unit': 12.42,  # without taxes", "'doc_type': 'rfq' or 'order',", "}]"]}, {"name": "odoo.addons.sale_order_import.wizard.sale_order_import.SaleOrderImport._prepare_order", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parsed_order", "type": null, "default": null}, {"name": "price_source", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.sale_order_import.wizard.sale_order_import.SaleOrderImport._validate_currency", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "partner", "type": null, "default": null}, {"name": "currency", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.sale_order_import.wizard.sale_order_import.SaleOrderImport._validate_existing_orders", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "partner", "type": null, "default": null}, {"name": "parsed_order", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.sale_order_import.wizard.sale_order_import.SaleOrderImport.create_order", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parsed_order", "type": null, "default": null}, {"name": "price_source", "type": null, "default": null}, {"name": "order_filename", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "odoo.addons.sale_order_import.wizard.sale_order_import.SaleOrderImport.create_order_ws", "asynchronous": false, "params"