they are methods, classmethods, staticmethods"]}, {"name": "pep8ext_naming.NamingChecker.set_function_nodes_types", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "nodes", "type": null, "default": null}, {"name": "ismetaclass", "type": null, "default": null}, {"name": "late_decoration", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pep8ext_naming.NamingChecker.find_decorator_name", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "d", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pep8ext_naming.NamingChecker.find_global_defs", "asynchronous": false, "params": [{"name": "func_def_node", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "pep8ext_naming.NamingChecker.name", "type": null, "documentation": []}, {"name": "pep8ext_naming.NamingChecker.version", "type": null, "documentation": []}, {"name": "pep8ext_naming.NamingChecker.visitors", "type": null, "documentation": []}, {"name": "pep8ext_naming.NamingChecker.decorator_to_type", "type": null, "documentation": []}, {"name": "pep8ext_naming.NamingChecker.ignore_names", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Checker of PEP-8 Naming Conventions."]}, {"name": "pep8ext_naming.ClassNameCheck", "bases": ["BaseASTCheck"], "methods": [{"name": "pep8ext_naming.ClassNameCheck.get_classdef", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "parents", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "pep8ext_naming.ClassNameCheck.superclass_names", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name"