, "documentation": []}, {"name": "pep8ext_naming.FunctionNameCheck.visit_asyncfunctiondef", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Function names should be lowercase, with words separated by underscores\nas necessary to improve readability.\n\nFunctions *not* being methods '__' in front and back are not allowed.\n\nmixedCase is allowed only in contexts where that's already the\nprevailing style (e.g. threading.py), to retain backwards compatibility."]}, {"name": "pep8ext_naming.FunctionArgNamesCheck", "bases": ["BaseASTCheck"], "methods": [{"name": "pep8ext_naming.FunctionArgNamesCheck.visit_functiondef", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": null, "default": null}, {"name": "parents", "type": {"name": "Iterable", "xref": {"fqname": "collections.abc.Iterable", "project": "--std--"}, "params": null}, "default": null}, {"name": "ignore", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [{"name": "pep8ext_naming.FunctionArgNamesCheck.N803", "type": null, "documentation": []}, {"name": "pep8ext_naming.FunctionArgNamesCheck.N804", "type": null, "documentation": []}, {"name": "pep8ext_naming.FunctionArgNamesCheck.N805", "type": null, "documentation": []}, {"name": "pep8ext_naming.FunctionArgNamesCheck.visit_asyncfunctiondef", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["The argument names of a function should be lowercase, with words separated\nby underscores.\n\nA classmethod should have 'cls' as first argument.\nA method should have 'self' as first argument."]}, {"name": "pep8ext_naming.ImportAsCheck", "bases": ["BaseASTCheck"], "methods": [{"name": "pep8ext_naming.ImportAsCheck.visit_importfrom", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": null, "default": null}, {"name": "p