ool_with_openai", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "state", "type": {"name": "BaseAgentState", "xref": {"fqname": "gptstonks.multiagents.graphs.states.BaseAgentState", "project": null}, "params": null}, "default": null}], "returns": null, "documentation": ["Function to execute tools."]}, {"name": "gptstonks.multiagents.graphs.agent_with_tools.GraphAgentWithTools._define_basic_workflow", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "alternative_node", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "alternative_node_func", "type": {"name": "RunnableLike | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "StateGraph", "xref": {"fqname": "langgraph.graph.StateGraph", "project": "langgraph"}, "params": null}, "documentation": ["Defines basic workflow with agent and action nodes.\n\nThe nodes are called:\n- \"agent\": calls the LLM to generate a response or a tool call.\n- \"action\": executes the tool when a tool call is generated by \"action\".\n\nThe graph is as follows:\nagent -> action | alternative_node; action -> agent\n\nArgs:\n    alternative_node (`str`): state to go to when no action is called.\n    alternative_node_func (`RunnableLike | None`):\n        LangGraph node implementation. None if `alternative_node` is left as default.\n\nReturns:\n    `StateGraph`: StateGraph with action and agent nodes included."]}, {"name": "gptstonks.multiagents.graphs.agent_with_tools.GraphAgentWithTools.define_basic_graph", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "CompiledGraph", "xref": {"fqname": "langgraph.graph.graph.CompiledGraph", "project": "langgraph"}, "params": null}, "documentation": ["Defines basic LangGraph graph."]}], "class_variables": [{"name": "gptstonks.multiagents.graphs.agent_with_to