ns.float", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Searches videos on Youtube related to a query."]}, {"name": "gptstonks.multiagents.tools.mitheithel_search.MitheithelSearchTool.create", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "description", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "return_direct", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "timeout", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "StructuredTool", "xref": {"fqname": "langchain.tools.StructuredTool", "project": "langchain"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [{"name": "gptstonks.multiagents.tools.mitheithel_search.MitheithelSearchTool.MitheithelSearchInput", "bases": ["BaseModel"], "methods": [], "class_variables": [{"name": "gptstonks.multiagents.tools.mitheithel_search.MitheithelSearchTool.MitheithelSearchInput.query", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "documentation": ["StructuredTool that searches the Internet."]}], "exports": []}, {"name": "gptstonks.multiagents.tools.world_knowledge", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "gptstonks.multiagents.tools.world_knowledge.WorldKnowledgeTool", "bases": ["LlamaIndexTool"], "methods": [{"name": "gptstonks.multiagents.tools.world_knowledge.WorldKnowledgeTool.from_llamaindex_llm", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "llamaindex_llm", "type": {"name": "LlamaIndexLLM", "xref": {"fqname": "llama_index.core.llms.llm.LLM", "project": null}, "params": null}, "default": null}, {"name": "tool_description", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "use_openai_agent", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "return_direct", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "verbose", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "search_tool_description", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "wikipedia_tool_description", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "auto_multistep_query_engine_index_summary", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "auto_multistep_query_engine_qa_template", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "auto_multistep_query_engine_refine_template", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}, {"name": "auto_multistep_query_engine_stepdecompose_query_prompt", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "LlamaIndexTool", "xref": {"fqname": "llama_index.core.langchain_helpers.agents.LlamaIndexTool", "project": null}, "params": null}, "documentation": ["Initialize World Knowledge tool.\n\nThe World Knowledge tool can solve complex queries by applying [multi-step reasoning](https://arxiv.org/abs/2303.09014). It has several tools available,\nwhich include:\n\n- Search: to look up information on the Internet.\n- Wikipedia: to look up information about places, people, etc.\n- Request: to look up specific webpages on the Internet (not implemented).\n\nIn each step, the LLM can select any tool (or its own knowledge) to solve the target query. The final response is generated\nby combining the responses to each subquery.\n\nArgs:\n    llamaindex_llm (`llama_index.core.llms.llm.LLM`):\n        LLM that will decompose the main query and answer the subqueries.\n    name (`str`): name of the tool.\n    return_direct (`bool`): whether or not the tool should return when the final answer is given.\n    verbose (`bool`): whether or not the tool should write to stdout the intermediate information.\n    search_tool_description (`str | None`): description of the search tool. Defaults to the one provided by LangChain.\n    wikipedia_tool_description (`str | None`): description of the Wikipedia tool. Defaults to the one provided by LangChain.\n    auto_multistep_query_engine_index_summary (`str`): summary for the auto multistep query engine index. Seen internally by LlamaIndex agent, important to set how the sub-questions are asked.\"\n    auto_multistep_query_engine_qa_template (`str | None`): template for QA in the auto multistep query engine. Defaults to the one provided by LlamaIndex.\n    auto_multistep_query_engine_refine_template (`str | None`): template for refining queries in the auto multistep query engine. Defaults to the one provided by LlamaIndex.\n    auto_multistep_query_engine_stepdecompose_query_prompt (`str | None`): prompt for decomposing steps in the auto multistep query engine. Defaults to the one provided by LlamaIndex.\n\nReturns:\n    `LlamaIndexTool`: LangChain and LlamaIndex compatible tool."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Adds factories for the World Knowledge tool."]}], "exports": []}]}