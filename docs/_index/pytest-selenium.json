ub.com/pytest-dev/pytest-selenium/issues\n```\n\n```{image} https://img.shields.io/requires/github/pytest-dev/pytest-selenium.svg\n:alt: Requirements\n:target: https://requires.io/github/pytest-dev/pytest-selenium/requirements/?branch=master\n```\n\n## Resources\n\n- [Documentation](http://pytest-selenium.readthedocs.io/en/latest/)\n- [Issue Tracker](http://github.com/pytest-dev/pytest-selenium/issues)\n- [Code](http://github.com/pytest-dev/pytest-selenium/)\n"], "modules": [{"name": "pytest_selenium.__version", "documentation": ["file generated by setuptools_scm", "don't change, don't track in version control"], "functions": [], "variables": [{"name": "pytest_selenium.__version.TYPE_CHECKING", "type": null, "documentation": []}, {"name": "pytest_selenium.__version.VERSION_TUPLE", "type": null, "documentation": []}, {"name": "pytest_selenium.__version.VERSION_TUPLE", "type": null, "documentation": []}, {"name": "pytest_selenium.__version.version", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pytest_selenium.__version.__version__", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pytest_selenium.__version.__version_tuple__", "type": {"name": "VERSION_TUPLE", "xref": {"fqname": "VERSION_TUPLE", "project": null}, "params": null}, "documentation": []}, {"name": "pytest_selenium.__version.version_tuple", "type": {"name": "VERSION_TUPLE", "xref": {"fqname": "VERSION_TUPLE", "project": null}, "params": null}, "documentation": []}], "classes": [], "exports": []}, {"name": "pytest_selenium.utils", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "pytest_selenium.utils.CaseInsensitiveDict", "bases": ["MutableMapping"], "methods": [{"name": "pytest_selenium.utils.CaseInsensitiveDict.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name":