{"name": "vavista-rpc", "metadata": {"name": "vavista-rpc", "version": "0.0.12", "classifiers": ["License :: OSI Approved :: GNU Affero General Public License v3 or later (AGPLv3+)", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/vernonOber/vavista-rpc3", "license": null, "documentation_url": null, "dependencies": [], "summary": "VAVista RPC interface", "upload_time": 1735755633}, "documentation": ["\n    This is a simple Pythonic mechanism for invoking VistA RPCs.\n    The code was developed by Conor Dowling as part of the FMQL\n    project.\n    \n"], "modules": [{"name": "vavista_rpc", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "vavista_rpc.brokerRPC3", "documentation": [" Broker Connection\n\n Module to provide access to VistA RPCs through either the new style\n VA Broker or IHS's CIA Broker. It provides thread-safe access through a Pool\n class.\n\n Base Connection for VistA and CIA Brokers with specializations for the\n particulars of those brokers.\n\nbrokerRPC3.py was started to provide Python 3 support", "!/usr/bin/env python3", "LICENSE:", "This program is free software; you can redistribute it and/or modify it", "under the terms of the GNU Affero General Public License version 3 (AGPL)", "as published by the Free Software Foundation.", "(c) 2010-2011 caregraf.org"], "functions": [{"name": "vavista_rpc.brokerRPC3.query_test", "asynchronous": false, "params": [{"name": "conn", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.main_test", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "vavista_rpc.brokerRPC3.__author__", "type": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.__copyright__", "type": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.__credits__", "type": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.__license__", "type": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.__version__", "type": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.__status__", "type": null, "documentation": []}], "classes": [{"name": "vavista_rpc.brokerRPC3.RPCConnection", "bases": ["object"], "methods": [{"name": "vavista_rpc.brokerRPC3.RPCConnection.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "host", "type": null, "default": null}, {"name": "port", "type": null, "default": null}, {"name": "access", "type": null, "default": null}, {"name": "verify", "type": null, "default": null}, {"name": "context", "type": null, "default": null}, {"name": "logger", "type": null, "default": null}, {"name": "endMark", "type": null, "default": null}, {"name": "poolId", "type": null, "default": null}], "returns": null, "documentation": ["- host/port\n- vista's security (access, verify)\n- a logger that implements logError and logInfo\n- endMark marks end of message\n- poolId is a connection pool's id for a connection.\nThis is used by the logger."]}, {"name": "vavista_rpc.brokerRPC3.RPCConnection.invokeRPC", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "params", "type": null, "default": null}], "returns": null, "documentation": ["Invoke an RPC. If the connection is closed, try to reopen it once.\nIf fail again then raise an exception.\nThis takes care of connection time outs\nwhich happens with the CIA Broker. Note CIA Broker does support\na Ping but\nthis approach avoids hogging connections when traffic is low."]}, {"name": "vavista_rpc.brokerRPC3.RPCConnection.connect", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["(Re)connect/activate the connection. Sets up basic pipe.\nThe hand shake\ndepends on this class' subclass"]}, {"name": "vavista_rpc.brokerRPC3.RPCConnection.encrypt", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "val", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.RPCConnection.readToEndMarker", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Endmarker:\n- VISTA: chr(4)\n- CIA: chr(255)"]}], "class_variables": [{"name": "vavista_rpc.brokerRPC3.RPCConnection.CIPHER", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Hardcoded in VistA/RPMS access code."]}, {"name": "vavista_rpc.brokerRPC3.VistARPCConnection", "bases": ["RPCConnection"], "methods": [{"name": "vavista_rpc.brokerRPC3.VistARPCConnection.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "host", "type": null, "default": null}, {"name": "port", "type": null, "default": null}, {"name": "access", "type": null, "default": null}, {"name": "verify", "type": null, "default": null}, {"name": "context", "type": null, "default": null}, {"name": "logger", "type": null, "default": null}, {"name": "poolId", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "vavista_rpc.brokerRPC3.VistARPCConnection.connect", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["How VistA Broker connects"]}, {"name": "vavista_rpc.brokerRPC3.VistARPCConnection.makeRequest", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "params", "type": null, "default": null}, {"name": "isCommand", "type": null, "default": "..."}], "returns": null, "documentation": ["Format a the RPC request to s