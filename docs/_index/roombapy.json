ms": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["On disconnect callback."]}, {"name": "roombapy.roomba.Roomba.on_message", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "_client", "type": {"name": "Client", "xref": {"fqname": "paho.mqtt.client.Client", "project": "paho-mqtt"}, "params": null}, "default": null}, {"name": "_userdata", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}, {"name": "msg", "type": {"name": "MQTTMessage", "xref": {"fqname": "paho.mqtt.client.MQTTMessage", "project": "paho-mqtt"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["On message callback."]}, {"name": "roombapy.roomba.Roomba.send_command", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "command", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "params", "type": {"name": "dict[str, Any] | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Send a command to the Roomba."]}, {"name": "roombapy.roomba.Roomba.set_preference", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "preference", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "setting", "type": {"name": "RobotPreference", "xref": {"fqname": "RobotPreference", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Set a preference on the Roomba."]}, {"name": "roombapy.roomba.Roomba.dict_merge", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dct", "type": {"name": "RoombaMessage", "xref": {"fqname": "RoombaMessage", "project": null}, "params": null}, "default": null}, {"name": "merge_dct", "type": {"name": "RoombaMessage", "xref": {"fqname": "RoombaMessage", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Recursive dict merge.\n\nInspired by :meth:`dict.update()`, instead\nof updating only top-level keys, dict_merge recurses down into dicts\nnested to an arbitrary depth, updating keys. The `merge_dct` is\nmerged into `dct`.\n\nTODO: Do not mutate arguments!\n"]}, {"name": "roombapy.roomba.Roomba.decode_topics", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "state", "type": {"name": "RoombaMessage", "xref": {"fqname": "RoombaMessage", "project": null}, "params": null}, "default": null}, {"name": "prefix", "type": {"name": "str | None", "xref": null, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Decode json data dict and publish as individual topics.\n\nPublish to brokerFeedback/topic the keys are concatenated with _\nto make one unique topic name strings are expressively converted\nto strings to avoid unicode representations"]}, {"name": "roombapy.roomba.Roomba.update_state_machine", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "new_state", "type": {"name": "State", "xref": {"fqname": "roombapy.const.State", "project": null}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Roomba progresses through states (phases).\n\nNormal Sequence is \"\" -> charge -> run -> hmPostMsn -> charge\nMid mission recharge is \"\" -> charge -> run -> hmMidMsn -> charge\n                           -> run -> hmPostMsn -> charge\nStuck is \"\" -> charge -> run -> hmPostMsn -> stuck\n            -> run/charge/stop/hmUsrDock -> charge\nStart program during run is \"\" -> run -> hmPostMsn -> charge\n\nNeed to identify a new mission to initialize map, and end of mission to\nfinalise map.\nAssume  charge -> run = start of mission (init map)\n        stuck - > charge = init map\nAssume hmPostMsn -> charge = end of mission (finalize map)\nAnything else = continue with existing map"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Class for Roomba 900 series WiFi connected Vacuum cleaners.\n\nRequires firmware version 2.0 and above (not V1.0). Tested with Roomba 980\nusername (blid) and password are required, and can be found using the\npassword() class above (or can be auto discovered)\nMost of the underlying info was obtained from here:\nhttps://github.com/koalazak/dorita980 many thanks!\nThe values received from the Roomba as stored in a dictionary called\nmaster_state, and can be accessed at any time, the contents are live, and\nwill build with time after connection.\nThis is not needed if the forward to mqtt option is used, as the events\nwill be decoded and published on the designated mqtt client topic."]}], "exports": []}]}