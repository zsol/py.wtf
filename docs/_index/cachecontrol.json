turns": null, "documentation": []}, {"name": "cachecontrol.cache.SeparateBodyBaseCache.get_body", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": ["Return the body as file-like object."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["In this variant, the body is not stored mixed in with the metadata, but is\npassed in (as a bytes-like object) in a separate call to `set_body()`.\n\nThat is, the expected interaction pattern is:\n\n```\ncache.set(key, serialized_metadata)\ncache.set_body(key)\n```\n\nSimilarly, the body should be loaded separately via `get_body()`.\n"]}], "exports": []}, {"name": "cachecontrol.filewrapper", "documentation": ["SPDX-FileCopyrightText: 2015 Eric Larson", "SPDX-License-Identifier: Apache-2.0"], "functions": [], "variables": [], "classes": [{"name": "cachecontrol.filewrapper.CallbackFileWrapper", "bases": ["object"], "methods": [{"name": "cachecontrol.filewrapper.CallbackFileWrapper.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "fp", "type": null, "default": null}, {"name": "callback", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cachecontrol.filewrapper.CallbackFileWrapper.__getattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cachecontrol.filewrapper.CallbackFileWrapper.__is_fp_closed", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cachecontrol.filewrapper.CallbackFileWrapper._close", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cachecontrol.filewrapper.CallbackFileWrapper.read", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "amt", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cachecontrol.filewrapper.CallbackFileWrapper._safe_read", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "amt", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Small wrapper around a fp object which will tee everything read into a\nbuffer, and when that file is closed it will execute a callback with the\ncontents of that buffer.\n\nAll attributes are proxied to the underlying file object.\n\nThis class uses members with a double underscore (\\_\\_) leading prefix so as\nnot to accidentally shadow an attribute.\n\nThe data is stored in a temporary file until it is all available.  As long\nas the temporary files directory is disk-based (sometimes it's a\nmemory-backed-`tmpfs` on Linux), data will be unloaded to disk if memory\npressure is high.  For small files the disk usually won't be used at all,\nit'll all be in the filesystem memory cache, so there should be no\nperformance impact.\n"]}], "exports": []}, {"name": "cachecontrol.adapter", "documentation": ["SPDX-FileCopyrightText: 2015 Eric Larson", "SPDX-License-Identifier: Apache-2.0"], "functions": [], "variables": [], "classes": [{"name": "cachecontrol.adapter.CacheControlAdapter", "bases": ["HTTPAdapter"], "methods": [{"name": "cachecontrol.adapter.CacheControlAdapter.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cache", "type": null, "default": "..."}, {"name": "cache_etags", "type": null, "default": "..."}, {"name": "controller_class", "type": null, "default": "..."}, {"name": "serializer", "type": null, "default": "..."}, {"name": "heuristic", "type": null, "default": "..."}, {"name": "cacheable_methods", "type"