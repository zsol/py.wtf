eloper.mozilla.org/en-US/docs/Web/HTTP/Caching_FAQ\nhttp://lxr.mozilla.org/mozilla-release/source/netwerk/protocol/http/nsHttpResponseHead.cpp#397\nUnlike mozilla we limit this to 24-hr."]}], "exports": []}, {"name": "cachecontrol.serialize", "documentation": ["SPDX-FileCopyrightText: 2015 Eric Larson", "SPDX-License-Identifier: Apache-2.0"], "functions": [{"name": "cachecontrol.serialize._b64_decode_bytes", "asynchronous": false, "params": [{"name": "b", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cachecontrol.serialize._b64_decode_str", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "cachecontrol.serialize._default_body_read", "type": null, "documentation": []}], "classes": [{"name": "cachecontrol.serialize.Serializer", "bases": ["object"], "methods": [{"name": "cachecontrol.serialize.Serializer.dumps", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "request", "type": null, "default": null}, {"name": "response", "type": null, "default": null}, {"name": "body", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cachecontrol.serialize.Serializer.loads", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "request", "type": null, "default": null}, {"name": "data", "type": null, "default": null}, {"name": "body_file", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cachecontrol.serialize.Serializer.prepare_response", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "request", "type": null, "default": null}, {"name": "cached", "type": null, "default": null}, {"name": "body_file", "type": null, "default": "..."}], "returns": null, "documentation": ["Verify our vary headers match and construct a real urllib3\nHTTPResponse object."]}, {"name": "cac