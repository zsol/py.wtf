tions.type", "project": "--std--"}, "params": [{"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "type", "xref": {"fqname": "functions.type", "project": "--std--"}, "params": [{"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "documentation": ["Create a proxy subclass that wraps the given class.\n\nThis method creates a new class that inherits from the original class\nand adds proxy functionality. All instances of the wrapped class will\nautomatically be proxied.\n\nArgs:\n    cls (Type[T]): The class to wrap with proxy functionality.\n\nReturns:\n    Type[T]: A new class that inherits from the original and includes\n            proxy capabilities.\n\nExample:\n    >>> @transformer.wrap_class\n    >>> class MyClass:\n    >>>     def __init__(self):\n    >>>         self.value = 42"]}, {"name": "Transformer.transformer.Transformer.reshape_references", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "original", "type": {"name": "object", "xref": {"fqname": "functions.object", "project": "--std--"}, "params": null}, "default": null}, {"name": "transformed", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Update all references to the original object with the transformed version.\n\nThis method scans the entire object graph to find references to the original\nobject and replaces them with references to the transformed proxy object.\n\nArgs:\n    original (T): The original object whose references need to be updated.\n    transformed (Any): The transformed proxy object to replace references with.\n\nRaises:\n    TransformationError: If an error occurs during reference reshaping."]}, {"name": "Transformer.transformer.Transformer.add_class", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cls", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Register a class for transformation tracking.\n\nThis method wraps the class and makes it available globally for transformation.\n\nArgs:\n    cls (Type[T]): The class to add to the transformation registry."]}, {"name": "Transformer.transformer.Transformer.add_instance", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "instance", "type": {"name": "object", "xref": {"fqname": "functions.object", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Register an instance for transformation tracking.\n\nThis method transforms the instance and adds it to the transformation registry.\n\nArgs:\n    instance (object): The instance to add to the transformation registry."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["A class that transforms Python objects to enable tracking and monitoring.\n\nThe Transformer class serves as the main entry point for object transformation.\nIt maintains a registry of transformed instances and provides methods to transform\nvarious Python types into their corresponding proxy objects.\n\nAttributes:\n    _instances (dict): A registry mapping object IDs to their transformed proxies.\n                     This ensures consistency in transformation across the\n                     object graph.\n\nExample:\n    >>> transformer = Transformer()\n    >>> obj = {\"key\": \"value\"}\n    >>> transformed = transformer.t