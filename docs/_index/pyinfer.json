, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pyinfer.inference_report.InferenceReport._median_run", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "runs", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pyinfer.inference_report.MultiInferenceReport", "bases": [], "methods": [{"name": "pyinfer.inference_report.MultiInferenceReport.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "models", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "inputs", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "n_seconds", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "n_iterations", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "exit_on_inputs_exhausted", "type": {"name": "bool", "xref": {"fqna