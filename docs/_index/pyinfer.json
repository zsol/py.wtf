l}, "default": "..."}, {"name": "exit_on_inputs_exhausted", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "infer_failure_point", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "model_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "drop_stats", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": null, "documentation": ["Args:\n    model (Callable): The callable method or function for the model.\n\n    inputs (Any): The input(s) parameters the model receives.\n\n    n_seconds (Union[int, float, None], optional): Number of seconds to run model inferences.\n        If this is `None` it is expected that `n_iterations` will be set. Defaults to None.\n\n    n_iterations (int, optional): Number of iterations to run model inferences for.\n        If this is `None` it is expected that `n_seconds` will be set. Defaults to None.\n\n    exit_on_inputs_exhausted (bool, optional): If inputs are a iterable of inputs exit\n        on completion. This feature is not yet implemented. Defaults to False.\n\n    infer_failure_point (Union[int, float, None], optional): Time in seconds (int or float)\n        at which an inference is to be considered a failure in the reporting stats.\n        Defaults to None.\n\n    model_name (str, optional): The name to give to the model for the report.\n        Defaults to None.\n\n    drop_stats (List[str], optional): List of keys to drop from the report.\n        Defaults to None.\n\nRaises:\n    ModelIsNotCallableError: Will raise if the model provided is not callable.\n    MeasurementIntervalNotSetError: Will raise if neither `n_seconds` or\n        `n_iterations` are set."]}, {"name": "pyinfer.inference_report.InferenceReport._timeout", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "duration", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "pyinfer.inference_report.InferenceReport.run", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "print_report", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Runs the inference report for `self.model` with input(s) `self.inputs`\n\nArgs:\n    print_report (bool, optional): If true a table representation of the report will be\n    printed to console. Defaults to True.\n\nReturns:\n    dict: A dictionary containing all the report stats created during the run."]}, {"name": "pyinfer.inference_report.InferenceReport._make_results_dict", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "completed", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "failed", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "runs", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "total_time_taken", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pyinfer.inference_report.InferenceReport._cpu_monitor", "asynchronous": false, "params": [{"name": "target_function", "type": null, "default": null}], "returns": null, "documentation": ["Monitors cpu usage of a `target_function`. Not currently in use\nAs psutil requires root access when running a worker process."]}, {"name": "pyinfer.inference_report.InferenceReport.report", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "results_dict", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Prints a report to console based on the values\nfound in `results_dict`\n\nArgs:\n    results_dict (dict): Dictionary containing compiled stats from a run."]}, {"name": "pyinfer.inference_report.InferenceReport.plot", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "show", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "save_location", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Creates a simple plot of `self.runs`. Plots run number\non the x-axis and run time in milliseconds on the y-axis.\n\nArgs:\n    show (bool, optional): Whether to show the plot after calling method. Defaults to True.\n\n    save_location (str, optional): Location to save plot at. If None the plot will not\n        be saved. Defaults to None.\n\nRaises:\n    MatplotlibNotInstalledError: Raise if matplotlib is not installed i