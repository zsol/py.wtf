ll}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lazify.LazyProxy.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lazify.LazyProxy.__setitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lazify.LazyProxy.__copy__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lazify.LazyProxy.__deepcopy__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "memo", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "lazify.LazyProxy.__slots__", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Class for proxy objects that delegate to a specified function to evaluate\nthe actual object.\n\n```pycon\n>>> def greeting(name='world'):\n...     return 'Hello, {}!'.format(name)\n>>> lazy_greeting = LazyProxy(greeting, name='Joe')\n>>> print(lazy_greeting)\nHello, Joe!\n>>> '  ' + lazy_greeting\n'  Hello, Joe!'\n>>> '({})'.format(lazy_greeting)\n'(Hello, Joe!)'\n```\n\nThis can be used, for example, to implement lazy translation functions that\ndelay the actual translation until the string is actually used. The\nrationale for such behavior is that the locale of the user may not always\nbe available. In web applications, you only know the locale when processing\na request.\n\nThe proxy implementation attempts to be as complete as possible, so that\nthe lazy objects should mostly work as expected, for example for sorting:\n\n```pycon\n>>> greetings = [\n...     LazyProxy(greeting, 'world'),\n...     LazyProxy(greeting, 'Joe'),\n...     LazyProxy(greeting, 'universe'),\n... ]\n>>> greetings.sort()\n>>> for greeting in greetings:\n...     print(greeting)\nHello, Joe!\nHello, universe!\nHello, world!\n```\n"]}], "exports": [{"name": "lazify.lazify", "xref": {"fqname": "lazify.lazify", "project": null}}, {"name": "lazify.LazyProxy", "xref": {"fqname": "lazify.LazyProxy", "project": null}}]}]}