[], "documentation": []}, {"name": "multiaddr.multiaddr.Multiaddr", "bases": ["collections.abc.Mapping"], "methods": [{"name": "multiaddr.multiaddr.Multiaddr.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "addr", "type": null, "default": null}], "returns": null, "documentation": ["Instantiate a new Multiaddr.\n\nArgs:\n    addr : A string-encoded or a byte-encoded Multiaddr"]}, {"name": "multiaddr.multiaddr.Multiaddr.join", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "*addrs", "type": null, "default": null}], "returns": null, "documentation": ["Concatenate the values of the given MultiAddr strings or objects,\nencapsulating each successive MultiAddr value with the previous ones."]}, {"name": "multiaddr.multiaddr.Multiaddr.__eq__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": ["Checks if two Multiaddr objects are exactly equal."]}, {"name": "multiaddr.multiaddr.Multiaddr.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return the string representation of this Multiaddr.\n\nMay raise a {class}`~multiaddr.exceptions.BinaryParseError` if the\nstored MultiAddr binary representation is invalid.\n"]}, {"name": "multiaddr.multiaddr.Multiaddr.__contains__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "proto", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "multiaddr.multiaddr.Multiaddr.__iter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "multiaddr.multiaddr.Multiaddr.__len__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name