 file. Valid options are 96 and 384\n    query: Pandas query to filter the file list.\n    order_name: Name of the order\n    barcode: Barcode of the plate\n    overwrite: Whether to overwrite the zarr file if it already exists\n    binning: Binning factor to downsample the original image. If set to 2,\n        an image that is 2x2 downsampled in xy will be produced.\n    parallelize: The automatic distribute.Client option often fails to\n        finish when running the task locally. Set parallelize to false to\n        avoid that.\n\nReturns:\n    Metadata dictionary"]}], "variables": [{"name": "fractal_faim_ipa.convert_ome_zarr.logger", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "fractal_faim_ipa.imagexpress_zmb.MixedAcquisition", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "fractal_faim_ipa.imagexpress_zmb.MixedAcquisition.MixedAcquisition", "bases": ["ImageXpressPlateAcquisition"], "methods": [{"name": "fractal_faim_ipa.imagexpress_zmb.MixedAcquisition.MixedAcquisition.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "acquisition_dir", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "alignment", "type": {"name": "TileAlignmentOptions", "xref": {"fqname": "faim_ipa.hcs.acquisition.TileAlignmentOptions", "project": "faim-ipa"}, "params": null}, "default": null}, {"name": "background_correction_matrices", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "U