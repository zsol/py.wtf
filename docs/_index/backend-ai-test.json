efault": null}, {"name": "ctx", "type": {"name": "click.Context", "xref": {"fqname": "click.Context", "project": "click"}, "params": null}, "default": null}, {"name": "formatter", "type": {"name": "click.HelpFormatter", "xref": {"fqname": "click.HelpFormatter", "project": "click"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "ai.backend.test.cli.__main__", "documentation": [], "functions": [{"name": "ai.backend.test.cli.__main__.main", "asynchronous": false, "params": [{"name": "ctx", "type": {"name": "click.Context", "xref": {"fqname": "click.Context", "project": "click"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["The integration test suite"]}, {"name": "ai.backend.test.cli.__main__.run_cli", "asynchronous": false, "params": [{"name": "ctx", "type": {"name": "click.Context", "xref": {"fqname": "click.Context", "project": "click"}, "params": null}, "default": null}, {"name": "pkgs", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "user_file", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "user2_file", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "admin_file", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["A shortcut command to run pytest against a specific set of CLI-based\nintegration tests\n\nIt takes one or more test package names in a comma-separated list (PKGS)\nand forwards all other extra arguments and options (PYTEST_ARGS) to\nthe underlying pytest command.\n\n\n\b\nParameters:\n    pkgs: A comma-separated list of package names to test. Available options are 'admin' and 'user'.\n    user_file: Path to the environment file for the 'user' profile. Defaults to 'env-local-user-api.sh'.\n    user2_file: Path to the environment file for the 'user2' profile. Defaults to 'env-local-user2-api.sh'.\n    admin_file: Path to the environment file for the 'admin' profile. Defaults to 'env-local-admin-api.sh'.\n\n\b\nUsage:\n    run_cli [PKGS] [PYTEST_ARGS] --user-file [PATH] --user2-file [PATH] --admin-file [PATH]\n\n\b\nExamples:\n    run_cli admin,user --some-pytest-option\n    run_cli user --user-file custom-user-env.sh --pytest-arg1 --pytest-arg2\n\nThe command simplifies the process of running CLI-based integration tests for specific packages, allowing customization of the environment and passing additional arguments to pytest."]}], "variables": [], "classes": [], "exports": []}]}