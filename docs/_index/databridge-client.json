 content_type: MIME type (optional, will be guessed if not provided)\n    metadata: Optional metadata dictionary\n\nReturns:\n    Document: Metadata of the ingested document\n\nExample:\n    ```python\n    # From file path\n    doc = await db.ingest_file(\n        \"document.pdf\",\n        filename=\"document.pdf\",\n        content_type=\"application/pdf\",\n        metadata={\"department\": \"research\"}\n    )\n    \n    # From file object\n    with open(\"document.pdf\", \"rb\") as f:\n        doc = await db.ingest_file(f, \"document.pdf\")\n    ```"]}, {"name": "databridge.client.DataBridge.query", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "query", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "return_type", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "filters", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, "default": "..."}, {"name": "k", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "min_score", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "ChunkResult", "xref": {"fqname": "databridge.client.ChunkResult", "project": null}, "params": null}]}, {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "DocumentResult", "xref": {"fqname": "databridge.client.DocumentResult", "project": null}, "params": null}]}]}, "documentation": ["Query documents in DataBridge.\n\nArgs:\n    query: Search query text\n    return_type: Type of results (\"chunks\" or \"documents\")\n    filters: Optional metadata filters\n    k: Number of results (default: 4)\n    min_score: Minimum similarity threshold (default: 0.0)\n\nReturns:\n    List[ChunkResult] or List[DocumentResult] depending on return_type\n\nExample:\n    ```python\n    # Query for chunks\n    chunks = await db.query(\n        \"What are the key findings?\",\n        return_type=\"chunks\",\n        filters={\"department\": \"research\"}\n    )\n\n    # Query for documents\n    docs = await db.query(\n        \"machine learning\",\n        return_type=\"documents\",\n        k=5\n    )\n    ```"]}, {"name": "databridge.client.DataBridge.list_documents", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "skip", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "limit", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "filters", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, "default": "..."}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Document", "xref": {"fqname": "databridge.client.Document", "project": null}, "params": null}]}, "documentation": ["List accessible documents.\n\nArgs:\n    skip: Number of documents to skip\n    limit: Maximum number of documents to return\n    filters: Optional filters\n\nReturns:\n    List[Document]: List of accessible documents\n\nExample:\n    ```python\n    # Get first page\n    docs = await db.list_documents(limit=10)\n    \n    # Get next page\n    next_page = await db.list_documents(skip=10, limit=10, filters={\"department\": \"research\"})\n    ```"]}, {"name": "databridge.client.DataBridge.get_document", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "document_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Document", "xref": {"fqname": "databridge.client.Document", "project": null}, "params": null}, "documentation": ["Get document metadata by ID.\n\nArgs:\n    document_id: ID of the document\n\nReturns:\n    Document: Document metadata\n\nExample:\n    ```python\n    doc = await db.get_document(\"doc_123\")\n    print(f\"Title: {doc.metadata.get('title')}\")\n    ```"]}, {"name": "databridge.client.DataBridge.close", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Close the HTTP client"]}, {"name": "databridge.client.DataBridge.__aenter__", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "databridge.client.DataBridge.__aexit__", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "exc_type", "type": null, "default": null}, {"name": "exc_val", "type": null, "default": null}, {"name": "exc_tb", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["DataBridge client for document operations.\n\nArgs:\n    uri (str): DataBridge URI in the format \"databridge://<owner_id>:<token>@<host>\"\n    timeout (int, optional): Request timeout in seconds. Defaults to 30.\n\nExamples:\n    ```python\n    async with DataBridge(\"databridge://owner_id:token@api.databridge.ai\") as db:\n        # Ingest text\n        doc = await db.ingest_text(\n            \"Sample content\",\n            metadata={\"category\": \"sample\"}\n        )\n        \n        # Query documents\n        results = await db.query(\"search query\")\n    ```"]}], "exports": []}, {"name": "databridge", "documentation": [], "functions": [], "variables": [{"name": "databridge.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "databridge.AuthenticationError", "xref": {"fqname": "databridge.exceptions.AuthenticationError", "project": null}}, {"name": "databridge.DataBridge", "xref": {"fqname": "databridge.client.DataBridge", "project": null}}, {"name": "databridge.DataBridgeError", "xref": {"fqname": "databridge.exceptions.DataBridgeError", "project": null}}]}]}