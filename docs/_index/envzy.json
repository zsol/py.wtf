: '3.3.1',\n 'certifi': '2023.7.22',\n 'pydantic_core': '2.10.1',\n 'packaging': '23.2',\n 'soupsieve': '2.5',\n 'importlib-metadata': '6.8.0',\n 'pypi-simple': '1.2.0',\n 'annotated-types': '0.6.0',\n 'idna': '3.4',\n 'zipp': '3.17.0',\n 'attrs': '23.1.0',\n 'beautifulsoup4': '4.12.2',\n 'pydantic': '2.4.2',\n 'typing_extensions': '4.8.0',\n 'requests': '2.31.0'}\n```\n\n## Development\n\n* `poetry install` for installing project in dev-mode with all of it dependencies.\n* `poetry publish --build` for publishing package to PyPI.\n* `tox` for run tests.\n"], "modules": [{"name": "envzy.auto", "documentation": [], "functions": [], "variables": [{"name": "envzy.auto.logger", "type": null, "documentation": []}, {"name": "envzy.auto.P", "type": null, "documentation": []}, {"name": "envzy.auto.PythonVersion", "type": null, "documentation": []}], "classes": [{"name": "envzy.auto.AutoExplorer", "bases": ["BaseExplorer"], "methods": [{"name": "envzy.auto.AutoExplorer.get_local_module_paths", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "namespace", "type": {"name": "VarsNamespace", "xref": {"fqname": "envzy.auto.search.VarsNamespace", "project": null}, "params": null}, "default": null}], "returns": {"name": "ModulePathsList", "xref": {"fqname": "envzy.auto.spec.ModulePathsList", "project": null}, "params": null}, "documentation": []}, {"name": "envzy.auto.AutoExplorer._get_local_module_paths", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "packages", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "LocalPackage", "xref": {"fqname": "envzy.auto.packages.LocalPackage", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "ModulePathsList", "xref": {"fqname": "envzy.auto.spec.ModulePathsList", "project": null}, "params": null}, "documentation": []}, {"name": "envzy.auto.AutoExplorer.get_pypi_packages", "asynch