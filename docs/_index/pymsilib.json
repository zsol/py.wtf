tory's default\nflags are used. If no keyfile is given, the KeyPath is left null in the Component\ntable."]}, {"name": "pymsilib.Directory.make_short", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "file", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pymsilib.Directory.add_file", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "file", "type": null, "default": null}, {"name": "src", "type": null, "default": "..."}, {"name": "version", "type": null, "default": "..."}, {"name": "language", "type": null, "default": "..."}], "returns": null, "documentation": ["Add a file to the current component of the directory, starting a new one\nif there is no current component. By default, the file name in the source\nand the file table will be identical. If the src file is specified, it is\ninterpreted relative to the current directory. Optionally, a version and a\nlanguage can be specified for the entry in the File table."]}, {"name": "pymsilib.Directory.glob", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pattern", "type": null, "default": null}, {"name": "exclude", "type": null, "default": "..."}], "returns": null, "documentation": ["Add a list of files to the current component as specified in the\nglob pattern. Individual files can be excluded in the exclude list."]}, {"name": "pymsilib.Directory.remove_pyc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pymsilib.Binary", "bases": [], "methods": [{"name": "pymsilib.Binary.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "fname", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pymsilib.Binary.__