emo.omega.fetch_grad", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "f", "type": null, "default": null}, {"name": "i", "type": null, "default": null}], "returns": null, "documentation": ["Estimate the first and second derivatives at x[i] using finite differences\nand Lagrange interpolation.\n\nParameters:\nx (list or array): x values.\nf (list or array): Corresponding f(x) values.\ni (int): Index of the point to estimate derivatives.\n\nReturns:\ntuple: (first_derivative, second_derivative) at x[i].", "##############################################################"]}, {"name": "nemo.omega.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "nemo.__main__", "documentation": ["This module contains the main function for the NEMO program, \nwhich is a tool for simulating photophysical processes in organic materials.", "!/usr/bin/env python3"], "functions": [{"name": "nemo.__main__.interface", "asynchronous": false, "params": [], "returns": null, "documentation": ["This function displays a menu of options for the user to choose from\nand prompts the user for input.\nThe user's input is then used to call the appropriate function\nto perform the selected operation.", "pylint: disable=unbalanced-tuple-unpacking"]}, {"name": "nemo.__main__.main", "asynchronous": false, "params": [], "returns": null, "documentation": ["This function is the entry point for the NEMO program. It takes command line arguments\nand either prints out the geometry of a molecule or launches the program's interface."]}], "variables": [], "classes": [], "exports": []}, {"name": "nemo.batch", "documentation": ["!/usr/bin/env python3"], "functions": [{"name": "nemo.batch.run_batch", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "nemo.batch.BATCH_FILE", "type": null, "documentation": []}, {"name": "nemo.batch.NPROC", "type": null, "documentation": []}, {"name": "nemo.batch.NUM", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "nemo.eom", "documentation": [], "functions": [{"name": "nemo.eom.pega_energias", "asynchronous": false, "params": [{"name": "file", "type": null, "default": null}], "returns": null, "documentation": ["##############################################################", "#GETS ENERGIES, OSCS, AND INDICES FOR Sn AND Tn STATES##################################"]}, {"name": "nemo.eom.pega_soc_singlet", "asynchronous": false, "params": [{"name": "file", "type": null, "default": null}, {"name": "n_state", "type": null, "default": null}, {"name": "ind_s", "type": null, "default": null}, {"name": "ind_t", "type": null, "default": null}], "returns": null, "documentation": ["########################################################################################", "#GETS SOC BETWEEN Sn STATE AND TRIPLETS#################################################"]}, {"name": "nemo.eom.pega_soc_triplet", "asynchronous": false, "params": [{"name": "file", "type": null, "default": null}, {"name": "n_state", "type": null, "default": null}, {"name": "ind_s", "type": null, "default": null}, {"name": "ind_t", "type": null, "default": null}], "returns": null, "documentation": ["########################################################################################", "#GETS SOC BETWEEN Tn STATE AND SINGLETS#################################################"]}, {"name": "nemo.eom.pega_soc_ground", "asynchronous": false, "params": [{"name": "file", "type": null, "default": null}, {"name": "n_state", "type": null, "default": null}, {"name": "ind_s", "type": null, "default": null}, {"name": "ind_t", "type": null, "default": null}], "returns": null, "documentation": ["########################################################################################", "#GETS SOC BETWEEN Tn STATE AND S0#######################################################"]}, {"name": "nemo.eom.p