tion.ClauseC", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "rule", "type": null, "default": null}, {"name": "tokens", "type": null, "default": null}, {"name": "_parent", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "yapps.grammar.ParserDescription.ClauseD", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "rule", "type": null, "default": null}, {"name": "tokens", "type": null, "default": null}, {"name": "_parent", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "yapps.grammar.ParserDescription.OptParam", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "_parent", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "yapps.grammar.ParserDescription.Str", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "_parent", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [{"name": "yapps.grammar.ParserDescription.Context", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "yapps.parsetree", "documentation": ["Classes used to represent parse trees and generate output.\n\nThis module defines the Generator class, which drives the generation\nof Python output from a grammar parse tree.  It also defines nodes\nused to represent the parse tree; they are derived from class Node.\n\nThe main logic of Yapps is in this module.", "parsetree.py, part of Yapps 2 - yet another python parser system", "Copyright 1999-2003 by Amit J. Patel <amitp@cs.stanford.edu>", "This version of the Yapps 2 Runtime can be distributed under the", "terms of the MIT open source license, either found in the LICENSE file", "included with the Yapps distribution", "<http://theory.stanford.edu/~amitp/yapps/> or at", "<http://www.opensource.org/licenses/mit-license.php>"], "functions": [], "variables": [{"name": "yapps.parsetree.INDENT", "type": null, "documentation": []}], "classes": [{"name": "yapps.parsetree.Generator", "bases": [], "methods": [{"name": "yapps.parsetree.Generator.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "options", "type": null, "default": null}, {"name": "tokens", "type": null, "default": null}, {"name": "rules", "type": null, "default": null}], "returns": null, "documentation": ["TODO: many of the methods here should be class methods, not instance methods"]}, {"name": "yapps.parsetree.Generator.has_option", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yapps.parsetree.Generator.non_ignored_tokens", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yapps.parsetree.Generator.changed", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Increments the change count.\n\n```pycon\n>>> t = Generator('', [], [], [])\n>>> old_count = t.change_count\n>>> t.changed()\n>>> assert t.change_count == old_count + 1\n```\n"]}, {"name": "yapps.parsetree.Generator.set_subtract", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "a", "type": null, "default": null}, {"name": "b", "type": null, "default": null}], "returns": null, "documentation": ["Returns the elements of a that are not in b.\n\n```pycon\n>>> t = Generator('', [], [], [])\n>>> t.set_subtract([], [])\n[]\n>>> t.set_subtract([1, 2], [1, 2])\n[]\n>>> t.set_subtract([1, 2, 3], [2])\n[1, 3]\n>>> t.set_subtract([1], [2, 3, 4])\n[1]\n```\n"]}, {"name": "yapps.parsetree.Generator.subset", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "a", "type": null, "default": null}, {"name": "b", "type": null, "default": null}], "returns": null, "documentation": ["True iff all elements of sequence a are inside sequence b\n\n```pycon\n>>> t = Generator('', [], [], [])\n>>> t.subset([], [1, 2, 3])\n1\n>>> t.subset([1, 2, 3], [])\n0\n>>> t.subset([1], [1, 2, 3])\n1\n>>> t.subset([3, 2, 1], [1, 2, 3])\n1\n>>> t.subset([1, 1, 1], [1, 2, 3])\n1\n>>> t.subset([1, 2, 3], [1, 1, 1])\n0\n```\n"]}, {"name": "yapps.parsetree.Generator.equal_set", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "a", "type": null, "default": null}, {"name": "b", "type": null, "default": null}], "returns": null, "documentation": ["True iff subset(a, b) and subset(b, a)\n\n```pycon\n>>> t = Generator('', [], [], [])\n>>> a_set = [1, 2, 3]\n>>> t.equal_set(a_set, a_set)\n1\n>>> t.equal_set(a_set, a_set[:])\n1\n>>> t.equal_set([], a_set)\n0\n>>> t.equal_set([1, 2, 3], [3, 2, 1])\n1\n```\n"]}, {"name": "yapps.parsetree.Generator.add_to", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parent", "type": null, "default": null}, {"name": "additions", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yapps.parsetree.Generator.equate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "a", "type": null, "default": null}, {"name": "b", "type": null, "default": null}], "returns": null, "documentation": ["Extend (a) and (b) so that they contain each others' elements.\n\n```pycon\n>>> t = Generator('', [], [], [])\n>>> a = [1, 2]\n>>> b = [2, 3]\n>>> t.equate(a, b)\n>>> a\n[1, 2, 3]\n>>> b\n[2, 3, 1]\n```\n"]}, {"name": "yapps.parsetree.Generator.write", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yapps.parsetree.Generator.in_test", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "expr", "type": null, "default": null}, {"name": "full", "type": null, "default": null}, {"name": "set", "type": null, "default": null}], "returns": null, "documentation": ["Generate a test of (expr) being in (set), where (set) is a subset of (full)\n\nexpr is a string (Python expression)\nset is a list of values (which will be converted with repr)\nfull is the list of all values expr could possibly evaluate to\n\n```pycon\n>>> t = Generator('', [], [], [])\n>>> t.in_test('x', [1,2,3,4], [])\n'0'\n>>> t.in_test('x', [1,2,3,4], [1,2,3,4])\n'1'\n>>> t.in_test('x', [1,2,3,4], [1])\n'x == 1'\n>>> t.in_test('a+b', [1,2,3,4], [1,2])\n'a+b in [1, 2]'\n>>> t.in_test('x', [1,2,3,4,5], [1,2,3])\n'x not in [4, 5]'\n>>> t.in_test('x', [1,2,3,4,5], [1,2,3,4])\n'x != 5'\n```\n"]}, {"name": "yapps.parsetree.Generator.not_in_test", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "expr", "type": null, "default": null}, {"name": "full", "type": null, "default": null}, {"name": "set", "type": null, "default": null}], "returns": null, "documentation": ["Like in_test, but the reverse test."]}, {"name": "yapps.parsetree.Generator.peek_call", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "a", "type": null, "default": null}], "returns": null, "documentation": ["Generate a call to scan for a token in the set 'a'"]}, {"name": "yapps.parsetree.Generator.peek_test", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "a", "type": null, "default": null}, {"name": "b", "type": null, "default": null}], "returns": null, "documentation": ["Generate a call to test whether the next token (which could be any of\nthe elements in a) is in the set b."]}, {"name": "yapps.parsetree.Generator.not_peek_test", "asynchronous": f