{"name": "yapps2-logilab", "metadata": {"name": "Yapps2-logilab", "version": "2.2.1", "classifiers": [], "home_page": "https://github.com/mk-fg/yapps", "license": "MIT", "documentation_url": null, "dependencies": [], "summary": "Yet Another Python Parser System", "upload_time": 1639492812}, "documentation": [""], "modules": [{"name": "yapps.cli_tool", "documentation": ["!/usr/bin/env python", "Yapps 2 - yet another python parser system", "Copyright 1999-2003 by Amit J. Patel <amitp@cs.stanford.edu>", "This version of Yapps 2 can be distributed under the", "terms of the MIT open source license, either found in the LICENSE file", "included with the Yapps distribution", "<http://theory.stanford.edu/~amitp/yapps/> or at", "<http://www.opensource.org/licenses/mit-license.php>"], "functions": [{"name": "yapps.cli_tool.generate", "asynchronous": false, "params": [{"name": "inputfile", "type": null, "default": null}, {"name": "outputfile", "type": null, "default": "..."}, {"name": "dump", "type": null, "default": "..."}, {"name": "**flags", "type": null, "default": null}], "returns": null, "documentation": ["Generate a grammar, given an input filename (X.g)\nand an output filename (defaulting to X.py)."]}, {"name": "yapps.cli_tool.main", "asynchronous": false, "params": [{"name": "argv", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [{"name": "yapps.cli_tool.PY2", "type": null, "documentation": []}, {"name": "yapps.cli_tool.string_types", "type": null, "documentation": []}, {"name": "yapps.cli_tool.string_types", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "yapps", "documentation": [], "functions": [], "variables": [{"name": "yapps.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "yapps.runtime", "documentation": ["Run time libraries needed to run parsers generated by Yapps.\n\nThis module defines parse-time exception classes, a scanner class, a\nbase class for parsers produced by Yapps, and a context class that\nkeeps track of the parse stack.", "Yapps 2 Runtime, part of Yapps 2 - yet another python parser system", "Copyright 1999-2003 by Amit J. Patel <amitp@cs.stanford.edu>", "Enhancements copyright 2003-2004 by Matthias Urlichs <smurf@debian.org>", "This version of the Yapps 2 Runtime can be distributed under the", "terms of the MIT open source license, either found in the LICENSE file", "included with the Yapps distribution", "<http://theory.stanford.edu/~amitp/yapps/> or at", "<http://www.opensource.org/licenses/mit-license.php>"], "functions": [{"name": "yapps.runtime.print_error", "asynchronous": false, "params": [{"name": "err", "type": null, "default": null}, {"name": "scanner", "type": null, "default": null}, {"name": "max_ctx", "type": null, "default": "..."}], "returns": null, "documentation": ["Print error messages, the parser stack, and the input text -- for human-readable error messages."]}, {"name": "yapps.runtime.wrap_error_reporter", "asynchronous": false, "params": [{"name": "parser", "type": null, "default": null}, {"name": "rule", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kw", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "yapps.runtime.MIN_WINDOW", "type": null, "documentation": []}, {"name": "yapps.runtime.in_name", "type": null, "documentation": []}], "classes": [{"name": "yapps.runtime.SyntaxError", "bases": ["Exception"], "methods": [{"name": "yapps.runtime.SyntaxError.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pos", "type": null, "default": "..."}, {"name": "msg", "type": null, "default": "..."}, {"name": "context", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "yapps.runtime.SyntaxError.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["When we run into an unexpected token, this is the exception to use", "File lookup window"]}, {"name": "yapps.runtime.NoMoreTokens", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Another exception object, for when we run out of tokens"]}, {"name": "yapps.runtime.Token", "bases": ["object"], "methods": [{"name": "yapps.runtime.Token.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "type", "type": null, "default": null}, {"name": "value", "type": null, "default": null}, {"name": "pos", "type": null, "default": "..."}], "returns": null, "documentation": ["Initialize a token."]}, {"name": "yapps.runtime.Token.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Yapps token.\n\nThis is a container for a scanned token."]}, {"name": "yapps.runtime.Scanner", "bases": ["object"], "methods": [{"name": "yapps.runtime.Scanner.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "patterns", "type": null, "default": null}, {"name": "ignore", "type": null, "default": null}, {"name": "input", "type": null, "default": "..."}, {"name": "file", "type": null, "default": "..."}, {"name": "filename", "type": null, "default": "..."}, {"name": "stacked", "type": null, "default": "..."}], "returns": null, "documentation": ["Initialize the scanner.\n\nParameters:\n  patterns : [(terminal, uncompiled regex), ...] or None\n  ignore : {terminal:None, ...}\n  input : string\n\nIf patterns is None, we assume that the subclass has\ndefined self.patterns : [(terminal, compiled regex), ...].\nNote that the patterns parameter expects uncompiled regexes,\nwhereas the self.patterns field expects compiled regexes.\n\nThe 'ignore' value is either None or a callable, which is called\nwith the scanner and the to-be-ignored match object; this can\nbe used for include file or comment handling."]}, {"name": "yapps.runtime.Scanner.stack_input", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "input", "type": null, "default": "..."}, {"name": "file", "type": null, "default": "..."}, {"name": "filename", "type": null, "default": "..."}], "returns": null, "documentation": ["Temporarily parse from a second file."]}, {"name": "yapps.runtime.Scanner.get_pos", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return a file/line/char tuple."]}, {"name": "yapps.runtime.Scanner.print_line_with_pointer", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pos", "type": null, "default": null}, {"name": "length", "type": null, "default": "..."}, {"name": "out", "type": null, "default": "..."}], "returns": null, "documentation": ["Print the line of 'text' that includes position 'p',\nalong with a second line with a single caret (^) at position p", "def __repr__(self):", "\"\"\"Print the last few tokens that have been scanned in\"\"\"", "output = ''", "for t in self.tokens:", "output += '%s\\n' % (repr(t),)", "return output"]}, {"name": "yapps.runtime.Scanner.grab_input", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Get more input if possible."]}, {"name": "yapps.runtime.Scanner.getchar", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return the next character."]}, {"name": "yapps.runtime.Scanner.token", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "restrict", "type": null, "default": null}, {"name": "context", "type": null, "default": "..."}], "returns": null, "documentation": ["Scan for another token."]}, {"name": "yapps.runtime.Scanner.peek", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*types", "type": null, "default": null}, {"name": "**kw", "type": null, "default": null}], "returns": null, "documentation": ["Returns the token type for lookahead; if there are any args\nthen the list of args is the set of token types to allow"]}, {"name": "yapps.runtime.Scanner.scan", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "type", "type": null, "default": null}, {"name": "**kw", "type": null, "default": null}], "returns": null, "documentation": ["Returns the matched text, and moves to the next token"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Yapps scanner.\n\nThe Yapps scanner can work in context sensitive or context\ninsensitive modes.  The token(i) method is used to retrieve the\ni-th token.  It takes a restrict set that limits the set of tokens\nit is allowed to return.  In context sensitive mode, this restrict\nset guides the scanner.  In context insensitive mode, there is no\nrestriction (the set is always the full set of tokens)."]}, {"name": "yapps.runtime.Parser", "bases": ["object"], "methods": [{"name": "yapps.runtime.Parser.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "scanner", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yapps.runtime.Parser._stack", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "input", "type": null, "default": "..."}, {"name": "file", "type": null, "default": "..."}, {"name": "filename", "type": null, "default": "..."}], "returns": null, "documentation": ["Temporarily read from someplace else"]}, {"name": "yapps.runtime.Parser._peek", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*types", "type": null, "default": null}, {"name": "**kw", "type": null, "default": null}], "returns": null, "documentation": ["Returns the token type for lookahead; if there are any args\nthen the list of args is the set of token types to allow"]}, {"name": "yapps.runtime.Parser._scan", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "type", "type": null, "default": null}, {"name": "**kw", "type": null, "default": null}], "returns": null, "documentation": ["Returns the matched text, and moves to the next token"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Base class for Yapps-generated parsers.\n\n    "]}, {"name": "yapps.runtime.Context", "bases": ["object"], "methods": [{"name": "yapps.runtime.Context.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parent", "type": null, "default": null}, {"name": "scanner", "type": null, "default": null}, {"name": "rule", "type": null, "default": null}, {"name": "args", "type": null, "default": "..."}], "returns": null, "documentation": ["Create a new context.\n\nArgs:\nparent: Context object or None\nscanner: Scanner object\nrule: string (name of the rule)\nargs: tuple listing parameters to the rule"]}, {"name": "yapps.runtime.Context.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Class to represent the parser's call stack.\n\nEvery rule creates a Context that links to its parent rule.  The\ncontexts can be used for debugging."]}], "exports": []}, {"name": "yapps.grammar", "documentation": ["Parser for Yapps grammars.\n\nThis file defines the grammar of Yapps grammars.  Naturally, it is\nimplemented in Yapps.  The grammar.py module needed by Yapps is built\nby running Yapps on yapps_grammar.g.  (Holy circularity, Batman!)", "grammar.py, part of Yapps 2 - yet another python parser system", "Copyright 1999-2003 by Amit J. Patel <amitp@cs.stanford.edu>", "Enhancements copyright 2003-2004 by Matthias Urlichs <smurf@debian.org>", "This version of the Yapps 2 grammar can be distributed under the", "terms of the MIT open source license, either found in the LICENSE", "file included with the Yapps distribution", "<http://theory.stanford.edu/~amitp/yapps/> or at", "<http://www.opensource.org/licenses/mit-license.php>"], "functions": [{"name": "yapps.grammar.cleanup_choice", "asynchronous": false, "params": [{"name": "rule", "type": null, "default": null}, {"name": "lst", "type": null, "default": null}], "returns": null, "documentation": ["#####################################################################"]}, {"name": "yapps.grammar.cleanup_sequence", "asynchronous": false, "params": [{"name": "rule", "type": null, "default": null}, {"name": "lst", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yapps.grammar.resolve_name", "asynchronous": false, "params": [{"name": "rule", "type": null, "default": null}, {"name": "tokens", "type": null, "default": null}, {"name": "id", "type": null, "default": null}, {"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yapps.grammar.parse", "asynchronous": false, "params": [{"name": "rule", "type": null, "default": null}, {"name": "text", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "yapps.grammar.ParserDescriptionScanner", "bases": ["runtime.Scanner"], "methods": [{"name": "yapps.grammar.ParserDescriptionScanner.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "str", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**k