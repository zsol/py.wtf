"default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "zipfile36.ZipFile.fp", "type": null, "documentation": ["Set here since __del__ checks it"]}, {"name": "zipfile36.ZipFile._windows_illegal_name_trans_table", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Class with methods to open, read, write, close, list zip files.\n\nz = ZipFile(file, mode=\"r\", compression=ZIP_STORED, allowZip64=True)\n\nfile: Either the path to the file, or a file-like object.\n      If it is a path, the file will be opened and closed by ZipFile.\nmode: The mode can be either read 'r', write 'w', exclusive create 'x',\n      or append 'a'.\ncompression: ZIP_STORED (no compression), ZIP_DEFLATED (requires zlib),\n             ZIP_BZIP2 (requires bz2) or ZIP_LZMA (requires lzma).\nallowZip64: if True ZipFile will create files with ZIP64 extensions when\n            needed, otherwise it will raise an exception when this would\n            be necessary."]}, {"name": "zipfile36.PyZipFile", "bases": ["ZipFile"], "methods": [{"name": "zipfile36.PyZipFile.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "file", "type": null, "default": null}, {"name": "mode", "type": null, "default": "..."}, {"name": "compression", "type": null, "default": "..."}, {"name": "allowZip64", "type": null, "default": "..."}, {"name": "optimize", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "zipfile36.PyZipFile.writepy", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pathname", "type": null, "default": null}, {"name": "basename", "type": null, "default": "..."}, {"name": "filterfunc", "type": null, "default": "..."}], "returns": null, "documentation": ["Add all files from \"pathname\" to the ZIP archive.\n\nIf pathname is a package directory, search the directory and\nall package subdirectories recursively for all *.py and enter\nthe modules into the archive.  If pathname is a plain\ndirectory, listdir *.py and enter all modules.  Else, pathname\nmust be a Python *.py file and the module will be put into the\narchive.  Added modules are always module.pyc.\nThis method will compile the module.py into module.pyc if\nnecessary.\nIf filterfunc(pathname) is given, it is called with every argument.\nWhen it is False, the file or directory is skipped."]}, {"name": "zipfile36.PyZipFile._get_codename", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pathname", "type": null, "default": null}, {"name": "basename", "type": null, "default": null}], "returns": null, "documentation": ["Return (filename, archivename) for the path.\n\nGiven a module name path, return the correct file path and\narchive name, compiling if necessary.  For example, given\n/python/lib/string, return (/python/lib/string.pyc, string)."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Class to create ZIP archives with Python library files and packages."]}], "exports": [{"name": "zipfile36.BadZipfile", "xref": {"fqname": "zipfile36.BadZipfile", "project": null}}, {"name": "zipfile36.BadZipFile", "xref": {"fqname": "zipfile36.BadZipFile", "project": null}}, {"name": "zipfile36.error", "xref": {"fqname": "zipfile36.error", "project": null}}, {"name": "zipfile36.is_zipfile", "xref": {"fqname": "zipfile36.is_zipfile", "project": null}}, {"name": "zipfile36.LargeZipFile", "xref": {"fqname": "zipfile36.LargeZipFile", "project": null}}, {"name": "zipfile36.PyZipFile", "xref": {"fqname": "zipfile36.PyZipFile", "project": null}}, {"name": "zipfile36.ZIP_BZIP2", "xref": {"fqname": "zipfile36.ZIP_BZIP2", "project": null}}, {"name": "zipfile36.ZIP_DEFLATED", "xref": {"fqname": "zipfile36.ZIP_DEFLATED", "project": null}}, {"name": "zipfile36.ZIP_LZMA", "xref": {"fqname": "zipfile36.ZIP_LZMA", "project": null}}, {"name": "zipfi