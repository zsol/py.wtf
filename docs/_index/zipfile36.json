e.setpassword", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pwd", "type": null, "default": null}], "returns": null, "documentation": ["Set default password for encrypted files."]}, {"name": "zipfile36.ZipFile.comment", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["The comment text associated with the ZIP file."]}, {"name": "zipfile36.ZipFile.comment", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "comment", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "zipfile36.ZipFile.read", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "pwd", "type": null, "default": "..."}], "returns": null, "documentation": ["Return file bytes (as a string) for name."]}, {"name": "zipfile36.ZipFile.open", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "mode", "type": null, "default": "..."}, {"name": "pwd", "type": null, "default": "..."}, {"name": "force_zip64", "type": null, "default": "..."}], "returns": null, "documentation": ["Return file-like object for 'name'.\n\nname is a string for the file name within the ZIP file, or a ZipInfo\nobject.\n\nmode should be 'r' to read a file already in the ZIP file, or 'w' to\nwrite to a file newly added to the archive.\n\npwd is the password to decrypt files (only used for reading).\n\nWhen writing, if the file size is not known in advance but may exceed\n2 GiB, pass force_zip64 to use the ZIP64 format, which can handle large\nfiles.  If the size is known in advance, it is best to pass a ZipInfo\ninstance for name, with zinfo.file_size set."]}, {"name": "zipfile36.ZipFile._open_to_write", "asynchronous": false, "params": [{"name": "self", "type": null, "default": nu