null, "documentation": []}, {"name": "pytket_qirpass.utils.ORDER_PATTERN", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "pytket_qirpass.apply_qirpass", "documentation": [], "functions": [{"name": "pytket_qirpass.apply_qirpass.encode_double", "asynchronous": false, "params": [{"name": "a", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pytket_qirpass.apply_qirpass.argrep", "asynchronous": false, "params": [{"name": "arg", "type": {"name": "UnitID", "xref": {"fqname": "pytket.circuit.UnitID", "project": null}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pytket_qirpass.apply_qirpass.is_known_type", "asynchronous": false, "params": [{"name": "instr", "type": {"name": "ValueRef", "xref": {"fqname": "llvmlite.binding.ValueRef", "project": null}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pytket_qirpass.apply_qirpass.partition_instrs", "asynchronous": false, "params": [{"name": "instrs", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "ValueRef", "xref": {"fqname": "llvmlite.binding.ValueRef", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "ValueRef", "xref": {"fqname": "llvmlite.binding.ValueRef", "project": null}, "params": null}]}, {"