rams": null}, "default": null}, {"name": "options", "type": {"name": "ConsoleOptions", "xref": {"fqname": "rich.console.ConsoleOptions", "project": "rich"}, "params": null}, "default": null}], "returns": {"name": "RenderResult", "xref": {"fqname": "rich.console.RenderResult", "project": "rich"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["A reStructuredText renderable for rich.\n\nParameters\n----------\nmarkup : str\n    A string containing reStructuredText markup.\ncode_theme : Optional[Union[str, SyntaxTheme]]\n    Pygments theme for code blocks. Defaults to \"monokai\".\nshow_errors : Optional[bool]\n    Whether to show system_messages aka errors and warnings.\nguess_lexer : Optional[bool]\n    Whether to guess lexers for code blocks without specified language.\ndefault_lexer : Optional[str]\n    Which lexer to use if no lexer is guessed or found. Defaults to \"python\"\nfilename : Optional[str]\n    A file name to use for error messages, useful for debugging purposes. Defaults to \"<rst-document>\""]}], "exports": [{"name": "rich_rst.reStructuredText", "xref": {"fqname": "rich_rst.reStructuredText", "project": null}}, {"name": "rich_rst.ReStructuredText", "xref": {"fqname": "rich_rst.ReStructuredText", "project": null}}, {"name": "rich_rst.RestructuredText", "xref": {"fqname": "rich_rst.RestructuredText", "project": null}}, {"name": "rich_rst.RST", "xref": {"fqname": "rich_rst.RST", "project": null}}]}]}