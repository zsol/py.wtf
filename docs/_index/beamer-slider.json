ams": [{"name": "slide_deck_pdf", "type": null, "default": null}, {"name": "tex_output_path", "type": null, "default": "..."}, {"name": "num_to_take", "type": null, "default": "..."}, {"name": "force", "type": null, "default": "..."}, {"name": "svg_pfix", "type": null, "default": "..."}, {"name": "svg_height", "type": null, "default": "..."}, {"name": "svg_width", "type": null, "default": "..."}, {"name": "svg_converted_slides", "type": null, "default": "..."}], "returns": null, "documentation": ["svg_height and svg_width are used to scale the converted image. This is useful because otherwise the viewbox\nwill fail to match the DTU template. I.e. these numbers will generally change dependent on the LaTeX template.\n\n```\nparam slide_deck_pdf\n\n\n\nparam tex_output_path\n\n\n\nparam num_to_take\n\n\n\nparam force\n\n\n\nparam svg_pfix\n\n\n\nparam svg_height\n\n\n\nparam svg_width\n\n\n\nreturn\n\n```\n"]}, {"name": "slider.legacy_importer.raw_svg_to_osvg", "asynchronous": false, "params": [{"name": "raw_svg_file", "type": null, "default": null}, {"name": "overwrite_existing", "type": null, "default": "..."}, {"name": "height", "type": null, "default": "..."}, {"name": "width", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "slider.legacy_importer.svg_set_hw_", "asynchronous": false, "params": [{"name": "svg_in", "type": null, "default": null}, {"name": "svg_out", "type": null, "default": null}, {"name": "height", "type": null, "default": null}, {"name": "width", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "slider.legacy_importer.svg_check_background_layer", "asynchronous": false, "params": [{"name": "svg_edit_file", "type": null, "default": null}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "slider.legacy_importer.svg_edit_to_importable", "asynchronous": false, "params": [{"name": "svg_edit_file", "type": null, "default": null}, {"name"