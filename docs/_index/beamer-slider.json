"default": null}], "returns": null, "documentation": ["Count number of pages in a pdf file./ "]}, {"name": "slider.legacy_importer.slide_to_image", "asynchronous": false, "params": [{"name": "slide_deck_pdf", "type": null, "default": null}, {"name": "output", "type": null, "default": null}, {"name": "page_to_take", "type": null, "default": "..."}, {"name": "use_inkscape", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "slider.legacy_importer.move_template_files", "asynchronous": false, "params": [{"name": "output_dir", "type": null, "default": "..."}, {"name": "output_tex_file", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "slider.legacy_importer.rm_svg_bg", "asynchronous": false, "params": [{"name": "svg_input", "type": null, "default": null}, {"name": "svg_output", "type": null, "default": "..."}, {"name": "fix_bg", "type": null, "default": "..."}, {"name": "fix_txt", "type": null, "default": "..."}, {"name": "fix_logo", "type": null, "default": "..."}, {"name": "height", "type": null, "default": "..."}, {"name": "width", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [{"name": "slider.legacy_importer.CDIR", "type": null, "documentation": []}, {"name": "slider.legacy_importer.CDIR", "type": null, "documentation": []}, {"name": "slider.legacy_importer.SVG_EDIT_RELPATH", "type": null, "documentation": ["files that are supposed to be edited goes here."]}, {"name": "slider.legacy_importer.SVG_TMP_RELPATH", "type": null, "documentation": ["various files that can be flat out deleted goes here"]}, {"name": "slider.legacy_importer.SVG_TEXINCLUDE_RELPATH", "type": null, "documentation": ["the no_fonts version and the pure (+fonts) versions goes here"]}, {"name": "slider.legacy_importer.DTU_beamer_base", "type": null, "documentation": []}, {"name": "slider.legacy_importer.BLANK_PNG", "type": null, "documentation": []}, {"name": "slider.legacy_importer.lecture_tex_