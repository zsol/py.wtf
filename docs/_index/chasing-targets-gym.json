t_when_target_reached (bool): A flag indicating whether the environment should resetwhen a robot reaches the target.\n    recording_path (Path | None) : Optional path to write a video of the simulation to,if none no video (default: None).\n    sandbox_dimensions (Tuple[float, float, float, float] | None): the extents of the sandboxdimensions, default value is (-4., -3., 4., 3.)", "from .robots import Robots"]}], "exports": []}, {"name": "chasing_targets_gym.robots", "documentation": [], "functions": [{"name": "chasing_targets_gym.robots.wrap_angle", "asynchronous": false, "params": [{"name": "angle", "type": null, "default": null}], "returns": null, "documentation": ["Ensure angle is in range [-pi,pi]"]}], "variables": [], "classes": [{"name": "chasing_targets_gym.robots.Robots", "bases": [], "methods": [{"name": "chasing_targets_gym.robots.Robots.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "n_robots", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "radius", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}, {"name": "dt", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}, {"name": "accel_limit", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "chasing_targets_gym.robots.Robots.__len__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "chasing_targets_gym.robots.Robots.reset", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "chasing_targets_gym.robots.Robots.width", "asynchronous": false, "params": [{"nam