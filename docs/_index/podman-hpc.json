man_hpc.podman_hpc.podhpc", "asynchronous": false, "params": [{"name": "ctx", "type": null, "default": null}, {"name": "additional_stores", "type": null, "default": null}, {"name": "squash_dir", "type": null, "default": null}, {"name": "log_level", "type": null, "default": null}], "returns": null, "documentation": ["Manage pods, containers and images ... on HPC!\n\nThe podman-hpc utility is a wrapper script around the podman\ncontainer engine. It provides additional subcommands for ease of\nuse and configuration of podman in a multi-node, multi-user high\nperformance computing environment.", "podman-hpc command #######################################################"]}, {"name": "podman_hpc.podman_hpc.infohpc", "asynchronous": false, "params": [{"name": "siteconf", "type": null, "default": null}], "returns": null, "documentation": ["Dump configuration information for podman_hpc.", "podman-hpc infohpc subcommand ############################################"]}, {"name": "podman_hpc.podman_hpc.migrate", "asynchronous": false, "params": [{"name": "siteconf", "type": null, "default": null}, {"name": "image", "type": null, "default": null}], "returns": null, "documentation": ["Migrate an image to squashed.", "podman-hpc migrate subcommand ############################################"]}, {"name": "podman_hpc.podman_hpc.rmsqi", "asynchronous": false, "params": [{"name": "siteconf", "type": null, "default": null}, {"name": "image", "type": null, "default": null}], "returns": null, "documentation": ["Removes a squashed image.", "podman-hpc rmsqi subcommand ##############################################"]}, {"name": "podman_hpc.podman_hpc.images", "asynchronous": false, "params": [{"name": "ctx", "type": null, "default": null}, {"name": "siteconf", "type": null, "default": null}, {"name": "image", "type": null, "default": null}, {"name": "podman_args", "type": null, "default": null}, {"name": "**site_opts", "type": null, "default": null}], "returns": null, "documentation": ["D