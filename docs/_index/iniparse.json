{"name": "iniparse", "metadata": {"name": "iniparse", "version": "0.5", "classifiers": ["Development Status :: 5 - Production/Stable", "Intended Audience :: Developers", "License :: OSI Approved :: MIT License", "License :: OSI Approved :: Python Software Foundation License", "Operating System :: OS Independent", "Programming Language :: Python", "Programming Language :: Python :: 2", "Programming Language :: Python :: 2.6", "Programming Language :: Python :: 2.7", "Programming Language :: Python :: 3", "Programming Language :: Python :: 3.3", "Programming Language :: Python :: 3.4", "Topic :: Software Development :: Libraries :: Python Modules"], "home_page": "https://github.com/candlepin/python-iniparse", "license": "MIT", "documentation_url": null, "dependencies": ["six"], "summary": "Accessing and Modifying INI files", "upload_time": 1580307152}, "documentation": ["iniparse is an INI parser for Python which is API compatible\nwith the standard library's ConfigParser, preserves structure of INI\nfiles (order of sections & options, indentation, comments, and blank\nlines are preserved when data is updated), and is more convenient to\nuse.\n\n"], "modules": [{"name": "iniparse.configparser", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "iniparse", "documentation": ["Copyright (c) 2001, 2002, 2003 Python Software Foundation", "Copyright (c) 2004-2008 Paramjit Oberoi <param.cs.wisc.edu>", "Copyright (c) 2007 Tim Lauridsen <tla@rasmil.dk>", "All Rights Reserved.  See LICENSE-PSF & LICENSE for details."], "functions": [], "variables": [], "classes": [], "exports": [{"name": "iniparse.BasicConfig", "xref": {"fqname": "iniparse.config.BasicConfig", "project": null}}, {"name": "iniparse.change_comment_syntax", "xref": {"fqname": "iniparse.ini.change_comment_syntax", "project": null}}, {"name": "iniparse.ConfigNamespace", "xref": {"fqname": "iniparse.config.ConfigNamespace", "project": null}}, {"name": "iniparse.ConfigParser", "xref": {"fqname": "iniparse.compat.ConfigParser", "project": null}}, {"name": "iniparse.DEFAULTSECT", "xref": {"fqname": "iniparse.configparser.DEFAULTSECT", "project": null}}, {"name": "iniparse.DuplicateSectionError", "xref": {"fqname": "iniparse.configparser.DuplicateSectionError", "project": null}}, {"name": "iniparse.INIConfig", "xref": {"fqname": "iniparse.ini.INIConfig", "project": null}}, {"name": "iniparse.InterpolationDepthError", "xref": {"fqname": "iniparse.configparser.InterpolationDepthError", "project": null}}, {"name": "iniparse.InterpolationMissingOptionError", "xref": {"fqname": "iniparse.configparser.InterpolationMissingOptionError", "project": null}}, {"name": "iniparse.InterpolationSyntaxError", "xref": {"fqname": "iniparse.configparser.InterpolationSyntaxError", "project": null}}, {"name": "iniparse.MAX_INTERPOLATION_DEPTH", "xref": {"fqname": "iniparse.configparser.MAX_INTERPOLATION_DEPTH", "project": null}}, {"name": "iniparse.NoOptionError", "xref": {"fqname": "iniparse.configparser.NoOptionError", "project": null}}, {"name": "iniparse.NoSectionError", "xref": {"fqname": "iniparse.configparser.NoSectionError", "project": null}}, {"name": "iniparse.RawConfigParser", "xref": {"fqname": "iniparse.compat.RawConfigParser", "project": null}}, {"name": "iniparse.SafeConfigParser", "xref": {"fqname": "iniparse.compat.SafeConfigParser", "project": null}}, {"name": "iniparse.tidy", "xref": {"fqname": "iniparse.utils.tidy", "project": null}}]}, {"name": "iniparse.utils", "documentation": [], "functions": [{"name": "iniparse.utils.tidy", "asynchronous": false, "params": [{"name": "cfg", "type": null, "default": null}], "returns": null, "documentation": ["Clean up blank lines.\n\nThis functions makes the configuration look clean and\nhandwritten - consecutive empty lines and empty lines at\nthe start of the file are removed, and one is guaranteed\nto be at the end of the file."]}, {"name": "iniparse.utils.tidy_section", "asynchronous": false, "params": [{"name": "lc", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "iniparse.compat", "documentation": ["Compatibility interfaces for ConfigParser\n\nInterfaces of ConfigParser, RawConfigParser and SafeConfigParser\nshould be completely identical to the Python standard library\nversions.  Tested with the unit tests included with Python-2.3.4\n\nThe underlying INIConfig object can be accessed as cfg.data", "Copyright (c) 2001, 2002, 2003 Python Software Foundation", "Copyright (c) 2004-2008 Paramjit Oberoi <param.cs.wisc.edu>", "All Rights Reserved.  See LICENSE-PSF & LICENSE for details."], "functions": [], "variables": [], "classes": [{"name": "iniparse.compat.RawConfigParser", "bases": ["object"], "methods": [{"name": "iniparse.compat.RawConfigParser.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "defaults", "type": null, "default": "..."}, {"name": "dict_type", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "iniparse.compat.RawConfigParser.optionxform", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "optionstr", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.RawConfigParser.defaults", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.RawConfigParser.sections", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return a list of section names, excluding [DEFAULT]"]}, {"name": "iniparse.compat.RawConfigParser.add_section", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}], "returns": null, "documentation": ["Create a new section in the configuration.\n\nRaise DuplicateSectionError if a section by the specified name\nalready exists.  Raise ValueError if name is DEFAULT or any of\nits case-insensitive variants."]}, {"name": "iniparse.compat.RawConfigParser.has_section", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}], "returns": null, "documentation": ["Indicate whether the named section is present in the configuration.\n\nThe DEFAULT section is not acknowledged."]}, {"name": "iniparse.compat.RawConfigParser.options", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}], "returns": null, "documentation": ["Return a list of option names for the given section name."]}, {"name": "iniparse.compat.RawConfigParser.read", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "filenames", "type": null, "default": null}], "returns": null, "documentation": ["Read and parse a filename or a list of filenames.\n\nFiles that cannot be opened are silently ignored; this is\ndesigned so that you can specify a list of potential\nconfiguration file locations (e.g. current directory, user's\nhome directory, systemwide directory), and all existing\nconfiguration files in the list will be read.  A single\nfilename may also be given."]}, {"name": "iniparse.compat.RawConfigParser.readfp", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "fp", "type": null, "default": null}, {"name": "filename", "type": null, "default": "..."}], "returns": null, "documentation": ["Like read() but the argument must be a file-like object.\n\nThe `fp' argument must have a `readline' method.  Optional\nsecond argument is the `filename', which if not given, is\ntaken from fp.name.  If fp has no `name' attribute, `<???>' is\nused."]}, {"name": "iniparse.compat.RawConfigParser.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}, {"name": "vars", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "iniparse.compat.RawConfigParser.items", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.RawConfigParser.getint", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.RawConfigParser.getfloat", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.RawConfigParser.getboolean", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.RawConfigParser.has_option", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}], "returns": null, "documentation": ["Check for the existence of a given option in a given section."]}, {"name": "iniparse.compat.RawConfigParser.set", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": ["Set an option."]}, {"name": "iniparse.compat.RawConfigParser.write", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "fp", "type": null, "default": null}], "returns": null, "documentation": ["Write an .ini-format representation of the configuration state."]}, {"name": "iniparse.compat.RawConfigParser.remove_option", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}], "returns": null, "documentation": ["Remove an option."]}, {"name": "iniparse.compat.RawConfigParser.remove_section", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}], "returns": null, "documentation": ["Remove a file section."]}], "class_variables": [{"name": "iniparse.compat.RawConfigParser._boolean_states", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "iniparse.compat.ConfigDict", "bases": ["object"], "methods": [{"name": "iniparse.compat.ConfigDict.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cfg", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "vars", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.ConfigDict.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Present a dict interface to a ini section."]}, {"name": "iniparse.compat.ConfigParser", "bases": ["RawConfigParser"], "methods": [{"name": "iniparse.compat.ConfigParser.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}, {"name": "raw", "type": null, "default": "..."}, {"name": "vars", "type": null, "default": "..."}], "returns": null, "documentation": ["Get an option value for a given section.\n\nAll % interpolations are expanded in the return values, based on the\ndefaults passed into the constructor, unless the optional argument\n`raw' is true.  Additional substitutions may be provided using the\n`vars' argument, which must be a dictionary whose contents overrides\nany pre-existing defaults.\n\nThe section DEFAULT is special."]}, {"name": "iniparse.compat.ConfigParser._interpolate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}, {"name": "rawval", "type": null, "default": null}, {"name": "vars", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.ConfigParser.items", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "raw", "type": null, "default": "..."}, {"name": "vars", "type": null, "default": "..."}], "returns": null, "documentation": ["Return a list of tuples with (name, value) for each option\nin the section.\n\nAll % interpolations are expanded in the return values, based on the\ndefaults passed into the constructor, unless the optional argument\n`raw' is true.  Additional substitutions may be provided using the\n`vars' argument, which must be a dictionary whose contents overrides\nany pre-existing defaults.\n\nThe section DEFAULT is special."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "iniparse.compat.SafeConfigParser", "bases": ["ConfigParser"], "methods": [{"name": "iniparse.compat.SafeConfigParser.set", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.SafeConfigParser._interpolate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "option", "type": null, "default": null}, {"name": "rawval", "type": null, "default": null}, {"name": "vars", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.compat.SafeConfigParser._interpolate_some", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "option", "type": null, "default": null}, {"name": "accum", "type": null, "default": null}, {"name": "rest", "type": null, "default": null}, {"name": "section", "type": null, "default": null}, {"name": "map", "type": null, "default": null}, {"name": "depth", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "iniparse.compat.SafeConfigParser._interpvar_re", "type": null, "documentation": []}, {"name": "iniparse.compat.SafeConfigParser._badpercent_re", "type": null, "documentation": []}, {"name": "iniparse.compat.SafeConfigParser._interpvar_match", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "iniparse.config", "documentation": [], "functions": [{"name": "iniparse.config.update_config", "asynchronous": false, "params": [{"name": "target", "type": null, "default": null}, {"name": "source", "type": null, "default": null}], "returns": null, "documentation": ["Imports values from source into target.\n\nRecursively walks the \\<source> ConfigNamespace and inserts values\ninto the \\<target> ConfigNamespace.  For example:\n\n```pycon\n>>> n = BasicConfig()\n>>> n.playlist.expand_playlist = True\n>>> n.ui.display_clock = True\n>>> n.ui.display_qlength = True\n>>> n.ui.width = 150\n>>> print(n)\nplaylist.expand_playlist = True\nui.display_clock = True\nui.display_qlength = True\nui.width = 150\n```\n\n```pycon\n>>> from iniparse import ini\n>>> i = ini.INIConfig()\n>>> update_config(i, n)\n>>> print(i)\n[playlist]\nexpand_playlist = True\n<BLANKLINE>\n[ui]\ndisplay_clock = True\ndisplay_qlength = True\nwidth = 150\n```\n", "---- Utility functions"]}], "variables": [], "classes": [{"name": "iniparse.config.ConfigNamespace", "bases": ["object"], "methods": [{"name": "iniparse.config.ConfigNamespace._getitem", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": ["Methods that must be implemented by subclasses"]}, {"name": "iniparse.config.ConfigNamespace.__setitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.ConfigNamespace.__delitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.ConfigNamespace.__iter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.ConfigNamespace._new_namespace", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.ConfigNamespace.__contains__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.ConfigNamespace.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": ["Machinery for converting dotted access into container access,", "and automatically creating new sections/namespaces.", "To distinguish between accesses of class members and namespace", "keys, we first call object.__getattribute__().  If that succeeds,", "the name is assumed to be a class member.  Otherwise it is", "treated as a namespace key.", "Therefore, member variables should be defined in the class,", "not just in the __init__() function.  See BasicNamespace for", "an example."]}, {"name": "iniparse.config.ConfigNamespace.__getattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.ConfigNamespace.__setattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.ConfigNamespace.__delattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.ConfigNamespace.__setstate__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "state", "type": null, "default": null}], "returns": null, "documentation": ["During unpickling, Python checks if the class has a __setstate__", "method.  But, the data dicts have not been initialised yet, which", "leads to  _getitem and hence __getattr__ raising an exception.  So", "we explicitly impement default __setstate__ behavior."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Abstract class representing the interface of Config objects.\n\nA ConfigNamespace is a collection of names mapped to values, where\nthe values may be nested namespaces.  Values can be accessed via\ncontainer notation - obj[key] - or via dotted notation - obj.key.\nBoth these access methods are equivalent.\n\nTo minimize name conflicts between namespace keys and class members,\nthe number of class members should be minimized, and the names of\nall class members should start with an underscore.\n\nSubclasses must implement the methods for container-like access,\nand this class will automatically provide dotted access."]}, {"name": "iniparse.config.Undefined", "bases": ["object"], "methods": [{"name": "iniparse.config.Undefined.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "namespace", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.Undefined.__setattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.Undefined.__setitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Helper class used to hold undefined names until assignment.\n\nThis class helps create any undefined subsections when an\nassignment is made to a nested value.  For example, if the\nstatement is \"cfg.a.b.c = 42\", but \"cfg.a.b\" does not exist yet."]}, {"name": "iniparse.config.BasicConfig", "bases": ["ConfigNamespace"], "methods": [{"name": "iniparse.config.BasicConfig.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.BasicConfig._getitem", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.BasicConfig.__setitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.BasicConfig.__delitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "key", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.BasicConfig.__iter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.BasicConfig.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prefix", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "iniparse.config.BasicConfig._new_namespace", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.config.BasicConfig._readfp", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "fp", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "iniparse.config.BasicConfig._data", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Represents a hierarchical collection of named values.\n\nValues are added using dotted notation:\n\n```pycon\n>>> n = BasicConfig()\n>>> n.x = 7\n>>> n.name.first = 'paramjit'\n>>> n.name.last = 'oberoi'\n```\n\n...and accessed the same way, or with \\[...\\]:\n\n```pycon\n>>> n.x\n7\n>>> n.name.first\n'paramjit'\n>>> n.name.last\n'oberoi'\n>>> n['x']\n7\n>>> n['name']['first']\n'paramjit'\n```\n\nIterating over the namespace object returns the keys:\n\n```pycon\n>>> l = list(n)\n>>> l.sort()\n>>> l\n['name', 'x']\n```\n\nValues can be deleted using 'del' and printed using 'print'.\n\n```pycon\n>>> n.aaa = 42\n>>> del n.x\n>>> print(n)\naaa = 42\nname.first = paramjit\nname.last = oberoi\n```\n\nNested namespaces are also namespaces:\n\n```pycon\n>>> isinstance(n.name, ConfigNamespace)\nTrue\n>>> print(n.name)\nfirst = paramjit\nlast = oberoi\n>>> sorted(list(n.name))\n['first', 'last']\n```\n\nFinally, values can be read from a file as follows:\n\n```pycon\n>>> from six import StringIO\n>>> sio = StringIO('''\n... # comment\n... ui.height = 100\n... ui.width = 150\n... complexity = medium\n... have_python\n... data.secret.password = goodness=gracious me\n... ''')\n>>> n = BasicConfig()\n>>> n._readfp(sio)\n>>> print(n)\ncomplexity = medium\ndata.secret.password = goodness=gracious me\nhave_python\nui.height = 100\nui.width = 150\n```\n", "---- Basic implementation of a ConfigNamespace"]}], "exports": []}, {"name": "iniparse.ini", "documentation": ["Access and/or modify INI files\n\n* Compatiable with ConfigParser\n* Preserves order of sections & options\n* Preserves comments/blank lines/etc\n* More conveninet access to data\n\nExample:\n\n    >>> from six import StringIO\n    >>> sio = StringIO('''# configure foo-application\n    ... [foo]\n    ... bar1 = qualia\n    ... bar2 = 1977\n    ... [foo-ext]\n    ... special = 1''')\n\n    >>> cfg = INIConfig(sio)\n    >>> print(cfg.foo.bar1)\n    qualia\n    >>> print(cfg['foo-ext'].special)\n    1\n    >>> cfg.foo.newopt = 'hi!'\n    >>> cfg.baz.enabled = 0\n\n    >>> print(cfg)\n    # configure foo-application\n    [foo]\n    bar1 = qualia\n    bar2 = 1977\n    newopt = hi!\n    [foo-ext]\n    special = 1\n    <BLANKLINE>\n    [baz]\n    enabled = 0"], "functions": [{"name": "iniparse.ini.change_comment_syntax", "asynchronous": false, "params": [{"name": "comment_chars", "type": null, "default": "..."}, {"name": "allow_rem", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "iniparse.ini._make_xform_property", "asynchronous": false, "params": [{"name": "myattrname", "type": null, "default": null}, {"name": "srcattrname", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "iniparse.ini.make_comment", "asynchronous": false, "params": [{"name": "line", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "iniparse.ini.readline_iterator", "asynchronous": false, "params": [{"name": "f", "type": null, "default": null}], "returns": null, "documentation": ["iterate over a file by only using the file object's readline method"]}, {"name": "iniparse.ini.lower", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "iniparse.ini.LineType", "bases": ["object"], "methods": [{"name": "iniparse.ini.LineType.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "line", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "iniparse.ini.LineType.__str__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return the original line for unmodified objects", "Otherwise construct using the current attribute values"]}, {"name": "iniparse.ini.LineType.__setattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": ["If an attribute is modif