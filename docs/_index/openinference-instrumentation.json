l read this Context and pass the session id as a span attribute,\nfollowing the OpenInference semantic conventions.\n\nExamples:\n    with using_session(\"my-session-id\"):\n        # Tracing within this block will include the span attribute:\n        # \"session.id\" = \"my-session-id\"\n        ..."]}, {"name": "openinference.instrumentation.context_attributes.using_user", "bases": ["_UsingAttributesContextManager"], "methods": [{"name": "openinference.instrumentation.context_attributes.using_user.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Context manager to add user id to the current OpenTelemetry Context. OpenInference\ninstrumentations will read this Context and pass the user id as a span attribute,\nfollowing the OpenInference semantic conventions.\n\nExamples:\n    with using_user(\"my-user-id\"):\n        # Tracing within this block will include the span attribute:\n        # \"user.id\" = \"my-user-id\"\n        ..."]}, {"name": "openinference.instrumentation.context_attributes.using_metadata", "bases": ["_UsingAttributesContextManager"], "methods": [{"name": "openinference.instrumentation.context_attributes.using_metadata.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "metadata", "type": {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Context manager to add metadata to the current OpenTelemetry Context. OpenInference\ninstrumentations will read this Context and pass the metadata as a span attribute,\nfollowing the OpenInference semantic conventions.\n\nExamples:\n    metadata = {\n        \"key-1\": value_1,\n        \"key-2\": value_2,\n        ...\n    }\n    with using_metadata(metadata):\n        # Tracing within this block will include the span attribute:\n        # \"metadata\" = \"{\"key-1\": value_1, \"key-2\": value_2, ... }\"\n        ..."]}, {"name": "openinference.instrumentation.context_attributes.using_tags", "bases": ["_UsingAttributesContextManager"], "methods": [{"name": "openinference.instrumentation.context_attributes.using_tags.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "tags", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Context manager to add tags to the current OpenTelemetry Context. OpenInference\ninstrumentations will read this Context and pass the tags as a span attribute,\nfollowing the OpenInference semantic conventions.\n\nExamples:\n    tags = [\n        \"tag_1\",\n        \"tag_2\",\n        ...\n    ]\n    with using_tags(tags):\n        # Tracing within this block will include the span attribute:\n        # \"tag.tags\" = \"[\"tag_1\",\"tag_2\",...]\"\n        ..."]}, {"name": "openinference.instrumentation.context_attributes.using_prompt_template", "bases": ["_UsingAttributesContextManager"], "methods": [{"name": "openinference.instrumentation.context_attributes.using_prompt_template.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "template", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "version", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "variables", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Context manager to add prompt template, with its version and variables a to the\ncurrent OpenTelemetry Context. OpenInference instrumentations will read this\nContext and pass the prompt template as a span attribute, following the\nOpenInference semantic conventions.\n\nExamples:\n    prompt_template = \"Please describe the weather forecast for {city} on {date}\"\n    prompt_template_variables = {\"city\": \"Johannesburg\", date:\"July 11\"}\n    with using_prompt_template(\n        template=prompt_template,\n        version=prompt_template_variables,\n        variables=\"v1.0\",\n        ):\n        # Tracing within this block will include the span attribute:\n        # \"llm.prompt_template.template\" = \"Please describe the weather\n        forecast for {city} on {date}\"\n        # \"llm.prompt_template.version\" = \"v1.0\"\n        # \"llm.prompt_template.variables\" = \"{\"city\": \"Johannesburg\",\n        \"date\": \"July 11\"}\"\n        ..."]}, {"name": "openinference.instrumentation.context_attributes.using_attributes", "bases": ["_UsingAttributesContextManager"], "methods": [{"name": "openinference.instrumentation.context_attributes.using_attributes.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "session_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "user_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "metadata", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, "default": "..."}, {"name": "tags", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}]}, "default": "..."}, {"name": "prompt_template", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "prompt_template_version", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "prompt_template_variables", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", 