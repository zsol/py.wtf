       ...\n\nThe previous example is equivalent to doing:\n    with (\n        using_session(\"my-session-id\"),\n        using_user(\"my-user-id\"),\n        using_metadata(metadata),\n        using_tags(tags),\n        using_prompt_template(\n            template=prompt_template,\n            version=prompt_template_version,\n            variables=prompt_template_variables,\n        ),\n    ):\n        ..."]}], "exports": []}, {"name": "openinference.instrumentation.version", "documentation": [], "functions": [], "variables": [{"name": "openinference.instrumentation.version.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "openinference.instrumentation.logging", "documentation": [], "functions": [], "variables": [{"name": "openinference.instrumentation.logging.logger", "type": null, "documentation": []}, {"name": "openinference.instrumentation.logging.console_handler", "type": null, "documentation": []}, {"name": "openinference.instrumentation.logging.logger.propagate", "type": null, "documentation": []}], "classes": [{"name": "openinference.instrumentation.logging.CustomFormatter", "bases": ["logging.Formatter"], "methods": [{"name": "openinference.instrumentation.logging.CustomFormatter.format", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "record", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "openinference.instrumentation.config", "documentation": [], "functions": [{"name": "openinference.instrumentation.config.is_base64_url", "asynchronous": false, "params": [{"name": "url", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}], "variables