s.CaseUA.ACCUSATIVE", "type": null, "documentation": ["\"\u0417\u043d\u0430\u0445\u0456\u0434\u043d\u0438\u0439 \u0432\u0456\u0434\u043c\u0456\u043d\u043e\u043a (Accusative)\"  # Accusative case"]}, {"name": "lesya.language.case_helpers.CaseUA.INSTRUMENTAL", "type": null, "documentation": ["\"\u041e\u0440\u0443\u0434\u043d\u0438\u0439 \u0432\u0456\u0434\u043c\u0456\u043d\u043e\u043a (Instrumental)\"  # Instrumental case"]}, {"name": "lesya.language.case_helpers.CaseUA.PREPOSITIONAL", "type": null, "documentation": ["\"\u041c\u0456\u0441\u0446\u0435\u0432\u0438\u0439 \u0432\u0456\u0434\u043c\u0456\u043d\u043e\u043a (Prepositional)\"  # Prepositional case"]}, {"name": "lesya.language.case_helpers.CaseUA.VOCATIVE", "type": null, "documentation": ["\"\u041a\u043b\u0438\u0447\u043d\u0438\u0439 \u0432\u0456\u0434\u043c\u0456\u043d\u043e\u043a (Vocative)\"  # Vocative case"]}], "instance_variables": [], "inner_classes": [], "documentation": ["A class containing constants for grammatical cases in Ukrainian"]}, {"name": "lesya.language.case_helpers.NamePart", "bases": [], "methods": [], "class_variables": [{"name": "lesya.language.case_helpers.NamePart.FIRSTNAME", "type": null, "documentation": []}, {"name": "lesya.language.case_helpers.NamePart.LASTNAME", "type": null, "documentation": []}, {"name": "lesya.language.case_helpers.NamePart.PATRONYMIC", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "lesya.language.case_helpers.NCLNameCaseWord", "bases": [], "methods": [{"name": "lesya.language.case_helpers.NCLNameCaseWord.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "word", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "lesya.language.case_helpers.NCLNameCaseWord.create_mask", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "word", "type": null, "default": null}], "returns": 