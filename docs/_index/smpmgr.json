 allows the\nuser to change the log level and log file without restarting the program.\n\nFor example, to change the log level to DEBUG and the log file to `smpmgr.log`:\n\n```shell\nsmpmgr > --loglevel DEBUG --logfile smpmgr.log\n```\nThis is a valid stand alone command that will save those log settings for the duration of the\nshell session, until one or the other is updated with new values."]}], "variables": [], "classes": [{"name": "smpmgr.logging.LogLevel", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "smpmgr.logging.LogLevel.CRITICAL", "type": null, "documentation": []}, {"name": "smpmgr.logging.LogLevel.ERROR", "type": null, "documentation": []}, {"name": "smpmgr.logging.LogLevel.WARNING", "type": null, "documentation": []}, {"name": "smpmgr.logging.LogLevel.INFO", "type": null, "documentation": []}, {"name": "smpmgr.logging.LogLevel.DEBUG", "type": null, "documentation": []}, {"name": "smpmgr.logging.LogLevel.NOTSET", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "smpmgr.os_management", "documentation": [], "functions": [{"name": "smpmgr.os_management.echo", "asynchronous": false, "params": [{"name": "ctx", "type": {"name": "typer.Context", "xref": {"fqname": "typer.Context", "project": null}, "params": null}, "default": null}, {"name": "message", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Request that the SMP Server echo the given message."]}, {"name": "smpmgr.os_management.reset", "asynchronous": false, "params": [{"name": "ctx", "type": {"name": "typer.Context", "xref": {"fqname": "typer.Context", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "do