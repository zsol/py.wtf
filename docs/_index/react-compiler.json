 "default": null}, {"name": "node", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "react.transforms.sparsify_loops.RewriteSparseTensorRead", "bases": ["ast.NodeTransformer"], "methods": [{"name": "react.transforms.sparsify_loops.RewriteSparseTensorRead.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "var", "type": null, "default": null}, {"name": "new_index", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "react.transforms.sparsify_loops.RewriteSparseTensorRead.visit_Subscript", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Rewrite A[i,k] to A.data[_k] if A is a sparse tensor."]}, {"name": "react.transforms.sparsify_loops.SparsifyLoops", "bases": ["ast.NodeTransformer"], "methods": [{"name": "react.transforms.sparsify_loops.SparsifyLoops.visit_FunctionDef", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "react.transforms.sparsify_loops.SparsifyLoops.visit_For", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "react.transforms.to_inplace_sp_add_form", "documentation": [], "functions": [{"name": "react.transforms.to_inplace_sp_add_form.transform", "asynchronous": false, "params": [{"name": "node", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "react.transforms.to_inplace_sp_add_form.ToSparseInplaceAddForm", "bases": ["ast.NodeTransformer"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["This pass does a number of transformations:\n1. It checks binary operators, and if both operands are sparse, it \ncreates a dense copy for one of them, and adds the other operand to it.\nAfter the conversion, each statement will have at most one sparse operand.\nmatmul is a special binary operator, and we will always create a dense copy\nfor the second operand (if both operands are CSR format), because CSR x dense\nis easier to do. Note that non-CSR formats are not supported yet.\n2. For \"dA = spA\", \"dA = spA * B\", \"dA = spA @ B\" assignments, it converts them to an in-place update form,\nlike \"dA = 0; dA = dA + spA\". The in-place sparse update statement will be \nmarked as having sparse operand spA, which will later be processed by the\nsparsify_loop pass.\nFor example, for assignment \"C = spA * spB\", the conversion process is\nC = spA * dB   => C = 0; C = C + spA * dB\n\nC = dA * spB   => C = spB * dA\n               => C = 0; C = C + spB * dA\n\nC = spA * spB  => dB = spB * 1; C = spA * dB\n               => dB = 0; dB = dB + spB * 1; C = 0; C = C + spA * dB\n\nC = spA + dB   => C = dB; C = C + spA\n\nC = dA + spB   => C = spB + dA\n               => C = dA; C = C + spB\n\nC = spA + spB  => dB = spB * 1; C = spA + dB\n               => dB = 0; dB = dB + spB * 1; C = dB; C = C + spA * 1\n\nC = spA @ dB   => C = spA @ dB\n               => it needs to be converted to form C = 0; C = C + spA @ dB\n               => but this should be handled by the fix-reduction pass\n               => from the sparse-dense assignment point of view, C = 0 is not needed\n\nC = spA @ spB  => dB = spB * 1; C = spA @ dB\n               => dB = 0; dB = dB + spB * 1; C = spA @ dB\n\nC = dA @ spB   => C = dA @ spB\n               => no conversion seems necessary, just applying sparse-loop pass should work"]}, {"name": "react.transforms.to_inplace_sp_add_form.ConvertToInplaceSpAddForm", "bases": ["ast.NodeTransformer"], "methods": [{"name": "react.transforms.to_inplace_sp_add_form.ConvertToInplaceSpAddForm.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "react.transforms.to_inplace_sp_add_form.ConvertToInplaceSpAddForm.visit_FunctionDef", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "react.transforms.to_inplace_sp_add_form.ConvertToInplaceSpAddForm.visit_Assign", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": null, "default": null}], "returns": null, "documentation": ["Convert a binary operation to a form that uses in-place update.\nExamples:\nC = spA + dB   => C = dB; C = C + spA\nC = spA * dB   => C = 0; C = C + spA * dB"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "react.transforms.check_for_undefined", "documentation": [], "functions": [{"name": "react.transforms.check_for_undefined.transform", "asynchronous": false, "params": [{"name": "node", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "react.transforms.check_for_undefined.GetDefinedVariables", "bases": ["ast.NodeVisitor"], "methods": [{"name": "react.transforms.check_for_undefined.GetDefinedVariables.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "react.transforms.check_for_undefined.GetDefinedVariables.visit_FunctionDef", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "node", "type": 