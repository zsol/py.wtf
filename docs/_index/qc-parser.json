etrics.txt         --additional-files /PATH/additional_output_1.pdf         --additional-files /PATH/additional_output_2.tsv         --output-zip metrics.zip\n    --output-json qc_values.json\n\nThis command will parse samtools and picard_CollectInsertSizeMetrics metrics from the files provided for each\ntool and create a qc.json file. It will also create a zip archive with all 4 provided files."]}], "variables": [], "classes": [], "exports": []}, {"name": "src.QMGeneric", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "src.QMGeneric.QMValue", "bases": [], "methods": [{"name": "src.QMGeneric.QMValue.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "metrics_definition", "type": {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": null}, "default": null}, {"name": "value", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "src.QMGeneric.QMValue.to_dict", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["    ", "#######################################################################", "QMGeneric", "QMValue", "#######################################################################"]}, {"name": "src.QMGeneric.QMGeneric", "bases": [], "methods": [{"name": "src.QMGeneric.QMGeneric.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "src.QMGeneric.QMGeneric.add_value", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "QMValue_", "type": {"name": "QMValue", "xref": {"fqname": "src.QMGeneric.QMValue", "project": null}, "params": null}, "default": null}], "returns": null, "documentation": []}, {