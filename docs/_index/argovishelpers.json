e pypi servers): \n   ```\n   docker container run -v $(pwd):/src -v $(pwd)/pypirc:/root/.pypirc -it argovis/argovis_helpers:build-240118 twine upload -r testpypi dist/<your new rc>\n   ```\n - Test install and try: `python -m pip install -i https://test.pypi.org/simple argovis_helpers`\n - If all is well, rebuild without the rc tag and push to pypi: \n   ```\n   docker container run -v $(pwd):/src -v $(pwd)/pypirc:/root/.pypirc -it argovis/argovis_helpers:build-240118 twine upload dist/<your new release>\n   ```\n - `git add` your new build artifacts under `/dist`\n - Push to github and mint a release matching the version number in `pyproject.toml`.\n\n  \n"], "modules": [{"name": "argovisHelpers", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "argovisHelpers.gridtools", "xref": {"fqname": "argovisHelpers..gridtools", "project": null}}, {"name": "argovisHelpers.helpers", "xref": {"fqname": "argovisHelpers..helpers", "project": null}}]}, {"name": "argovisHelpers.helpers", "documentation": [], "functions": [{"name": "argovisHelpers.helpers.slice_timesteps", "asynchronous": false, "params": [{"name": "options", "type": null, "default": null}, {"name": "r", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "argovisHelpers.helpers.data_inflate", "asynchronous": false, "params": [{"name": "data_doc", "type": null, "default": null}, {"name": "metadata_doc", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "argovisHelpers.helpers.find_key", "asynchronous": false, "params": [{"name": "key", "type": null, "default": null}, {"name": "data_doc", "type": null, "default": null}, {"name": "metadata_doc", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "argovisHelpers.helpers.parsetime", "asynchronous": false, "params": [{"name": "time", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "argovisHelpers.helpers.