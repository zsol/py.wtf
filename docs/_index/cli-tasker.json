{"name": "cli-tasker", "metadata": {"name": "cli-tasker", "version": "1.0.0", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/luyan0422/cli-tasker", "license": null, "documentation_url": null, "dependencies": ["tabulate"], "summary": "A simple CLI task tracker", "upload_time": 1735177448}, "documentation": ["# cli-tasker\n\n## Description:\ncli-tasker is a project used to track and manage tasks.\n\n## Features\n\ncli-tasker can help user:\n\n1. Add a Task: Users can add a new task to their task list by providing a description. Each task is assigned a unique ID and is initially set to the \"todo\" status.\n2. Delete a Task: User can removed from the tasks by specifying their unique ID. After delete the task, you can choose whether to rearrange the task id or not.\n3. Update a Task: Users can update the description of an existing task. This requires the task's ID and the new description.\n4. List Tasks: Users can list all tasks (default) or filter them by status. The statuses available for filtering are \"done\", \"todo\", and \"on-going\".\n5. Mark Task as On Goning: Tasks can be marked as \"on-going\" by providing their ID.\n6. Mark Task as Done: Tasks can be marked as \"done\" by specifying their ID. After mark as done, you can choose to leave the task on the list or delete it.\n"], "modules": [{"name": "cli_tasker", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "cli_tasker.cli", "documentation": ["!/usr/bin/env python3"], "functions": [{"name": "cli_tasker.cli.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "cli_tasker.utils", "documentation": [], "functions": [{"name": "cli_tasker.utils.add_task", "asynchronous": false, "params": [{"name": "task_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.update_task", "asynchronous": false, "params": [{"name": "id", "type": null, "default": null}, {"name": "new_name", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.delete_task", "asynchronous": false, "params": [{"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.list_tasks", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.list_done", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.list_todo", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.list_onGoing", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.mark_todo", "asynchronous": false, "params": [{"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.mark_done", "asynchronous": false, "params": [{"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.mark_onGoing", "asynchronous": false, "params": [{"name": "args", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.generate_task_id", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.load_tasks", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "cli_tasker.utils.save_tasks", "asynchronous": false, "params": [{"name": "tasks", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "cli_tasker.utils.TASK_FILE", "type": null, "documentation": []}, {"name": "cli_tasker.utils.table_header", "type": null, "documentation": []}], "classes": [], "exports": []}]}