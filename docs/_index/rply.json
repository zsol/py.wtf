generator.Rule.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "pattern", "type": null, "default": null}, {"name": "flags", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "rply.lexergenerator.Rule._freeze_", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.lexergenerator.Rule.matches", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "s", "type": null, "default": null}, {"name": "pos", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "rply.lexergenerator.Rule._attrs_", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "rply.lexergenerator.Match", "bases": ["object"], "methods": [{"name": "rply.lexergenerator.Match.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "start", "type": null, "default": null}, {"name": "end", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "rply.lexergenerator.Match._attrs_", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "rply.lexergenerator.LexerGenerator", "bases": ["object"], "methods": [{"name": "rply.lexergenerator.LexerGenerator.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.lexergenerator.LexerGenerator.add", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "pattern", "type": null, "default": null}, {"name": "flags", "type": null, "default": "..."}], "returns": null, "documentation": ["Adds a rule with the given `name` and `pattern`. In case of ambiguity,\nthe first rule added wins."]}, {"name": "rply.lexergenerator.LexerGenerator.ignore", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pattern", "type": null, "default": null}, {"name": "flags", "type": null, "default": "..."}], "returns": null, "documentation": ["Adds a rule whose matched value will be ignored. Ignored rules will be\nmatched before regular ones."]}, {"name": "rply.lexergenerator.LexerGenerator.build", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns a lexer instance, which provides a `lex` method that must be\ncalled with a string and returns an iterator yielding\n{class}`~rply.Token` instances.\n"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["A LexerGenerator represents a set of rules that match pieces of text that\nshould either be turned into tokens or ignored by the lexer.\n\nRules are added using the {meth}`add` and {meth}`ignore` methods:\n\n```pycon\n>>> from rply import LexerGenerator\n>>> lg = LexerGenerator()\n>>> lg.add('NUMBER', r'\\d+')\n>>> lg.add('ADD', r'\\+')\n>>> lg.ignore(r'\\s+')\n```\n\nThe rules are passed to {func}`re.compile`. If you need additional flags,\ne.g. {const}`re.DOTALL`, you can pass them to {meth}`add` and\n{meth}`ignore` as an additional optional parameter:\n\n```pycon\n>>> import re\n>>> lg.add('ALL', r'.*', flags=re.DOTALL)\n```\n\nYou can then build a lexer with which you can lex a string to produce an\niterator yielding tokens:\n\n```pycon\n>>> lexer = lg.build()\n>>> iterator = lexer.lex('1 + 1')\n>>> iterator.next()\nToken('NUMBER', '1')\n>>> iterator.next()\nToken('ADD', '+')\n>>> iterator.next()\nToken('NUMBER', '1')\n>>> iterator.next()\nTraceback (most recent call last):\n...\nStopIteration\n```\n"]}], "exports": []}, {"name": "rply.lexer", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "rply.lexer.Lexer", "bases": ["object"], "methods": [{"name": "rply.lexer.Lexer.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "rules", "type": null, "default": null}, {"name": "ignore_rules", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.lexer.Lexer.lex", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "rply.lexer.LexerStream", "bases": ["object"], "methods": [{"name": "rply.lexer.LexerStream.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "lexer", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.lexer.LexerStream.__iter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.lexer.LexerStream._update_pos", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "match", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.lexer.LexerStream.next", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.lexer.LexerStream.__next__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "rply.grammar", "documentation": [], "functions": [{"name": "rply.grammar.rightmost_terminal", "asynchronous": false, "params": [{"name": "symbols", "type": null, "default": null}, {"name": "terminals", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "rply.grammar.Grammar", "bases": ["object"], "methods": [{"name": "rply.grammar.Grammar.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "terminals", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Grammar.add_production", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prod_name", "type": null, "default": null}, {"name": "syms", "type": null, "default": null}, {"name": "func", "type": null, "default": null}, {"name": "precedence", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Grammar.set_precedence", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "term", "type": null, "default": null}, {"name": "assoc", "type": null, "default": null}, {"name": "level", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Grammar.set_start", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Grammar.unused_terminals", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Grammar.unused_productions", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Grammar.build_lritems", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Walks the list of productions and builds a complete set of the LR\nitems."]}, {"name": "rply.grammar.Grammar._first", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "beta", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Grammar.compute_first", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Grammar.compute_follow", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "rply.grammar.Production", "bases": ["object"], "methods": [{"name": "rply.grammar.Production.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "num", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "prod", "type": null, "default": null}, {"name": "precedence", "type": null, "default": null}, {"name": "func", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Production.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.Production.getlength", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "rply.grammar.LRItem", "bases": ["object"], "methods": [{"name": "rply.grammar.LRItem.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "p", "type": null, "default": null}, {"name": "n", "type": null, "default": null}, {"name": "before", "type": null, "default": null}, {"name": "after", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "rply.grammar.LRItem.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": 