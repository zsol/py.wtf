": null, "default": null}, {"name": "line", "type": null, "default": null}], "returns": null, "documentation": ["Parse a KEY or CONSTRAINT line.\n\n```\nparam line\n\nA line of SHOW CREATE TABLE output\n```\n", "def _parse_indexes(self, indexes, state):", "\"\"\"Parses results from SHOW INDEX FROM table, if required -N.B. not any longer, just Starrocks takes a while to create indexes on table\"\"\"", "i = 0", "while (i < len(indexes)):", "ir = indexes[i]", "table = ir[0]", "unique = not ir[1]", "index_name = ir[2]", "index_type = ir[10]", "index_cols = []", "while (i < len(indexes) and table == ir[0] and index_name == ir[2]):", "index_cols.append((ir[4], None, '')) # name, length, modifiers", "i += 1", "state.keys.append({", "\"name\": index_name,", "\"columns\": index_cols,", "\"unique\": unique,", "\"type\": \"INDEX\",", "\"parser\": None,", "})"]}, {"name": "starrocks.reflection.StarRocksTableDefinitionParser._parse_table_name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "line", "type": null, "default": null}, {"name": "state", "type": null, "default": null}], "returns": null, "documentation": ["Extract the table name.\n\n```\nparam line\n\nThe first line of SHOW CREATE TABLE\n```\n"]}, {"name": "starrocks.reflection.StarRocksTableDefinitionParser._parse_table_options", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "lines", "type": null, "default": null}, {"name": "state", "type": null, "default": null}], "returns": null, "documentation": ["def _parse_table_options(self, line, state):", "\"\"\"Build a dictionary of all reflected table-level options.", ":param line: The final line of SHOW CREATE TABLE output.", "\"\"\"", "options = {}", "if not line or line == \")\":", "pass", "else:", "rest_of_line = line[:]", "for regex, cleanup in self._pr_options:", "m = regex.search(rest_of_line)", "if not m:", "continue", "directive, value = m.group(\"directive\"), m.group(\"val\")", "if cleanup:", "value = cleanup(value)", "options[directive.lower()] = value", "rest_of_line = regex.sub(\"\", rest_of_line)", "for nope in (\"auto_increment\", \"data directory\", \"index directory\"):", "options.pop(nope, None)", "for opt, val in options.items():", "state.table_options[\"%s_%s\" % (self.dialect.name, opt)] = val"]}, {"name": "starrocks.reflection.StarRocksTableDefinitionParser._parse_engine", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "line", "type": null, "default": null}, {"name": "state", "type": null, "default": null}], "returns": null, "documentation": ["'ENGINE=OLAP '", "'DUPLICATE KEY(`a`, `b`)'", "'DISTRIBUTED BY RANDOM'", "'PROPERTIES ('", "'\"replication_num\" = \"1\",'", "'\"datacache.enable\" = \"true\",'", "'\"storage_volume\" = \"plaid_volume\",'", "'\"enable_async_write_back\" = \"false\",'", "'\"enable_persistent_index\" = \"false\",'", "'\"compression\" = \"LZ4\"'", "');'"]}, {"name": "starrocks.reflection.StarRocksTableDefinitionParser._parse_key_desc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "line", "type": null, "default": null}, {"name": "state", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "starrocks.reflection.StarRocksTableDefinitionParser._parse_table_comment", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "line", "type": null, "default": null}, {"name": "state", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "starrocks.reflection.StarRocksTableDefinitionParser._parse_partition_desc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "lines", "type": null, "default": null}, {"name": "index", "type": null, "default": null}, {"name": "state", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "starrocks.reflection.StarRocksTableDefinition