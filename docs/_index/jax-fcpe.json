{"name": "jax-fcpe", "metadata": {"name": "jax-fcpe", "version": "0.0.5", "classifiers": ["Development Status :: 5 - Production/Stable", "Intended Audience :: Developers", "Intended Audience :: Education", "Intended Audience :: Science/Research", "License :: OSI Approved :: MIT License", "Programming Language :: Python :: 3", "Topic :: Scientific/Engineering :: Artificial Intelligence", "Topic :: Scientific/Engineering :: Mathematics", "Topic :: Software Development :: Libraries :: Python Modules", "Topic :: System :: Distributed Computing"], "home_page": "https://github.com/flyingblackshark/jax-fcpe", "license": null, "documentation_url": null, "dependencies": ["jax", "flax", "audax", "torch"], "summary": "JAX Implementation FCPE", "upload_time": 1734941159}, "documentation": ["\n# FCPE jax version \n## This version is working perfectly fine. \ud83d\ude00 \n### Original https://github.com/CNChTu/FCPE\n\n# Example\n```Python\nimport jax_fcpe\nimport jax.numpy as jnp\n\na = jnp.ones((16000))\nf0 = jax_fcpe.get_f0(a,16000)\nprint(f0)\n```\n## Advanced Usage\n```Python\nWIN_SIZE = 1024\nHOP_SIZE = 160\nN_FFT = 1024\nNUM_MELS = 128\nf0_min = 80.\nf0_max = 880.\nmel_basis = librosa_mel_fn(sr=16000, n_fft=N_FFT, n_mels=NUM_MELS, fmin=0, fmax=8000)\nmel_basis = jnp.asarray(mel_basis,dtype=jnp.float32)\n\ndef get_f0(wav,model,params):\n    wav = jnp.asarray(wav)\n    window = jnp.hanning(WIN_SIZE)\n    pad_size = (WIN_SIZE-HOP_SIZE)//2\n    wav = jnp.pad(wav, ((0,0),(pad_size, pad_size)),mode=\"reflect\")\n    spec = audax.core.stft.stft(wav,N_FFT,HOP_SIZE,WIN_SIZE,window,onesided=True,center=False)\n    spec = jnp.sqrt(spec.real**2 + spec.imag**2 + (1e-9))\n    spec = spec.transpose(0,2,1)\n    mel = jnp.matmul(mel_basis, spec)\n    mel = jnp.log(jnp.clip(mel, min=1e-5) * 1)\n    mel = mel.transpose(0,2,1)\n\n    def model_predict(mel):\n        f0 = model.apply(params,mel,threshold=0.006,method=model.infer)\n        uv = (f0 < f0_min).astype(jnp.float32)\n        f0 = f0 * (1 - uv)\n        return f0\n    return model_predict(mel).squeeze(-1)\n```\n"], "modules": [{"name": "jax_fcpe.infer", "documentation": [], "functions": [{"name": "jax_fcpe.infer.get_f0", "asynchronous": false, "params": [{"name": "wav", "type": null, "default": null}, {"name": "sr", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "jax_fcpe.utils", "documentation": [], "functions": [{"name": "jax_fcpe.utils.convert_torch_weights_to_msgpack", "asynchronous": false, "params": [{"name": "torch_weights_path", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}, {"name": "write_path", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "jax_fcpe.utils.download_model", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "jax_fcpe.utils.load_model", "asynchronous": false, "params": [{"name": "load_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "jax_fcpe", "documentation": [], "functions": [], "variables": [{"name": "jax_fcpe.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "jax_fcpe.get_f0", "xref": {"fqname": "jax_fcpe.infer.get_f0", "project": null}}, {"name": "jax_fcpe.load_model", "xref": {"fqname": "jax_fcpe.utils.load_model", "project": null}}]}, {"name": "jax_fcpe.convert", "documentation": [], "functions": [{"name": "jax_fcpe.convert.convert_torch_weights", "asynchronous": false, "params": [{"name": "path", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "jax_fcpe.model_conformer