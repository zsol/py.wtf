{"name": "premium-calculator-shivangi", "metadata": {"name": "premium-calculator-shivangi", "version": "0.0.1", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/pypa/sampleproject", "license": null, "documentation_url": null, "dependencies": [], "summary": "This is a premium calculator", "upload_time": 1733055380}, "documentation": [""], "modules": [{"name": "premium_calculator", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "premium_calculator.premium_calculator", "documentation": ["def calculate_premium(age, coverage, term):", "# Example premium calculation logic", "base_rate = 5  # Base rate per $1000 coverage", "age_factor = 0.1 * (age - 30)  # Increase 10% for each year over 30", "term_factor = 0.2 * (term - 1)  # Increase 20% for each additional year", "premium = (coverage / 1000) * base_rate * (1 + age_factor) * (1 + term_factor)", "return round(premium, 2)"], "functions": [{"name": "premium_calculator.premium_calculator.calculate_life_premium", "asynchronous": false, "params": [{"name": "age", "type": null, "default": null}, {"name": "coverage", "type": null, "default": null}, {"name": "term", "type": null, "default": null}], "returns": null, "documentation": ["Calculate life insurance premium."]}, {"name": "premium_calculator.premium_calculator.calculate_health_premium", "asynchronous": false, "params": [{"name": "age", "type": null, "default": null}, {"name": "coverage", "type": null, "default": null}, {"name": "pre_existing_conditions", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate health insurance premium."]}, {"name": "premium_calculator.premium_calculator.calculate_vehicle_premium", "asynchronous": false, "params": [{"name": "vehicle_age", "type": null, "default": null}, {"name": "vehicle_value", "type": null, "default": null}, {"name": "driver_age", "type": null, "default": null}], "returns": null, "documentation": ["Calculate vehicle insurance premium.", "def calculate_health_premium(age, coverage, pre_existing_conditions=False):", "\"\"\"", "Calculate health insurance premium.", "\"\"\"", "base_rate = 7", "age_factor = 0.15 * (age - 25) if age > 25 else 0", "condition_factor = 1.5 if pre_existing_conditions else 1", "premium = (coverage / 1000) * base_rate * (1 + age_factor) * condition_factor", "return round(premium, 2)"]}], "variables": [], "classes": [], "exports": []}]}