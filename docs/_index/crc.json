functions.int", "project": "--std--"}, "params": null}, "documentation": ["Calculates the reversed value of the crc register.\n\nReturns:\n    The reversed value of the crc register."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Abstract base class / Interface a crc register needs to implement.\n\nWorkflow:\n    1. The Crc-Register needs to be initialized.    1 time     (init)\n    2. Data is feed into the crc register.          1..n times (update)\n    3. Final result is calculated.                  1 time     (digest)"]}, {"name": "crc._crc.Configuration", "bases": [], "methods": [], "class_variables": [{"name": "crc._crc.Configuration.width", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "crc._crc.Configuration.polynomial", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "crc._crc.Configuration.init_value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "crc._crc.Configuration.final_xor_value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "crc._crc.Configuration.reverse_input", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "crc._crc.Configuration.reverse_output", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["A Configuration provides all settings necessary to determine the concrete\nimplementation of a specific crc algorithm/register.\n\nExample:\n    Create a custom configuration\n\n    ```python\n    from crc import Configuration\n\n    saej1850 = Configuration(\n        width=8,\n        polynomial=0x1D,\n        init_value=0xFF,\n        final_xor_value=0xFF,\n        reverse_input=False,\n        reverse_output=False\n    )\n    ```"]}, {"name": "crc._crc.BasicRegister", "bases": ["AbstractRegister"], "methods": [{"name": "crc._crc.BasicRegister.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "configuration", "type": {"name": "Configuration", "xref": {"fqname": "crc._crc.Configuration", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Create a new BasicRegister.\n\nArgs:\n    configuration: Used to configure the crc algorithm."]}, {"name": "crc._crc.BasicRegister.__len__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["Returns:\n    The width of the register."]}, {"name": "crc._crc.BasicRegister.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "index", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["Gets a single byte of the register.\n\nArgs:\n    index: byte which shall be returned.\n\nReturns:\n    The byte at the specified index.\n\nRaises:\n    IndexError: Invalid index for this register."]}, {"name": "crc._crc.BasicRegister.init", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["See `AbstractRegister.init`"]}, {"name": "crc._crc.BasicRegister.update", "asynchronous": fal