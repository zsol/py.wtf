 "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.run", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.nap", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.set_progress_desc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "desc", "type": null, "default": null}, {"name": "pref", "type": null, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.tdesc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns the formatted timespan of the duration.\n\nReturns:\n    str: The formatted timespan of the duration.\n\nExamples:\n    >>> t = tdesc(self)\n    >>> print(t)\n    '2 hours 30 minutes'"]}, {"name": "logmap.logmap.logmap.lap", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.lap_duration", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.lap_tdesc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.duration", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Calculates the duration of an event.\n\nReturns:\n    float: The duration of the event in seconds."]}, {"name": "logmap.logmap.logmap.pref", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.inner_pref", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.logmap.logmap.desc", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns a description of the task.\n\nIf the task has both a start time and an end time, it returns a string\nindicating the task name and the time it took to complete the task.\n\nIf the task is currently running, it returns a string indicating that\nthe task is still running.\n\nReturns:\n    str: A description of the task."]}, {"name": "logmap.logmap.logmap.__enter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Context manager method that is called when entering a 'with' statement.\n\nThis method logs the description of the context manager and starts the timer.\n\nExamples:\n    with Logwatch():\n        # code to be executed within the context manager"]}, {"name": "logmap.logmap.logmap.__exit__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "exc_type", "type": null, "default": null}, {"name": "exc_value", "type": null, "default": null}, {"name": "traceback", "type": null, "default": null}], "returns": null, "documentation": ["Logs the resulting time."]}], "class_variables": [{"name": "logmap.logmap.logmap.is_quiet", "type": null, "documentation": []}, {"name": "logmap.logmap.logmap.disabled", "type": null, "documentation": []}, {"name": "logmap.logmap.logmap.enabled", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["A class for monitoring and logging the duration of tasks.\n\nAttributes:\n    started (float): The timestamp when the task started.\n    ended (float): The timestamp when the task ended.\n    level (str): The logging level for the task. Default is 'DEBUG'.\n    log (Logger): The logger object for logging the task status.\n    task_name (str): The name of the task being monitored."]}], "exports": []}, {"name": "logmap", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "logmap.yapmap", "documentation": [], "functions": [{"name": "logmap.yapmap.in_jupyter", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "logmap.yapmap.get_tqdm", "asynchronous": false, "params": [{"name": "iterable", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.yapmap.pmap_iter", "asynchronous": false, "params": [{"name": "func", "type": null, "default": null}, {"name": "objs", "type": null, "default": null}, {"name": "args", "type": null, "default": "..."}, {"name": "kwargs", "type": null, "default": "..."}, {"name": "lim", "type": null, "default": "..."}, {"name": "num_proc", "type": null, "default": "..."}, {"name": "use_threads", "type": null, "default": "..."}, {"name": "progress", "type": null, "default": "..."}, {"name": "progress_pos", "type": null, "default": "..."}, {"name": "desc", "type": null, "default": "..."}, {"name": "shuffle", "type": null, "default": "..."}, {"name": "context", "type": null, "default": "..."}, {"name": "**y", "type": null, "default": null}], "returns": null, "documentation": ["Yields results of func(obj) for each obj in objs\nUses multiprocessing.Pool(num_proc) for parallelism.\nIf use_threads, use ThreadPool instead of Pool.\nResults in any order."]}, {"name": "logmap.yapmap._pmap_do", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "logmap.yapmap.pmap", "asynchronous": false, "params": [{"name": "*x", "type": null, "default": null}, {"name": "**y", "type": null, "default": null}], "returns": null, "documentation": ["Non iterator version of pmap_iter"]}, {"name": "logmap.yapmap.pmap_run", "asynchronous": false, "params": [{"name": "*x", "type": null, "default": null}, {"name": "**y", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "logmap.imports", "documentation": [], "functions": [], "variables": [{"name": "logmap.imports.LOG_FORMAT", "type": null, "documentation": []}, {"name": "logmap.imports.NUM_LOGWATCHES", "type": null, "documentation": []}, {"name": "logmap.imports.LOGWATCH_ID", "type": null, "documentation": []}, {"name": "logmap.imports.LOG_LEVEL", "type": null, "documentation": []}, {"name": "logmap.imports.CONTEXT", "type": null, "documentation": []}, {"name": "logmap.imports.mp_cpu_count", "type": null, "documentation": []}, {"name": "logmap.imports.DEFAULT_NUM_PROC", "type": null, "documentation": []}, {"name": "logmap.imports.DEFAULT_NUM_PROC", "type": null, "documentation": []}, {"name": "logmap.imports.DEFAULT_NUM_PROC", "type": null, "documentation": []}, {"name": "logmap.imports.DEFAULT_NUM_PROC", "type": null, "documentation": []}], "classes": [], "exports": []}]}