{"name": "mulpyplexer", "metadata": {"name": "mulpyplexer", "version": "0.09", "classifiers": [], "home_page": "", "license": "BSD", "documentation_url": null, "dependencies": [], "summary": "A module that multiplexes interactions with lists of python objects.", "upload_time": 1610399421}, "documentation": ["Mulpyplexer is a piece of code that can multiplex interactions with lists of python objects.\nIt's easier to show you:\n\n    import mulpyplexer\n\n    class A:\n        def __init__(self, i):\n            self.i = i\n\n        def add(self, j):\n            return A(self.i + (j.i if isinstance(j, A) else j))\n\n        def sub(self, j):\n            return A(self.i - (j.i if isinstance(j, A) else j))\n\n        def __repr__(self):\n            return \"<A %d>\" % self.i\n\n        def str(self):\n            return str(self.i)\n\n        def __eq__(self, o):\n            return self.i == o.i\n\n    one = mulpyplexer.MP([ A(10), A(20), A(30) ])\n\n    two = one.add(5)\n    assert two.mp_items == [ A(15), A(25), A(35) ]\n\n    three = two.sub(10)\n    assert three.mp_items == [ A(5), A(15), A(25) ]\n\n    four = three.add(one)\n    assert four.mp_items == [ A(15), A(35), A(55) ]\n\n    five = four.str()\n    assert five.mp_items == [ \"15\", \"35\", \"55\" ]\n\n    six = four.i\n    assert six.mp_items == [ 15, 35, 55 ]"], "modules": [{"name": "setup", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "mulpyplexer", "documentation": [], "functions": [{"name": "mulpyplexer.test", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "mulpyplexer.MP", "bases": ["object"], "methods": [{"name": "mulpyplexer.MP.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "items", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mulpyplexer.MP._resolve_object", "asynchronous": false, "params