": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "rox_icu.cli.info", "asynchronous": false, "params": [], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Print package info"]}, {"name": "rox_icu.cli.mock", "asynchronous": false, "params": [{"name": "node_id", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "sim_inputs", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": null}, {"name": "mqtt_broker", "type": {"name": "str | None", "xref": null, "params": null}, "default": null}], "returns": null, "documentation": ["Mock ICU device on CAN bus"]}, {"name": "rox_icu.cli.monitor", "asynchronous": false, "params": [], "returns": null, "documentation": ["Monitor ICU devices on CAN bus"]}, {"name": "rox_icu.cli.inspect", "asynchronous": false, "params": [], "returns": null, "documentation": ["Inspect ICU messages on CAN bus (ignoring heartbeat)"]}, {"name": "rox_icu.cli.output", "asynchronous": false, "params": [{"name": "node_id", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "hex_input", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Set output state, provide hex value"]}], "variables": [], "classes": [], "exports": []}, {"name": "rox_icu.inspector", "documentation": ["Inspect icu messages on can bus\n\nCopyright (c) 2024 ROX Automation - Jev Kuznetsov", "!/usr/bin/env python3"], "functions": [{"name": "rox_icu.inspector.process_message", "asynchronous": false, "params": [{"name": "msg", "type": {"name": "can.Message", "xref": {"fqname": "can.Message", "project": "python-can"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "rox_icu.inspector.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "rox_icu.mock", "documentation": ["ICU Mock CAN Interface Module\n\nThis module provides a mock implementation of the ICU (Integrated Control Unit) CAN interface.\nIt simulates CAN-based remote I/O control for testing and development purposes, supporting message\nencoding/decoding, MQTT integration, and simulated I/O toggling.\n\nKey Features:\n- CAN communication simulation using `python-can`.\n- I/O state management with message broadcasting.\n- Heartbeat generation for system health monitoring.\n- MQTT command interface for remote I/O control.\n- Support for toggling outputs in a simulated environment.\n\nClasses:\n- ICUMock: Core class that simulates the ICU interface, providing methods for managing I/O states,\n  sending heartbeats, and handling CAN or MQTT messages.\n\nFunctions:\n- main(node_id: int): Entry point for running the mock interface as a standalone application.\n\nMQTT Command Structure:\nThe MQTT interface allows remote interaction with the ICU mock through structured JSON messages.\nCommands are published to the topic `/icu_mock/<node_id>/cmd` and must follow the format:\n```json\n{\n    \"cmd\": \"<command_name>\",\n    \"args\": {\n        \"arg1\": <value>,\n        \"arg2\": <value>,\n        ...\n    }\n}\n````\n\n\nCopyright (c) 2024 ROX Automation - Jev Kuznetsov", "!/usr/bin/env python3"], "functions": [{"name": "rox_icu.mock.main", "asynchronous": false, "params": [{"name": "node_id", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}], "variables": [{"name": "rox_icu.mock.NODE_ID", "type": null, "documentation": []}, {"name": "rox_icu.mock.DEVICE_TYPE", "typ