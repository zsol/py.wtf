osition in\nboth reference and read (query). If in forward orientation in the read,\nno adjustment is needed, and if in reverse orientation, we subtract one."]}, {"name": "delfies.SAM_utils.has_softclipped_telo_array", "asynchronous": false, "params": [{"name": "read", "type": {"name": "SoftclippedRead", "xref": {"fqname": "delfies.SAM_utils.SoftclippedRead", "project": null}, "params": null}, "default": null}, {"name": "orientation", "type": {"name": "Orientation", "xref": {"fqname": "delfies.seq_utils.Orientation", "project": null}, "params": null}, "default": null}, {"name": "telomere_seqs", "type": null, "default": null}, {"name": "min_telo_array_size", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "max_edit_distance", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Note: we allow for the softclipped telo array to start with any cyclic shift\nof the telomeric repeat unit."]}], "variables": [{"name": "delfies.SAM_utils._ordered_flags", "type": null, "documentation": []}, {"name": "delfies.SAM_utils.FLAGS", "type": null, "documentation": []}, {"name": "delfies.SAM_utils.DEFAULT_READ_FILTER_NAMES", "type": null, "documentation": []}, {"name": "delfies.SAM_utils.DEFAULT_READ_FILTER_FLAG", "type": null, "documentation": []}, {"name": "delfies.SAM_utils.DEFAULT_MIN_MAPQ", "type": null, "documentation": []}], "classes": [{"name": "delfies.SAM_utils.SoftclippedRead", "bases": [], "methods": [], "class_variables": [{"name": "delfies.SAM_utils.SoftclippedRead.sequence", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "delfies.SAM_utils.SoftclippedRead.name", "type": {"name": "str", "xref": {"fqname": "functions.str", "p