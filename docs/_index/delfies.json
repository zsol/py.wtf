"project": null}}, {"name": "delfies.metadata", "xref": {"fqname": "importlib.metadata", "project": null}}]}, {"name": "delfies.breakpoint_sequences", "documentation": [], "functions": [{"name": "delfies.breakpoint_sequences.extract_breakpoint_sequences", "asynchronous": false, "params": [{"name": "maximal_foci", "type": {"name": "MaximalFoci", "xref": {"fqname": "delfies.breakpoint_foci.MaximalFoci", "project": null}, "params": null}, "default": null}, {"name": "genome", "type": {"name": "Fasta", "xref": {"fqname": "pyfastx.Fasta", "project": null}, "params": null}, "default": null}, {"name": "seq_window_size", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "FastaRecord", "xref": {"fqname": "delfies.seq_utils.FastaRecord", "project": null}, "params": null}]}, "documentation": []}, {"name": "delfies.breakpoint_sequences.write_breakpoint_sequences", "asynchronous": false, "params": [{"name": "genome_fname", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "maximal_foci", "type": {"name": "MaximalFoci", "xref": {"fqname": "delfies.breakpoint_foci.MaximalFoci", "project": null}, "params": null}, "default": null}, {"name": "odirname", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "seq_window_size", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "delfies.delfies", "documentation": [], "functions": [{"name": "delfies.delfies.run_breakpoint_detection", "asynchronous": false, "params": [{"nam