}, {"name": "errno", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "mopidy_local", "documentation": [], "functions": [], "variables": [{"name": "mopidy_local.__version__", "type": null, "documentation": []}], "classes": [{"name": "mopidy_local.Extension", "bases": ["ext.Extension"], "methods": [{"name": "mopidy_local.Extension.get_default_config", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mopidy_local.Extension.get_config_schema", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mopidy_local.Extension.setup", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "registry", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mopidy_local.Extension.get_command", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mopidy_local.Extension.webapp", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "config", "type": null, "default": null}, {"name": "core", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mopidy_local.Extension.get_data_subdir", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "config", "type": null, "default": null}, {"name": "*paths", "type": null, "default": null}], "returns": null, "documentation": ["TODO: Add *paths to Extension.get_data_dir()?"]}, {"name": "mopidy_local.Extension.get_image_dir", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "config", "type": null, "default": null}], "returns": null, "documentation": []}], "class_v