cret isn't compromised."]}, {"name": "plain.passwords.tokens.PasswordResetTokenGenerator._num_seconds", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "dt", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "plain.passwords.tokens.PasswordResetTokenGenerator._now", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "plain.passwords.tokens.PasswordResetTokenGenerator.key_salt", "type": null, "documentation": []}, {"name": "plain.passwords.tokens.PasswordResetTokenGenerator.algorithm", "type": null, "documentation": []}, {"name": "plain.passwords.tokens.PasswordResetTokenGenerator._secret", "type": null, "documentation": []}, {"name": "plain.passwords.tokens.PasswordResetTokenGenerator._secret_fallbacks", "type": null, "documentation": []}, {"name": "plain.passwords.tokens.PasswordResetTokenGenerator.secret", "type": null, "documentation": []}, {"name": "plain.passwords.tokens.PasswordResetTokenGenerator.secret_fallbacks", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Strategy object used to generate and check tokens for the password\nreset mechanism."]}], "exports": []}, {"name": "plain.passwords.hashers", "documentation": [], "functions": [{"name": "plain.passwords.hashers.check_password", "asynchronous": false, "params": [{"name": "password", "type": null, "default": null}, {"name": "encoded", "type": null, "default": null}, {"name": "setter", "type": null, "default": "..."}, {"name": "preferred", "type": null, "default": "..."}], "returns": null, "documentation": ["Return a boolean of whether the raw password matches the three\npart encoded digest.\n\nIf setter is specified, it'll be called when you need to\nregenerate the password."]}, {"name": "plain.passwords.hashers.hash_password", "asynchronous": false, "params": [{"name": "password", "type": null, "default": null}, {"name": "salt", "type": null, "default": "..."}, {"name": "hasher", "type": null, "default": "..."}], "returns": null, "documentation": ["Turn a plain-text password into a hash for database storage\n\nSame as encode() but generate a new random salt. If password is None then\nreturn a concatenation of UNUSABLE_PASSWORD_PREFIX and a random string,\nwhich disallows logins. Additional random string reduces chances of gaining\naccess to staff or superuser accounts. See ticket #20079 for more info."]}, {"name": "plain.passwords.hashers.get_hashers", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "plain.passwords.hashers.get_hashers_by_algorithm", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "plain.passwords.hashers.get_hasher", "asynchronous": false, "params": [{"name": "algorithm", "type": null, "default": "..."}], "returns": null, "documentation": ["Return an instance of a loaded password hasher.\n\nIf algorithm is 'default', return the default hasher. Lazily import hashers\nspecified in the project's settings file if needed."]}, {"name": "plain.passwords.hashers.identify_hasher", "asynchronous": false, "params": [{"name": "encoded", "type": null, "default": null}], "returns": null, "documentation": ["Return an instance of a loaded password hasher.\n\nIdentify hasher algorithm by examining encoded hash, and call\nget_hasher() to return hasher. Raise ValueError if\nalgorithm cannot be identified, or if hasher is not loaded."]}, {"name": "plain.passwords.hashers.mask_hash", "asynchronous": false, "params": [{"name": "hash", "type": null, "default": null}, {"name": "show", "type": null, "default": "..."}, {"name": "char", "type": null, "default": "..."}], "returns": null, "documentation": ["Return the given hash, with only the first `show` number shown. The\nrest are masked with `char` for security reasons.\n"]}, {"name": "plain.passwords.hashers.must_update_salt", "asynchronous": false, "params": [{"name": "salt", "type": null, "default": null}, {"name": "expected_entropy", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "plain.passwords.hashers.BasePasswordHasher", "bases": [], "methods": [{"name": "plain.passwords.hashers.BasePasswordHasher._load_library", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "plain.passwords.hashers.BasePasswordHasher.salt", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Generate a cryptographically secure nonce salt in ASCII with an entropy\nof at least `salt_entropy` bits."]}, {"name": "plain.passwords.hashers.BasePasswordHasher.verify", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "password", "type": null, "default": null}, {"name": "encoded", "type": null, "default": null}], "returns": null, "documentation": ["Check if the given password is correct."]}, {"name": "plain.passwords.hashers.BasePasswordHasher._check_encode_args", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "password", "type": null, "default": null}, {"name": "salt", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "plain.passwords.hashers.BasePasswordHasher.encode", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "password", "type": null, "default": null}, {"name": "salt", "type": null, "default": null}], "returns": null, "documentation": ["Create an encoded database value.\n\nThe result is normally formatted as \"algorithm$salt$hash\" and\nmust be fewer than 128 characters."]}, {"name": "plain.passwords.hashers.BasePasswordHasher.decode", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "encoded", "type": null, "default": null}], "returns": null, "documentation": ["Return a decoded database value.\n\nThe result is a dictionary and should contain `algorithm`, `hash`, and\n`salt`. Extra keys can be algorithm specific like `iterations` or\n`work_factor`."]}, {"name": "plain.passwords.hashers.BasePasswordHasher.safe_summary", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "encoded", "type": null, "default": null}], "returns": null, "documentation": ["Return a summary of safe values.\n\nThe result is a dictionary and will be used where the password field\nmust be displayed to construct a safe representation of the password."]}, {"name": "plain.passwords.hashers.BasePasswordHasher.must_update", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "encoded", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "plain.passwords.hashers.BasePasswordHasher.harden_runtime", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "password", "type": null, "default": null}, {"name": "encoded", "type": null, "default": null}], "returns": null, "documentation": ["Bridge the runtime gap between the work factor supplied in `encoded`\nand the work factor suggested by this hasher.\n\nTaking PBKDF2 as an example, if `encoded` contains 20000 iterations and\n`self.iterations` is 30000, this method should run password through\nanother 10000 iterations of PBKDF2. Similar approaches should exist\nfor any hasher that has a work factor. If not, this method should be\ndefined as a no-op to silence the warning."]}], "class_variables": [{"name": "plain.passwords.hashers.BasePasswordHasher.algorithm", "type": null, "documentation": []}, {"name": "plain.passwords.hashers.BasePasswordHasher.library", "type": null, "documentation": []}, {"name": "plain.passwords.hashers.BasePasswordHasher.salt_entropy", "type": null, "documentation": []}], "i