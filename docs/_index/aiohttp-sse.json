   specifying the reconnection time in milliseconds. If a non-integer\n    value is specified, the field is ignored."]}, {"name": "aiohttp_sse.EventSourceResponse.wait", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["EventSourceResponse object is used for streaming data to the client,\nthis method returns future, so we can wait until connection will\nbe closed or other task explicitly call `stop_streaming` method.\n"]}, {"name": "aiohttp_sse.EventSourceResponse.stop_streaming", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Used in conjunction with `wait` could be called from other task\nto notify client that server no longer wants to stream anything.\n"]}, {"name": "aiohttp_sse.EventSourceResponse.enable_compression", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "force", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, {"name": "ContentCoding", "xref": {"fqname": "aiohttp.web.ContentCoding", "project": "aiohttp"}, "params": null}, {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "aiohttp_sse.EventSourceResponse.last_event_id", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["Last event ID, requested by client."]}, {"name": "aiohttp_sse.EventSourceResponse.ping_interval", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "documentation": ["Time interval between two ping massages"]}, {"name": "aiohttp_sse.EventSourceResponse.ping_interval", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Setter for ping_interval property.\n\n```\nparam value\n\ninterval in sec between two ping values.\n```\n"]}, {"name": "aiohttp_sse.EventSourceResponse._ping", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "aiohttp_sse.EventSourceResponse.__aenter__", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "EventSourceResponse", "xref": {"fqname": "aiohttp_sse.EventSourceResponse", "project": null}, "params": null}, "documentation": []}, {"name": "aiohttp_sse.EventSourceResponse.__aexit__", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "exc_type", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "BaseException", "xref": {"fqname": "functions.BaseException", "project": "--std--"}, "params": null}]}]}, "default": null}, {"name": "exc", "type": {"name": "Optional", "x