", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Remove ANSI escape sequences from text"]}, {"name": "logmagix.logger.Logger.get_time", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "logmagix.logger.Logger.message3", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "level", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "message", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "start", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "end", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "logmagix.logger.Logger._should_log", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "message_level", "type": {"name": "LogLevel", "xref": {"fqname": "logmagix.logger.LogLevel", "project": null}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "logmagix.logger.Logger.success", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "t