"--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}, {"name": "WkSqlite3.WkSqlite3.WkSqlite3.set_table", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "table", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "WkSqlite3.WkSqlite3.WkSqlite3.get_cursor", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "WkSqlite3.WkSqlite3.WkSqlite3.create_table", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "obj", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}, {"name": "delete_if_exists", "type": null, "default": "..."}], "returns": null, "documentation": ["\u521b\u5efa\u8868\n\\:param obj: \u5b57\u5178\u5bf9\u8c61\uff0c\u952e\u4e3a\u5217\u540d\uff0c\u503c\u4e3a\u5217\u7c7b\u578b\n\\:param delete_if_exists: \u662f\u5426\u5220\u9664\u539f\u6709\u8868\n\\:return: True/False\n"]}, {"name": "WkSqlite3.WkSqlite3.WkSqlite3.delete_table", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["\u5220\u9664\u8868\n\\:return: True/False\n"]}, {"name": "WkSqlite3.WkSqlite3.WkSqlite3.get_column_names", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "WkSqlite3.WkSqlite3.WkSqlite3.exists", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["\u6839\u636e\u5b57\u5178\u5bf9\u8c61\u5224\u65ad\u5143\u7d20\u662f\u5426\u5b58\u5728\n- demo:\n    - exists({\"id\": 1, \"name\": \"wangkang\"})\n    - exists({id=1, name=wangkang})"]}, {"name": "WkSqlite3.WkSqlite3.WkSqlite3.insert_row