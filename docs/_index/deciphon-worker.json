ables": [], "classes": [{"name": "deciphon_worker.alarm.Alarm", "bases": [], "methods": [{"name": "deciphon_worker.alarm.Alarm.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "seconds", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}, {"name": "callback", "type": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "", "xref": null, "params": []}, {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "deciphon_worker.alarm.Alarm._loop", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "deciphon_worker.alarm.Alarm.start", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "deciphon_worker.alarm.Alarm.stop", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "deciphon_worker.alarm.Alarm.__enter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "deciphon_worker.alarm.Alarm.__exit__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*_", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "deciphon_worker.queue313", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "deciphon_worker.queue313.Empty", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "deciphon_worker.queue313.Full", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "deciphon_worker.queue313.ShutDown", "bases": ["Exception"], "methods": [], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Raised when put/get with shut-down queue."]}, {"name": "deciphon_worker.queue313.Queue", "bases": [], "methods": [{"name": "deciphon_worker.queue313.Queue.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "maxsize", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "deciphon_worker.queue313.Queue.task_done", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Indicate that a formerly enqueued task is complete.\n\nUsed by Queue consumer threads.  For each get() used to fetch a task,\na subsequent call to task_done() tells the queue that the processing\non the task is complete.\n\nIf a join() is currently blocking, it will resume when all items\nhave been processed (meaning that a task_done() call was received\nfor every item that had been put() into the queue).\n\nshutdown(immediate=True) calls task_done() for each remaining item in\nthe queue.\n\nRaises a ValueError if called more times than there were items\nplaced in the queue."]}, {"name": "deciphon_worker.queue313.Queue.join", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Blocks until all items in the Queue have been gotten and processed.\n\nThe count of unfinished tasks goes up whenever an item is added to the\nqueue. The count goes down whenever a consumer thread calls task_done()\nto indicate the item was retrieved and all work on it is complete.\n\nWhen the count of unfinished tasks drops to zero, join() unblocks."]}, {"name": "deciphon_worker.queue313.Queue.qsize", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return the approximate size of the queue (not reliable!)."]}, {"name": "deciphon_worker.queue313.Queue.empty", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return True if the queue is empty, False otherwise (not reliable!).\n\nThis method is likely to be removed at some point.  Use qsize() == 0\nas a direct substitute, but be aware that either approach risks a race\ncondition where a queue can grow before the result of empty() or\nqsize() can be used.\n\nTo create code that needs to wait for all queued tasks to be\ncompleted, the preferred technique is to use the join() method."]}, {"name": "deciphon_worker.queue313.Queue.full", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return True if the queue is full, False otherwise (not reliable!).\n\nThis method is likely to be removed at some point.  Use qsize() >= n\nas a direct substitute, but be aware that either approach risks a race\ncondition where a queue can shrink before the result of full() or\nqsize() can be used."]}, {"name": "deciphon_worker.queue313.Queue.put", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "item", "type": null, "default": null}, {"name": "block", "type": null, "default": "..."}, {"name": "timeout", "type": null, "default": "..."}], "returns": null, "documentation": ["Put an item into the queue.\n\nIf optional args 'block' is true and 'timeout' is None (the default),\nblock if necessary until a free slot is available. If 'timeout' is\na non-negative number, it blocks at most 'timeout' seconds and raises\nthe Full exception if no free slot was available within that time.\nOtherwise ('block' is false), put an item on the queue if a free slot\nis immediately available, else raise the Full exception ('timeout'\nis ignored in that case).\n\nRaises ShutDown if the queue has been shut down."]}, {"name": "deciphon_worker.queue313.Queue.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "block", "type": null, "default": "..."}, {"name": "timeout", "type": null, "default": "..."}], "returns": null, "documentation": ["Remove and return an item from the queue.\n\nIf optional args 'block' is true and 'timeout' is None (the default),\nblock if necessary until an item is available. If 'timeout' is\na non-negative number, it blocks at most 'timeout' seconds and raises\nthe Empty exception if no item was available within that time.\nOtherwise ('block' is false), return an item if one is immediately\navailable, else raise the Empty exception ('timeout' is ignored\nin that case).\n\nRaises ShutDown if the queue has been shut down and is empty,\nor if the queue has been shut down immediately."]}, {"name": "deciphon_worker.queue313.Queue.put_nowait", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "item", "type": null, "default": null}], "returns": null, "documentation": ["Put an item into the queue without blocking.\n\nOnly enqueue the item if a free slot is immediately available.\nOtherwise raise the Full exception."]}, {"name": "deciphon_worker.queue313.Queue.get_nowait", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Remove and return an item from the queue without blocking.\n\nOnly get an item if one is immediately available. Otherwise\nraise the Empty exception."]}, {"name": "deciphon_worker.queue313.Queue.shutdown", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "immediate", "type": null, "default": "..."}], "returns": null, "documentation": ["Shut-down the queue, making queue gets and puts raise ShutDown.\n\nBy default, gets will only raise once the queue is empty. Set\n'immediate' to True to make gets raise immediately instead.\n\nAll blocked callers of put() and get() will be unblocked. If\n'immediate', a task is marked as done for each item remaining in\nthe queue, which may unblock callers of join()."]}, {"name": "deciphon_worker.queue313.Queue._init", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "maxsize", "type": null, "default": null}], "returns": null, "documentation": ["Override these methods to implement other queue organizations", "(e.g. stack or priority queue).", "These will only be called with appropriate locks held", "Initialize the queue representation"]}, {"name": "deciphon_worker.queue313.Queue._qsize", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "deciphon_worker.queue313.Queue._put", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "item", "type": null, "default": null}], "returns": null, "documentation": ["Put a new item in the queue"]}, {"name": "deciphon_worker.queue313.Queue._get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Get an item from the queue"]}], "class_variables": [{"name": "deciphon_worker.queue313.Queue.__class_getitem__", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Create a queue object with a given maximum size.\n\nIf maxsize is <= 0, the queue size is infinite."]}], "exports": []}]}