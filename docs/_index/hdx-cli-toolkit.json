s": null}, "default": "..."}], "returns": {"name": "Counter", "xref": {"fqname": "collections.Counter", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "hdx_cli_toolkit.ckan_utilities.scan_distribution", "asynchronous": false, "params": [{"name": "response", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "default": null}, {"name": "key", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "verbose", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Counter", "xref": {"fqname": "collections.Counter", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [{"name": "hdx_cli_toolkit.ckan_utilities.DEFAULT_ROW_LIMIT", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "hdx_cli_toolkit.utilities", "documentation": ["!/usr/bin/env python", "encoding: utf-8"], "functions": [{"name": "hdx_cli_toolkit.utilities.write_dictionary", "asynchronous": false, "params": [{"name": "output_filepath", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "output_rows", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, "default": null}, {"name": "append", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Write a list of dictionaries to a CSV file\n\nArguments:\n    output_filepath {str} -- a file path for the output CSV file\n    output_rows {list[dict[str, Any]]} -- a list of dictionaries\n\nKeyword Arguments:\n    append {bool} -- if True rows are appended to an existing file (default: {True})\n\nReturns:\n    str -- a status message"]}, {"name": "hdx_cli_toolkit.utilities._make_write_dictionary_status", "asynchronous": false, "params": [{"name": "append", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": null}, {"name": "filepath", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "newfile", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["A simple helper function to generate a status message for write_dictionary\n\nArguments:\n    append {bool} -- the append flag\n    filepath {str} -- the file path for the output CSV file\n    newfile {bool} -- a file indicating whether a newfile was created\n\nReturns:\n    str -- a status string"]}, {"name": "hdx_cli_toolkit.utilities.print_table_from_list_of_dicts", "asynchronous": false, "params": [{"name": "column_data_rows", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}]}, "default": null}, {"name": "excluded_fields", "type": {"name": "None | list[str]", "xref": null, "params": null}, "default": "..."}, {"name": "included_fields", "type": {"name": "None | list[str]", "xref": null, "params": null}, "default": "..."}, {"name": "truncate_width", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "max_total_width", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["A helper function to print a list of dictionaries as a table\n\nArguments:\n    column_data_rows {list[dict]} -- the list of dictionaries to print\n\nKeyword Arguments:\n    excluded_fields {None|list} -- any fields to be ommitted, none excluded by default\n                                    (default: {None})\n    included_fields {None|list} -- any fields to be included, all included by default\n                                    (default: {None})\n    truncate_width {int} -- width at which to truncate a column (default: {130})\n    max_total_width {int} -- total width of the table (default: {150})"]}, {"name": "hdx_cli_toolkit.utilities.censor_secret", "asynchronous": false, "params": [{"name": "secret", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["A function to censor a string containing a secret. If the length of the string is less than\n10 characters then all characters are censored, if it is more then the last 10 characters are\nleft in place.\n\nArguments:\n    secret {str} -- a secret\n\nReturns:\n    str -- the secret, censored"]}, {"name": "hdx_cli_toolkit.utilities.str_to_bool", "asynchronous": false, "params": [{"name": "x", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["A function that converts a string into a boolean using the formalism that any casing of the\nstring \"True\" is True and all other strings are False. The default behaviour of the builtin\nbool is that any non-empty string is True\n\nArguments:\n    x {str} -- a string\n\nReturns:\n    bool -- a boolean representation of the string"]}, {"name": "hdx_cli_toolkit.utilities.make_conversion_func", "asynchronous": false, "params": [{"name": "value", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": [{"name": "Callable | None", "xref": null, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["A function that takes a value of Any type and returns the function that will convert a string\n to that type. Used to take values from dataset attributes and work out how to convert a string\n from the commandline.\n\nArguments:\n    value {Any} -- a value of Any type\n\nReturns:\n    tuple[Callable | None, str] -- a function that will convert a string to the provided type,\n                                   and the name of that type"]}, {"name": "hdx_cli_toolkit.utilities.read_attributes", "asynchronous": false, "params": [{"name": "dataset_name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "attributes_filepath", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["A function for reading attributes from a standard attributes.csv file with columns:\ndataset_name,timestamp,attribute,value,secondary_value or a JSON format file containing\neither a list or a single dictionary.\n\nArguments:\n    dataset_name {str} -- the name of the dataset for which attributes are required\n    attributes_filepath {str} -- path to attributes file either CSV or JSON\n\nReturns:\n    dict -- a dictionary containing the attributes"]}, {"name": "hdx_cli_toolkit.utilities.print_banner", "asynchronous": false, "params": [{"name": "action", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Simple function to output a banner to console, uses click's secho command but not colour\nbecause the underlying colorama does not output correctly to git-bash terminals.\n\nArguments:\n    action {str} -- _description_"]}, {"name": "hdx_cli_toolkit.utilities.make_path_unique", "asynchronous": false, "params": [{"name": "input_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "hdx_cli_toolkit.utilities.print_dictionary_comparison", "asynchronous": false, "params": [{"name": "dict1", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "dict2", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "name1", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "name2", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "differences", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "hdx_cli_toolkit.utilities.query_dict", "asynchronous": false, "params": [{"name": "keys", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "dataset_dict", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "output_row", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, "documentation": ["This function takes a list of key definitions which can be simple (i.e. archived) or nested\n(resource.name). Nested keys can access simple dictionaries or the same key in each element\nof a list. Key depth is limited to 2, and list.list nested keys are not handled.\n\nArguments:\n    keys {list[str]} -- a list of key definitions\n    dataset_dict {dict[str, Any]} -- the dictionary from which data is to be extracted\n    output_row {dict[str, Any]} -- a dictionary containing any prefix information\n\nReturns:\n    list[dict[str, Any]] -- a list of dictionaries which contain the prefix and extracted values"]}, {"name": "hdx_cli_toolkit.utilities.traverse", "asynchronous": false, "params": [{"name": "keys", "type": null, "default": null}, {"name": "dictionary", "type": null, "default": null}, {"name": "value_list", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "hdx_cli_toolkit.hdx_utilities", "documentation": ["!/usr/bin/env python", "encoding: utf-8"], "functions": [{"name": "hdx_cli_toolkit.hdx_utilities.hdx_error_handler", "asynchronous": false, "params": [{"name": "f", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "hdx_cli_toolkit.hdx_utilities.parse_hdxerror_traceback", "asynchronous": false, "params": [{"name": "traceback_message", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "hdx_cli_toolkit.hdx_utilities.get_filtered_datasets", "asynchronous": false, "params": [{"name": "organization", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "dataset_filter", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "query", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "func