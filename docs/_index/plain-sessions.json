 stores data on the server side and\nabstracts the sending and receiving of cookies. Cookies contain a\nsession ID -- not the data itself.\n\nThe Plain sessions framework is entirely cookie-based. It does\nnot fall back to putting session IDs in URLs. This is an intentional\ndesign decision. Not only does that behavior make URLs ugly, it makes\nyour site vulnerable to session-ID theft via the \"Referer\" header.\n\nFor complete documentation on using Sessions in your code, consult\nthe sessions documentation that is shipped with Plain (also available\non the Plain web site)."]}], "exports": []}, {"name": "plain.sessions.cli", "documentation": [], "functions": [{"name": "plain.sessions.cli.cli", "asynchronous": false, "params": [], "returns": null, "documentation": ["Sessions management commands."]}, {"name": "plain.sessions.cli.clear_expired", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "plain.sessions.backends.db", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "plain.sessions.backends.db.SessionStore", "bases": ["SessionBase"], "methods": [{"name": "plain.sessions.backends.db.SessionStore.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "session_key", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "plain.sessions.backends.db.SessionStore.get_model_class", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "plain.sessions.backends.db.SessionStore.model", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "plain.sessions.backends.db.SessionStore._get_session_from_db", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "plain