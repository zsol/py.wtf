classes": [], "exports": []}, {"name": "fastapi_filter.contrib.sqlalchemy", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "fastapi_filter.contrib.sqlalchemy.Filter", "xref": {"fqname": "fastapi_filter.contrib.sqlalchemy.filter.Filter", "project": null}}]}, {"name": "fastapi_filter.base.filter", "documentation": [], "functions": [{"name": "fastapi_filter.base.filter.with_prefix", "asynchronous": false, "params": [{"name": "prefix", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "Filter", "type": {"name": "type", "xref": {"fqname": "functions.type", "project": "--std--"}, "params": [{"name": "BaseFilterModel", "xref": {"fqname": "fastapi_filter.base.filter.BaseFilterModel", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "type", "xref": {"fqname": "functions.type", "project": "--std--"}, "params": [{"name": "BaseFilterModel", "xref": {"fqname": "fastapi_filter.base.filter.BaseFilterModel", "project": null}, "params": null}]}, "documentation": ["Allow re-using existing filter under a prefix.\n\nExample:\n    ```python\n    from pydantic import BaseModel\n\n    from fastapi_filter.filter import FilterDepends\n\n    class NumberFilter(BaseModel):\n        count: Optional[int]\n\n    class MainFilter(BaseModel):\n        name: str\n        number_filter: Optional[Filter] = FilterDepends(with_prefix(\"number_filter\", Filter))\n    ```\n\nAs a result, you'll get the following filters:\n    * name\n    * number_filter__count\n\n# Limitation\n\nThe alias generator is the last to be picked in order of prevalence. So if one of the fields has a `Query` as\ndefault and declares an alias already, this will be picked first and you won't get the prefix.\n\nExample:\n    ```python\n     from pydantic import BaseModel\n\n    class NumberFilter(BaseModel):\n        count: Optional[int] = Query(default=10, alias=counter)\n\n    class MainFilter(BaseModel):\n        name: str\n        number_filter: Optional[Filter] = FilterDepends(with_prefix(\"number_filter\", Filter))\n    ```\n\nAs a result, you'll get the following filters:\n    * name\n    * counter (*NOT* number_filter__counter)"]}, {"name": "fastapi_filter.base.filter._list_to_str_fields", "asynchronous": false, "params": [{"name": "Filter", "type": {"name": "type", "xref": {"fqname": "functions.type", "project": "--std--"}, "params": [{"name": "BaseFilterModel", "xref": {"fqname": "fastapi_filter.base.filter.BaseFilterModel", "project": null}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "fastapi_filter.base.filter.FilterDepends", "asynchronous": false, "params": [{"name": "Filter", "type": {"name": "type", "xref": {"fqname": "functions.type", "project": "--std--"}, "params": [{"name": "BaseFilterModel", "xref": {"fqname": "fastapi_filter.base.filter.BaseFilterModel", "project": null}, "params": null}]}, "default": null}, {"name": "by_alias", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "use_cache", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": ["Use a hack to support lists in filters.\n\nFastAPI doesn't support it yet: https://github.com/tiangolo/fastapi/issues/50\n\nWhat we do is loop through the fields of a filter and change any `list` field to a `str` one so that it won't be\nexcluded from the possible query parameters.\n\nWhen we apply the filter, we build the original filter to properly validate the data (i.e. can the string be parsed\nand formatted as a list of <type>?)"]}], "variables": [{"name": "fastapi_filter.base.filter.UNION_TYPES", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--