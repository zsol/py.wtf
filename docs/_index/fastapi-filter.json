ute`.\n\n# Filtering\n\n## Query string examples:\n\n    >>> \"?my_field__gt=12&my_other_field=Tomato\"\n    >>> \"?my_field__in=12,13,15&my_other_field__not_in=Tomato,Pepper\""]}], "exports": []}, {"name": "fastapi_filter.contrib.sqlalchemy.filter", "documentation": [], "functions": [{"name": "fastapi_filter.contrib.sqlalchemy.filter._backward_compatible_value_for_like_and_ilike", "asynchronous": false, "params": [{"name": "value", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["Add % if not in value to be backward compatible.\n\nArgs:\n    value (str): The value to filter.\n\nReturns:\n    Either the unmodified value if a percent sign is present, the value wrapped in % otherwise to preserve\n    current behavior."]}], "variables": [{"name": "fastapi_filter.contrib.sqlalchemy.filter._orm_operator_transformer", "type": null, "documentation": ["Operators \u00e0 la Django.\n\nExamples:\n    my_datetime__gte\n    count__lt\n    name__isnull\n    user_id__in"]}], "classes": [{"name": "fastapi_filter.contrib.sqlalchemy.filter.Filter", "bases": ["BaseFilterModel"], "methods": [{"name": "fastapi_filter.contrib.sqlalchemy.filter.Filter.split_str", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "value", "type": null, "default": null}, {"name": "field", "type": {"name": "ValidationInfo", "xref": {"fqname": "pydantic.ValidationInfo", "project": "pydantic"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "fastapi_filter.contrib.sqlalchemy.filter.Filter.filter", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "query", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "Query", "xref": {"fqname": "sqlalchemy.orm.Query", "project": null}, "params": null}, {"name": "Select", "xref": {"fqname": "sqlalch