profile", "def get_full_json_from_output_config_mem_optimized(output_config: OutputConfig = None,", "job_id: str = None,", "s3_client=None) -> dict:", "import ijson", "import codecs", "if not output_config or not job_id:", "raise ValueError(\"no output_config or job_id\")", "if not output_config.s3_bucket or not output_config.s3_prefix:", "raise ValueError(\"no output_config or job_id\")", "if not s3_client:", "s3_client = boto3.client(\"s3\")", "result_value = {'Blocks': []}", "all_objects = []", "for key in get_s3_output_config_keys(output_config=output_config, job_id=job_id, s3_client=s3_client):", "logger.info(f\"found keys: {key}\")", "s3_object = s3_client.get_object(Bucket=output_config.s3_bucket, Key=key)", "body = s3_object['Body']", "f = codecs.getreader('utf-8')(body)", "objects = ijson.items(f, 'Blocks.item', use_float=True)", "# result_value['Blocks'].extend([o for o in objects])", "all_objects.append(objects)", "del objects", "return result_value"]}, {"name": "textractcaller.t_call.get_full_json_lending_from_output_config", "asynchronous": false, "params": [{"name": "output_config", "type": {"name": "OutputConfig", "xref": {"fqname": "textractcaller.t_call.OutputConfig", "project": null}, "params": null}, "default": null}, {"name": "job_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "s3_client", "type": null, "default": "..."}, {"name": "subfolder", "type": null, "default": "..."}], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "textractcaller.t_call.get_full_json_lending", "asynchronous": false, "params": [{"name": "job_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "boto3_textract_client", "type": null, "default": null}, {"name": "job_done_polling_interval", "type": null, "default": "..."}], "re