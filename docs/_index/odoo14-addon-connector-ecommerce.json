null}], "returns": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.write", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "values", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.action_cancel", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.ignore_cancellation", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "reason", "type": null, "default": null}], "returns": null, "documentation": ["Manually set the cancellation from the backend as resolved.\n\nThe user can choose to keep the sales order active for some reason,\nit only requires to push a button to keep it alive."]}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.action_view_parent", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return an action to display the parent sales order"]}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder._create_delivery_line", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "carrier", "type": null, "default": null}, {"name": "price_unit", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder._inherit", "type": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.canceled_in_backend", "type": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.cancellation_resolved", "type": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.parent_id", "type": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.need_cancel", "type": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder.parent_need_cancel", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Add a cancellation mecanism in the sales orders\n\nWhen a sales order is canceled in a backend, the connectors can flag\nthe 'canceled_in_backend' flag. It will:\n\n* try to automatically cancel the sales order\n* block the confirmation of the sales orders using a 'sales exception'\n\nWhen a sales order is canceled or the user used the button to force\nto 'keep it open', the flag 'cancellation_resolved' is set to True.\n\nThe second axe which can be used by the connectors is the 'parent'\nsales order. When a sales order has a parent sales order (logic to\nlink with the parent to be defined by each connector), it will be\nblocked until the cancellation of the sales order is resolved.\n\nThis is used by, for instance, the magento connector, when one\nmodifies a sales order, Magento cancels it and create a new one with\nthe first one as parent."]}], "exports": []}, {"name": "odoo.addons.connector_ecommerce.components", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "odoo.addons.connector_ecommerce.components.line_builder", "xref": {"fqname": "odoo.addons.connector_ecommerce.components..line_builder", "project": null}}, {"name": "odoo.addons.connector_ecommerce.components.sale_order_onchange", "xref": {"fqname": "odoo.addons.connector_ecommerce.components..sale_order_onchange", "project": null}}]}, {"name": "odoo.addons.connector_ecommerce.tests.test_onchange", "documentation": ["\u00a9 2013-TODAY Akretion (S\u00e9bastien Beau)", "\u00a9 2018 FactorLibre", "License AGPL-3.0 or later (http://www.gnu.org/licenses/agpl.html)"], "functions": [], "variables": [{"name": "odoo.addons.connector_ecommerce.tests.test_onchange.DB", 