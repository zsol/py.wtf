Camptocamp SA", "\u00a9 2018 FactorLibre", "License AGPL-3.0 or later (http://www.gnu.org/licenses/agpl.html)"], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.connector_ecommerce.tests.test_invoice_event.TestInvoiceEvent", "bases": ["common.TransactionCase"], "methods": [{"name": "odoo.addons.connector_ecommerce.tests.test_invoice_event.TestInvoiceEvent.setUp", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.connector_ecommerce.tests.test_invoice_event.TestInvoiceEvent.test_event_validated", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test if the `on_invoice_validated` event is fired\nwhen an invoice is validated\n"]}, {"name": "odoo.addons.connector_ecommerce.tests.test_invoice_event.TestInvoiceEvent.test_event_paid", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Test if the `on_invoice_paid` event is fired\nwhen an invoice is paid\n"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Test if the events on the invoice are fired correctly"]}], "exports": []}, {"name": "odoo.addons.connector_ecommerce.models.sale", "documentation": ["\u00a9 2011-2013 Camptocamp", "\u00a9 2010-2013 Akretion (S\u00e9bastien Beau)", "License AGPL-3.0 or later (http://www.gnu.org/licenses/agpl.html)", "-*- coding: utf-8 -*-"], "functions": [], "variables": [{"name": "odoo.addons.connector_ecommerce.models.sale._logger", "type": null, "documentation": []}], "classes": [{"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder", "bases": ["models.Model"], "methods": [{"name": "odoo.addons.connector_ecommerce.models.sale.SaleOrder._compute_parent_id", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Need to be