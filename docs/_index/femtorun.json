ally calls get_vars()\nfor some set of variables that are monitored\n\nDoes not necessarily need to be implemented. Returns empty by default."]}, {"name": "femtorun.runner.FemtoRunner._quantize_inputs", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "input_vals", "type": {"name": "MaybeFVARVALS", "xref": {"fqname": "MaybeFVARVALS", "project": null}, "params": null}, "default": null}], "returns": {"name": "VARVALS", "xref": {"fqname": "VARVALS", "project": null}, "params": null}, "documentation": ["allows easy interoperability between runners that use real-valued inputs\nand those that dont"]}, {"name": "femtorun.runner.FemtoRunner._dequantize_inputs", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "output_vals", "type": {"name": "VARVALS", "xref": {"fqname": "VARVALS", "project": null}, "params": null}, "default": null}], "returns": {"name": "MaybeFVARVALS", "xref": {"fqname": "MaybeFVARVALS", "project": null}, "params": null}, "documentation": ["allows easy interoperability between runners that use real-valued outputs\nand those that dont"]}, {"name": "femtorun.runner.FemtoRunner._pad_inputs", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "input_vals", "type": {"name": "VARVALS", "xref": {"fqname": "VARVALS", "project": null}, "params": null}, "default": null}], "returns": {"name": "VARVALS", "xref": {"fqname": "VARVALS", "project": null}, "params": null}, "documentation": ["allows easy interoperability between runners that need padded inputs\nand those that dont"]}, {"name": "femtorun.runner.FemtoRunner._unpad_outputs", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "output_vals", "type": {"name": "VARVALS", "xref": {"fqname": "VARVALS", "project": null}, "params": null}, "default": null}], "returns": {"name": "VARVALS", "xref": {"fqname": "VARVALS", "project": null}, "params": null}, "