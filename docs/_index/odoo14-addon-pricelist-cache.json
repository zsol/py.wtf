documentation": []}], "classes": [], "exports": []}, {"name": "odoo.addons.pricelist_cache.tests", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "odoo.addons.pricelist_cache.tests.test_methods", "xref": {"fqname": "odoo.addons.pricelist_cache.tests..test_methods", "project": null}}, {"name": "odoo.addons.pricelist_cache.tests.test_partner_pricelist_cache", "xref": {"fqname": "odoo.addons.pricelist_cache.tests..test_partner_pricelist_cache", "project": null}}, {"name": "odoo.addons.pricelist_cache.tests.test_pricelist_cache", "xref": {"fqname": "odoo.addons.pricelist_cache.tests..test_pricelist_cache", "project": null}}]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache", "documentation": ["Copyright 2021 Camptocamp SA", "License AGPL-3.0 or later (http://www.gnu.org/licenses/agpl)"], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache", "bases": ["models.Model"], "methods": [{"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._update_existing_records", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "product_prices", "type": null, "default": null}], "returns": null, "documentation": ["Update existing records with provided prices.\n\nArgs:\n    - self : The recordset of cache records to update\n    - product_prices : The new prices to apply"]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._create_cache_records", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pricelist_id", "type": null, "default": null}, {"name": "product_ids", "type": null, "default": null}, {"name": "product_prices", "type": null, "default": null}], "returns": null, "documentation": ["Create price cache records for a given pricelist, applied to a list of\nproduct ids.\n\nargs:\n    - pricelist_id : The pricelist id on which prices are applied\n    - product_ids : A list of product ids to cache\n    - product_prices : A dict containing the prices for each product"]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._update_pricelist_cache", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pricelist_id", "type": null, "default": null}, {"name": "product_prices", "type": null, "default": null}], "returns": null, "documentation": ["Updates the cache, for a given pricelist, and product prices.\n\nArgs:\n    - pricelist: a product.pricelist record\n    - product_prices: A dictionary,\n      with product.product id as keys, and prices as values"]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._get_product_ids_to_update", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pricelist", "type": null, "default": null}, {"name": "product_ids", "type": null, "default": null}], "returns": null, "documentation": ["Returns a list of product_ids that are already cached\nfor the given pricelist.\n\nArgs:\n    - pricelist: The pricelist record on which new prices are applied\n    - product_prices: The list of products to check"]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache.update_product_pricelist_cache", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "product_ids", "type": null, "default": "..."}, {"name": "pricelist_ids", "type": null, "default": "..."}], "returns": null, "documentation": ["Updates price list cache given a product.product recordset and a pricelist,\nif specified."]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._update_pricelist_items_cache", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pricelist_items", "type": null, "default": null}], "returns": null, "documentation": ["Updates cache for a given recordset of pricelist items, then update\nthe items skipped state to False."]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache.create_full_cache", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Creates cache for all prices applied to all pricelists."]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache.flush_pricelist_cache", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache.cron_reset_pricelist_cache", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Recreates the whole price list cache."]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache.get_cached_prices_for_pricelist", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "pricelist", "type": null, "default": null}, {"name": "products", "type": null, "default": null}], "returns": null, "documentation": ["Retrieves product prices for a given pricelist."]}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._get_tree_view", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "domain", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [{"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._name", "type": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._description", "type": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache._rec_name", "type": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache.pricelist_id", "type": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache.product_id", "type": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.models.product_pricelist_cache.PricelistCache.price", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["This model aims to store all product prices depending on all pricelist.\n\nPrice cache is updated or created in the following cases:\n    - Product price is created / modified;\n      -> entrypoint \"product_product.py::{create,write}\"\n    - Pricelist item is created / modified;\n      -> entrypoint \"product_pricelist_item.py::update_product_pricelist_cache\"\n    - Pricelist is created;\n      -> entrypoint \"product_pricelist.py::create\"\nThere's also a daily cron task that updates cache prices\nthat have been skipped during the day:\n - see \"cron_reset_pricelist_cache\" for the cron method\n - see \"product_pricelist_item.py::update_product_pricelist_cache\"\n   for skip conditions\nEvery call to PricelistCache.update_product_pricelist_cache\nshould be made in a job as computation might be slow, depending on the case."]}], "exports": []}, {"name": "odoo.addons.pricelist_cache.tests.test_methods", "documentation": ["Copyright 2023 Camptocamp SA", "License AGPL-3.0 or later (http://www.gnu.org/licenses/agpl)"], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.pricelist_cache.tests.test_methods.TestPricelistCacheModels", "bases": ["TestPricelistCacheCommon"], "methods": [{"name": "odoo.addons.pricelist_cache.tests.test_methods.TestPricelistCacheModels.test_get_parent_lists_tree", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.tests.test_methods.TestPricelistCacheModels.test_get_parent_pricelists", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "odoo.addons.pricelist_cache.tests.test_partner_pricelist_cache", "documentation": ["Copyright 2021 Camptocamp SA", "License AGPL-3.0 or later (http://www.gnu.org/licenses/agpl)."], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.pricelist_cache.tests.test_partner_pricelist_cache.TestPricelistCache", "bases": ["TestPricelistCacheCommon"], "methods": [{"name": "odoo.addons.pricelist_cache.tests.test_partner_pricelist_cache.TestPricelistCache.test_partner_pricelists", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.tests.test_partner_pricelist_cache.TestPricelistCache.assert_partner_cache_not_available", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.tests.test_partner_pricelist_cache.TestPricelistCache.assert_partner_cache_available", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.pricelist_cache.tests.test_partner_pricelist_cache.TestPricelistCache.test_partner_inconsistent_cache", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "odoo.addons.pricelist_cache", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "odoo.addons.pricelist_cache.models", "xref": {"fqname": "odoo.addons.pricelist_cache..models", "project": 