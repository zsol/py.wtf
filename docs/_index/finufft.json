fft.finufft._finufft._makeplanf", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._makeplanf.argtypes", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._makeplanf.restypes", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._setpts", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._setpts.argtypes", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._setpts.restype", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._setptsf", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._setptsf.argtypes", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._setptsf.restype", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._execute", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._execute.argtypes", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._execute.restype", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._executef", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._executef.argtypes", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._executef.restype", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._destroy", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._destroy.argtypes", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._destroy.restype", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._destroyf", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._destroyf.argtypes", "type": null, "documentation": []}, {"name": "python.finufft.finufft._finufft._destroyf.restype", "type": null, "documentation": []}], "classes": [{"name": "