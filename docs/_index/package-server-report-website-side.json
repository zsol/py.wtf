{"name": "package-server-report-website-side", "metadata": {"name": "package-server-report-website-side", "version": "0.1.0", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/yourusername/package_server_report_website_side", "license": "MIT", "documentation_url": null, "dependencies": ["flask", "requests", "beautifulsoup4", "pandas", "openpyxl", "reportlab", "lxml"], "summary": "A tool to monitor website performance, SEO, UI, and security, and generate reports.", "upload_time": 1733476738}, "documentation": ["# Website Monitoring Software\n\nA Python-based software tool designed to monitor various aspects of a website, including performance, SEO, UI, and security details. The software collects data using HTTP requests, performs analysis, and generates comprehensive reports in PDF or Excel formats. It includes both a command-line interface and a web interface for ease of use.\n\n## Features\n\n- **Website Performance Monitoring**: Analyzes website loading speed and performance metrics.\n- **SEO Analysis**: Checks critical SEO elements such as page titles, meta descriptions, and keywords.\n- **UI Evaluation**: Provides feedback on the usability and design of the website.\n- **Security Assessment**: Verifies security-related aspects like HTTPS, security headers, and more.\n- **Report Generation**: Outputs detailed reports in PDF or Excel formats.\n\n## Installation\n\n### Prerequisites\n\n- Python 3.6 or higher\n- `pip` (Python package manager)\n\n### Steps to Install\n\n1. Clone the repository to your local machine:\n   ```bash\n   git clone https://github.com/yourusername/website-monitoring-software.git\n   cd website-monitoring-software\n"], "modules": [{"name": "monitor.ui", "documentation": [], "functions": [{"name": "monitor.ui.get_ui_details", "asynchronous": false, "params": [{"name": "url", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "monitor.seo", "documentation": [], "functions": [{"name": "monitor.seo.get_seo_details", "asynchronous": false, "params": [{"name": "url", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "monitor.performance", "documentation": [], "functions": [{"name": "monitor.performance.get_website_performance", "asynchronous": false, "params": [{"name": "url", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "monitor.security", "documentation": [], "functions": [{"name": "monitor.security.get_ssl_certificate", "asynchronous": false, "params": [{"name": "url", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "monitor.security.get_http_headers", "asynchronous": false, "params": [{"name": "url", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "monitor", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "monitor.get_http_headers", "xref": {"fqname": "monitor.security.get_http_headers", "project": null}}, {"name": "monitor.get_seo_details", "xref": {"fqname": "monitor.seo.get_seo_details", "project": null}}, {"name": "monitor.get_ssl_certificate", "xref": {"fqname": "monitor.security.get_ssl_certificate", "project": null}}, {"name": "monitor.get_ui_details", "xref": {"fqname": "monitor.ui.get_ui_details", "project": null}}, {"name": "monitor.get_website_performance", "xref": {"fqname": "monitor.performance.get_website_performance", "project": null}}]}, {"name": "report", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "report.generate_pdf_report", "xref": {"fqname": "report.pdf_report.generate_pdf_report", "project": null}}]}, {"name": "report.pdf_report", "documentation": [], "functions": [{"name": "report.pdf_report.generate_pdf_report", "asynchronous": false, "params": [{"name": "data", "type": null, "default": null}, {"name": "filename", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "report.xlsx_report", "documentation": ["import openpyxl", "def generate_xlsx_report(data, filename):", "wb = openpyxl.Workbook()", "ws = wb.active", "ws.title = \"Website Monitoring\"", "# Add headers", "ws['A1'] = 'Metric'", "ws['B1'] = 'Value'", "# Performance Data", "ws.append(['Performance',", "f\"Status: {data['performance']['status']} | Response Time: {data['performance']['response_time']}s\"])", "# SEO Data", "ws.append(['Title', data['seo']['title']])", "ws.append(['Meta Description', data['seo']['meta_description']])", "ws.append(['H1 Tag', data['seo']['h1']])", "# UI Data", "ws.append(['Missing Alt Text', ', '.join(data['ui']['missing_alt_text'])])", "# Security Data", "ws.append(['SSL Certificate', data['security']['ssl_certificate_status']])", "wb.save(filename)"], "functions": [], "variables": [], "classes": [], "exports": []}]}