"default": "..."}, {"name": "true_cost", "type": null, "default": "..."}, {"name": "true_dynamics", "type": null, "default": "..."}, {"name": "delta_space", "type": null, "default": "..."}, {"name": "current_x", "type": null, "default": "..."}, {"name": "current_u", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}, {"name": "back_eps", "type": null, "default": "..."}, {"name": "no_op_forward", "type": null, "default": "..."}], "returns": null, "documentation": ["A single step of the box-constrained iLQR solver.\n\nRequired Args:\n    n_state, n_ctrl, T\n    x_init: The initial state [n_batch, n_state]\n\nOptional Args:\n    u_lower, u_upper: The lower- and upper-bounds on the controls.\n        These can either be floats or shaped as [T, n_batch, n_ctrl]\n        TODO: Better support automatic expansion of these.\n    TODO"]}], "variables": [{"name": "mpc.lqr_step.LqrBackOut", "type": null, "documentation": []}, {"name": "mpc.lqr_step.LqrForOut", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "mpc.mpc", "documentation": [], "functions": [], "variables": [{"name": "mpc.mpc.QuadCost", "type": null, "documentation": []}, {"name": "mpc.mpc.LinDx", "type": null, "documentation": []}, {"name": "mpc.mpc.QuadCost.__new__.__defaults__", "type": null, "documentation": []}, {"name": "mpc.mpc.LinDx.__new__.__defaults__", "type": null, "documentation": []}], "classes": [{"name": "mpc.mpc.GradMethods", "bases": ["Enum"], "methods": [], "class_variables": [{"name": "mpc.mpc.GradMethods.AUTO_DIFF", "type": null, "documentation": []}, {"name": "mpc.mpc.GradMethods.FINITE_DIFF", "type": null, "documentation": []}, {"name": "mpc.mpc.GradMethods.ANALYTIC", "type": null, "documentation": []}, {"name": "mpc.mpc.GradMethods.ANALYTIC_CHECK", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "mpc.mpc.SlewRateCost", "bases": ["Module"], "methods": [{"name": "mpc.mpc.SlewRateCost.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cost", "type": null, "default": null}, {"name": "slew_C", "type": null, "default": null}, {"name": "n_state", "type": null, "default": null}, {"name": "n_ctrl", "type": null, "default": null}], "returns": null, "documentation": ["TODO: It would be cleaner to update this to just use the slew", "rate penalty instead of # slew_C"]}, {"name": "mpc.mpc.SlewRateCost.forward", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "tau", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mpc.mpc.SlewRateCost.grad_input", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "u", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Hacky way of adding the slew rate penalty to costs."]}, {"name": "mpc.mpc.MPC", "bases": ["Module"], "methods": [{"name": "mpc.mpc.MPC.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "n_state", "type": null, "default": null}, {"name": "n_ctrl", "type": null, "default": null}, {"name": "T", "type": null, "default": null}, {"name": "u_lower", "type": null, "default": "..."}, {"name": "u_upper", "type": null, "default": "..."}, {"name": "u_zero_I", "type": null, "default": "..."}, {"name": "u_init", "type": null, "default": "..."}, {"name": "lqr_iter", "type": null, "default": "..."}, {"name": "grad_method", "type": null, "default": "..."}, {"name": "delta_u", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}, {"name": "eps", "type": null, "default": "..."}, {"name": "back_eps", "type": null, "default": "..."}, {"name": "n_batch", "type": null, "default": "..."}, {"name": "linesearch_decay", "type": null, "default": "..."}, {"name": "max_linesearch_iter", "type": null, "default": "..."}, {"name": "exit_unconverged", "type": null, "default": "..."}, {"name": "detach_unconverged", "type": null, "default": "..."}, {"name": "backprop", "type": null, "default": "..."}, {"name": "slew_rate_penalty", "type": null, "default": "..."}, {"name": "prev_ctrl", "type": null, "default": "..."}, {"name": "not_improved_lim", "type": null, "default": "..."}, {"name": "best_cost_eps", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "mpc.mpc.MPC.forward", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x_init", "type": null, "default": null}, {"name": "cost", "type": null, "default": null}, {"name": "dx", "type": null, "default": null}], "returns": null, "documentation": ["@profile"]}, {"name": "mpc.mpc.MPC.solve_lqr_subproblem", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x_init", "type": null, "default": null}, {"name": "C", "type": null, "default": null}, {"name": "c", "type": null, "default": null}, {"name": "F", "type": null, "default": null}, {"name": "f", "type": null, "default": null}, {"name": "cost", "type": null, "default": null}, {"name": "dynamics", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "u", "type": null, "default": null}, {"name": "no_op_forward", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "mpc.mpc.MPC.approximate_cost", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "u", "type": null, "default": null}, {"name": "Cf", "type": null, "default": null}, {"name": "diff", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "mpc.mpc.MPC.linearize_dynamics", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "u", "type": null, "default": null}, {"name": "dynamics", "type": null, "default": null}, {"name": "diff", "type": null, "default": null}], "returns": null, "documentation": ["@profile"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["A differentiable box-constrained iLQR solver.\n\nThis provides a differentiable solver for the following box-constrained\ncontrol problem with a quadratic cost (defined by C and c) and\nnon-linear dynamics (defined by f):\n\n    min_{tau={x,u}} sum_t 0.5 tau_t^T C_t tau_t + c_t^T tau_t\n                    s.t. x_{t+1} = f(x_t, u_t)\n                        x_0 = x_init\n                        u_lower <= u <= u_upper\n\nThis implements the Control-Limited Differential Dynamic Programming\npaper with a first-order approximation to the non-linear dynamics:\nhttps://homes.cs.washington.edu/~todorov/papers/TassaICRA14.pdf\n\nSome of the notation here is from Sergey Levine's notes:\nhttp://rll.berkeley.edu/deeprlcourse/f17docs/lecture_8_model_based_planning.pdf\n\nRequired Args:\n    n_state, n_ctrl, T\n\nOptional Args:\n    u_lower, u_upper: The lower- and upper-bounds on the controls.\n        These can either be floats or shaped as [T, n_batch, n_ctrl]\n    u_init: The initial control sequence, useful for warm-starting:\n        [T, n_batch, n_ctrl]\n    lqr_iter: The number of LQR iterations to perform.\n    grad_method: The method to compute the Jacobian of the dynamics.\n        GradMethods.ANALYTIC: Use a manually-defined Jacobian.\n            + Fast and accurate, use this if possible\n        GradMethods.AUTO_DIFF: Use PyTorch's autograd.\n            + Slow\n        GradMethods.FINITE_DIFF: Use naive finite differences\n            + Inaccurate\n    delta_u (float): The amount each component of the controls\n        is allowed to change in each LQR iteration.\n    verbose (int):\n        -1: No output or warnings\n         0: Warnings\n        1+: Detailed iteration info\n    eps: Termination threshold, on the norm of the full control\n         step (without line search)\n    back_eps: `eps` value to use in the backwards pass.\n    n_batch: May be necessary for now if it can't be inferred.\n             TODO: Infer, potentially remove this.\n    linesearch_decay (float): Multiplicative decay factor for the\n        line search.\n    max_linesearch_iter (int): Can be used to disable the line search\n        if 1 is used for some problems the line search can\n        be harmful.\n    exit_unconverged: Assert False if a fixed point is not reached.\n    detach_unconverged: Detach examples from the graph that do\n        not hit a fixed point so they are not differentiated through.\n    backprop: Allow the solver to be differentiated through.\n    slew_rate_penalty (float): Penalty term applied to\n        ||u_t - u_{t+1}||_2^2 in the objective.\n    prev_ctrl: The previous nominal control sequence to initialize\n        the solver with.\n    not_improved_lim: The number of iterations to allow that don't\n        improve the objective before returning early.\n    best_cost_eps: Absolute threshold for the best cost\n        to be updated."]}], "exports": []}]}