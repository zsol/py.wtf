xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Box", "xref": {"fqname": "pywinbox._pywinbox_macos._main.Box", "project": null}, "params": null}, "documentation": []}, {"name": "pywinbox._pywinbox_macos._NSmoveResizeTo", "asynchronous": false, "params": [{"name": "window", "type": {"name": "AppKit.NSWindow", "xref": {"fqname": "AppKit.NSWindow", "project": null}, "params": null}, "default": null}, {"name": "newBox", "type": {"name": "Box", "xref": {"fqname": "pywinbox._pywinbox_macos._main.Box", "project": null}, "params": null}, "default": null}, {"name": "flipValues", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [{"name": "pywinbox._pywinbox_macos._macOSNSHandle", "bases": ["NamedTuple"], "methods": [], "class_variables": [{"name": "pywinbox._pywinbox_macos._macOSNSHandle.isNSHandle", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pywinbox._pywinbox_macos._macOSNSHandle.window", "type": {"name": "AppKit.NSWindow", "xref": {"fqname": "AppKit.NSWindow", "project": null}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pywinbox._pywinbox_macos._macOSCGHandle", "bases": ["NamedTuple"], "methods": [], "class_variables": [{"name": "pywinbox._pywinbox_macos._macOSCGHandle.isNSHandle", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pywinbox._pywinbox_macos._macOSCGHandle.appName", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "pywinbox._pywinbox_macos._macOSCGHandle.windowTitle", "type": {"name": "str", "xref": {"fqname": "functions.str",