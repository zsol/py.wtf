bles": [{"name": "awinrm.protocol.xmlns", "type": null, "documentation": []}], "classes": [{"name": "awinrm.protocol.Protocol", "bases": ["object"], "methods": [{"name": "awinrm.protocol.Protocol.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "endpoint", "type": null, "default": null}, {"name": "credential", "type": null, "default": null}, {"name": "proxies", "type": null, "default": null}, {"name": "ssl_ctx", "type": null, "default": "..."}, {"name": "service", "type": null, "default": "..."}, {"name": "read_timeout_sec", "type": null, "default": "..."}, {"name": "operation_timeout_sec", "type": null, "default": "..."}, {"name": "message_encryption", "type": null, "default": "..."}, {"name": "authtype", "type": null, "default": "..."}], "returns": null, "documentation": ["@param string endpoint: the WinRM webservice endpoint\n@param string transport: transport type, one of 'plaintext' (default), 'kerberos', 'ssl', 'ntlm', 'credssp'  # NOQA\n@param string username: username\n@param string password: password\n@param string realm: unused\n@param string service: the service name, default is HTTP\n@param string keytab: the path to a keytab file if you are using one\n@param string ca_trust_path: Certification Authority trust path. If server_cert_validation is set to 'validate':\n                                'legacy_requests'(default) to use environment variables,\n                                None to explicitly disallow any additional CA trust path\n                                Any other value will be considered the CA trust path to use.\n@param string cert_pem: client authentication certificate file path in PEM format  # NOQA\n@param string cert_key_pem: client authentication certificate key file path in PEM format  # NOQA\n@param string server_cert_validation: whether server certificate should be validated on Python versions that support it; one of 'validate' (default), 'ignore' #NOQA\n@param bool kerberos_delegation: if True, TGT is sent to target server to allow multiple hops  # NOQA\n@param int read_timeout_sec: maximum seconds to wait before an HTTP connect/read times out (default 30). This value should be slightly higher than operation_timeout_sec, as the server can block *at least* that long. # NOQA\n@param int operation_timeout_sec: maximum allowed time in seconds for any single wsman HTTP operation (default 20). Note that operation timeouts while receiving output (the only wsman operation that should take any significant time, and where these timeouts are expected) will be silently retried indefinitely. # NOQA\n@param string kerberos_hostname_override: the hostname to use for the kerberos exchange (defaults to the hostname in the endpoint URL)\n@param bool message_encryption_enabled: Will encrypt the WinRM messages if set to True and the transport auth supports message encryption (Default True).\n@param string proxy: Specify a proxy for the WinRM connection to use. 'legacy_requests'(default) to use environment variables, None to disable proxies completely or the proxy URL itself."]}, {"name": "awinrm.protocol.Protocol.close", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.protocol.Protocol.open_shell", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "i_stream", "type": null, "default": "..."}, {"name": "o_stream", "type": null, "default": "..."}, {"name": "working_directory", "type": null, "default": "..."}, {"name": "env_vars", "type": null, "default": "..."}, {"name": "noprofile", "type": null, "default": "..."}, {"name": "codepage", "type": null, "default": "..."}, {"name": "lifetime", "type": null, "default": "..."}, {"name": "idle_timeout", "type": null, "default": "..."}], "returns": null, "documentation": ["Create a Shell on the destination host\n@param string i_stream: Which input stream to open. Leave this alone\n unless you know what you're doing (default: stdin)\n@param string o_stream: Which output stream to open. Leave this alone\n unless you know what you're doing (default: stdout stderr)\n@param string working_directory: the directory to create the shell in\n@param dict env_vars: environment variables to set for the shell. For\n instance: {'PATH': '%PATH%;c:/Program Files (x86)/Git/bin/', 'CYGWIN':\n  'nontsec codepage:utf8'}\n@returns The ShellId from the SOAP response. This is our open shell\n instance on the remote machine.\n@rtype string"]}, {"name": "awinrm.protocol.Protocol._get_soap_header", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "action", "type": null, "default": "..."}, {"name": "resource_uri", "type": null, "default": "..."}, {"name": "shell_id", "type": null, "default": "..."}, {"name": "message_id", "type": null, "default": "..."}], "returns": null, "documentation": ["Helper method for building SOAP Header"]}, {"name": "awinrm.protocol.Protocol.send_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.protocol.Protocol.close_shell", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "shell_id", "type": null, "default": null}, {"name": "close_session", "type": null, "default": "..."}], "returns": null, "documentation": ["Close the shell\n@param string shell_id: The shell id on the remote machine.\n See #open_shell\n@param bool close_session: If we want to close the requests's session.\n Allows to completely close all TCP connections to the server.\n@returns This should have more error checking but it just returns true\n for now.\n@rtype bool"]}, {"name": "awinrm.protocol.Protocol.run_command", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "shell_id", "type": null, "default": null}, {"name": "command", "type": null, "default": null}, {"name": "arguments", "type": null, "default": "..."}, {"name": "console_mode_stdin", "type": null, "default": "..."}, {"name": "skip_cmd_shell", "type": null, "default": "..."}], "returns": null, "documentation": ["Run a command on a machine with an open shell\n@param string shell_id: The shell id on the remote machine.\n See #open_shell\n@param string command: The command to run on the remote machine\n@param iterable of string arguments: An array of arguments for this\n command\n@param bool console_mode_stdin: (default: True)\n@param bool skip_cmd_shell: (default: False)\n@return: The CommandId from the SOAP response.\n This is the ID we need to query in order to get output.\n@rtype string"]}, {"name": "awinrm.protocol.Protocol.cleanup_command", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "shell_id", "type": null, "default": null}, {"name": "command_id", "type": null, "default": null}], "returns": null, "documentation": ["Clean-up after a command. @see #run_command\n@param string shell_id: The shell id on the remote machine.\n See #open_shell\n@param string command_id: The command id on the remote machine.\n See #run_command\n@returns: This should have more error checking but it just returns true\n for now.\n@rtype bool"]}, {"name": "awinrm.protocol.Protocol.send_command_input", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "shell_id", "type": null, "default": null}, {"name": "command_id", "type": null, "default": null}, {"name": "stdin_input", "type": null, "default": null}, {"name": "end", "type": null, "default": "..."}], "returns": null, "documentation": ["Send input to the given shell and command.\n@param string shell_id: The shell id on the remote machine.\n See #open_shell\n@param string command_id: The command id on the remote machine.\n See #run_command\n@param string stdin_input: The input unicode string or byte string to be sent.\n@param bool end: Boolean value which will close the stdin stream. If end=True then the stdin pipe to the\nremotely running process will be closed causing the next read by the remote process to stdin to return a\nEndOfFile error; the behavior of each process when this error is encountered is defined by the process, but most\nprocesses ( like CMD and powershell for instance) will just exit. Setting this value to 'True' means that no\nmore input will be able to be sent to the process and attempting to do so should result in an error.\n@return: None"]}, {"name": "awinrm.protocol.Protocol.get_command_output", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "shell_id", "type": null, "default": null}, {"name": "command_id", "type": null, "default": null}], "returns": null, "documentation": ["Get the Output of the given shell and command\n@param string shell_id: The shell id on the remote machine.\n See #open_shell\n@param string command_id: The command id on the remote machine.\n See #run_command\n#@return [Hash] Returns a Hash with a key :exitcode and :data.\n Data is an Array of Hashes where the corresponding key\n#   is either :stdout or :stderr.  The reason it is in an Array so so\n we can get the output in the order it occurs on\n#   the console."]}, {"name": "awinrm.protocol.Protocol._raw_get_command_output", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "shell_id", "type": null, "default": null}, {"name": "command_id", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "awinrm.protocol.Protocol.DEFAULT_READ_TIMEOUT_SEC", "type": null, "documentation": []}, {"name": "awinrm.protocol.Protocol.DEFAULT_OPERATION_TIMEOUT_SEC", "type": null, "documentation": []}, {"name": "awinrm.protocol.Protocol.DEFAULT_MAX_ENV_SIZE", "type": null, "documentation": []}, {"name": "awinrm.protocol.Protocol.DEFAULT_LOCALE", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["This is the main class that does the SOAP request/response logic. There\nare a few helper classes, but pretty much everything comes through here\nfirst."]}], "exports": []}, {"name": "awinrm.encryption", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "awinrm.encryption.Encryption", "bases": ["object"], "methods": [{"name": "awinrm.encryption.Encryption.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "session", "type": null, "default": null}, {"name": "protocol", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": ["[MS-WSMV] v30.0 2016-07-14\n\n2.2.9.1 Encrypted Message Types\nWhen using Encryption, there are three options available\n\n> 1. Negotiate/SPNEGO\n> 2. Kerberos\n> 3. CredSSP\n\nDetails for each implementation can be found in this document under this section\n\nThis init sets the following values to use to encrypt and decrypt. This is to help generify\nthe methods used in the body of the class.\n\n> wrap: A method that will return the encrypted message and a signature\n> unwrap: A method that will return an unencrypted message and verify the signature\n> protocol_string: The protocol string used for the particular auth protocol\n\n```\nparam session\n\nThe handle of the session to get GSS-API wrap and unwrap methods\n\nparam protocol\n\nThe auth protocol used, will determine the wrapping and unwrapping method plus\nthe protocol string to use. Currently only NTLM and CredSSP is supported\n```\n"]}, {"name": "awinrm.encryption.Encryption.prepare_encrypted_request", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "endpoint", "type": null, "default": null}, {"name": "message", "type": null, "default": null}], "returns": null, "documentation": ["Creates a prepared request to send to the server with an encrypted message\nand correct headers\n\n```\nparam endpoint\n\nThe endpoint/server to prepare requests to\n\nparam message\n\nThe unencrypted message to send to the server\n\nreturn\n\nA prepared request that has an encrypted message\n```\n"]}, {"name": "awinrm.encryption.Encryption.parse_encrypted_response", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "response", "type": null, "default": null}, {"name": "data", "type": null, "default": null}], "returns": null, "documentation": ["Takes in the encrypted response from the server and decrypts it\n\n```\nparam response\n\nThe response that needs to be decrypted\n\nreturn\n\nThe unencrypted message from the server\n```\n"]}, {"name": "awinrm.encryption.Encryption._encrypt_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": null, "default": null}, {"name": "host", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.encryption.Encryption._decrypt_response", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "host", "type": null, "default": null}, {"name": "data", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.encryption.Encryption._decrypt_ntlm_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "encrypted_data", "type": null, "default": null}, {"name": "host", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.encryption.Encryption._decrypt_credssp_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "encrypted_data", "type": null, "default": null}, {"name": "host", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.encryption.Encryption._decrypt_kerberos_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "encrypted_data", "type": null, "default": null}, {"name": "host", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.encryption.Encryption._build_ntlm_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": null, "default": null}, {"name": "host", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.encryption.Encryption._build_credssp_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": null, "default": null}, {"name": "host", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.encryption.Encryption._build_kerberos_message", "asynchronous": true, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": null, "default": null}, {"name": "host", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "awinrm.encryption.Encryption._get_credssp_trailer_length", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "message_length", "type": null, "default": null}, {"name": "cipher_suite", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "awinrm.encryption.Encryption.SIXTEN_KB", "type": null, "documentation": []}, {"name": "awinrm.encryption.Encryption.MIME_BOUNDARY", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}