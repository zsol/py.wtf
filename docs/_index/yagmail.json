ons for yagmail. Note that the logger is set on the SMTP class.\n\nThe default is to only log errors. If wanted, it is possible to do logging with:\n\nyag = SMTP()\nyag.setLog(log_level = logging.DEBUG)\n\nFurthermore, after creating a SMTP object, it is possible to overwrite and use your own logger by:\n\nyag = SMTP()\nyag.log = myOwnLogger"], "functions": [{"name": "yagmail.log.get_logger", "asynchronous": false, "params": [{"name": "log_level", "type": null, "default": "..."}, {"name": "file_path_name", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "yagmail.__main__", "documentation": [], "functions": [{"name": "yagmail.__main__.register", "asynchronous": false, "params": [{"name": "username", "type": null, "default": null}, {"name": "password", "type": null, "default": null}], "returns": null, "documentation": ["Use this to add a new gmail account to your OS' keyring so it can be used in yagmail "]}, {"name": "yagmail.__main__.main", "asynchronous": false, "params": [], "returns": null, "documentation": ["This is the function that is run from commandline with `yagmail` "]}], "variables": [], "classes": [], "exports": []}, {"name": "yagmail.compat", "documentation": [], "functions": [], "variables": [{"name": "yagmail.compat.PY3", "type": null, "documentation": []}, {"name": "yagmail.compat.text_type", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "yagmail.sender", "documentation": ["when there is a bcc a different message has to be sent to the bcc", "person, to show that they are bcc'ed"], "functions": [], "variables": [], "classes": [{"name": "yagmail.sender.SMTP", "bases": [], "methods": [{"name": "yagmail.sender.SMTP.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "user", "type": null, "default": "..."}, {"name": "password", "type": null, "default": "..."}, {"name": "host", "type": null, "default": "..."}, {"name": "port", "type": null, "default": "..."}, {"name": "smtp_starttls", "type": null, "default": "..."}, {"name": "smtp_ssl", "type": null, "default": "..."}, {"name": "smtp_set_debuglevel", "type": null, "default": "..."}, {"name": "smtp_skip_login", "type": null, "default": "..."}, {"name": "encoding", "type": null, "default": "..."}, {"name": "oauth2_file", "type": null, "default": "..."}, {"name": "soft_email_validation", "type": null, "default": "..."}, {"name": "dkim", "type": null, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.__enter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.__exit__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "exc_type", "type": null, "default": null}, {"name": "exc_val", "type": null, "default": null}, {"name": "exc_tb", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.connection", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.starttls", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.set_logging", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "log_level", "type": null, "default": "..."}, {"name": "file_path_name", "type": null, "default": "..."}], "returns": null, "documentation": ["This function allows to change the logging backend, either output or file as backend\nIt also allows to set the logging level (whether to display only critical/error/info/debug.\nfor example:\n\n```\nyag = yagmail.SMTP()\nyag.set_logging(yagmail.logging.DEBUG)  # to see everything\n```\n\nand:\n\n```\nyagmail.set_logging(yagmail.logging.DEBUG, 'somelocalfile.log')\n```\n\nlastly, a log_level of {py:class}`None` will make sure there is no I/O.\n"]}, {"name": "yagmail.sender.SMTP.prepare_send", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "to", "type": null, "default": "..."}, {"name": "subject", "type": null, "default": "..."}, {"name": "contents", "type": null, "default": "..."}, {"name": "attachments", "type": null, "default": "..."}, {"name": "cc", "type": null, "default": "..."}, {"name": "bcc", "type": null, "default": "..."}, {"name": "headers", "type": null, "default": "..."}, {"name": "prettify_html", "type": null, "default": "..."}, {"name": "message_id", "type": null, "default": "..."}, {"name": "group_messages", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.send", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "to", "type": null, "default": "..."}, {"name": "subject", "type": null, "default": "..."}, {"name": "contents", "type": null, "default": "..."}, {"name": "attachments", "type": null, "default": "..."}, {"name": "cc", "type": null, "default": "..."}, {"name": "bcc", "type": null, "default": "..."}, {"name": "preview_only", "type": null, "default": "..."}, {"name": "headers", "type": null, "default": "..."}, {"name": "prettify_html", "type": null, "default": "..."}, {"name": "message_id", "type": null, "default": "..."}, {"name": "group_messages", "type": null, "default": "..."}], "returns": null, "documentation": ["Use this to send an email with gmail"]}, {"name": "yagmail.sender.SMTP._attempt_send", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "recipients", "type": null, "default": null}, {"name": "msg_strings", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.send_unsent", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Emails that were not being able to send will be stored in {attr}`self.unsent`.\nUse this function to attempt to send these again\n"]}, {"name": "yagmail.sender.SMTP.close", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Close the connection to the SMTP server "]}, {"name": "yagmail.sender.SMTP.login", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP._login", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "password", "type": null, "default": null}], "returns": null, "documentation": ["Login to the SMTP server using password. `login` only needs to be manually run when the\nconnection to the SMTP server was closed by the user."]}, {"name": "yagmail.sender.SMTP.handle_password", "asynchronous": false, "params": [{"name": "user", "type": null, "default": null}, {"name": "password", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.get_oauth_string", "asynchronous": false, "params": [{"name": "user", "type": null, "default": null}, {"name": "oauth2_info", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP._login_oauth2", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "oauth2_info", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "yagmail.sender.SMTP.feedback", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "message", "type": null, "default": "..."}], "returns": null, "documentation": ["Most important function. Please send me feedback :-) "]}, {"name": "yagmail.sender.SMTP.__del__", "asynchronous": false, "params": [{"na