ef": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "no_data_threshold", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "overwrite", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "ocm_batch_size", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "ocm_inference_dtype", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "debug_cache", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "np.ndarray", "xref": {"fqname": "numpy.ndarray", "project": null}, "params": null}, {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "documentation": ["Create a Sentinel-2 mosaic for a specified grid and time range.\n\nThis function generates a mosaic from Sentinel-2 satellite imagery based on the provided\ngrid ID and time range. It can either return the mosaic data and metadata or save it as\na GeoTIFF file.\n\nArgs:\n    grid_id (str): The ID of the grid area for which to create the mosaic (e.g., \"50HMH\").\n    start_year (int): The start year of the time range.\n    start_month (int, optional): The start month of the time range. Defaults to 1 (January).\n    start_day (int, optional): The start day of the time range. Defaults to 1.\n    output_dir (Optional[Union[Path, str]], optional): Directory to save the output GeoTIFF.\n        If None, the mosaic is not saved to disk and is returned instead. Defaults to None.\n    sort_method (str, optional): Method to sort scenes. Options are \"valid_data\", \"oldest\", or \"newest\". Defaults to \"valid_data\".\n    mosaic_method (str, optional): Method to create the mosaic. Options are \"mean\" or \"first\". Defaults to \"mean\".\n    duration_years (int, optional): Duration in years to add to the start date. Defaults to 0.\n    duration_months (int, optional): Duration in months to add to the start date. Defaults to 0.\n    duration_days (int, optional): Duration in days to add to the start date. Defaults to 0.\n    required_bands (List[str], optional): List of required spectral bands.\n        Defaults to [\"B04\", \"B03\", \"B02\", \"B08\"] (Red, Green, Blue, NIR).\n    no_data_threshold (float, optional): Threshold for no data values. Defaults to 0.01.\n    overwrite (bool, optional): Whether to overwrite existing output files. Defaults to True.\n    ocm_batch_size (int, optional): Batch size for OCM inference. Defaults to 1.\n    ocm_inference_dtype (str, optional): Data type for OCM inference. Defaults to \"bf16\".\n    debug_cache (bool, optional): Whether to cache downloads for faster debugging. Defaults to False.\n\nReturns:\n    Union[Tuple[np.ndarray, Dict[str, Any]], Path]: If output_dir is None, returns a tuple\n    containing the mosaic array and metadata dictionary. If output_dir is provided,\n    returns the path to the saved GeoTIFF file.\n\nRaises:\n    Exception: If no scenes are found for the specified grid ID and time range.\n\nNote:\n    - The function uses the STAC API to search for Sentinel-2 scenes.\n    - If 'visual' is included in required_bands, it will be replaced with 'Red', 'Green', 'Blue' in the output.\n    - The time range for scene selection is inclusive of the start date and exclusive of the end date."]}], "variables": [], "classes": [], "exports": []}, {"name": "s2mosaic", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "s2mosaic.__version__", "xref": {"fqname": "s2mosaic.__version__.__version__", "project": null}}, {"name": "s2mosaic.mosaic", "xref": {"fqname": "s2mosaic.coordinator.mosaic", "project": null}}]}, {"name": "s2mosaic.frequent_coverage", "documentation": [], "functions": [{"name": "s2mosaic.frequent_coverage.get_coverage", "asynchronous": false, "params": [{"name": "scenes", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Item", "xref": {"fqname": "pystac.item.Item", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "gpd.GeoDataFrame", "xref": {"fqname": "geopandas.GeoDataFrame", "project": "geopandas"}, "params": null}, "documentation": []}, {"name": "s2mosaic.frequent_coverage.get_raster_coverage", "asynchronous": false, "params": [{"name": "scene_bounds", "type": {"name": "Polygon", "xref": {"fqname": "shapely.geometry.Polygon", "project": null}, "params": null}, "default": null}, {"name": "coverage_gdf", "type": {"name": "GeoDataFrame", "xref": {"fqname": "geopandas.GeoDataFrame", "project": "geopandas"}, "params": null}, "default": null}, {"name": "local_crs", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}, {"name": "resolution", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "s2mosaic.frequent_coverage.get_frequent_coverage", "asynchronous": false, "params": [{"name": "scene_bounds", "type": {"name": "Polygon", "xref": {"fqname": "shapely.geometry.Polygon", "proj