ico plugins.", "Copyright (C) 2020 - 2024 CERN and ENEA", "The Indico plugins are free software; you can redistribute", "them and/or modify them under the terms of the MIT License;", "see the LICENSE file for more details."], "functions": [{"name": "indico_vc_zoom.util._iter_user_identifiers", "asynchronous": false, "params": [{"name": "user", "type": null, "default": null}], "returns": null, "documentation": ["Iterates over all existing user identifiers that can be used with Zoom"]}, {"name": "indico_vc_zoom.util.iter_user_emails", "asynchronous": false, "params": [{"name": "user", "type": null, "default": null}], "returns": null, "documentation": ["Yield all emails of a user that may work with zoom.\n\n```\nparam user\n\nthe  in question\n```\n"]}, {"name": "indico_vc_zoom.util.find_enterprise_email", "asynchronous": false, "params": [{"name": "user", "type": null, "default": null}], "returns": null, "documentation": ["Get the email address of a user that has a zoom account."]}, {"name": "indico_vc_zoom.util.gen_random_password", "asynchronous": false, "params": [], "returns": null, "documentation": ["Generate a random 8-character-long numeric string."]}, {"name": "indico_vc_zoom.util.fetch_zoom_meeting", "asynchronous": false, "params": [{"name": "vc_room", "type": null, "default": null}, {"name": "client", "type": null, "default": "..."}, {"name": "is_webinar", "type": null, "default": "..."}], "returns": null, "documentation": ["Fetch a Zoom meeting from the Zoom API.\n\n```\nparam vc_room\n\nThe  object\n\nparam client\n\na  object, otherwise a fresh one will be created\n\nparam is_webinar\n\nwhether the call concerns a webinar (used to call the correct endpoint)\n```\n"]}, {"name": "indico_vc_zoom.util.update_zoom_meeting", "asynchronous": false, "params": [{"name": "zoom_id", "type": null, "default": null}, {"name": "changes", "type": null, "default": null}, {"name": "is_webinar", "type": null, "default": "..."}], "returns": null, "documentation": ["Update a