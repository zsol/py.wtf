mlEncoder"], "methods": [{"name": "toml.encoder.TomlPreserveCommentEncoder.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "_dict", "type": null, "default": "..."}, {"name": "preserve", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "toml.encoder.TomlPathlibEncoder", "bases": ["TomlEncoder"], "methods": [{"name": "toml.encoder.TomlPathlibEncoder._dump_pathlib_path", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "v", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "toml.encoder.TomlPathlibEncoder.dump_value", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "v", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "toml.decoder", "documentation": [], "functions": [{"name": "toml.decoder._detect_pathlib_path", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "toml.decoder._ispath", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "toml.decoder._getpath", "asynchronous": false, "params": [{"name": "p", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "toml.decoder._strictly_valid_num", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "toml.decoder.load", "asynchronous": false, "params": [{"name": "f", "type": null, "default": null}, {"name": "_dict", "type": null, "default": "..."}, {"name": "decoder", "type": null, "default": "..."}], "returns": null, "documentation": ["Parses named file or files as toml and returns a dictionary\n\nArgs:\n    f: Path to the file to open, array of files to read into single dict\n       or a file descriptor\n    _dict: (optional) Specifies the class of the returned toml dictionary\n    decoder: The decoder to use\n\nReturns:\n    Parsed toml file represented as a dictionary\n\nRaises:\n    TypeError -- When f is invalid type\n    TomlDecodeError: Error while decoding toml\n    IOError / FileNotFoundError -- When an array with no valid (existing)\n    (Python 2 / Python 3)          file paths is passed"]}, {"name": "toml.decoder.loads", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}, {"name": "_dict", "type": null, "default": "..."}, {"name": "decoder", "type": null, "default": "..."}], "returns": null, "documentation": ["Parses string as toml\n\nArgs:\n    s: String to be parsed\n    _dict: (optional) Specifies the class of the returned toml dictionary\n\nReturns:\n    Parsed toml file represented as a dictionary\n\nRaises:\n    TypeError: When a non-string is passed\n    TomlDecodeError: Error while decoding toml"]}, {"name": "toml.decoder._load_date", "asynchronous": false, "params": [{"name": "val", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "toml.decoder._load_unicode_escapes", "asynchronous": false, "params": [{"name": "v", "type": null, "default": null}, {"name": "hexbytes", "type": null, "default": null}, {"name": "prefix", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "toml.decoder._unescape", "asynchronous": false, "params": [{"name": "v", "type": null, "default": null}], "returns": null, "documentation": ["Unescape characters in a TOML string."]}], "variables": [{"name": "toml.decoder._range", "type": null, "documentation": ["noqa: F821"]}, {"name": "toml.decoder.unicode", "type": null, "documentation": []}, {"name": "toml.decoder._range", "type": null, "documentation": []}, {"name":