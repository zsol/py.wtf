on", "type": null, "default": null}, {"name": "num_shifts", "type": null, "default": null}], "returns": null, "documentation": ["Move datetime 1 week in the chosen direction.\nunit is a no-op, to keep the API the same as the day case"]}, {"name": "delorean.dates.move_datetime_year", "asynchronous": false, "params": [{"name": "dt", "type": null, "default": null}, {"name": "direction", "type": null, "default": null}, {"name": "num_shifts", "type": null, "default": null}], "returns": null, "documentation": ["Move datetime 1 year in the chosen direction.\nunit is a no-op, to keep the API the same as the day case"]}, {"name": "delorean.dates.move_datetime_hour", "asynchronous": false, "params": [{"name": "dt", "type": null, "default": null}, {"name": "direction", "type": null, "default": null}, {"name": "num_shifts", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.move_datetime_minute", "asynchronous": false, "params": [{"name": "dt", "type": null, "default": null}, {"name": "direction", "type": null, "default": null}, {"name": "num_shifts", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.move_datetime_second", "asynchronous": false, "params": [{"name": "dt", "type": null, "default": null}, {"name": "direction", "type": null, "default": null}, {"name": "num_shifts", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.datetime_timezone", "asynchronous": false, "params": [{"name": "tz", "type": null, "default": null}], "returns": null, "documentation": ["This method given a timezone returns a localized datetime object."]}, {"name": "delorean.dates.localize", "asynchronous": false, "params": [{"name": "dt", "type": null, "default": null}, {"name": "tz", "type": null, "default": null}], "returns": null, "documentation": ["Given a naive datetime object this method will return a localized\ndatetime object"]}, {"name": "delorean.dates.normalize", "asynchronous": false, "params": [{"name": "dt", "type": null, "default": null}, {"name": "tz", "type": null, "default": null}], "returns": null, "documentation": ["Given a object with a timezone return a datetime object\nnormalized to the proper timezone.\n\nThis means take the give localized datetime and returns the\ndatetime normalized to match the specificed timezone."]}], "variables": [], "classes": [{"name": "delorean.dates.Delorean", "bases": ["object"], "methods": [{"name": "delorean.dates.Delorean.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "datetime", "type": null, "default": "..."}, {"name": "timezone", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__eq__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__lt__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__gt__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__ge__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__le__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__ne__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__add__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__sub__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.__getattr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "name", "type": null, "default": null}], "returns": null, "documentation": ["Implement __getattr__ to call `shift_date` function when function\ncalled does not exist"]}, {"name": "delorean.dates.Delorean._shift_date", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "direction", "type": null, "default": null}, {"name": "unit", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}], "returns": null, "documentation": ["Shift datetime in `direction` in _VALID_SHIFT_DIRECTIONS and by some\nunit in _VALID_SHIFTS and shift that amount by some multiple,\ndefined by by args[0] if it exists"]}, {"name": "delorean.dates.Delorean.timezone", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns a valid tzinfo object associated with\nthe Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1), timezone='UTC')\n    >>> d.timezone\n    <UTC>\n```\n"]}, {"name": "delorean.dates.Delorean.truncate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": ["Truncate the delorian object to the nearest s\n(second, minute, hour, day, month, year)\n\nThis is a destructive method, modifies the internal datetime\nobject associated with the Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1, 12, 10), timezone='US/Pacific')\n    >>> d.truncate('hour')\n    Delorean(datetime=datetime.datetime(2015, 1, 1, 12, 0), timezone='US/Pacific')\n```\n"]}, {"name": "delorean.dates.Delorean.naive", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns a naive datetime object associated with the Delorean\nobject, this method simply converts the localize datetime to UTC\nand removes the tzinfo that is associated with it modifying the Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1), timezone='US/Pacific')\n    >>> d.naive\n    datetime.datetime(2015, 1, 1, 8, 0)\n```\n"]}, {"name": "delorean.dates.Delorean.now", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "timezone", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.utcnow", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.dates.Delorean.midnight", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns midnight for datetime associated with\nthe Delorean object modifying the Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1, 12), timezone='UTC')\n    >>> d.midnight\n    datetime.datetime(2015, 1, 1, 0, 0, tzinfo=<UTC>)\n```\n"]}, {"name": "delorean.dates.Delorean.start_of_day", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns the start of the day for datetime assoicated\nwith the Delorean object, modifying the Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1, 12), timezone='UTC')\n    >>> d.start_of_day\n    datetime.datetime(2015, 1, 1, 0, 0, tzinfo=<UTC>)\n```\n"]}, {"name": "delorean.dates.Delorean.end_of_day", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns the end of the day for the datetime\nassocaited with the Delorean object, modifying the Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1, 12), timezone='UTC')\n    >>> d.end_of_day\n    datetime.datetime(2015, 1, 1, 23, 59, 59, 999999, tzinfo=<UTC>)\n```\n"]}, {"name": "delorean.dates.Delorean.shift", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "timezone", "type": null, "default": null}], "returns": null, "documentation": ["Shifts the timezone from the current timezone to the specified timezone associated with the Delorean object,\nmodifying the Delorean object and returning the modified object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1), timezone='US/Pacific')\n    >>> d.shift('UTC')\n    Delorean(datetime=datetime.datetime(2015, 1, 1, 8, 0), timezone='UTC')\n```\n"]}, {"name": "delorean.dates.Delorean.epoch", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns the total seconds since epoch associated with\nthe Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1), timezone='US/Pacific')\n    >>> d.epoch\n    1420099200.0\n```\n"]}, {"name": "delorean.dates.Delorean.date", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns the actual date object associated with\nthe Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1, 12, 15), timezone='US/Pacific')\n    >>> d.date\n    datetime.date(2015, 1, 1)\n```\n"]}, {"name": "delorean.dates.Delorean.datetime", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns the actual datetime object associated with\nthe Delorean object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1, 12, 15), timezone='UTC')\n    >>> d.datetime\n    datetime.datetime(2015, 1, 1, 12, 15, tzinfo=<UTC>)\n```\n"]}, {"name": "delorean.dates.Delorean.replace", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Returns a new Delorean object after applying replace on the\nexisting datetime object.\n\n```\n.. testsetup::\n\n    from datetime import datetime\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1, 12, 15), timezone='UTC')\n    >>> d.replace(hour=8)\n    Delorean(datetime=datetime.datetime(2015, 1, 1, 8, 15), timezone='UTC')\n```\n"]}, {"name": "delorean.dates.Delorean.humanize", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Humanize relative to now:\n\n```\n.. testsetup::\n\n    from datetime import timedelta\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> past = Delorean.utcnow() - timedelta(hours=1)\n    >>> past.humanize()\n    'an hour ago'\n```\n"]}, {"name": "delorean.dates.Delorean.format_datetime", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "format", "type": null, "default": "..."}, {"name": "locale", "type": null, "default": "..."}], "returns": null, "documentation": ["Return a date string formatted to the given pattern.\n\n```\n.. testsetup::\n\n    from delorean import Delorean\n```\n\n```\n.. doctest::\n\n    >>> d = Delorean(datetime(2015, 1, 1, 12, 30), timezone='US/Pacific')\n    >>> d.format_datetime(locale='en_US')\n    u'Jan 1, 2015, 12:30:00 PM'\n\n    >>> d.format_datetime(format='long', locale='de_DE')\n    u'1. Januar 2015 12:30:00 -0800'\n```\n\n```\nparam format\n\none of \"full\", \"long\", \"medium\", \"short\", or a custom datetime pattern\n\nparam locale\n\na locale identifier\n```\n"]}], "class_variables": [{"name": "delorean.dates.Delorean._VALID_SHIFT_DIRECTIONS", "type": null, "documentation": []}, {"name": "delorean.dates.Delorean._VALID_SHIFT_UNITS", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["The class `Delorean <Delorean>` object. This method accepts naive\ndatetime objects, with a string timezone."]}], "exports": []}, {"name": "tests.delorean_tests", "documentation": ["Testing for Delorean", "!/usr/bin/env python", "-*- coding: utf-8 -*-"], "functions": [], "variables": [{"name": "tests.delorean_tests.UTC", "type": null, "documentation": []}, {"name": "test