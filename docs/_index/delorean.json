me_year", "project": null}}, {"name": "delorean.normalize", "xref": {"fqname": "delorean.dates.normalize", "project": null}}, {"name": "delorean.now", "xref": {"fqname": "delorean.interface.now", "project": null}}, {"name": "delorean.parse", "xref": {"fqname": "delorean.interface.parse", "project": null}}, {"name": "delorean.range_daily", "xref": {"fqname": "delorean.interface.range_daily", "project": null}}, {"name": "delorean.range_hourly", "xref": {"fqname": "delorean.interface.range_hourly", "project": null}}, {"name": "delorean.range_monthly", "xref": {"fqname": "delorean.interface.range_monthly", "project": null}}, {"name": "delorean.range_yearly", "xref": {"fqname": "delorean.interface.range_yearly", "project": null}}, {"name": "delorean.SA", "xref": {"fqname": "dateutil.rrule.SA", "project": null}}, {"name": "delorean.SECONDLY", "xref": {"fqname": "dateutil.rrule.SECONDLY", "project": null}}, {"name": "delorean.stops", "xref": {"fqname": "delorean.interface.stops", "project": null}}, {"name": "delorean.SU", "xref": {"fqname": "dateutil.rrule.SU", "project": null}}, {"name": "delorean.TH", "xref": {"fqname": "dateutil.rrule.TH", "project": null}}, {"name": "delorean.TU", "xref": {"fqname": "dateutil.rrule.TU", "project": null}}, {"name": "delorean.utcnow", "xref": {"fqname": "delorean.interface.utcnow", "project": null}}, {"name": "delorean.WE", "xref": {"fqname": "dateutil.rrule.WE", "project": null}}, {"name": "delorean.WEEKLY", "xref": {"fqname": "dateutil.rrule.WEEKLY", "project": null}}, {"name": "delorean.YEARLY", "xref": {"fqname": "dateutil.rrule.YEARLY", "project": null}}]}, {"name": "version", "documentation": [], "functions": [], "variables": [{"name": "version.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "delorean.interface", "documentation": [], "functions": [{"name": "delorean.interface.parse", "asynchronous": false, "params": [{"name": "datetime_str", "type": null, "default": null}, {"name": "timezone", "type": null, "default": "..."}, {"name": "dayfirst", "type": null, "default": "..."}, {"name": "yearfirst", "type": null, "default": "..."}], "returns": null, "documentation": ["Parses a datetime string and returns a `Delorean` object.\n\n```\nparam datetime_str\n\nThe string to be interpreted into a  object.\n\nparam timezone\n\nPass this parameter and the returned Delorean object will be normalized to this timezone. Any\noffsets passed as part of datetime_str will be ignored.\n\nparam dayfirst\n\nWhether to interpret the first value in an ambiguous 3-integer date (ex. 01/05/09) as the day\n(True) or month (False). If yearfirst is set to True, this distinguishes between YDM and YMD.\n\nparam yearfirst\n\nWhether to interpret the first value in an ambiguous 3-integer date (ex. 01/05/09) as the\nyear. If True, the first number is taken to be the year, otherwise the last number is taken to be the year.\n```\n\n```\n.. testsetup::\n\n    from delorean import Delorean\n    from delorean import parse\n```\n\n```\n.. doctest::\n\n    >>> parse('2015-01-01 00:01:02')\n    Delorean(datetime=datetime.datetime(2015, 1, 1, 0, 1, 2), timezone='UTC')\n```\n\nIf a fixed offset is provided in the datetime_str, it will be parsed and the returned `Delorean` object will store a\n`pytz.FixedOffest` as it's timezone.\n\n```\n.. doctest::\n\n    >>> parse('2015-01-01 00:01:02 -0800')\n    Delorean(datetime=datetime.datetime(2015, 1, 1, 0, 1, 2), timezone=pytz.FixedOffset(-480))\n```\n\nIf the timezone argument is supplied, the returned Delorean object will be in the timezone supplied. Any offsets in\nthe datetime_str will be ignored.\n\n```\n.. doctest::\n\n    >>> parse('2015-01-01 00:01:02 -0500', timezone='US/Pacific')\n    Delorean(datetime=datetime.datetime(2015, 1, 1, 0, 1, 2), timezone='US/Pacific')\n```\n\nIf an unambiguous timezone is detected in the datetime string, a Delorean object with that datetime and\ntimezone will be returned.\n\n```\n.. doctest::\n\n    >>> parse('2015-01-01 00:01:02 PST')\n    Delorean(datetime=datetime.datetime(2015, 1, 1, 0, 1, 2), timezone='America/Los_Angeles')\n```\n\nHowever if the provided timezone is ambiguous, parse will ignore the timezone and return a `Delorean` object in UTC\ntime.\n\n> ```pycon\n> >>> parse('2015-01-01 00:01:02 EST')\n> Delorean(datetime=datetime.datetime(2015, 1, 1, 0, 1, 2), timezone='UTC')\n> ```\n"]}, {"name": "delorean.interface.range_daily", "asynchronous": false, "params": [{"name": "start", "type": null, "default": "..."}, {"name": "stop", "type": null, "default": "..."}, {"name": "timezone", "type": null, "default": "..."}, {"name": "count", "type": null, "default": "..."}], "returns": null, "documentation": ["This an alternative way to generating sets of Delorean objects with\nDAILY stops"]}, {"name": "delorean.interface.range_hourly", "asynchronous": false, "params": [{"name": "start", "type": null, "default": "..."}, {"name": "stop", "type": null, "default": "..."}, {"name": "timezone", "type": null, "default": "..."}, {"name": "count", "type": null, "default": "..."}], "returns": null, "documentation": ["This an alternative way to generating sets of Delorean objects with\nHOURLY stops"]}, {"name": "delorean.interface.range_monthly", "asynchronous": false, "params": [{"name": "start", "type": null, "default": "..."}, {"name": "stop", "type": null, "default": "..."}, {"name": "timezone", "type": null, "default": "..."}, {"name": "count", "type": null, "default": "..."}], "returns": null, "documentation": ["This an alternative way to generating sets of Delorean objects with\nMONTHLY stops"]}, {"name": "delorean.interface.range_yearly", "asynchronous": false, "params": [{"name": "start", "type": null, "default": "..."}, {"name": "stop", "type": null, "default": "..."}, {"name": "timezone", "type": null, "default": "..."}, {"name": "count", "type": null, "default": "..."}], "returns": null, "documentation": ["This an alternative way to generating sets of Delorean objects with\nYEARLY stops"]}, {"name": "delorean.interface.stops", "asynchronous": false, "params": [{"name": "freq", "type": null, "default": null}, {"name": "interval", "type": null, "default": "..."}, {"name": "count", "type": null, "default": "..."}, {"name": "wkst", "type": null, "default": "..."}, {"name": "bysetpos", "type": null, "default": "..."}, {"name": "bymonth", "type": null, "default": "..."}, {"name": "bymonthday", "type": null, "default": "..."}, {"name": "byyearday", "type": null, "default": "..."}, {"name": "byeaster", "type": null, "default": "..."}, {"name": "byweekno", "type": null, "default": "..."}, {"name": "byweekday", "type": null, "default": "..."}, {"name": "byhour", "type": null, "default": "..."}, {"name": "byminute", "type": null, "default": "..."}, {"name": "bysecond", "type": null, "default": "..."}, {"name": "timezone", "type": null, "default": "..."}, {"name": "start", "type": null, "default": "..."}, {"name": "stop", "type": null, "default": "..."}], "returns": null, "documentation": ["This will create a list of delorean objects the apply to\nsetting possed in."]}, {"name": "delorean.interface.epoch", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "delorean.interface.flux", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "delorean.interface.utcnow", "asynchronous": false, "params": [], "returns": null, "documentation": ["Return a Delorean object for the current UTC date and time, setting the timezone to UTC."]}, {"name": "delorean.interface.now", "asynchronous": false, "params": [], "returns": null, "documentation": ["Return a Delorean object for the current local date and time, setting the timezone to the local timezone of the\ncaller."]}], "variables": [], "classes": [], "exports": []}, {"name": "delorean.dates", "documentation": [], "functions": [{"name": "delorean.dates.get_total_second", "asynchronous": false, "