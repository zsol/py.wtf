f the subclass."]}], "classes": [{"name": "registrable.Registrable", "bases": [], "methods": [{"name": "registrable.Registrable.register", "asynchronous": false, "params": [{"name": "cls", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}, "default": null}, {"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "override", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "hooks", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "HookType", "xref": {"fqname": "HookType", "project": null}, "params": null}]}]}, "default": "..."}], "returns": null, "documentation": ["Class decorator for registering a subclass.\n\n# Parameters\n\nname\n\n: The name to register the subclass under.\n\noverride\n\n: If `name` is already registered a {class}`registrable.exceptions.RegistrationError` will be raised\n  unless this is set to `True`.\n\nhooks\n\n: Hooks to run when the subclass is registered.\n\n# Raises\n\nRegistrationError\n"]}, {"name": "registrable.Registrable.hook", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "hook", "type": {"name": "HookType", "xref": {"fqname": "HookType", "project": null}, "params": null}, "default": null}], "returns": null, "documentation": ["Function decorator for adding a default hook to a registrable base class."]}, {"name": "registrable.Registrable.by_name", "asynchronous": false, "params": [{"name": "cls", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}, "default": null}, {"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}, "documentation": ["Get a subclass by its registered name, or its fully qualified class name.\n\n# Parameters\n\nname : `str`\n\n# Returns\n\nType[T]\n\n: The subclass registered under `name`.\n\n# Raises\n\nRegistrationError\n\n: If name is not a registered subclass or valid fully qualified class name.\n"]}, {"name": "registrable.Registrable.list_available", "asynchronous": false, "params": [{"name": "cls", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["List all registered subclasses."]}, {"name": "registrable.Registrable.is_registered", "asynchronous": false, "params": [{"name": "cls", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}, "default": null}, {"name": "name", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "documentation": ["Returns True if `name` is a registered name.\n"]}, {"name": "registrable.Registrable.iter_registered", "asynchronous": false, "params": [{"name": "cls", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "Iterable", "xref": {"fqname": "typing.Iterable", "project": "--std--"}, "params": [{"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}]}]}, "documentation": ["Iterate through the registered names and subclasses."]}], "class_variables": [{"name": "registrable.Registrable._registry", "type": {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": null}, {"name": "Dict", "xref": {"fqname": "typing.Dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": null}]}]}, "documentation": []}, {"name": "registrable.Registrable._hooks", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "HookType", "xref": {"fqname": "HookType", "project": null}, "params": null}]}]}, "documentation": []}, {"name": "registrable.Registrable.default_implementation", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Adapted from [allennlp.common.registrable](https://github.com/allenai/allennlp/blob/master/allennlp/common/registrable.py).\n\nAny class that inherits from `Registrable` gains access to a named registry for its\nsubclasses. To register them, just decorate them with the classmethod\n`@BaseClass.register(name)`.\n\nAfter which you can call `BaseClass.list_available()` to get the keys for the\nregistered subclasses, and `BaseClass.by_name(name)` to get the corresponding subclass.\nNote that the registry stores the subclasses themselves; not class instances.\n\nYou can specify a default by setting `BaseClass.default_implementation`.\nIf it is set, it will be the first element of `list_available()`.\n\nNote that if you use this class to implement a new `Registrable` abstract class,\nyou must ensure that all subclasses of the abstract class are loaded when the module is\nloaded, because the subclasses register themselves in their respective files. You can\nachieve this by having the abstract class and all subclasses in the `__init__.py` of the\nmodule in which they reside (as this causes any import of either the abstract class or\na subclass to load all other subclasses and the abstract class).\n"]}], "exports": [{"name": "registrable.Callable", "xref": {"fqname": "typing.Callable", "project": null}}, {"name": "registrable.defaultdict", "xref": {"fqname": "collections.defaultdict", "project": null}}, {"name": "registrable.Dict", "xref": {"fqname": "typing.Dict", "project": null}}, {"name": "registrable.Iterable", "xref": {"fqname": "typing.Iterable", "project": null}}, {"name": "registrable.List", "xref": {"fqname": "typing.List", "project": null}}, {"name": "registrable.Optional", "xref": {"fqname": "typing.Optional", "project": null}}, {"name": "registrable.RegistrationError", "xref": {"fqname": "registrable.exceptions.RegistrationError", "project": null}}, {"name": "registrable.Tuple", "xref": {"fqname": "typing.Tuple", "project": null}}, {"name": "registrable.Type", "xref": {"fqname": "typing.Type", "project": null}}, {"name": "registrable.TypeVar", "xref": {"fqname": "typing.TypeVar", "project": null}}, {"name": "registrable.warn", "xref": {"fqname": "warnings.warn", "project": null}}]}]}