-io/esse) for additional context regarding the data schemas used here.\n\nUseful commands for development:\n\n```bash\n# run linter without persistence\nnpm run lint\n\n# run linter and save edits\nnpm run lint:fix\n\n# compile the library\nnpm run transpile\n\n# run tests\nnpm run test\n```\n"], "modules": [{"name": "mat3ra.code.constants", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "mat3ra.code.constants.Coefficients", "bases": [], "methods": [], "class_variables": [{"name": "mat3ra.code.constants.Coefficients.EV_TO_RY", "type": null, "documentation": []}, {"name": "mat3ra.code.constants.Coefficients.BOHR_TO_ANGSTROM", "type": null, "documentation": []}, {"name": "mat3ra.code.constants.Coefficients.ANGSTROM_TO_BOHR", "type": null, "documentation": []}, {"name": "mat3ra.code.constants.Coefficients.EV_A_TO_RY_BOHR", "type": null, "documentation": []}, {"name": "mat3ra.code.constants.Coefficients._c", "type": null, "documentation": ["speed of light, m/s"]}, {"name": "mat3ra.code.constants.Coefficients._mu0", "type": null, "documentation": ["permeability of vacuum"]}, {"name": "mat3ra.code.constants.Coefficients._eps0", "type": null, "documentation": ["permittivity of vacuum"]}, {"name": "mat3ra.code.constants.Coefficients._Grav", "type": null, "documentation": ["gravitational constant"]}, {"name": "mat3ra.code.constants.Coefficients._hplanck", "type": null, "documentation": ["Planck constant, J s"]}, {"name": "mat3ra.code.constants.Coefficients._hbar", "type": null, "documentation": ["Planck constant / 2pi, J s"]}, {"name": "mat3ra.code.constants.Coefficients._e", "type": null, "documentation": ["elementary charge"]}, {"name": "mat3ra.code.constants.Coefficients._me", "type": null, "documentation": ["electron mass"]}, {"name": "mat3ra.code.constants.Coefficients._mp", "type": null, "documentation": ["proton mass"]}, {"name": "mat3ra.code.constants.Coefficients._Nav", "type": null, "documentation": ["Avogadro number"]}, {"name": "mat3r