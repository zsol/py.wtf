/genascii)\n\n## Install\n\n```sh\npip install genascii\n```\n\n## Usage\n\nImage to ASCII text:\n\n```sh\npython -m genascii img2txt --input /path/to/image.jpg --output /path/to/output.txt\n```\n\nImage to ASCII image:\n\n```sh\npython -m genascii img2img --input /path/to/image.jpg --output /path/to/output.jpg\n```\n\nVideo to ASCII video:\n\n```sh\npython -m genascii video2video --input /path/to/image.mp4 --output /path/to/output.mp4\n```\n"], "modules": [{"name": "genascii.main", "documentation": ["!/usr/bin/env python3"], "functions": [{"name": "genascii.main.make_arg_parser", "asynchronous": false, "params": [{"name": "argv", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "genascii.main.make_txt_parser", "asynchronous": false, "params": [{"name": "subparsers", "type": {"name": "argparse._SubParsersAction", "xref": {"fqname": "argparse._SubParsersAction", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "argparse.ArgumentParser", "xref": {"fqname": "argparse.ArgumentParser", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "genascii.main.make_img_parser", "asynchronous": false, "params": [{"name": "subparsers", "type": {"name": "argparse._SubParsersAction", "xref": {"fqname": "argparse._SubParsersAction", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "argparse.ArgumentParser", "xref": {"fqname": "argparse.ArgumentParser", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "genascii.main.make_video_parser", "asynchronous": false, "params": [{"name": "subparsers", "type": {"name": "argparse._SubParsersAction", "xref": {"fqname": "argparse._SubParsersAction", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "argparse.ArgumentP