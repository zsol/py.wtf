TS='\n[\n  {\n    \"id\": \"i@example.com\",\n    \"name\": \"Name\",\n    \"password\": \"p4ssw0rd\",\n    \"subject\": \"Sent by NoneBot\",\n    \"imap\": {\n      \"host\": \"imap.example.com\",\n      \"port\": 993,\n      \"tls\": true\n    },\n    \"smtp\": {\n      \"host\": \"smtp.example.com\",\n      \"port\": 465,\n      \"tls\": true\n    }\n  }\n]\n'\n```\n"], "modules": [{"name": "nonebot.adapters.mail.model", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "nonebot.adapters.mail.model.User", "bases": ["BaseModel"], "methods": [], "class_variables": [{"name": "nonebot.adapters.mail.model.User.id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nonebot.adapters.mail.model.User.name", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "nonebot.adapters.mail.model.Mail", "bases": ["BaseModel"], "methods": [], "class_variables": [{"name": "nonebot.adapters.mail.model.Mail.id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "nonebot.adapters.mail.model.Mail.sender", "type": {"name": "User", "xref": {"fqname": "nonebot.adapters.mail.model.User", "project": null}, "params": null}, "documentation": []}, {"name": "nonebot.adapters.mail.model.Mail.recipients_to", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "User", "xref": {"fqname": "nonebot.adapters.mail.model.User", "project": null}, "params": null}]}, "documentation": []}, {"name": "nonebot.adapters.mail.model.Mail.recipients_cc", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "