eward, it has to be called with a list of\n{class}`SensorInformation` objects:\n\n```\nreward = MyReward()\nvalue = reward([SensorInformation(...), SensorInformation(...)])\n```\n\n# Parameters\n\nparams: dict\n\n: A dict that can be used to pass configuration parameters to\n  the reward instance.\n"]}], "exports": []}, {"name": "midas_palaestrai.rewards", "documentation": [], "functions": [{"name": "midas_palaestrai.rewards.gauss_norm", "asynchronous": false, "params": [{"name": "raw_value", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}, {"name": "mu", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "sigma", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "c", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "a", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}], "variables": [{"name": "midas_palaestrai.rewards.LOG", "type": null, "documentation": []}], "classes": [{"name": "midas_palaestrai.rewards.NoExtGridHealthReward", "bases": ["Reward"], "methods": [{"name": "midas_palaestrai.rewards.NoExtGridHealthReward.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "**params", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "midas_palaestrai.rewards.NoExtGridHealthReward.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "state", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}], "