qname": "palaestrai.agent.RewardInformation", "project": null}, "params": null}]}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Standard extended grid state reward\n\nThis reward tries to give a complete overview over the current health of\na MIDAS power grid.\nIt is a *vectorized* reward, meaning that it does not simply provide one\nvalue, but rather a vector of different values.\nThe difference between this reward and the agent's sensors is that the\n*ExtendedGridHealthReward* provides complete information, whereas an\nagent's sensors can be limited in score.\nIt encompasses the following values:\n\n**Voltage Band:**\n\n- `vm_pu-min`\n- `vm_pu-max`\n- `vm_pu-mean`\n- `vm_pu-median`\n- `vm_pu-std`\n\n**Line Loads:**\n\n- `lineload-min`\n- `lineload-max`\n- `lineload-mean`\n- `lineload-median`\n- `lineload-std`\n\n**Bus Connection Status:**\n\n- `num_in_service`\n- `num_out_if_service`\n\nAll values are provided as separate ::`RewardInformation` objects with the\ngiven ID.\n"]}, {"name": "midas_palaestrai.rewards.AllesDestroyAllPire2RewardIchWeissNicht", "bases": ["Reward"], "methods": [{"name": "midas_palaestrai.rewards.AllesDestroyAllPire2RewardIchWeissNicht.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "reward_value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "small_penalty_value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "large_penalty_value", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": []}, {"name": "midas_palaestrai.rewards.AllesDestroyAllPire2RewardIchWeissNicht.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "state", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "SensorInformation", "xref": {"fqname": "palaestrai.agent.SensorInformation", "project": null}, "params": null}]}, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "RewardInformation", "xref": {"fqname": "palaestrai.agent.RewardInformation", "project": null}, "params": null}]}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["This is a reward for classic ARL.\n\nDespite its unique name, this is a serious reward for the use\nwith a constrainted power grid model from MIDAS.\n\nIt checks all available power grid sensors and creates a score\nbased on the *Technische Anschlussregeln Mittelspannung* (TAR-MS).\n\nEvery component in a healthy state gives one point while each\ncomponent that is out of its usual operation state gives ten minus\npoints.\n\nAdditionally, this reward includes everything from the\n{class}`ExtendedGridHealthReward` and can be used instead of that\nreward.\n"]}, {"name": "midas_palaestrai.rewards.RetroPsiReward", "bases": ["Reward"], "methods": [{"name": "midas_palaestrai.rewards.RetroPsiReward.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "state", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "SensorInformation", "xref": {"fqname": "palaestrai.agent.SensorInformation", "project": null}, "params": null}]}, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "RewardInformation", "xref": {"fqname": "palaestrai.agent.Re