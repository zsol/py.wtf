or.ansicolor.make_func", "asynchronous": false, "params": [{"name": "color", "type": null, "default": null}], "returns": null, "documentation": ["Define coloring shorthands"]}, {"name": "ansicolor.ansicolor.get_highlighter", "asynchronous": false, "params": [{"name": "colorid", "type": null, "default": null}], "returns": null, "documentation": ["Map a color index to a highlighting color.\n\n```\nparam int colorid\n\nThe index.\n\nrtype\n\n```\n", "Coloring functions"]}, {"name": "ansicolor.ansicolor.get_code", "asynchronous": false, "params": [{"name": "color", "type": null, "default": null}, {"name": "bold", "type": null, "default": "..."}, {"name": "reverse", "type": null, "default": "..."}], "returns": null, "documentation": ["Returns the escape code for styling with the given color,\nin bold and/or reverse.\n\n```\nparam color\n\nThe color to use.\n\ntype color\n\n class\n\nparam bool bold\n\nWhether to mark up in bold.\n\nparam bool reverse\n\nWhether to mark up in reverse video.\n\nrtype\n\nstring\n```\n"]}, {"name": "ansicolor.ansicolor.get_code_v2", "asynchronous": false, "params": [{"name": "color", "type": null, "default": null}, {"name": "bold", "type": null, "default": "..."}, {"name": "reverse", "type": null, "default": "..."}, {"name": "underline", "type": null, "default": "..."}, {"name": "blink", "type": null, "default": "..."}], "returns": null, "documentation": ["Returns the escape code for styling with the given color,\nin bold and/or reverse.\n\n```\nparam color\n\nThe color to use.\n\ntype color\n\n class\n\nparam bool bold\n\nWhether to mark up in bold.\n\nparam bool underline\n\nWhether to mark up in underline.\n\nparam bool blink\n\nWhether to mark up in blink.\n\nparam bool reverse\n\nWhether to mark up in reverse video.\n\nrtype\n\nstring\n```\n"]}, {"name": "ansicolor.ansicolor.colorize", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}, {"name": "color", "type": null, "default": null}, {"name": "bold", "type": null, "default": "..."}, {"name": "reverse", "type": null, "default": "..."}, {"name": "start", "type": null, "default": "..."}, {"name": "end", "type": null, "default": "..."}], "returns": null, "documentation": ["Colorize a string with the color given.\n\n```\nparam string s\n\nThe string to colorize.\n\nparam color\n\nThe color to use.\n\ntype color\n\n class\n\nparam bool bold\n\nWhether to mark up in bold.\n\nparam bool reverse\n\nWhether to mark up in reverse video.\n\nparam int start\n\nIndex at which to start coloring.\n\nparam int end\n\nIndex at which to end coloring.\n\nrtype\n\nstring\n```\n"]}, {"name": "ansicolor.ansicolor.colorize_v2", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}, {"name": "color", "type": null, "default": null}, {"name": "bold", "type": null, "default": "..."}, {"name": "reverse", "type": null, "default": "..."}, {"name": "underline", "type": null, "default": "..."}, {"name": "blink", "type": null, "default": "..."}, {"name": "start", "type": null, "default": "..."}, {"name": "end", "type": null, "default": "..."}], "returns": null, "documentation": ["Colorize a string with the color given.\n\n```\nparam string s\n\nThe string to colorize.\n\nparam color\n\nThe color to use.\n\ntype color\n\n class\n\nparam bool bold\n\nWhether to mark up in bold.\n\nparam bool reverse\n\nWhether to mark up in reverse video.\n\nparam bool blink\n\nWhether to mark up in blink.\n\nparam bool reverse\n\nWhether to mark up in reverse video.\n\nparam int start\n\nIndex at which to start coloring.\n\nparam int end\n\nIndex at which to end coloring.\n\nrtype\n\nstring\n```\n"]}, {"name": "ansicolor.ansicolor.wrap_string", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}, {"name": "pos", "type": null, "default": null}, {"name": "color", "type": null, "default": null}, {"name": "bold", "type": null, "default": "..."}, {"name": "reverse", "type": null, "default": "..."}], "returns": null, "documentation": ["Colorize the string up to a position.\n\n```\nparam string s\n\nThe string to colorize.\n\nparam int pos\n\nThe position at which to stop.\n\nparam color\n\nThe color to use.\n\ntype color\n\n class\n\nparam bool bold\n\nWhether to mark up in bold.\n\nparam bool reverse\n\nWhether to mark up in reverse video.\n\nrtype\n\nstring\n```\n\n:::{deprecated} 0.2.2 This function has been deprecated in favor of :func:`colorize`.\n:::\n"]}, {"name": "ansicolor.ansicolor.highlight_string", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}, {"name": "*spanlists", "type": null, "default": null}, {"name": "**kw", "type": null, "default": null}], "returns": null, "documentation": ["Highlight spans in a string using a list of (begin, end) pairs. Each\nlist is treated as a layer of highlighting. Up to four layers of\nhighlighting are supported.\n\n```\nparam string s\n\nThe string to highlight\n\nparam list spanlists\n\nA list of tuples on the form [(begin, end)*]*\n\nparam kw\n\nMay include: , , ,  and \n\nrtype\n\nstring\n```\n\n:::{deprecated} 0.2.3 The `color` parameter has been deprecated in favor of `colors`.\n:::\n"]}, {"name": "ansicolor.ansicolor.colordiff", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "color_x", "type": null, "default": "..."}, {"name": "color_y", "type": null, "default": "..."}, {"name": "debug", "type": null, "default": "..."}], "returns": null, "documentation": ["Formats a diff of two strings using the longest common subsequence by\nhighlighting characters that differ between the strings.\n\nReturns the strings `x` and `y` with highlighting.\n\n```\nparam string x\n\nThe first string.\n\nparam string y\n\nThe second string.\n\nparam color_x\n\nThe color to use for the first string.\n\ntype color_x\n\n class\n\nparam color_y\n\nThe color to use for the second string.\n\ntype color_y\n\n class\n\nparam bool debug\n\nWhether to print debug output underway.\n\nrtype\n\ntuple\n```\n"]}, {"name": "ansicolor.ansicolor.justify_formatted", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}, {"name": "justify_func", "type": null, "default": null}, {"name": "width", "type": null, "default": null}], "returns": null, "documentation": ["Justify a formatted string to a width using a function\n(eg. `string.ljust`).\n\n```\nparam string s\n\nThe formatted string.\n\nparam justify_func\n\nThe justify function.\n\nparam int width\n\nThe width at which to justify.\n\nrtype\n\nstring\n```\n"]}, {"name": "ansicolor.ansicolor.strip_escapes", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": ["Strips escapes from the string.\n\n```\nparam string s\n\nThe string.\n\nrtype\n\nstring\n```\n"]}, {"name": "ansicolor.ansicolor.set_term_title", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": ["Set the title of a terminal window.\n\n:param string s: The title.", "Output functions"]}, {"name": "ansicolor.ansicolor.write_to", "asynchronous": false, "params": [{"name": "target", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "ansicolor.ansicolor.write_out", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": ["Write a string to `sys.stdout`, strip escapes if output is a pipe.\n\n```\nparam string s\n\nThe title.\n```\n"]}, {"name": "ansicolor.ansicolor.write_err", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": ["Write a string to `sys.stderr`, strip escapes if output is a pipe.\n\n```\nparam string s\n\nThe title.\n```\n"]}], "variables": [{"name": "ansicolor.ansicolor._disabled", "type": null, "documentation": []}, {"name": "ansicolor.ansicolor.highlight