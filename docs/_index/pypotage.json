age\n````python\nimport pypotage\nimport logging\n\n@pypotage.prepare\ndef logger():\n    logging.basicConfig(level=logging.DEBUG)\n    return logging.getLogger(__name__)\n\npypotage.cook(logging.Logger).take_out().info(\"Hello World!\")\n````\n\n#### Using classes\n````python\nimport pypotage\n\nclass A:\n    def __init__(self):\n        ...\n\n@pypotage.prepare\nclass B(A):\n    def __init__(self):\n        ...\n\npypotage.cook(A).take_out()  # returns an instance of B\n````\n"], "modules": [{"name": "pypotage.utils", "documentation": [], "functions": [{"name": "pypotage.utils.traverse_subclasses", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "pypotage.utils._B", "type": null, "documentation": []}], "classes": [{"name": "pypotage.utils.Priority", "bases": ["IntEnum"], "methods": [], "class_variables": [{"name": "pypotage.utils.Priority.LAST", "type": null, "documentation": []}, {"name": "pypotage.utils.Priority.BEFORE_LAST", "type": null, "documentation": []}, {"name": "pypotage.utils.Priority.MIDDLE", "type": null, "documentation": []}, {"name": "pypotage.utils.Priority.AFTER_FIRST", "type": null, "documentation": []}, {"name": "pypotage.utils.Priority.FIRST", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pypotage.utils.Priorized", "bases": [], "methods": [{"name": "pypotage.utils.Priorized.sort", "asynchronous": false, "params": [{"name": "line", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "_B", "xref": {"fqname": "_B", "project": null}, "params": null}]}, "default": null}, {"name": "reverse", "type": null, "default": "..."}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "_B", "xref": {"fqname": "_B", "project": null}, "params": null}]}, "documentation": []}, {"name": "pyp