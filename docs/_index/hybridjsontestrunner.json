tion": []}, {"name": "autograder_utils.JSONTestResult.JSONTestResult.getLeaderboardData", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "autograder_utils.JSONTestResult.JSONTestResult.getImageData", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "autograder_utils.JSONTestResult.JSONTestResult.startTest", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "autograder_utils.JSONTestResult.JSONTestResult.getOutput", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "autograder_utils.JSONTestResult.JSONTestResult.buildResult", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test", "type": null, "default": null}, {"name": "err", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "autograder_utils.JSONTestResult.JSONTestResult.buildLeaderboardEntry", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "autograder_utils.JSONTestResult.JSONTestResult.processResult", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test", "type": null, "default": null}, {"name": "err", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "autograder_utils.JSONTestResult.JSONTestResult.addSuccess", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "test", "ty