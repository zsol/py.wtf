lude:\n\n- Map dimensions and tile properties\n- Settlement hierarchy and attributes \n- Vendor inventories and properties\n- Cargo and vehicle details\n- Special map markers (highlights/lowlights)\n\nThe deep comparison helps catch any data loss or corruption that might occur during serialization."], "functions": [{"name": "test.test_basic_map_pack_unpack.compare_none_is_0", "asynchronous": false, "params": [{"name": "a", "type": null, "default": null}, {"name": "b", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "test.test_basic_map_pack_unpack.test_map_roundtrip", "asynchronous": false, "params": [{"name": "test_map_json_1", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "df_lib.map_struct", "documentation": ["SPDX-FileCopyrightText: 2023-present Oori Data <info@oori.dev>", "SPDX-License-Identifier: UNLICENSED", "df_lib.map_struct"], "functions": [{"name": "df_lib.map_struct.process_uuid", "asynchronous": false, "params": [{"name": "uuid_val", "type": {"name": "str | UUID | None", "xref": null, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Helper function to handle UUID fields"]}, {"name": "df_lib.map_struct.pack_string", "asynchronous": false, "params": [{"name": "s", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "length", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}, "documentation": ["Pack a string into fixed-length bytes with UTF-8 encoding"]}, {"name": "df_lib.map_struct.serialize_cargo", "asynchronous": false, "params": [{"name": "cargo", "type": {"name": "dict", "xref": {"fqn