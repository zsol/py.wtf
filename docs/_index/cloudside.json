"cloudside.ncdc.cooptxt", "type": null, "documentation": []}, {"name": "cloudside.ncdc.summary", "type": null, "documentation": []}, {"name": "cloudside.ncdc.pct_avail", "type": null, "documentation": []}, {"name": "cloudside.ncdc.pct_avail", "type": null, "documentation": []}, {"name": "cloudside.ncdc.pct_avail_grid", "type": null, "documentation": []}, {"name": "cloudside.ncdc.fig", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "cloudside.viz", "documentation": [], "functions": [{"name": "cloudside.viz._resampler", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "col", "type": null, "default": null}, {"name": "freq", "type": null, "default": null}, {"name": "how", "type": null, "default": "..."}, {"name": "fillna", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cloudside.viz._plotter", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "col", "type": null, "default": null}, {"name": "ylabel", "type": null, "default": null}, {"name": "freq", "type": null, "default": "..."}, {"name": "how", "type": null, "default": "..."}, {"name": "ax", "type": null, "default": "..."}, {"name": "downward", "type": null, "default": "..."}, {"name": "fillna", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cloudside.viz.hyetograph", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "col", "type": null, "default": "..."}, {"name": "freq", "type": null, "default": "..."}, {"name": "ax", "type": null, "default": "..."}, {"name": "downward", "type": null, "default": "..."}], "returns": null, "documentation": ["Plot showing rainfall depth over time.\n\nParameters\n----------\ndataframe : pandas.DataFrame\n    Must have a datetime index.\ncol : string, optional (default = 'precip')\n    The name of the column in *dataframe* that contains the\n    rainall series.\nfreq : str, optional (default = 'hourly')\n    The frequency to which the rainfall depth should be\n    accumulated.\nax : matplotlib.Axes object, optional\n    The Axes on which the plot will be placed. If not provided,\n    a new Figure and Axes will be created.\ndownward : bool, optional (default = True)\n    Inverts the y-axis to show the rainfall depths \"falling\"\n    from the top.\n\nReturns\n-------\nfig : matplotlib.Figure"]}, {"name": "cloudside.viz.psychromograph", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "col", "type": null, "default": "..."}, {"name": "freq", "type": null, "default": "..."}, {"name": "how", "type": null, "default": "..."}, {"name": "ax", "type": null, "default": "..."}], "returns": null, "documentation": ["Plot showing barometric pressure over time.\n\nParameters\n----------\ndataframe : pandas.DataFrame\n    Must have a datetime index.\ncol : string, optional (default = 'precip')\n    The name of the column in *dataframe* that contains the\n    barometric pressure series.\nfreq : str, optional (default = 'hourly')\n    The frequency to which the barometrix pressure should be\n    aggregated.\nhow : {'mean', 'max', 'min'}, optional (default = 'mean')\n    Specifies how the data will be aggregted.\nax : matplotlib.Axes object, optional\n    The Axes on which the plot will be placed. If not provided,\n    a new Figure and Axes will be created.\n\nReturns\n-------\nfig : matplotlib.Figure"]}, {"name": "cloudside.viz.temperature", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "col", "type": null, "default": "..."}, {"name": "freq", "type": null, "default": "..."}, {"name": "how", "type": null, "default": "..."}, {"name": "ax", "type": null, "default": "..."}], "returns": null, "documentation": ["Plot showing temperature over time.\n\nParameters\n----------\ndataframe : pandas.DataFrame\n    Must have a datetime index.\nc