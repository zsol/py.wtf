loudside.storms._wet_window_diff", "asynchronous": false, "params": [{"name": "is_wet", "type": null, "default": null}, {"name": "ie_periods", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cloudside.storms.parse_record", "asynchronous": false, "params": [{"name": "data", "type": null, "default": null}, {"name": "intereventHours", "type": null, "default": null}, {"name": "outputfreqMinutes", "type": null, "default": null}, {"name": "precipcol", "type": null, "default": "..."}, {"name": "inflowcol", "type": null, "default": "..."}, {"name": "outflowcol", "type": null, "default": "..."}, {"name": "baseflowcol", "type": null, "default": "..."}, {"name": "stormcol", "type": null, "default": "..."}, {"name": "debug", "type": null, "default": "..."}], "returns": null, "documentation": ["Parses the hydrologic data into distinct storms.\n\nIn this context, a storm is defined as starting whenever the\nhydrologic records shows non-zero precipitation or [in|out]flow\nfrom the BMP after a minimum inter-event dry period duration\nspecified in the the function call. The storms ends the observation\n*after* the last non-zero precipitation or flow value.\n\nParameters\n----------\ndata : pandas.DataFrame\nintereventHours : float\n    The Inter-Event dry duration (in hours) that classifies the\n    next hydrlogic activity as a new event.\nprecipcol : string, optional (default = None)\n    Name of column in `hydrodata` containing precipiation data.\ninflowcol : string, optional (default = None)\n    Name of column in `hydrodata` containing influent flow data.\noutflowcol : string, optional (default = None)\n    Name of column in `hydrodata` containing effluent flow data.\nbaseflowcol : string, optional (default = None)\n    Name of column in `hydrodata` containing boolean indicating\n    which records are considered baseflow.\nstormcol : string (default = 'storm')\n    Name of column in `hydrodata` indentifying distinct storms.\ndebug : bool (default = False)\n    If True, diagnostic columns will not be dropped prior to\n    returning the dataframe of parsed_storms.\n\nWrites\n------\nNone\n\nReturns\n-------\nparsed_storms : pandas.DataFrame\n    Copy of the original `data` DataFrame, but resampled to a\n    fixed frequency, columns possibly renamed, and a `storm` column\n    added to denote the storm to which each record belongs. Records\n    where `storm` == 0 are not a part of any storm."]}], "variables": [{"name": "cloudside.storms.SEC_PER_MINUTE", "type": null, "documentation": []}, {"name": "cloudside.storms.MIN_PER_HOUR", "type": null, "documentation": []}, {"name": "cloudside.storms.HOUR_PER_DAY", "type": null, "documentation": []}, {"name": "cloudside.storms.SEC_PER_HOUR", "type": null, "documentation": []}, {"name": "cloudside.storms.SEC_PER_DAY", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "cloudside.exporters", "documentation": [], "functions": [{"name": "cloudside.exporters.SWMM5Format", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "stationid", "type": null, "default": null}, {"name": "col", "type": null, "default": "..."}, {"name": "freq", "type": null, "default": "..."}, {"name": "dropzeros", "type": null, "default": "..."}, {"name": "filename", "type": null, "default": "..."}, {"name": "sep", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cloudside.exporters.NCDCFormat", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "coopid", "type": null, "default": null}, {"name": "statename", "type": null, "default": null}, {"name": "col", "type": null, "default": "..."}, {"name": "filename", "type": null, "default": "..."}], "returns": null, "documentation": ["Always resamples to hourly"]}, {"name": "cloudside.exporters.hourXtab", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "col", "type": null, "default": null}, {"name": "filename", "type": null, "default": "..."}, {"name": "flag", "type": null, "default": "..."}], "returns": null, "documentation": ["Always resamples to hourly"]}, {"name": "cloudside.exporters.NCDCtoCSV", "asynchronous": false, "params": [{"name": "ncdc", "type": null, "default": null}, {"name": "csv", "type": null, "default": null}], "returns": null, "documentation": ["Convert NCDC format files to csv\n\nParameters\n----------\nncdc : filepath to raw NCDC format\ncsv : filepath to output CSV file"]}, {"name": "cloudside.exporters._pop_many", "asynchronous": false, "params": [{"name": "mylist", "type": null, "default": null}, {"name": "N", "type": null, "default": null}, {"name": "side", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cloudside.exporters._parse_obs", "asynchronous": false, "params": [{"name": "obs", "type": null, "default": null}, {"name": "units", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cloudside.exporters._write_obs", "asynchronous": false, "params": [{"name": "rowheader", "type": null, "default": null}, {"name": "year", "type": null, "default": null}, {"name": "month", "type": null, "default": null}, {"name": "day", "type": null, "default": null}, {"name": "obs", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cloudside.exporters._obs_from_row", "asynchronous": false, "params": [{"name": "row", "type": null, "default": null}], "returns": null, "documentation": ["Parses the NCDC format illustrated below:\nHPD04511406HPCPHI19480700010040100000000 1300000000M 2400000000M 2500000000I\nAAABBBBBBCCCCCCDDEEEEFFGGGGHHHIIJJJJJJJJ IIJJJJJJJJK IIJJJJJJJJK IIJJJJJJJJK\n\nGroup A - the Record Type\nGroup B - the station COOPID\nGroup C - the element (i.e., parameter; e.g., precip)\nGroup D - units (HI = hundreths of an inch)\nGroup E - year\nGroup F - month\nGroup H - day\nGroup I - hour\nGroup J - observed value\nGroup K - qualifier"]}], "variables": [{"name": "cloudside.exporters.states", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "cloudside.ncdc", "documentation": ["standard library models"], "functions": [{"name": "cloudside.ncdc.date_parser", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cloudside.ncdc.remove_bad_rain_values", "asynchronous": false, "params": [{"name": "df", "type": null, "default": null}, {"name": "raincol", "type": null, "default": "..."}, {"name": "threshold", "type": null, "default": "..."}], "returns": null, "documentation": ["Filters invalid rainfall values and returns a new series.\n\nNCDC use 99999 1/100th of inch for invalid/missing values.\nWe downloaded the data in mm so NCDC coverted that value to\n25399 mm. However, we default the invalid threshold value to\n500 mm since 12 inches of rain in an hour is equally\nunreasonable."]}, {"name": "cloudside.ncdc.get_percent_available", "asynchronous": false, "params": [{"name": "grid", "type": null, "default": null}, {"name": "coopid", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cloudside.ncdc.xdates", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "pos", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cloudside.ncdc.set_status", "asynchronous": false, "params": [{"name": "dataframe", "type": null, "default": null}, {"name": "opener", "type": null, "default": null}, {"name": "closer", "type": null, "default": null}, {"name": "flagval", "type": null, "default": null}, {"name": "flagcol", "type": null, "default": "..."}, {"name": "raincol", "type": null, "default": "..."}, {"name": "statuscol", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "cloudside.ncdc.setup_station_data", "asynchronous": false, "params": [{"name": "dataframe", "type"