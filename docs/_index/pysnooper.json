", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.get_path_and_source_from_frame", "asynchronous": false, "params": [{"name": "frame", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.get_write_function", "asynchronous": false, "params": [{"name": "output", "type": null, "default": null}, {"name": "overwrite", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "pysnooper.tracer.ipython_filename_pattern", "type": null, "documentation": []}, {"name": "pysnooper.tracer.ansible_filename_pattern", "type": null, "documentation": []}, {"name": "pysnooper.tracer.ipykernel_filename_pattern", "type": null, "documentation": []}, {"name": "pysnooper.tracer.RETURN_OPCODES", "type": null, "documentation": []}, {"name": "pysnooper.tracer.source_and_path_cache", "type": null, "documentation": []}, {"name": "pysnooper.tracer.thread_global", "type": null, "documentation": []}, {"name": "pysnooper.tracer.DISABLED", "type": null, "documentation": []}], "classes": [{"name": "pysnooper.tracer.UnavailableSource", "bases": ["object"], "methods": [{"name": "pysnooper.tracer.UnavailableSource.__getitem__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "i", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pysnooper.tracer.FileWriter", "bases": ["object"], "methods": [{"name": "pysnooper.tracer.FileWriter.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "path", "type": null, "default": null}, {"name": "overwrite", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.FileWriter.write", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "pysnooper.tracer.Tracer", "bases": [], "methods": [{"name": "pysnooper.tracer.Tracer.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "output", "type": null, "default": "..."}, {"name": "watch", "type": null, "default": "..."}, {"name": "watch_explode", "type": null, "default": "..."}, {"name": "depth", "type": null, "default": "..."}, {"name": "prefix", "type": null, "default": "..."}, {"name": "overwrite", "type": null, "default": "..."}, {"name": "thread_info", "type": null, "default": "..."}, {"name": "custom_repr", "type": null, "default": "..."}, {"name": "max_variable_length", "type": null, "default": "..."}, {"name": "normalize", "type": null, "default": "..."}, {"name": "relative_time", "type": null, "default": "..."}, {"name": "color", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer.__call__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "function_or_class", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer._wrap_class", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cls", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer._wrap_function", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "function", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer.write", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer.__enter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer.__exit__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "exc_type", "type": null, "default": null}, {"name": "exc_value", "type": null, "default": null}, {"name": "exc_traceback", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer._is_internal_frame", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "frame", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer.set_thread_info_padding", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "thread_info", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.tracer.Tracer.trace", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "frame", "type": null, "default": null}, {"name": "event", "type": null, "default": null}, {"name": "arg", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Snoop on the function, writing everything it's doing to stderr.\n\nThis is useful for debugging.\n\nWhen you decorate a function with `@pysnooper.snoop()`\nor wrap a block of code in `with pysnooper.snoop():`, you'll get a log of\nevery line that ran in the function and a play-by-play of every local\nvariable that changed.\n\nIf stderr is not easily accessible for you, you can redirect the output to\na file:\n\n```\n@pysnooper.snoop('/my/log/file.log')\n```\n\nSee values of some expressions that aren't local variables:\n\n```\n@pysnooper.snoop(watch=('foo.bar', 'self.x[\"whatever\"]'))\n```\n\nExpand values to see all their attributes or items of lists/dictionaries:\n\n> @pysnooper.snoop(watch_explode=('foo', 'self'))\n\n(see Advanced Usage in the README for more control)\n\nShow snoop lines for functions that your function calls:\n\n```\n@pysnooper.snoop(depth=2)\n```\n\nStart all snoop lines with a prefix, to grep for them easily:\n\n```\n@pysnooper.snoop(prefix='ZZZ ')\n```\n\nOn multi-threaded apps identify which thread are snooped in output:\n\n```\n@pysnooper.snoop(thread_info=True)\n```\n\nCustomize how values are represented as strings:\n\n```\n@pysnooper.snoop(custom_repr=((type1, custom_repr_func1),\n                 (condition2, custom_repr_func2), ...))\n```\n\nVariables and exceptions get truncated to 100 characters by default. You\ncan customize that:\n\n> @pysnooper.snoop(max_variable_length=200)\n\nYou can also use `max_variable_length=None` to never truncate them.\n\nShow timestamps relative to start time rather than wall time:\n\n```\n@pysnooper.snoop(relative_time=True)\n```\n\nThe output is colored for easy viewing by default, except on Windows.\nDisable colors like so:\n\n> @pysnooper.snoop(color=False)\n"]}], "exports": []}, {"name": "pysnooper.pycompat", "documentation": ["Python 2/3 compatibility", "Copyright 2019 Ram Rachum and collaborators.", "This program is distributed under the MIT license."], "functions": [{"name": "pysnooper.pycompat.time_isoformat", "asynchronous": false, "params": [{"name": "time", "type": null, "default": null}, {"name": "timespec", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "pysnooper.pycompat.timedelta_format", "asynchronous": false, "params": [{"name": "timedelta", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pysnooper.pycompat.timedelta_parse", "asynchronous": false, "params": [{"name": "s", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "pysnooper.pycompat.PY3", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.PY2", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.ABC", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.PathLike", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.iscoroutinefunction", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.iscoroutinefunction", "type": null, "documentation": ["Lolz"]}, {"name": "pysnooper.pycompat.isasyncgenfunction", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.isasyncgenfunction", "type": null, "documentation": ["Lolz"]}, {"name": "pysnooper.pycompat.string_types", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.text_type", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.binary_type", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.string_types", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.text_type", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.binary_type", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.time_isoformat", "type": null, "documentation": []}], "classes": [{"name": "pysnooper.pycompat.ABC", "bases": ["object"], "methods": [], "class_variables": [{"name": "pysnooper.pycompat.ABC.__metaclass__", "type": null, "documentation": []}, {"name": "pysnooper.pycompat.ABC.__slots__", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Helper class that provides a standard way to create an ABC using\ninheritance."]}, {"name": "pysnooper.pycompat.PathLike", "bases": ["ABC"], "methods": [{"name": "pysnooper.pycompat.PathLike.__fspath__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Return the file system path representation of the object."]}, {"name": "pysnooper.pycompat.PathLike.__subclasshook__", "asynchronous": false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "subclass", "type": null, "default": null}], "returns": null