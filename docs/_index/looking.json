{"name": "looking", "metadata": {"name": "looking", "version": "0.0.1", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/yx-z/looking", "license": null, "documentation_url": null, "dependencies": ["textual"], "summary": "A smart log viewer", "upload_time": 1735231076}, "documentation": ["# What\r\n\r\n`looking` is a smart log viewer.\r\n\r\n# How\r\n\r\n1. Install `pip install looking`\r\n2. Use `looking /path/to/log/file.txt`\r\n3. Other options:\r\n\r\n   a. `looking -f /path/to/log/file.txt` to follow the appended text, just like `tail -f`.\r\n\r\n   b. `looking -` to read standard input, just like `vim -`. e.g. `grep SOME_ID /path/to/log/file.txt | looking -`.\r\n\r\n# Features\r\n\r\n- `looking` highlights common keywords for programming languages, as well as user registered keywords for visual highlights.\r\n- `looking` makes viewing large objects of key-value pairs, or a long list of values easier.\r\n- `looking` smartly filters and parallelizes log lines for multi-thread logs.\r\n- `looking` makes copy/pasting from logs easier.\r\n"], "modules": [{"name": "looking.app", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "looking.app.Looking", "bases": ["App"], "methods": [{"name": "looking.app.Looking.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "args", "type": {"name": "Args", "xref": {"fqname": "looking.args.Args", "project": null}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "looking.app.Looking.compose", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "ComposeResult", "xref": {"fqname": "textual.app.ComposeResult", "project": "textual"}, "params": null}, "documentation": []}