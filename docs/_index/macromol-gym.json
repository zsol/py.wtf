{"name": "macromol-gym", "metadata": {"name": "macromol-gym", "version": "1.0.0", "classifiers": ["Programming Language :: Python :: 3"], "home_page": null, "license": null, "documentation_url": "https://macromol-gym.readthedocs.io/en/latest/", "dependencies": ["aiohttp", "docopt", "icosphere", "macromol_census", "macromol_dataframe", "macromol_voxelize", "more_itertools", "nestedtext", "networkx", "numpy", "periodictable", "pipeline_func", "reprfunc", "scikit-learn", "scipy", "tqdm", "xxhash"], "summary": "Macromolecular training sets that emphasize protein/non-protein interactions.", "upload_time": 1733714824}, "documentation": ["Macromolecular Gymnasium\n========================\n\n[![Last release](https://img.shields.io/pypi/v/macromol_gym.svg)](https://pypi.python.org/pypi/macromol_gym)\n[![Python version](https://img.shields.io/pypi/pyversions/macromol_gym.svg)](https://pypi.python.org/pypi/macromol_gym)\n[![Documentation](https://img.shields.io/readthedocs/macromol_gym.svg)](https://macromol-gym.readthedocs.io/en/latest)\n[![Test status](https://img.shields.io/github/actions/workflow/status/kalekundert/macromol_gym/test.yml?branch=master)](https://github.com/kalekundert/macromol_gym/actions)\n[![Test coverage](https://img.shields.io/codecov/c/github/kalekundert/macromol_gym)](https://app.codecov.io/github/kalekundert/macromol_gym)\n[![Last commit](https://img.shields.io/github/last-commit/kalekundert/macromol_gym?logo=github)](https://github.com/kalekundert/macromol_gym)\n\nThis package builds datasets of macromolecular structures, for machine \nlearning.  Some properties of these datasets:\n\n- Capable of processing the entire PDB.[^1]\n\n- Each data point is a particular coordinate in a particular structure.\n\n- Only data points with sufficient density, and that feature unique \n  combinations of molecules, are included.\n\n- The resulting database is self-contained; all of the necessary coordinates \n  are copied into the database.\n\n- Coordinates are taken from biological assemblies, not asymmetric units.\n\n- Train/validation/test splits are made such that all structures which share an \n  InterPro domain/family end up in the same split.\n\n[^1]: With the only exceptions being `8h2i` and `5zz8`.  Both of these \nstructures have errors in their biological assemblies, which cause the \nassemblies to have huge volumes of empty space.  Because of the way some \ninternal algorithms work, these particular errors end up requiring prohibitive \namounts of memory to process.\n\n\n"], "modules": [{"name": "macromol_gym.init", "documentation": ["Create an empty database.\n\nUsage:\n    mmt_init <db>\n\nSubsequent commands will fill this database with training examples."], "functions": [{"name": "macromol_gym.init.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "macromol_gym.pymol", "documentation": [], "functions": [{"name": "macromol_gym.pymol.show_zone", "asynchronous": false, "params": [{"name": "db_path", "type": null, "default": null}, {"name": "zone_id", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pymol._sum_occ", "asynchronous": false, "params": [{"name": "sele", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pymol.sum_occ", "asynchronous": false, "params": [{"name": "sele", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pymol._density", "asynchronous": false, "params": [{"name": "center", "type": null, "default": null}, {"name": "radius_A", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pymol.density", "asynchronous": false, "params": [{"name": "center", "type": null, "default": null}, {"name": "radius_A", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pymol.show_centers", "asynchronous": false, "params": [{"name": "spacing_A", "type": null, "default": "..."}, {"name": "density_target_atoms_nm3", "type": null, "default": "..."}, {"name": "density_radius_A", "type": null, "default": "..."}, {"name": "sele", "type": null, "default": "..."}, {"name": "state", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "macromol_gym.pymol.show_neighbors", "asynchronous": false, "params": [{"name": "sele", "type": null, "default": "..."}, {"name": "geometry", "type": null, "default": "..."}, {"name": "distance_A", "type": null, "default": "..."}, {"name": "density_target_atoms_nm3", "type": null, "default": "..."}, {"name": "density_radius_A", "type": null, "default": "..."}, {"name": "state", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "macromol_gym.pymol.sele_or_pseudoatom", "asynchronous": false, "params": [{"name": "sele_or_xyz", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pymol.tmp_pseudoatom", "asynchronous": false, "params": [{"name": "xyz", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "macromol_gym.density", "documentation": [], "functions": [{"name": "macromol_gym.density.make_density_interpolator", "asynchronous": false, "params": [{"name": "atoms", "type": null, "default": null}, {"name": "radius_A", "type": null, "default": null}, {"name": "voxel_size_A", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.density.make_sphere_kernel", "asynchronous": false, "params": [{"name": "radius_A", "type": null, "default": null}, {"name": "voxel_size_A", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "macromol_gym", "documentation": ["Macromolecular training sets that emphasize protein/non-protein interactions."], "functions": [], "variables": [{"name": "macromol_gym.__version__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "macromol_gym.split", "documentation": ["Split the dataset such that structures from the same cluster always end up in \nthe same split.\n\nUsage:\n    mmt_split_training_examples <db> <splits> <clusters> [-s <seed>] [-d]\n\nOptions:\n    -s --random-seed <int>          [default: 0]\n        Groups are assigned to splits with probability proportional to the \n        space that would be left in that split, after the group is added.  This \n        is a random but deterministic, controlled by this seed.\n\n    -d --dry-run\n        Calculate splits and report the final statistics, but don't write the \n        splits to the database.\n\nIt's ok to run this command multiple times.  Each invocation will overwrite any \npreviously assigned splits."], "functions": [{"name": "macromol_gym.split.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.split.load_split_targets", "asynchronous": false, "params": [{"name": "split_path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.split.load_clusters", "asynchronous": false, "params": [{"name": "csv_path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.split.make_splits", "asynchronous": false, "params": [{"name": "rng", "type": null, "default": null}, {"name": "struct_zone_counts", "type": null, "default": null}, {"name": "clusters", "type": null, "default": null}, {"name": "targets", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.split.group_related_structures", "asynchronous": false, "params": [{"name": "structures", "type": null, "default": null}, {"name": "clusters", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.split.select_struct_zone_counts", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.split.summarize_splits", "asynchronous": false, "params": [{"name": "struct_zone_counts", "type": null, "default": null}, {"name": "targets", "type": null, "default": null}, {"name": "splits", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "macromol_gym.geometry", "documentation": [], "functions": [{"name": "macromol_gym.geometry.tetrahedron_faces", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.geometry.cube_faces", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.geometry.octahedron_faces", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.geometry.dodecahedron_faces", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.geometry.icosahedron_faces", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.geometry._calc_edge_indices", "asynchronous": false, "params": [{"name": "verts", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.geometry._calc_face_indices", "asynchronous": false, "params": [{"name": "verts", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "macromol_gym.geometry.PHI", "type": null, "documentation": []}, {"name": "macromol_gym.geometry.v", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "macromol_gym.interpro", "documentation": ["Cluster PDB ids based on the InterPro domains and families they contain.\n\nUsage:\n    mmt_fetch_interpro_clusters <db> [-o <csv>] [-c <sqlite>] [-r <int>]\n\nOptions:\n    -o --output <csv>           [default: interpro_clusters.csv]\n        The path to the CSV file where the clusters should be written.  This \n        file will have two columns.  The first contains PDB ids.  The second \n        contains InterPro entry ids, each of which refers to a \"domain\" or \n        \"family\" as defined by InterPro.  Any two PDB ids that share a InterPro \n        domain or family should be considered to cluster together.\n        \n    -c --cache <sqlite>         [default: interpro_cache.sqlite]\n        The path where responses from the InterPro server should be cached.  \n        This cache is useful in the case that not all of the InterPro queries \n        are successful the first time, due to random network errors.  Once the \n        final clusters have been created, this cache can be deleted.\n\n    -r --max-requests <int>     [default: 50]\n        The maximum simultaneous number of requests to make to the InterPro web \n        server at any one time.  This is an important parameter.  Too few, and \n        we waste time waiting to hear back from the server.  Too many, and we \n        can overwhelm the server, or even our own resources (i.e. open socket \n        limits).  The default of 50 should balance these concerns pretty well.  \n        However, you might try a smaller number if you're getting a lot of \n        \"server disconnected\" errors."], "functions": [{"name": "macromol_gym.interpro.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.find_pdb_ids_to_fetch", "asynchronous": false, "params": [{"name": "train_db", "type": null, "default": null}, {"name": "cache_db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.cache_interpro_entries", "asynchronous": true, "params": [{"name": "db", "type": null, "default": null}, {"name": "pdb_ids", "type": null, "default": null}, {"name": "max_simultaneous_requests", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.fetch_interpro_entries_in_structure", "asynchronous": true, "params": [{"name": "session", "type": null, "default": null}, {"name": "pdb_id", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.summarize_downloads", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}, {"name": "pdb_ids", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.make_clusters", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.open_cache_db", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.select_needed_pdb_ids", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.select_cached_pdb_ids", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.select_interpro_responses", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.interpro.insert_interpro_response", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}, {"name": "response", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "macromol_gym.pick", "documentation": ["Usage:\n    mmt_pick_training_examples <db> <census> <config> [-c <dir>]\n\nArguments:\n    <db>\n        The path to a database initialized by `mmt_init`.\n\n    <census>\n        The path to the completed database produced by `macromol_census`.  This \n        database identifies all of the biological assemblies in the PDB that \n        are sufficiently unique and high-quality to be worth including in the \n        training data.\n\n    <config>\n        A NestedText file specifying the following parameters:\n\n        - `zone_size_A`\n\n        - `density_check_radius_A`\n        - `density_check_voxel_size_A`\n        - `density_check_min_atoms_nm3`\n        - `density_check_max_atoms_nm3`\n\n        - `subchain_check_radius_A`\n        - `subchain_check_fraction_of_zone`\n        - `subchain_check_fraction_of_subchain`\n        - `subchain_pair_check_fraction_of_zone`\n        - `subchain_pair_check_fraction_of_subchain`\n\n        - `neighbor_geometry`\n        - `neighbor_distance_A`\n        - `neighbor_count_threshold`\n\n        - `allowed_elements`:\n          A list of atomic elements that are allowed to be included in the \n          database.\n\n        - `nonbiological_residues`:\n          The path to a file containing a list of residue types to ignore when \n          calculating densities.  The file should be a text file with one \n          residue name on each line.  Most residue names are 3 letters.\n\n          These residues are not removed from the structures stored in the \n          database.  They just don't count for the various density thresholds \n          that are checked.  The idea is that regions of structure with more \n          \"non-biological\" atoms aren't as likely to be added to the database, \n          but if they are added, they won't be missing any atoms.\n\n        - `atom_inclusion_radius_A`\n        - `atom_inclusion_boundary_depth_A`\n\nOptions:\n    -c --cath <dir>\n        The path to a directory containing a copy of the CATH-Plus database.  \n        This directory must contain at least the following two files:\n\n            cath-classification-data/cath-domain-list.txt\n            cath-classification-data/cath-domain-boundaries-seqreschopping.txt\n\n        Both of these files may optionally have a version number inserted after \n        the file name and before the `.txt`.  If no path is specified, the \n        `$CATH_PLUS` environment variable will be used instead.  An error will \n        occur if no CATH directory can be found."], "functions": [{"name": "macromol_gym.pick.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.load_config", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}, {"name": "census_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "cath_paths", "type": {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}, "default": null}, {"name": "config", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.pick_polymer_labels", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.get_polymer_labels", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.pick_cath_labels", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}, {"name": "cath_domains", "type": null, "default": null}, {"name": "min_domains", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.pick_training_zones", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}, {"name": "census", "type": null, "default": null}, {"name": "config", "type": {"name": "Config", "xref": {"fqname": "macromol_gym.pick.Config", "project": null}, "params": null}, "default": null}, {"name": "get_mmcif_path", "type": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "", "xref": null, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, {"name": "Path", "xref": {"fqname": "pathlib.Path", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "polymer_labels", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "cath_labels", "type": {"name": "pl.DataFrame", "xref": {"fqname": "polars.DataFrame", "project": null}, "params": null}, "default": null}, {"name": "progress_factory", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.load_neighbors", "asynchronous": false, "params": [{"name": "db", "type": null, "default": null}, {"name": "geometry", "type": null, "default": null}, {"name": "distance_A", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.find_neighbor_centers_A", "asynchronous": false, "params": [{"name": "geometry", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "distance_A", "type": {"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.annotate_polymers", "asynchronous": false, "params": [{"name": "asym_atoms", "type": null, "default": null}, {"name": "entities", "type": null, "default": null}, {"name": "polymers", "type": null, "default": null}, {"name": "labels", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "macromol_gym.pick.anno