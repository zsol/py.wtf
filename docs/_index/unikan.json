{"name": "unikan", "metadata": {"name": "unikan", "version": "0.1.0", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/chikkkit/uni-kan", "license": null, "documentation_url": null, "dependencies": ["torch", "numpy"], "summary": "A Python library based on pytorch for universally building KAN-type networks", "upload_time": 1733798731}, "documentation": ["# uni-kan\r\nA Python library based on pytorch for universally building KAN-type networks\r\n"], "modules": [{"name": "unikan", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "unikan.UniversalKAN", "xref": {"fqname": "unikan.universal_KAN.UniversalKAN", "project": null}}, {"name": "unikan.UniversalKANLinear", "xref": {"fqname": "unikan.universal_KAN.UniversalKANLinear", "project": null}}, {"name": "unikan.UniversalKANNode", "xref": {"fqname": "unikan.universal_KAN.UniversalKANNode", "project": null}}]}, {"name": "unikan.universal_KAN", "documentation": [], "functions": [{"name": "unikan.universal_KAN.lshifted_softplus", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "k", "type": null, "default": null}], "returns": null, "documentation": ["default basis function"]}], "variables": [{"name": "unikan.universal_KAN.device", "type": null, "documentation": []}, {"name": "unikan.universal_KAN.function_lists", "type": null, "documentation": []}, {"name": "unikan.universal_KAN.net", "type": null, "documentation": []}], "classes": [{"name": "unikan.universal_KAN.UniversalKANNode", "bases": ["nn.Module"], "methods": [{"name": "unikan.universal_KAN.UniversalKANNode.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "in_features", "type": null, "default": null}, {"name": "out_features", "type": null, "default": null}, {"name": "node_type", "type": null, "default": "..."}, {"name": "function", "type": null, "default": "..."}, {"name": "param_num", "type": null, "default": "..."}, {"name": "use_bias", "type": null, "default": "..."}, {"name": "device", "type": null, "default": "..."}], "returns": null, "documentation": ["in_features: int, the number of input features\n\nout_features: int, the number of output features\n\nnode_type: str in ['add', 'mul'], the type of node, default is 'add'\n\nfunction: function, the basis function to use, default is lshifted_softplus\n\nparam_num: int, the number of parameters of this function\n\nuse_bias: bool, whether to add bias to this function\n\ndevice: str, the device to use, default is 'cpu'"]}, {"name": "unikan.universal_KAN.UniversalKANNode.reset_parameters", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKANNode.forward", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKANNode.extra_repr", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKANNode.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "unikan.universal_KAN.UniversalKANLinear", "bases": ["nn.Module"], "methods": [{"name": "unikan.universal_KAN.UniversalKANLinear.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "in_features", "type": null, "default": null}, {"name": "out_features", "type": null, "default": null}, {"name": "function_list", "type": null, "default": "..."}, {"name": "device", "type": null, "default": "..."}], "returns": null, "documentation": ["in_features: int, the number of input features\n\nout_features: int, the number of output features\n\nfunction_list: list, the list of basis functions\n    It shoulf be a list of function dict, each dict should have the following:\n        'function': function, the basis function such as 'lshifted_softplus(x, k)'\n        'param_num': int, the number of parameters of a single basis function\n        'node_type': str, the type of node, 'add' or 'mul'\n        'node_num': int, number to show how many nodes to use\n        'use_bias': bool, whether to add bias to this function\n    For example, if you want to use 2 basis functions lshifted_softplus and lsin, they are single parameterized functions, \n    each function only have 1 addition node and 0 multiplication node, then the function_list should be like:\n        function_list = [\n            {'function': lshifted_softplus, 'param_num': 1, 'node_type': 'add', 'node_num': 1, 'use_bias': True},\n            {'function': lsin, 'param_num': 1, 'node_type': 'add', 'node_num': 1, 'use_bias': True}\n        ]\n    Note that functions and nodes are bound, which means that a node can only have one function. This is to accelerate operation\n    in grid type network.\n\ndevice: str, the device to use, default is 'cpu'"]}, {"name": "unikan.universal_KAN.UniversalKANLinear.forward", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKANLinear.extra_repr", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKANLinear.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "unikan.universal_KAN.UniversalKAN", "bases": ["nn.Module"], "methods": [{"name": "unikan.universal_KAN.UniversalKAN.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "layer_sizes", "type": null, "default": null}, {"name": "function_lists", "type": null, "default": "..."}, {"name": "device", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKAN.forward", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKAN.extra_repr", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKAN.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "unikan.universal_KAN.UniversalKAN.get_graph", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["This function is to generate the computation graph of a network, return 3 parameters.\npos: dict, the position of each node, the key is the name of the node, the value is the position of the node. e.g.: \n    {'0, 1': (0.0, 0), '1, 1': (-2.0, 1), '1, 2': (-1.0, 1), '1, 3': (0.0, 1), \n    '1, 4': (1.0, 1), '1, 5': (2.0, 1), '0, b': (1.0, 0), '2, 1': (0.0, 2), '1, b': (3.0, 1)}\nedges: list, the edges between nodes, each element is a tuple, the first is the start node, the second is the end node. e.g.:\n    [('0, 1', '1, 1'), ('0, 1', '1, 2'), ('0, 1', '1, 3'), ('0, 1', '1, 4'), ('0, 1', '1, 5'),\n    ('0, b', '1, 1'), ('0, b', '1, 2'), ('0, b', '1, 3'), ('0, b', '1, 4'), ('0, b', '1, 5'),\n    ('1, 1', '2, 1'), ('1, 2', '2, 1'), ('1, 3', '2, 1'), ('1, 4', '2, 1'), ('1, 5', '2, 1'), ('1, b', '2, 1')]\nfuncs: dict, the function of each edge, the key is the edge, the value is the function. e.g.:\n    {('0, 1', '1, 1'): <function __main__.<lambda>(x, ev=0.6927026510238647)>,\n    ('0, 1', '1, 2'): <function __main__.<lambda>(x, ev=0.7938258051872253)>,\n    ('0, 1', '1, 3'): <function __main__.<lambda>(x, ev=0.9977601766586304)>,\n    ('0, 1', '1, 4'): <function __main__.<lambda>(x, ev=-0.29473429918289185)>,\n    ('0, 1', '1, 5'): <function __main__.<lambda>(x, ev=-0.5044335126876831)>,\n    ('0, b', '1, 1'): <function __main__.<lambda>(x, ev=-1.7965008020401)>,\n    ('0, b', '1, 2'): <function __main__.<lambda>(x, ev=-0.9162623882293701)>,\n    ('0, b', '1, 3'): <function __main__.<lambda>(x, ev=-0.9161001443862915)>,\n    ('0, b', '1, 4'): <function __main__.<lambda>(x, ev=-0.06848419457674026)>,\n    ('0, b', '1, 5'): <function __main__.<lambda>(x, ev=0.2307554930448532)>,\n    ('1, 1', '2, 1'): <function __main__.<lambda>(x, ev=-1.398566722869873)>,\n    ('1, 2', '2, 1'): <function __main__.<lambda>(x, ev=-0.33302581310272217)>,\n    ('1, 3', '2, 1'): <function __main__.<lambda>(x, ev=-0.8638795018196106)>,\n    ('1, 4', '2, 1'): <function __main__.<lambda>(x, ev=0.1741543859243393)>,\n    ('1, 5', '2, 1'): <function __main__.<lambda>(x, ev=0.3043987452983856)>,\n    ('1, b', '2, 1'): <function __main__.<lambda>(x, ev=-0.7070185542106628)>}"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}]}