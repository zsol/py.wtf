sult_response()"]}], "exports": []}, {"name": "dmtestutils.api_model_stubs.audit_event", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "dmtestutils.api_model_stubs.audit_event.AuditEventStub", "bases": ["BaseAPIModelStub"], "methods": [{"name": "dmtestutils.api_model_stubs.audit_event.AuditEventStub.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "dmtestutils.api_model_stubs.audit_event.AuditEventStub.resource_name", "type": null, "documentation": []}, {"name": "dmtestutils.api_model_stubs.audit_event.AuditEventStub.default_data", "type": null, "documentation": []}, {"name": "dmtestutils.api_model_stubs.audit_event.AuditEventStub.optional_keys", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "dmtestutils.comparisons", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "dmtestutils.comparisons.RestrictedAny", "bases": [], "methods": [{"name": "dmtestutils.comparisons.RestrictedAny.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "condition", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "dmtestutils.comparisons.RestrictedAny.__eq__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "other", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "dmtestutils.comparisons.RestrictedAny.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "dmtestutils.comparisons.RestrictedAny.__hash__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Analogous to mock.ANY, this class takes an arbitrary callable in its constructor and the returned instance will\nappear to \"equal\" anything that produces a truthy result when passed as an argument to the `condition` callable.\n\nUseful when wanting to assert the contents of a larger structure but be more flexible for certain members, e.g.\n\n\\# only care that second number is odd\n\\>>> (4, 5, 6,) == (4, RestrictedAny(lambda x: x % 2), 6,)\nTrue\n\\>>> (4, 9, 6,) == (4, RestrictedAny(lambda x: x % 2), 6,)\nTrue\n"]}, {"name": "dmtestutils.comparisons.AnySupersetOf", "bases": ["RestrictedAny"], "methods": [{"name": "dmtestutils.comparisons.AnySupersetOf.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "subset_dict", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "dmtestutils.comparisons.AnySupersetOf.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Instance will appear to \"equal\" any dictionary-like object that is a \"superset\" of the the constructor-supplied\n`subset_dict`, i.e. will ignore any keys present in the dictionary in question but missing from the reference\ndict. e.g.\n\n```pycon\n>>> [{\"a\": 123, \"b\": 456, \"less\": \"predictabananas\"}, 789] == [AnySupersetOf({\"a\": 123, \"b\": 456}), 789]\nTrue\n```\n"]}, {"name": "dmtestutils.comparisons.AnyStringMatching", "bases": ["RestrictedAny"], "methods": [{"name": "dmtestutils.comparisons.AnyStringMatching.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Construct an instance which will equal any string matching the supplied regex pattern. Supports all arguments\nrecognized by `re.compile`, alternatively accepts an existing regex pattern object as a single argument.\n"]}, {"name": "dmtestutils.comparisons.AnyStringMatching.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "dmtestutils.comparisons.AnyStringMatching._cached_re_compile", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Instance will appear to \"equal\" any string that matches the constructor-supplied regex pattern\n\n```pycon\n>>> {\"a\": \"Metempsychosis\", \"b\": \"c\"} == {\"a\": AnyStringMatching(r\"m+.+psycho.*\", flags=re.I), \"b\": \"c\"}\nTrue\n```\n"]}, {"name": "dmtestutils.comparisons.ExactIdentity", "bases": ["RestrictedAny"], "methods": [{"name": "dmtestutils.comparisons.ExactIdentity.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "reference_object", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "dmtestutils.comparisons.ExactIdentity.__repr__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Instance will appear to \"equal\" only to the exact object supplied at construction time.\n\n```pycon\n>>> x = []\n>>> (7, ExactIdentity(x),) == (7, x,)\nTrue\n>>> (7, ExactIdentity(x),) == (7, [],)\nFalse\n```\n"]}], "exports": []}, {"name": "dmtestutils.login", "documentation": [], "functions": [{"name": "dmtestutils.login.auto_supplier_login", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "dmtestutils.login.auto_buyer_login", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [{"name": "dmtestutils.login.login_for_tests", "type": null, "documentation": []}, {"name": "dmtestutils.login.USERS", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "dmtestutils.api_model_stubs.supplier_framework", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "dmtestutils.api_model_stubs.supplier_framework.SupplierFrameworkStub", "bases": ["BaseAPIModelStub"], "methods": [{"name": "dmtestutils.api_model_stubs.supplier_framework.SupplierFrameworkStub.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "dmtestutils.api_model_stubs.supplier_framework.SupplierFrameworkStub.resource_name", "type": null, "documentation": []}, {"name": "dmtestutils.api_model_stubs.supplier_framework.SupplierFrameworkStub.default_data", "type": null, "documentation": []}, {"name": "dmtestutils.api_model_stubs.supplier_framework.SupplierFrameworkStub.optional_keys", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "dmtestutils.mocking", "documentation": ["These closures are intended to be used as a `Mock` object's `side_effect`, allowing a mocked function's\nreturn value to be specified at the same time as the expected arguments. This is a very concise way of doing\nthings for simple uses where the mocked function is only ever called once (or with one set of arguments) and\ncan also be used to raise an `Exception` at the actual offending call site when there is an argument mismatch,\nleading to easy debugging.\n\n```pycon\n>>> from unittest.mock import Mock\n>>> mymock = Mock()\n>>> mymock.side_effect = assert_args_and_return(\"two eggs\", \"two bottles\", yards=50)\n>>> mymock('two bottles', yards=50)\n'two eggs'\n>>> mymock('two bottles', metres=50)\nTraceback (most recent call last):\n    ...\nAssertionError\n```\n\n```pycon\n>>> class EggBottleException(Exception):\n...     pass\n```\n\n```pycon\n>>> mymock.side_effect = assert_args_and_raise(EggBottleException, \"two bottles\", yards=50)\n>>> mymock('two bottles', yards=50)\nTraceback (most recent call last):\n    ...\nmocking.EggBottleException\n>>> mymock('two bottles', metres=50)\nTraceback (most recent call last):\n    ...\nAssertionError\n```\n\n```pycon\n>>> mymock.side_effect = assert_args_and_return_or_raise(\"two eggs\", EggBottleException, \"two bottles\", yards=50)\n>>> mymock('two bottles', yards=50)\n'two eggs'\n>>> mymock('two bottles', metres=50)\nTraceback (most recent call last):\n    ...\nmocking.EggBottleException\n```\n"], "functions": [{"name": "dmtestutils.mocking.assert_args_and_return", "asynchronous": false, "params": [{"name": "retval", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}, "documentation": ["Given a return value and an arbitrary set of arguments, returns a callable which will return `retval` when called\nwith arguments matching those specified here, otherwise will raise an `AssertionError`.\n"]}, {"name": "dmtestutils.mocking.assert_args_and_raise", "asynchronous": false, "params": [{"name": "e", "type": {"name": "Exception", "xref": {"fqname": "functions.Exception", "project": "--std--"}, "params": null}, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}, "documentation": ["Given a return value and an arbitrary set of arguments, returns a callable which will raise the `Exception` `e`\nwhen called with arguments matching those specified here.\n"]}, {"name": "dmtestutils.mocking.assert_args_and_return_or_raise", "asynchronous": false, "params": [{"name": "retval", "type": null, "default": null}, {"name": "e", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}, "documentation": ["Given a return value and an arbitrary set of arguments, returns a callable which will return `retval` when called\nwith arguments matching those specified here, otherwise will raise the exception `e`.\n"]}, {"name": "dmtestutils.mocking.assert_args_and_return_iter_over", "asynchronous": false, "params": [{"name": "retval", "type": {"name": "Iterable", "xref": {"fqname": "typing.Iterable", "project": "--std--"}, "params": null}, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": {"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": null}, "documentation": ["Given an iterable return value and an arbitrary set of arguments, returns a callable which will return\na fresh iterator over `retval` when called with arguments matching those specified here, otherwise will raise\nan `AssertionError`.\n"]}], "variables": [], "classes": [], "exports": []}]}