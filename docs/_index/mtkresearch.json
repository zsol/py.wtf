{"name": "mtkresearch", "metadata": {"name": "mtkresearch", "version": "0.1.0", "classifiers": ["Development Status :: 4 - Beta", "Intended Audience :: Developers", "Intended Audience :: Science/Research", "License :: OSI Approved :: Apache Software License", "Operating System :: OS Independent", "Programming Language :: Python :: 3", "Programming Language :: Python :: 3.6", "Programming Language :: Python :: 3.7"], "home_page": null, "license": "Apache License 2.0", "documentation_url": null, "dependencies": [], "summary": "mtkresearch", "upload_time": 1733454842}, "documentation": ["# MTK Research Package\n\n# Setup\n\n```\n$ pip install mtkresearch\n```\n\n# Prompt for chat\n\n```python\nfrom mtkresearch.llm.prompt import MRPromptV2\n\nprompt = MRPromptV2()\n\nconversations = [\n    {\n        \"role\": \"system\",\n        \"content\": \"SYS\"\n    },\n    {\n        \"role\": \"user\",\n        \"content\": \"QUERY1\"\n    },\n    {\n        \"role\": \"assistant\",\n        \"content\": \"RESPONSE1\"\n    },\n]\n\ntext = self.prompt.get_prompt(conversations)\n```\n\n# Prompt for function calling\n\n```python\nfrom mtkresearch.llm.prompt import MRPromptV2\n\nprompt = MRPromptV2()\n\nfunctions = [\n    {\n        'name': 'get_current_weather',\n        'description': 'Get the current_weather',\n        'parameters': {\n            'type': 'object',\n            'properties': {\n                'location': {\n                    'type': 'string',\n                    'description': 'The city and state, e.g. San Francisco, CA'\n                },\n                'unit': {\n                    'type': 'string',\n                    'enum': ['celsius', 'fahrenheit']\n                }\n            },\n            'required': ['location']\n        }\n    }\n]\nconversations = [\n    {\n        \"role\": \"user\",\n        \"content\": \"What's the weather in Boston?\"\n    },\n    {\n        \"role\": \"assistant\",\n        \"tool_calls\": [\n            {\n                'id': 'call_8jLWqlXaY3OisD24IHJLwD3G',\n                'type': 'function',\n                'function': {\n                    'arguments': \"{\\\"location\\\": \\\"Boston, MA\\\"}\",\n                    'name': 'get_current_weather'\n                }\n            }]\n    },\n    {\n        \"role\": \"tool\",\n        \"tool_call_id\": \"call_8jLWqlXaY3OisD24IHJLwD3G\",\n        \"name\": \"get_current_weather\",\n        \"content\": \"{\\\"temperature\\\": \\\"22 celsius\\\"}\"\n    },\n    {\n        \"role\": \"assistant\",\n        \"content\": \"The temperature is 22 celsius in Boston.\"\n    },\n]\n\ntext = self.prompt.get_prompt(conversations, functions)\n```\n"], "modules": [{"name": "mtkresearch", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "mtkresearch.llm.chat", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "mtkresearch.llm.chat.MRChatManager", "bases": [], "methods": [{"name": "mtkresearch.llm.chat.MRChatManager.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "prompt", "type": null, "default": null}, {"name": "sys_prompt", "type": null, "default": "..."}, {"name": "functions", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "mtkresearch.llm.chat.MRChatManager.__enter__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mtkresearch.llm.chat.MRChatManager.__exit__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "exc_type", "type": null, "default": null}, {"name": "exc_val", "type": null, "default": null}, {"name": "exc_tb", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "mtkresearch.llm.chat.MRChatManager.user_input", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "messa