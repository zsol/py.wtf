.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "jutsu_api.API.search", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "keyword", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "filter", "type": {"name": "Filter", "xref": {"fqname": "jutsu_api.Filter", "project": null}, "params": null}, "default": "..."}, {"name": "maxpage", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": [{"name": "Anime", "xref": {"fqname": "Anime", "project": null}, "params": null}]}, "documentation": []}, {"name": "jutsu_api.API.anime", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Anime", "xref": {"fqname": "Anime", "project": null}, "params": null}, "documentation": []}, {"name": "jutsu_api.API.episode", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Episode", "xref": {"fqname": "Episode", "project": null}, "params": null}, "documentation": []}], "class_variables": [{"name": "jutsu_api.API.instance", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "jutsu_api.Anime", "bases": [], "methods": [{"name": "jutsu_api.Anime.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"