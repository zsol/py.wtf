{"name": "dateutils", "metadata": {"name": "dateutils", "version": "0.6.12", "classifiers": ["Development Status :: 4 - Beta", "Intended Audience :: Developers", "License :: OSI Approved :: BSD License", "Natural Language :: English", "Operating System :: POSIX :: Linux", "Programming Language :: Python"], "home_page": "https://github.com/jmcantrell/python-dateutils", "license": "", "documentation_url": null, "dependencies": ["python-dateutil", "pytz"], "summary": "Various utilities for working with date and datetime objects", "upload_time": 1603436972}, "documentation": ["dateutils\n=========\n\nThe main purpose of this package is to provide more complex arithmetic\noperations on dates/times. Heavy use is made of the relativedelta type from\nLabix's dateutil library. Much of this package is just a light wrapper on top\nof this with some added features such as range generation and business day\ncalculation.\n\nInstallation\n------------\n\nYou should install dateutils with pip:\n\n    pip install dateutils\n\nOtherwise, you'll have to download the package and run:\n\n    python setup.py install\n\nIf you install it this way then you will also have to install all necessary\ndependencies manually.\n\n\n"], "modules": [{"name": "dateutils.dateadd", "documentation": [], "functions": [{"name": "dateutils.dateadd.get_arguments", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "dateutils.dateadd.main", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "dateutils", "documentation": [], "functions": [{"name": "dateutils.timezone", "asynchronous": false, "params": [{"name": "dt", "type": null, "default": null}, {"name": "timezone", "type": null, "default": "..."}], "returns": null, "documentation": ["Add timezone information to a naive datetime."]}, {"name": "dateutils.timezone_convert", "asynchronous": false, "params": [{"name": "dt", "type": null, "defaul