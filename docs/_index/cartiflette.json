params": null}, "default": "..."}, {"name": "filename", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "return_as_json", "type": {"name": "bool", "xref": {"fqname": "functions.bool", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": {"name": "typing.Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "gpd.GeoDataFrame", "xref": {"fqname": "geopandas.GeoDataFrame", "project": "geopandas"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "documentation": ["Downloads and aggregates official geographic datasets using the Cartiflette API\nfor a set of specified values.\nOptionally returns the data as a JSON string.\n\nThis function is useful for downloading and concatenating data related to different regions,\ncommunes, etc., into a single GeoDataFrame or JSON string.\n\nParameters:\n- values (List[Union[str, int, float]]):\n    A list of values to filter data by the filter_by parameter.\n- borders (str, optional):\n    The type of borders (default is \"COMMUNE\").\n- filter_by (str, optional):\n    The parameter to filter by (default is \"region\").\n- territory (str, optional):\n    The territory (default is \"metropole\").\n- vectorfile_format (str, optional):\n    The file format for vector files (default is \"geojson\").\n- year (Union[str, int, float], optional):\n    The year of the dataset. Defaults to the current year if not provided.\n- crs (Union[list, str, int, float], optional):\n    The coordinate reference system (default is 2154).\n- simplification (Union[str, int, float], optional):\n    The simplification parameter (default is None).\n- bucket, path_within_bucket, provider, dataset_family, source:\n    Other parameters required for accessing the Cartiflette API.\n\n- return_as_json (bool, optional):\n    If True, the function returns a JSON string representation of the aggregated GeoDataFrame.\n    If False, it returns a GeoDataFrame. Default is False.\n\nReturns:\n- Union[gpd.GeoDataFrame, str]:\n    A GeoDataFrame containing concatenated data from the\n        specified parameters if return_as_json is False.\n    A JSON string representation of the GeoDataFrame\n        if return_as_json is True."]}], "class_variables": [{"name": "cartiflette.client.CartifletteSession.CACHE_NAME", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "cartiflette.utils", "documentation": [], "functions": [{"name": "cartiflette.utils.dict_corresp_filter_by", "asynchronous": false, "params": [], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Transforms explicit administrative borders into relevant column\n\nReturns:\n    dict: Relevant column as well as initial\n        user prompted administrative level"]}, {"name": "cartiflette.utils.create_format_standardized", "asynchronous": false, "params": [], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Transforms user-prompted format into geopandas format\n\nReturns:\n    dict: Geopandas format as well as user-prompted\n     format"]}, {"name": "cartiflette.utils.create_format_driver", "asynchronous": false, "params": [], "returns": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": null}, "documentation": ["Transforms user-prompted format into Geopandas driver\n\nReturns:\n    dict: Geopandas driver as well as user-prompted\n     format"]}, {"name": "cartiflette.utils.standardize_inputs", "asynchronous": false, "params": [{"name": "vectorfile_format", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "cartiflette.utils.create_path_bucket", "asyn