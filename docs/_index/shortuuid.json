ocumentation": ["Generate and return a cryptographically secure short random string of `length`."]}, {"name": "shortuuid.main.ShortUUID.get_alphabet", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Return the current alphabet used for new UUIDs."]}, {"name": "shortuuid.main.ShortUUID.set_alphabet", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "alphabet", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Set the alphabet to be used for new UUIDs."]}, {"name": "shortuuid.main.ShortUUID.encoded_length", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "num_bytes", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["Return the string length of the shortened UUID."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "shortuuid.test_shortuuid", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "shortuuid.test_shortuuid.LegacyShortUUIDTest", "bases": ["unittest.TestCase"], "methods": [{"name": "shortuuid.test_shortuuid.LegacyShortUUIDTest.test_generation", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "shortuuid.test_shortuuid.LegacyShortUUIDTest.test_encoding", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentatio