in.random", "type": null, "documentation": []}, {"name": "shortuuid.main.get_alphabet", "type": null, "documentation": []}, {"name": "shortuuid.main.set_alphabet", "type": null, "documentation": []}], "classes": [{"name": "shortuuid.main.ShortUUID", "bases": ["object"], "methods": [{"name": "shortuuid.main.ShortUUID.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "alphabet", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "shortuuid.main.ShortUUID._length", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "documentation": ["Return the necessary length to fit the entire UUID given the current alphabet."]}, {"name": "shortuuid.main.ShortUUID.encode", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "uuid", "type": {"name": "_uu.UUID", "xref": {"fqname": "uuid.UUID", "project": "--std--"}, "params": null}, "default": null}, {"name": "pad_length", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Encode a UUID into a string (LSB first) according to the alphabet.\n\nIf leftmost (MSB) bits are 0, the string might be shorter."]}, {"name": "shortuuid.main.ShortUUID.decode", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name":