er_classes": [], "documentation": []}, {"name": "shortuuid.test_shortuuid.ShortUUIDPaddingTest", "bases": ["unittest.TestCase"], "methods": [{"name": "shortuuid.test_shortuuid.ShortUUIDPaddingTest.test_padding", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "shortuuid.test_shortuuid.ShortUUIDPaddingTest.test_decoding", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "shortuuid.test_shortuuid.ShortUUIDPaddingTest.test_consistency", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "shortuuid.test_shortuuid.EncodingEdgeCasesTest", "bases": ["unittest.TestCase"], "methods": [{"name": "shortuuid.test_shortuuid.EncodingEdgeCasesTest.test_decode_dict", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "shortuuid.test_shortuuid.DecodingEdgeCasesTest", "bases": ["unittest.TestCase"], "methods": [{"name": "shortuuid.test_shortuuid.DecodingEdgeCasesTest.test_decode_dict", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "shortuuid.test_shortuuid.CliTest", "bases": ["unittest.TestCase"], "methods": [{"name": "shortuuid.test_shortuuid.CliTest.test_shortuuid_command_produces_uuid", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "mock_print", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "shortuuid.test_shortuuid.CliTe