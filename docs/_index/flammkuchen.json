{"name": "flammkuchen", "metadata": {"name": "flammkuchen", "version": "1.0.3", "classifiers": ["Development Status :: 4 - Beta", "Intended Audience :: Science/Research", "License :: OSI Approved :: BSD License", "Programming Language :: Python :: 3.6", "Programming Language :: Python :: 3.7", "Programming Language :: Python :: 3.8", "Programming Language :: Python :: 3.9", "Topic :: Scientific/Engineering"], "home_page": "https://github.com/portugueslab/flammkuchen", "license": "BSD", "documentation_url": null, "dependencies": ["numpy", "scipy", "tables"], "summary": "Easy saving and loading of hdf5 files in python (forked from DeepDish)", "upload_time": 1689008149}, "documentation": [""], "modules": [{"name": "flammkuchen", "documentation": [], "functions": [], "variables": [{"name": "flammkuchen.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "flammkuchen.aslice", "xref": {"fqname": "flammkuchen.hdf5io.aslice", "project": null}}, {"name": "flammkuchen.Compression", "xref": {"fqname": "flammkuchen.hdf5io.Compression", "project": null}}, {"name": "flammkuchen.config", "xref": {"fqname": "flammkuchen.conf.config", "project": null}}, {"name": "flammkuchen.ForcePickle", "xref": {"fqname": "flammkuchen.hdf5io.ForcePickle", "project": null}}, {"name": "flammkuchen.load", "xref": {"fqname": "flammkuchen.hdf5io.load", "project": null}}, {"name": "flammkuchen.meta", "xref": {"fqname": "flammkuchen.hdf5io.meta", "project": null}}, {"name": "flammkuchen.save", "xref": {"fqname": "flammkuchen.hdf5io.save", "project": null}}]}, {"name": "flammkuchen.conf", "documentation": [], "functions": [{"name": "flammkuchen.conf.config", "asynchronous": false, "params": [], "returns": null, "documentation": ["Loads and returns a ConfigParser from `~/.flammkuchen.conf`.\n"]}], "variables": [], "classes": [], "exports": []}, {"name": "flammkuchen.hdf5io", "documentation": [], "functions": [{"name": "flammkuchen.hdf5io.is_pandas_dataframe", "asynchronous": false, "params": [{"name": "level", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io._dict_native_ok", "asynchronous": false, "params": [{"name": "d", "type": null, "default": null}], "returns": null, "documentation": ["This checks if a dictionary can be saved natively as HDF5 groups.\n\nIf it can't, it will be pickled."]}, {"name": "flammkuchen.hdf5io._get_compression_filters", "asynchronous": false, "params": [{"name": "compression", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io._save_ndarray", "asynchronous": false, "params": [{"name": "handler", "type": null, "default": null}, {"name": "group", "type": null, "default": null}, {"name": "name", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "filters", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io._save_pickled", "asynchronous": false, "params": [{"name": "handler", "type": null, "default": null}, {"name": "group", "type": null, "default": null}, {"name": "level", "type": null, "default": null}, {"name": "name", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io._is_linkable", "asynchronous": false, "params": [{"name": "level", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io._save_level", "asynchronous": false, "params": [{"name": "handler", "type": null, "default": null}, {"name": "group", "type": null, "default": null}, {"name": "level", "type": null, "default": null}, {"name": "name", "type": null, "default": "..."}, {"name": "filters", "type": null, "default": "..."}, {"name": "idtable", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io._load_specific_level", "asynchronous": false, "params": [{"name": "handler", "type": null, "default": null}, {"name": "grp", "type": null, "default": null}, {"name": "path", "type": null, "default": null}, {"name": "sel", "type": null, "default": "..."}, {"name": "pathtable", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io._load_pickled", "asynchronous": false, "params": [{"name": "level", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io._load_nonlink_level", "asynchronous": false, "params": [{"name": "handler", "type": null, "default": null}, {"name": "level", "type": null, "default": null}, {"name": "pathtable", "type": null, "default": null}, {"name": "pathname", "type": null, "default": null}], "returns": null, "documentation": ["Loads level and builds appropriate type, without handling softlinks"]}, {"name": "flammkuchen.hdf5io._load_level", "asynchronous": false, "params": [{"name": "handler", "type": null, "default": null}, {"name": "level", "type": null, "default": null}, {"name": "pathtable", "type": null, "default": null}], "returns": null, "documentation": ["Loads level and builds appropriate type, handling softlinks if necessary"]}, {"name": "flammkuchen.hdf5io._load_sliced_level", "asynchronous": false, "params": [{"name": "handler", "type": null, "default": null}, {"name": "level", "type": null, "default": null}, {"name": "sel", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "flammkuchen.hdf5io.meta", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}, {"name": "node", "type": null, "default": "..."}], "returns": null, "documentation": ["Returns the content of a given file as a multidimensional dictionary.\nIt is a lazy function for the `ls.get_tree` command and is easier\nto use upfront.\n\nThe node parameter can be easily used to track down a specific subnode.\nSimilar to `load`, one would use `/foo/bar` to access deeper nodes.\n\n# Parameters\n\npath\n\n: Filename which metadata is read\n\nnode\n\n: A node inside of the file similar to `load`, by default None\n\n# Returns\n\ndict or node\n\n: The metadata associated with a file, depending if the `node`\n  command was passed or not.\n"]}, {"name": "flammkuchen.hdf5io.save", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}, {"name": "data", "type": null, "default": null}, {"name": "compression", "type": null, "default": "..."}], "returns": null, "documentation": ["Save any Python structure to an HDF5 file. It is particularly suited for\nNumpy arrays. This function works similar to `numpy.save`, except if you\nsave a Python object at the top level, you do not need to issue\n`data.flat[0]` to retrieve it from inside a Numpy array of type\n`object`.\n\nSome types of objects get saved natively in HDF5. The rest get serialized\nautomatically. For most needs, you should be able to stick to the natively\nsupported types, which are:\n\n- Dictionaries\n- Short lists and tuples (\\<256 in length)\n- Basic data types (including strings and None)\n- Numpy arrays\n- Scipy sparse matrices\n- Pandas `DataFrame`, `Series`, and `Panel`\n- SimpleNamespaces (for Python >= 3.3, but see note below)\n\nA recommendation is to always convert your data to using only these types\nThat way your data will be portable and can be opened through any HDF5\nreader. A class that helps you with this is\n{class}`flammkuchen.util.Saveable`.\n\nLists and tuples are supported and can contain heterogeneous types. This is\nmostly useful and plays well with HDF5 for short lists and tuples. If you\nhave a long list (>256) it will be serialized automatically. However,\nin such cases it is common for the elements to have the same type, in which\ncase we strongly recommend converting to a Numpy array first.\n\nNote that the SimpleNamespace type will be read in as dictionaries for\nearlier versions of Python.\n\nThis function requires the [PyTables](http://www.pytables.org/) module to\nbe installed.\n\nYou can change the default compression method to `blosc` (much faster,\nbut less portable) by creating a `~/.flammkuchen.conf` with:\n\n```\n[io]\n    compression: blosc\n```\n\nThis is the recommended compression method if you plan to use your HDF5\nfiles exclusively through flammkuchen (or PyTables).\n\n# Parameters\n\npath\n\n: Filename to which the data is saved.\n\ndata\n\n: Data to be saved. This can be anything from a Numpy array, a string, an\n  object, or a dictionary containing all of them including more\n  dictionaries.\n\ncompression\n\n: Set compression method, choosing from `blosc`, `zlib`, `lzo`, `bzip2`\n  and more (see PyTables documentation). It can also be specified as a\n  tuple (e.g. `('blosc', 5)`), with the latter value specifying the\n  level of compression, choosing from 0 (no compression) to 9 (maximum\n  compression). Set to `None` to turn off compression. The default is\n  `zlib`, since it is highly portable; for much greater speed, try for\n  instance `blosc`.\n\n# See also\n\nload\n"]}, {"name": "flammkuchen.hdf5io.load", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}, {"name": "group", "type": null, "default": "..."}, {"name": "sel", "type": null, "default": "..."}, {"name": "unpack", "type": null, "default": "..."}], "returns": null, "documentation": ["Loads an HDF5 saved with `save`.\n\nThis function requires the [PyTables](http://www.pytables.org/) module to\nbe installed.\n\n# Parameters\n\npath\n\n: Filename from which to load the data.\n\ngroup\n\n: Load a specific group in the HDF5 hierarchy. If `group` is a list of\n  strings, then a tuple will be returned with all the groups that were\n  specified.\n\nsel\n\n: If you specify `group` and the target is a numpy array, then you can\n  use this to slice it. This is useful for opening subsets of large HDF5\n  files. To compose the selection, you can use `flammkuchen.aslice`.\n\nunpack\n\n: If True, a single-entry dictionaries will be unpacked and the value\n  will be returned directly. That is, if you save `dict(a=100)`, only\n  `100` will be loaded.\n\n# Returns\n\ndata\n\n: Hopefully an identical reconstruction of the data that was saved.\n\n# See also\n\nsave\n"]}], "variables": [{"name": "flammkuchen.hdf5io._pandas", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io._pandas", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io._sns", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io._sns", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io.IO_VERSION", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io.IO_PREFIX", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io.IO_VERSION_STR", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io.IO_UNPACK", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io.IO_ROOT_IS_SNS", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io.ATTR_TYPES", "type": null, "documentation": []}, {"name": "flammkuchen.hdf5io.aslice", "type": null, "documentation": []}], "classes": [{"name": "flammkuchen.hdf5io._HDFStoreWithHandle", "bases": ["pd.io.pytables.HDFStore"], "methods": [{"name": "flammkuchen.hdf5io._HDFStoreWithHandle.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "handle", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "flammkuchen.hdf5io.ForcePickle", "bases": ["object"], "methods": [{"name": "flammkuchen.hdf5io.ForcePickle.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "obj", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["When saving an object with `flammkuchen.save`, you can wrap objects in this\nclass to force them to be pickled