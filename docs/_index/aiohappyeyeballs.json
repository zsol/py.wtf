rns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Remove an address from the list of addr_infos.\n\nThe addr value is typically the return value of\nsock.getpeername()."]}], "variables": [], "classes": [], "exports": []}, {"name": "aiohappyeyeballs._staggered", "documentation": [], "functions": [{"name": "aiohappyeyeballs._staggered._set_result", "asynchronous": false, "params": [{"name": "wait_next", "type": {"name": "asyncio.Future", "xref": {"fqname": "asyncio.Future", "project": "--std--"}, "params": [{"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}]}, "default": null}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Set the result of a future if it is not already done."]}, {"name": "aiohappyeyeballs._staggered._wait_one", "asynchronous": true, "params": [{"name": "futures", "type": {"name": "Iterable", "xref": {"fqname": "typing.Iterable", "project": "--std--"}, "params": [{"name": "asyncio.Future", "xref": {"fqname": "asyncio.Future", "project": "--std--"}, "params": [{"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, "default": null}, {"name": "loop", "type": {"name": "asyncio.AbstractEventLoop", "xref": {"fqname": "asyncio.AbstractEventLoop", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "_T", "xref": {"fqname": "_T", "project": null}, "params": null}, "documentation": ["Wait for the first future to complete."]}, {"name": "aiohappyeyeballs._staggered.staggered_race", "asynchronous": true, "params": [{"name": "coro_fns", "type": {"name": "Iterable", "xref": {"fqname": "typing.Iterable", "project": "--std--"}, "params": [{"name": "Callable", "xref": {"fqname": "typing.Callable", "project": "--std--"}, "params": [{"name": "", "xref": null, "params": []}, {"name": "Awaitable", "xref": {"fqname": "typing.Awaitable", "project": "--std--"}, "params": [{"name": "_T", "xref": {"fqname": "_T", "project": null}, "params": null}]}]}]}, "default": null}, {"name": "delay", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}]}, "default": null}, {"name": "loop", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "asyncio.AbstractEventLoop", "xref": {"fqname": "asyncio.AbstractEventLoop", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "Tuple", "xref": {"fqname": "typing.Tuple", "project": "--std--"}, "params": [{"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "_T", "xref": {"fqname": "_T", "project": null}, "params": null}]}, {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "BaseException", "xref": {"fqname": "functions.BaseException", "project": "--std--"}, "params": null}]}]}]}, "documentation": ["Run coroutines with staggered start times and take the first to finish.\n\nThis method takes an iterable of coroutine functions. The first one is\nstarted immediately. From then on, whenever the immediately preceding one\nfails (raises an exception), or when *delay* seconds has passed, the next\ncoroutine is started. This continues until one of the coroutines complete\nsuccessfully, in which case all others are cancelled, or until all\ncoroutines fail.\n\nThe coroutines provided should be well-behaved in the following way:\n\n- They should only `return` if completed successfully.\n\n- They should always raise an exception if they did not complete\n  successfully. In particular, if they handle cancellation, they should\n  probably reraise, like this:\n\n  ```\n  try:\n      # do work\n  except asyncio.CancelledError:\n      # undo partially completed work\n      raise\n  ```\n\n# Args:\n\n> coro_fns: an iterable of coroutine functions, i.e. callables that\n>\n> : return a coroutine object when called. Use `functools.partial` or\n>   lambdas to pass arguments.\n>\n> delay: amount of time, in seconds, between starting coroutines. If\n>\n> : `None`, the coroutines will run sequentially.\n>\n> loop: the event loop to use. If `None`, the running loop is used.\n\n# Returns:\n\n> tuple *(winner_result, winner_index, exceptions)* where\n>\n> - *winner_result*: the result of the winning coroutine, or `None`\n>   if no coroutines won.\n> - *winner_index*: the index of the winning coroutine in\n>   `coro_fns`, or `None` if no coroutines won. If the winning\n>   coroutine may return None on success, *winner_index* can be used\n>   to definitively determine whether any coroutine won.\n> - *exceptions*: list of exceptions returned by the coroutines.\n>   `len(exceptions)` is equal to the number of coroutines actually\n>   started, and the order is the same as in `coro_fns`. The winning\n>   coroutine's entry is `None`.\n"]}], "variables": [{"name": "aiohappyeyeballs._staggered._T", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "aiohappyeyeballs.impl", "documentation": ["Base implementation."], "functions": [{"name": "aiohappyeyeballs.impl.start_connection", "asynchronous": true, "params": [{"name": "addr_infos", "type": {"name": "Sequence", "xref": {"fqname": "typing.Sequence", "project": "--std--"}, "params": [{"name": "AddrInfoType", "xref": {"fqname": "aiohappyeyeballs.impl.types.AddrInfoType", "project": null}, "params": null}]}, "default": null}, {"name": "local_addr_infos", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Sequence", "xref": {"fqname": "typing.Sequence", "project": "--std--"}, "params": [{"name": "AddrInfoType", "xref": {"fqname": "aiohappyeyeballs.impl.types.AddrInfoType", "project": null}, "params": null}]}]}, "default": "..."}, {"name": "happy_eyeballs_delay", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "float", "xref": {"fqname": "functions.float", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "interleave", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "loop", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "asyncio.AbstractEventLoop", "xref": {"fqname": "asyncio.AbstractEventLoop", "project": "--std--"}, "params": null}]}, "default": "..."}], "returns": {"name": "socket.socket", "xref": {"fqname": "socket.socket", "project": "--std--"}, "params": null}, "documentation": ["Connect to a TCP server.\n\nCreate a socket connection to a specified destination.  The\ndestination is specified as a list of AddrInfoType tuples as\nreturned from getaddrinfo().\n\nThe arguments are, in order:\n\n- `family`: the address family, e.g. `socket.AF_INET` or\n  : `socket.AF_INET6`.\n- `type`: the socket type, e.g. `socket.SOCK_STREAM` or\n  : `socket.SOCK_DGRAM`.\n- `proto`: the protocol, e.g. `socket.IPPROTO_TCP` or\n  : `socket.IPPROTO_UDP`.\n- `canonname`: the canonical name of the address, e.g.\n  : `\"www.python.org\"`.\n- `sockaddr`: the socket address\n\nThis method is a coroutine which will try to establish the connection\nin the background. When successful, the coroutine returns a\nsocket.\n\nThe expected use case is to use this method in conjunction with\nloop.create_connection() to establish a connection to a server:\n\n```\nsocket = await start_connection(addr_infos)\ntransport, protocol = await loop.create_connection(\n    MyProtocol, sock=socket, ...)\n```\n"]}, {"name": "aiohappyeyeballs.impl._connect_sock", "asynchronous": true, "params": [{"name": "loop", "type": {"name": "asyncio.AbstractEventLoop", "xref": {"fqname": "asyncio.AbstractEventLoop", "project": "--std--"}, "params": null}, "default": null}, {"name": "exceptions", "type": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "OSError", "xref": {"fqname": "functions.OSError", "project": "--std--"}, "params": null}, {"name": "RuntimeError", "xref": {"fqname": "functions.RuntimeError", "project": "--std--"}, "params": null}]}]}]}, "default": null}, {"name": "addr_info", "type": {"name": "AddrInfoType", "xref": {"fqname": "aiohappyeyeballs.impl.types.AddrInfoType", "project": null}, "params": null}, "default": null}, {"name": "local_addr_infos", "type": {"name": "Optional", "xref": {"fqname": "typing.Optional", "project": "--std--"}, "params": [{"name": "Sequence", "xref": {"fqname": "typing.Sequence", "project": "--std--"}, "params": [{"name": "AddrInfoType", "xref": {"fqname": "aiohappyeyeballs.impl.types.AddrInfoType", "project": null}, "params": null}]}]}, "default": "..."}], "returns": {"name": "socket.socket", "xref": {"fqname": "socket.socket", "project": "--std--"}, "params": null}, "documentation": ["Create, bind and connect one socket."]}, {"name": "aiohappyeyeballs.impl._interleave_addrinfos", "asynchronous": false, "params": [{"name": "addrinfos", "type": {"name": "Sequence", "xref": {"fqname": "typing.Sequence", "project": "--std--"}, "params": [{"name": "AddrInfoType", "xref": {"fqname": "aiohappyeyeballs.impl.types.AddrInfoType", "project": null}, "params": null}]}, "default": null}, {"name": "first_address_family_count", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "AddrInfoType", "xref": {"fqname": "aiohappyeyeballs.impl.types.AddrInfoType", "project": null}, "params": null}]}, "documentation": ["Interleave list of addrinfo tuples by family."]}], "variables": [{"name": "aiohappyeyeballs.impl.asyncio.futures.TimeoutError", "type": null, "documentation": ["type: ignore[attr-defined]"]}], "classes": [], "exports": []}]}