": [{"name": "restools.serving.shserver.SimpleHTTPRequestHandler.do_GET", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Serve a GET request."]}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.do_HEAD", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Serve a HEAD request."]}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.do_POST", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Serve a POST request."]}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.deal_post_data", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.send_head", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Common code for GET and HEAD commands.\n\nThis sends the response code and MIME headers.\n\nReturn value is either a file object (which has to be copied\nto the outputfile by the caller unless the command was HEAD,\nand must be closed by the caller under all circumstances), or\nNone, in which case the caller has nothing further to do."]}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.list_directory", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "path", "type": null, "default": null}], "returns": null, "documentation": ["Helper to produce a directory listing (absent index.html).\n\nReturn value is either a file object, or None (indicating an\nerror).  In either case, the headers are sent, making the\ninterface the same as for send_head()."]}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.translate_path", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "path", "type": null, "default": null}], "returns": null, "documentation": ["Translate a /-separated PATH to the local filename syntax.\n\nComponents that mean special things to the local file system\n(e.g. drive or directory names) are ignored.  (XXX They should\nprobably be diagnosed.)"]}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.copyfile", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "source", "type": null, "default": null}, {"name": "outputfile", "type": null, "default": null}], "returns": null, "documentation": ["Copy all data between two file objects.\n\nThe SOURCE argument is a file object open for reading\n(or anything with a read() method) and the DESTINATION\nargument is a file object open for writing (or\nanything with a write() method).\n\nThe only reason for overriding this would be to change\nthe block size or perhaps to replace newlines by CRLF\n-- note however that this the default server uses this\nto copy binary data as well."]}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.guess_type", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "path", "type": null, "default": null}], "returns": null, "documentation": ["Guess the type of a file.\nArgument is a PATH (a filename).\nReturn value is a string of the form type/subtype,\nusable for a MIME Content-type header.\nThe default implementation looks the file's extension\nup in the table self.extensions_map, using application/octet-stream\nas a default; however it would be permissible (if\nslow) to look inside the data to make a better guess."]}], "class_variables": [{"name": "restools.serving.shserver.SimpleHTTPRequestHandler.server_version", "type": null, "documentation": []}, {"name": "restools.serving.shserver.SimpleHTTPRequestHandler.extensions_map", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Simple HTTP request handler with GET/HEAD/POST commands.\n\nThis serves files from the current directory and any of its\nsubdirectories.  The MIME type for files is determined by\ncalling the .guess_type() method. And can reveive file uploaded\nby client.\n\nThe GET/HEAD/POST requests are identical except that the HEAD\nrequest omits the actual contents of the file."]}], "exports": [{"name": "restools.serving.shserver.SimpleHTTPRequestHandler", "xref": {"fqname": "restools.serving.shserver.SimpleHTTPRequestHandler", "project": null}}]}, {"name": "restools.plotting.plot_2D", "documentation": [], "functions": [{"name": "restools.plotting.plot_2D.savitzky_golay", "asynchronous": false, "params": [{"name": "y", "type": null, "default": null}, {"name": "window_size", "type": null, "default": null}, {"name": "order", "type": null, "default": null}, {"name": "deriv", "type": null, "default": "..."}, {"name": "rate", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "restools.plotting.plot_2D.plot_2D", "asynchronous": false, "params": [{"name": "ax", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "color", "type": null, "default": null}, {"name": "lab", "type": null, "default": null}, {"name": "y_min", "type": null, "default": "..."}, {"name": "y_max", "type": null, "default": "..."}, {"name": "y_var", "type": null, "default": "..."}, {"name": "is_smoothed", "type": null, "default": "..."}, {"name": "line_type", "type": null, "default": "..."}, {"name": "alpha", "type": null, "default": "..."}, {"name": "smooth_window", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "restools.plotting.plot_2D.extract_from_file", "asynchronous": false, "params": [{"name": "file_name", "type": null, "default": null}, {"name": "x_col", "type": null, "default": "..."}, {"name": "y_col", "type": null, "default": "..."}, {"name": "x_min", "ty