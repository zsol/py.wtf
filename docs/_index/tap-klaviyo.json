{"name": "tap-klaviyo", "metadata": {"name": "tap-klaviyo", "version": "1.0.1", "classifiers": ["Programming Language :: Python :: 3 :: Only"], "home_page": "http://singer.io", "license": null, "documentation_url": null, "dependencies": ["singer-python", "requests"], "summary": "Singer.io tap for extracting data from the Klaviyo API", "upload_time": 1734519760}, "documentation": [""], "modules": [{"name": "setup", "documentation": ["!/usr/bin/env python"], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "tests.test_klaviyo_discovery", "documentation": ["Test tap discovery mode and metadata."], "functions": [], "variables": [], "classes": [{"name": "tests.test_klaviyo_discovery.DiscoveryTest", "bases": ["KlaviyoBaseTest"], "methods": [{"name": "tests.test_klaviyo_discovery.DiscoveryTest.name", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_klaviyo_discovery.DiscoveryTest.test_run", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Testing that discovery creates the appropriate catalog with valid metadata.\n\n\u2022 Verify stream names follow naming convention\n  streams should only have lowercase alphas and underscores\n\u2022 Verify number of actual streams discovered match expected\n\u2022 verify there is only 1 top level breadcrumb\n\u2022 verify primary key(s)\n\u2022 verify the actual replication matches our expected replication method\n\u2022 verify that primary keys and bookmarks are given the inclusion of automatic.\n\u2022 verify that all other fields have inclusion of available metadata.\n\u2022 verify there are no duplicate metadata entries\n\u2022 verify replication key(s)\n\u2022 verify that if there is a replication key we are doing INCREMENTAL otherwise FULL"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Test tap discovery mode and metadata conforms to standards."]}], "exports": []}, {"name": "tests.test_klaviyo_bookmark", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "tests.test_klaviyo_bookmark.BookmarkTest", "bases": ["KlaviyoBaseTest"], "methods": [{"name": "tests.test_klaviyo_bookmark.BookmarkTest.name", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_klaviyo_bookmark.BookmarkTest.test_run", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Verify that for each stream you can do a sync which records bookmarks.\nThat the bookmark is the maximum value sent to the target for the replication key.\nThat a second sync respects the bookmark\n    All data of the second sync is >= the bookmark from the first sync\n    The number of records in the 2nd sync is less then the first (This assumes that\n        new data added to the stream is done at a rate slow enough that you haven't\n        doubled the amount of data from the start date to the first sync between\n        the first sync and second sync run in this test)\n\nVerify that for full table stream, all data replicated in sync 1 is replicated again in sync 2.\n\nPREREQUISITE\nFor EACH stream that is incrementally replicated there are multiple rows of data with\n    different values for the replication key"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Test tap sets a bookmark and respects it for the next sync of a stream"]}], "exports": []}, {"name": "tests.test_klaviyo_all_fields", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "tests.test_klaviyo_all_fields.TestKlaviyoAllFields", "bases": ["KlaviyoBaseTest"], "methods": [{"name": "tests.test_klaviyo_all_fields.TestKlaviyoAllFields.name", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tests.test_klaviyo_all_fields.TestKlaviyoAllFields.test_all_fields_run", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Assert given conditions:\n\u2022 verify no unexpected streams are replicated\n\u2022 Verify that more than just the automatic fields are replicated for each stream. \n\u2022 Verify all fields for each streams are replicated"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Ensure running the tap with all streams and fields selected results in the replication of all fields."]}], "exports": []}, {"name": "tests.test_klaviyo_pagination", "documentation": ["Test tap sync mode and metadata."], "functions": [], "variables": [], "classes": [{"name": "tests.test_klaviyo_pagination.PaginationTest", "bases": ["KlaviyoBaseTest"], "methods": [{"name": "tests.test_klaviyo_pagination.PaginationTest.name", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_klaviyo_pagination.PaginationTest.test_run", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Testing that sync creates the appropriate catalog with valid metadata.\n\n\u2022 Verify that all fields and all streams have selected set to True in the metadata"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["Test tap sync mode and metadata conforms to standards."]}], "exports": []}, {"name": "tests.test_klaviyo_sync_canary", "documentation": ["Test tap sync mode and metadata."], "functions": [], "variables": [], "classes": [{"name": "tests.test_klaviyo_sync_canary.SyncTest", "bases": ["KlaviyoBaseTest"], "methods": [{"name": "tests.test_klaviyo_sync_canary.SyncTest.name", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "tests.test_klaviyo_sync_canary.SyncTest.test_run", "asynchronous": false, "params": [{"name": "self", "type": null, "de