{"fqname": "T", "project": null}, "params": null}, "default": null}], "returns": {"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}, "documentation": ["Indicate that a method is intended to override a method in a base class.\nUsage:\n\n> class Base:\n> : def method(self) -> None: ...\n>\n>   : pass\n>\n> class Child(Base):\n>\n> : @override\n>   def method(self) -> None:\n>\n>   > super().method()\n\nWhen this decorator is applied to a method, the type checker will\nvalidate that it overrides a method with the same name on a base class.\nThis helps prevent bugs that may occur when a base class is changed\nwithout an equivalent change to a child class.\nThere is no runtime checking of these properties. The decorator\n\nsets the `__override__` attribute to `True` on the decorated object\nto allow runtime introspection.\n\nSee PEP 698 for details.\n"]}], "variables": [{"name": "pyre_extensions._T", "type": null, "documentation": []}, {"name": "pyre_extensions._R", "type": null, "documentation": []}, {"name": "pyre_extensions.TClass", "type": null, "documentation": []}, {"name": "pyre_extensions.JSON", "type": null, "documentation": []}, {"name": "pyre_extensions._A", "type": null, "documentation": []}, {"name": "pyre_extensions._B", "type": null, "documentation": []}, {"name": "pyre_extensions._T1", "type": null, "documentation": []}, {"name": "pyre_extensions._T2", "type": null, "documentation": []}, {"name": "pyre_extensions._Ts", "type": null, "documentation": []}, {"name": "pyre_extensions._P", "type": null, "documentation": []}, {"name": "pyre_extensions.T", "type": null, "documentation": []}], "classes": [{"name": "pyre_extensions.ParameterSpecification", "bases": ["list"], "methods": [{"name": "pyre_extensions.ParameterSpecification.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": {"name": "object", "xref": {"fqname": "functions.object", "project": "--std--"}, "params": n