pillow"}, "params": null}, "default": null}, {"name": "logo", "type": {"name": "Image.Image", "xref": {"fqname": "PIL.Image.Image", "project": "pillow"}, "params": null}, "default": null}, {"name": "title", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "subtitle", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "cta_text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "Image.Image", "xref": {"fqname": "PIL.Image.Image", "project": "pillow"}, "params": null}, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "poster_template.image_utils", "documentation": [], "functions": [{"name": "poster_template.image_utils.resize_image", "asynchronous": false, "params": [{"name": "pil_image", "type": null, "default": null}, {"name": "new_width", "type": null, "default": "..."}, {"name": "new_height", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "poster_template.image_utils.get_max_font_size", "asynchronous": false, "params": [{"name": "draw", "type": null, "default": null}, {"name": "text", "type": null, "default": null}, {"name": "font_path", "type": null, "default": null}, {"name": "max_width", "type": null, "default": null}, {"name": "max_height", "type": null, "default": null}, {"name": "initial_font_size", "type": null, "default": "..."}], "returns": null, "documentation": ["Get the maximum font size that allows the text to fit within the specified width and height.\n\n```\nparam draw\n\nImageDraw object.\n\nparam text\n\nThe text string.\n\nparam font_path\n\nPath to the .ttf font file.\n\nparam max_width\n\nMaximum allowed width for the text.\n\nparam max_height\n\nMaximum allowed height for the text.\n\nparam initial_font_size\n\nStarting font size.\n\nreturn\n\nThe best font size for the text to fit within the area.\n```\n"]}, {"name": "poster_template.image_utils.wrap_text", "asynchronous": false, "params": [{"name": "draw", "type": null, "default": null}, {"name": "text", "type": null, "default": null}, {"name": "font", "type": null, "default": null}, {"name": "max_width", "type": null, "default": null}], "returns": null, "documentation": ["Wrap the text to fit within the specified width.\n\n```\nparam draw\n\nImageDraw object.\n\nparam text\n\nThe text string.\n\nparam font\n\nImageFont object.\n\nparam max_width\n\nMaximum allowed width for the text.\n\nreturn\n\nA list of wrapped lines of text.\n```\n"]}, {"name": "poster_template.image_utils.random_alignment", "asynchronous": false, "params": [{"name": "text_width", "type": null, "default": null}, {"name": "max_width", "type": null, "default": null}, {"name": "alignment", "type": null, "default": null}], "returns": null, "documentation": ["Return a random alignment for the text.\nThe possible alignments are: 'left', 'center', 'right'.\nThe x-coordinate will be adjusted based on the selected alignment.\n\n```\nparam text_width\n\nWidth of the text.\n\nparam max_width\n\nMaximum width available for the text.\n\nreturn\n\nThe x-coordinate for the text based on the selected alignment.\n```\n"]}, {"name": "poster_template.image_utils.paste_title_subtitle_button", "asynchronous": false, "params": [{"name": "base_image", "type": {"name": "Image", "xref": {"fqname": "PIL.Image", "project": "pillow"}, "params": null}, "default": null}, {"name": "bbox", "type": {"name": "tuple", "xref": {"fqname": "functions.tuple", "project": "--std--"}, "params": null}, "default": null}, {"name": "title", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "subtitle", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "button_text", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "self_align", "type": null, "default": null}, {"name": "font_path", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": null, "documentation": ["Paste a title, subtitle, and action button inside a given bounding box on the base image,\nwith specific area allocations:\n\\- 40% for the title at the top\n\\- 40% for the subtitle in the middle\n\\- 20% width for the action button on the left side\nEach text element will have its font size dynamically adjusted based on the available area.\n\n```\nparam base_image\n\nThe base image (PIL Image).\n\nparam bbox\n\nA tuple (x, y, w, h) representing the top-left corner and width/height of the bounding box.\n\nparam title\n\nThe title text to display.\n\nparam subtitle\n\nThe subtitle text to display.\n\nparam button_text\n\nThe text on the action button.\n\nparam font_path\n\nPath to the .ttf font file (default is \"arial.ttf\").\n\nreturn\n\nThe modified PIL Image with the title, subtitle, and button pasted inside the bounding box.\n```\n"]}], "variables": [], "classes": [], "exports": []}]}