hronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "option", "type": null, "default": "..."}, {"name": "criteria", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Atom.__eq__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "atom", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "tsflow.chem.Atom.periodic_table", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": [":class Atom:\n    class Atom mainly contains atomic_number, element, and x,\n    Other attributes are not widely used\n    molecule_index shows on which molecule that this atom is contained in. For example, if we consider Intermediate C.C, \n    molecule_index can have either 0 or 1, and every atom within atom_list of Intermediate can be assigned by checking\n    which molecule does the atom belong to.\n\n:param data(str or integer):\n    Data is either symbol that represents element or atomic number"]}, {"name": "tsflow.chem.Molecule", "bases": [], "methods": [{"name": "tsflow.chem.Molecule.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "data", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.get_chg", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.get_multiplicity", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.get_adj_matrix", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.get_bo_matrix", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.copy", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.get_z_list", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns atomic number list of a given molecule\n \n:param:\n\n:return z_list(pyclass 'numpy.ndarray'):\n    list of atomic number"]}, {"name": "tsflow.chem.Molecule.get_element_list", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns element list of a given molecule\n \n:param:\n\n:return element_list(list of string):\n    list of element written as capital letters"]}, {"name": "tsflow.chem.Molecule.get_chg_list", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns chg list of a given molecule\n \n:param:\n\n:return chg_list(pyclass 'numpy.ndarray'):\n    list of formal charge"]}, {"name": "tsflow.chem.Molecule.get_radius_list", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns radius list of a given molecule\nEx. For CH4 with atom order [C,H,H,H,H], then radius_list is given as\n[0.8,0.5,0.5,0.5,0.5], if radius of C and H are given as 0.8 and 0.5 (unit is Angstrom)\n\n:param:\n\n:return radius_list(list of float):\n    list of radius of each atom"]}, {"name": "tsflow.chem.Molecule.get_bond_list", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "contain_bond_order", "type": null, "default": "..."}], "returns": null, "documentation": ["Returns the total bond list as list of tuples\nFor example, if CH4 is given with atom order [C,H,H,H,H], if contain_bond_order = False, the output is given as\n[(0,1),(0,2),(0,3),(0,4)]\nif contain_bond_order = True, the output is given as\n[(0,1,1),(0,2,1),(0,3,1),(0,4,1)]\n\n```\nparam contain_bond_order(boolean)\n\nIf contain_bond_order is False, it only returns bonds represented as (i,j) between atoms within the given intermediate.\nIf contain_bond_order is True, it returns bonds with bond order included (i,j,bond_order), where bond_order can only have 1,2,3.\nTherefore, a given molecule(self) should be kekulized.\n\nreturn bond_list(either list of tuple with size 2 or 3)\n\nbond_list\n```\n"]}, {"name": "tsflow.chem.Molecule.get_minimal_data", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.get_coordinate_list", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": ["Returns 3d coordinate of a given molecule\n\n:param:\n\n:return coordinate_list(list(size n) of tuple of float(size 3)):\n    "]}, {"name": "tsflow.chem.Molecule.print_coordinate_list", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "option", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.write_geometry", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "file_directory", "type": null, "default": null}, {"name": "option", "type": null, "default": "..."}, {"name": "criteria", "type": null, "default": "..."}], "returns": null, "documentation": ["Writes xyz file that contains the 3d molecular geometry\n\n```\nparam file_directory(str)\n\nDirectory for saving 3d geometry xyz file\n\nreturn\n\n```\n"]}, {"name": "tsflow.chem.Molecule.get_normal_vector", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "idx1", "type": null, "default": null}, {"name": "idx2", "type": null, "default": null}, {"name": "idx3", "type": null, "default": null}], "returns": null, "documentation": ["For given three atom indices, it returns normal vector that is perpendicular to\nthe plane generated by three indices\n\n```\nparam idx1,idx2,idx3(int)\n\nIndices for selected three atoms\n```\n\n:return normal_vector(pyclass 'numpy.ndarray' with length 3)\n\n: normal vector\n"]}, {"name": "tsflow.chem.Molecule.get_vector_between_atoms", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "idx1", "type": null, "default": null}, {"name": "idx2", "type": null, "default": null}, {"name": "normalize", "type": null, "default": "..."}], "returns": null, "documentation": ["For given two atom indices, it returns difference vector between two atoms. This function can be used to\nmove or rotate a given molecule\n\n```\nparam idx1,idx2(int)\n\nIndices for selected two atoms\n```\n\n\\:return difference_vector(pyclass 'numpy.ndarray' with length 3)\n"]}, {"name": "tsflow.chem.Molecule.get_internal_coordinate", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "indices", "type": null, "default": null}, {"name": "unit", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "tsflow.chem.Molecule.get_distance_between_atoms", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "idx1", "type": null, "default": null}, {"name": "idx2", "type": null, "default": null}], "returns": null, "documentation": ["Returns the distance between chosen two atoms\n\n```\nparam idx1,idx2(int)\n\nindices of chosen two atoms.\n\nreturn distance(float)\n\nDistance between selected two atoms\n```\n"]}, {"name": "tsflow.chem.Molecule.get_angle_between_atoms", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "idx1", "type": null, "default": null}, {"name": "idx2", "type": null, "default": null}, {"name": "idx3", "type": null, "default": null}, {"name": "unit", "type": null, "default": "..."}], "returns": null, "documentation": ["Returns the distance between chosen two atoms\n\n```\nparam idx1,idx2(int)\n\nindices of chosen two atoms.\n\nreturn distance(float)\n\nDistance between selected two atoms\n```\n"]}, {"name": "tsflow.chem.Molecule.get_dihedral_angle_between_atoms", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "idx1", "type": null, "default": null}, {"name": "idx2", "type": null, "default": null}, {"name": "idx3", "type": null, "default": null}, {"name": "idx4", "type": null, "default": null}, {"name": "unit", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": [":class Molecule:\n    class Molecule mainly contains atom_list, atom_feature, chg, bo_matrix, adj_matrix, energy, smiles, c_eig_list\n    atom_list is a list of atom (pyclass 'Atom')\n    atom_feature is a dict, where features of atom such as formal charge, number of pi bonds, etc, are stored.\n    Those information can be freely added by giving new dict\n    c_eig_list can be used to identify whether the given two molecules are the same. This c_eig_list is invariant\n    to the permutation of atom indexing, identification between any two generated molecules can be easily checked.\n\n:param data(str or xyz file or None):\n    data should be feeded as either smiles(str), xyz file(file) or None\n    * If smiles is used, rd_mol is generated using the given smiles and converted into ace_mol (pyclass 'Molecule)\n    * If xyz file is used, directly the 3d geometry of the given molecule is generated. If you want to generate adj_matrix,\n    bo_matrix, chg_list, etc, refer following method contained in pyclass 'Molecule' (charge of molecule should be given!!!)\n    i. Generate adj_matrix by using 'get_adj_matrix_from_distance' stored in class 'Molecule'\n    ii. Generate bo_matrix by using 'get_adj_matrix_from_adj_matrix' stored in class 'Molecule'\n    iii. Then, using those bo_matrix, get chg_list by using 'get_chg_list_from_bo_matrix' stored n class 'Molecule'\n    * If None is used, only blank virtual molecule is generated"]}], "exports": []}]}