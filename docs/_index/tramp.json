false, "params": [{"name": "cls", "type": null, "default": null}, {"name": "obj", "type": {"name": "T | None", "xref": null, "params": null}, "default": null}], "returns": {"name": "Optional", "xref": {"fqname": "tramp.optionals.Optional", "project": null}, "params": [{"name": "T", "xref": {"fqname": "T", "project": null}, "params": null}]}, "documentation": []}], "class_variables": [{"name": "tramp.optionals.Optional.Some", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "Optional", "xref": {"fqname": "tramp.optionals.Optional", "project": null}, "params": [{"name": "V", "xref": {"fqname": "V", "project": null}, "params": null}]}]}, "documentation": []}, {"name": "tramp.optionals.Optional.Nothing", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "Optional", "xref": {"fqname": "tramp.optionals.Optional", "project": null}, "params": [{"name": "V", "xref": {"fqname": "V", "project": null}, "params": null}]}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "tramp.optionals.Some", "bases": ["Optional"], "methods": [{"name": "tramp.optionals.Some.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "value", "type": {"name": "V", "xref": {"fqname": "V", "project": null}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "tramp.optionals.Some.value", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "V", "xref": {"fqname": "V", "project": null}, "params": null}, "documentation": []}, {"name": "tramp.optionals.Some.__bool__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "tramp.optionals.Some.__match_args__", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}, {"name": "tramp.optionals.Nothing", "bases": ["Optional"], "methods": [{"name": "tramp.optionals.Nothing.value", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": {"name": "NoReturn", "xref": {"fqname": "typing.NoReturn", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "tramp.optionals.Nothing.value_or", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "default", "type": {"name": "V", "xref": {"fqname": "V", "project": null}, "params": null}, "default": null}], "returns": {"name": "V", "xref": {"fqname": "V", "project": null}, "params": null}, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "tramp.annotations", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "tramp.async_batch_iterator", "documentation": ["Batched Async Iterator yields results one at a time from batches. It takes a coroutine that fetches batches and returns\nthem as an iterable. The iterable can be of either type Iterable or AsyncIterable. The coroutine should accept a batch\nindex to determine which batch to return next.\n\nThe AsyncBatchIterator can be preloaded with a batch by passing it to the constructor along with a batch index.\n\nExample:\n    async def get_batch(batch_index: int) -> Iterable[int] | None:\n        if batch_index > 1:\n            return\n\n        return range(batch_index * 2, (batch_index + 1) * 2)\n\n    async for result in AsyncBatchIterator(get_batch):\n        print(result)\n\n    # Output:\n    # 0\n    # 1\n    # 2\n    # 3\n\n\nAsync Iterator Example:\n    async def get_batch(batch_index: int) -> AsyncIterable[int] | None:\n        if batch_index > 1:\n            return\n\n        return gen(batch_index * 2)\n\n    async def gen(start: int) -> AsyncGenerator[int, None]:\n        