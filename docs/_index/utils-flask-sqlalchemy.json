izers", "documentation": ["Serialize function for SQLAlchemy models"], "functions": [{"name": "utils_flask_sqla.serializers.get_serializer", "asynchronous": false, "params": [{"name": "col", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "utils_flask_sqla.serializers.get_serializable_decorator", "asynchronous": false, "params": [{"name": "fields", "type": null, "default": "..."}, {"name": "exclude", "type": null, "default": "..."}, {"name": "stringify", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "utils_flask_sqla.serializers.serializable", "asynchronous": false, "params": [{"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [{"name": "utils_flask_sqla.serializers.SERIALIZERS", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "utils_flask_sqla.models", "documentation": [], "functions": [{"name": "utils_flask_sqla.models.is_whereclause_compatible", "asynchronous": false, "params": [{"name": "object", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "utils_flask_sqla.models.qfilter", "asynchronous": false, "params": [{"name": "*args_dec", "type": null, "default": null}, {"name": "**kwargs_dec", "type": null, "default": null}], "returns": null, "documentation": ["This decorator allows you to constrain a SQLAlchemy model method to return a whereclause (by default) or a query. If\nits `query` is set to True and no query is given in a `query` parameter, it will create one with a simple select: `select(model)`. The latter\nis accessible through `kwargs.get(\"query\")` in the decorated method.\n\nThe decorated query requires the following minimum parameters (cls,\\*\\*kwargs).\n\n```pycon\n>>> from utils_flask_sqla.models import qfilter\n>>> from sqlalchemy.sql import select\n>>> class Station(NomenclaturesMixin, db.Model):\n        __tablename__ = \"t_stations\"\n        __table_args__ = {\"schema\": \"pr_occhab\"}\n        # If you wish the method to return a whereclause\n        @qfilter\n        def filter_by_params(cls,**kwargs):\n            filters = []\n            if \"id_station\" in kwargs:\n                filters.append(Station.id_station == kwargs[\"id_station\"])\n            return sa.and_(*filters)\n        # If you wish the method to return a query\n        @qfilter(query=True)\n        def filter_by_paramsQ(cls,**kwargs):\n            query = kwargs(\"query\") #  select(Station)\n            if \"id_station\" in kwargs:\n                query = query.filter_by(id_station=kwargs[\"id_station\"])\n            return query\n```\n\n```pycon\n>>> query = Station.filter_by_paramsQ(id_station=1)\n>>> query2 = select(Station).where(Station.filter_by_params(id_station=1))\n```\n\n# Parameters\n\nquery\n\n: decorated function must (or not) return a query (Select)\n\n# Returns\n\nfunction\n\n: decorated method\n\n# Raises\n\nValueError\n\n: Method's class is not DefaultMeta class\n\nValueError\n\n: if query is True and return value of the decorated method is not Select\n\nValueError\n\n: if query is False and return value of the decorated method is not a : `bool` or sqlalchemy.sql.expression.BooleanClauseList\\` or `sqlalchemy.sql.expression.BinaryExpression`\n"]}, {"name": "utils_flask_sqla.models._qfilter", "asynchronous": false, "params": [{"name": "query", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [{"name": "utils_flask_sqla.models.AUTHORIZED_WHERECLAUSE_TYPES", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "utils_flask_sqla.schema", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "utils_flask_sqla.schema.SmartRelationshipsMixin", "bases": [], "methods": [{"name": "utils_flask_sqla.schema.SmartRelationshipsMixin.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["This mixin automatically exclude from serialization:\n\n- Nested, RelatedList and Related fields\n- all fields with exclude=True in their metadata (e.g. `fields.String(metadata={'exclude': True})`)\n\nAdding only Nested fields to `only` will not exclude others fields and serialize specified Nested fields.\nAdding exclude=True fields to `only` will serialize only specified fields (default marshmallow behaviour).\nYou can use '+field_name' syntax on `only` to serialize default excluded fields (with metadata exclude = True) without other fields.\n\nExamples :\n\n```python\nclass FooSchema(SmartRelationshipsMixin):\n    id = fields.Int()\n    name = field.Str()\n    default_excluded_field = fields.Str(metadata={\"exclude\": True})\n    relationship = fields.Nested(OtherSchema) # or field.RelatedList() / field.Related()\n\nFooSchema().dump() -> {\"id\": 1, \"name\": \"toto\" }\nFooSchema(only=[\"+default_excluded_field\"]).dump() -> {\"id\": 1, \"name\": \"toto\", default_excluded_field: \"test\" }\nFooSchema(only=[\"relationship\"]).dump() -> {\"id\": 1, \"name\": \"toto\",  relationship : {OtherSchema...} }\nFooSchema(only=[\"id\", \"relationship\"]).dump() -> {\"id\": 1, relationship : {OtherSchema...} }\n```\n", "from flask_marshmallow.fields import RelatedList"]}], "exports": []}, {"name": "utils_flask_sqla.tests.test_serializers", "documentation": [], "functions": [], "variables": [{"name": "utils_flask_sqla.tests.test_serializers.db", "type": null, "documentation": []}], "classes": [{"name": "utils_flask_sqla.tests.test_serializers.Parent", "bases": ["db.Model"], "methods": [], "class_variables": [{"name": "utils_flask_sqla.tests.test_serializers.Parent.pk", "type": null, "documentation": []}], "instance_variables": []