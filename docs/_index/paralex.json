name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Arguments:\n    basepath (str): Absolute path where the metadata file will be stored.\n\nReturns:\n    frictionless package"]}, {"name": "paralex.meta.paralex_factory", "asynchronous": false, "params": [{"name": "title", "type": null, "default": null}, {"name": "files", "type": null, "default": "..."}, {"name": "tables", "type": null, "default": "..."}, {"name": "**kwargs", "type": null, "default": null}], "returns": null, "documentation": ["Generate frictionless metadata for this paralex lexicon.\n\nUse the default package, fillin-in user specified information.\n    Keeps only existing tables,\n    updates foreign keys and table relations according to which tables are\n    declared.\n\nArgs:\n    title (str): a title for the package\n    files (dict): dictionary of file names to resource information\n    tables (dict): deprecated, see `files`\n    **kwargs:\n\nReturns:"]}], "variables": [{"name": "paralex.meta.relations", "type": null, "documentation": []}, {"name": "paralex.meta.resource_name_pattern", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "paralex", "documentation": [], "functions": [], "variables": [{"name": "paralex.VERSION", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "paralex.create_ids", "xref": {"fqname": "paralex.utils.create_ids", "project": null}}, {"name": "paralex.docs_path", "xref": {"fqname": "paralex.paths.docs_path", "project": null}}, {"name": "paralex.paralex_factory", "xref": {"fqname": "paralex.meta.paralex_factory", "project": null}}, {"name": "paralex.read_table", "xref": {"fqname": "paralex.utils.read_table", "project": null}}, {"name": "paralex.segment_sounds", "xref": {"fqname": "paralex.utils.segment_sounds", "project": null}}, {"name": "paralex.standard_path", "xref": {"fqname": "paralex.paths.standard_path", "project": null}}, {"name": "paralex.strategies", "xref": {"fqname": "parale