uth.adapter.VTSAdapter", "bases": [], "methods": [{"name": "pymouth.adapter.VTSAdapter.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "analyser", "type": {"name": "Type", "xref": {"fqname": "typing.Type", "project": "--std--"}, "params": [{"name": "Analyser", "xref": {"fqname": "pymouth.adapter.analyser.Analyser", "project": null}, "params": null}]}, "default": null}, {"name": "db_vts_mouth_param", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "vowel_vts_mouth_param", "type": {"name": "dict", "xref": {"fqname": "functions.dict", "project": "--std--"}, "params": [{"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}]}, "default": "..."}, {"name": "ws_uri", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "plugin_info", "type": {"name": "VTSPluginInfo", "xref": {"fqname": "pymouth.adapter.vts_websockets.VTSPluginInfo", "project": null}, "params": null}, "default": "..."}], "returns": null, "documentation": ["VTubeStudio Adapter.\n\\:param analyser: \u5206\u6790\u4eea,\u5fc5\u987b\u662f Analyser \u7684\u5b50\u7c7b\n\\:param db_vts_mouth_param: \u4ec5\u4f5c\u7528\u4e8e\\`DBAnalyser\\`, VTS\u4e2d\u63a7\u5236mouth_input\u7684\u53c2\u6570, \u5982\u679c\u4e0d\u662f\u9ed8\u8ba4\u503c\u8bf7\u81ea\u884c\u4fee\u6539.\n\\:param vowel_vts_mouth_param: \u4ec5\u4f5c\u7528\u4e8eVowelAnalyser, VTS\u4e2d\u63a7\u5236mouth\u7684\u53c2\u6570,\u8fd9\u4e2a\u53c2\u6570\u9ed8\u8ba4\u662f ('VoiceSilence', 'VoiceA', 'VoiceI', 'VoiceU', 'VoiceE', 'VoiceO')\n\n> \u5982\u679c\u4f60\u7684VTS\u4e2d\u4e0d\u662f\u8fd9\u4e9b\u9ed8\u8ba4\u503c\uff0c\u4f60\u53ef\u4ee5\u901a\u8fc7\u8fd9\u4e2a\u53c2\u6570\u4fee\u6539\u4ee5\u5339\u914d\u4f60VTS\u4e2d\u5173\u4e8eAIUEO