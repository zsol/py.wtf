ion": []}, {"name": "pytest_sftpserver.sftp.server.SFTPServer.host", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pytest_sftpserver.sftp.server.SFTPServer.url", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pytest_sftpserver.sftp.server.SFTPServer.wait_for_bind", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "timeout", "type": null, "default": "..."}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "pytest_sftpserver.compat", "documentation": ["encoding: utf-8"], "functions": [{"name": "pytest_sftpserver.compat.getcallargs", "asynchronous": false, "params": [{"name": "func", "type": null, "default": null}, {"name": "*args", "type": null, "default": null}, {"name": "**kwds", "type": null, "default": null}], "returns": null, "documentation": ["Get the actual value bounded to each formal parameter when calling\n`func(*args,**kwds)`.\n\nIt works for methods too (bounded, unbounded, staticmethods, classmethods).\n\n@returns: `(bindings, missing_args)`, where:\n: - `bindings` is a mapping of every formal parameter (including varargs\n    : and kwargs if present) of the function to the respective bounded value.\n  - `missing_args` is a tuple of the formal parameters whose value was not\n    : provided (i.e. using the respective default value)\n\nExamples::\n: ```pycon\n  >>> def func(a, b='foo', c=None, *x, **y):\n  ...     pass\n  >>> getcallargs(func, 5)\n  ({'a': 5, 'y': {}, 'c': None, 'b': 'foo', 'x': ()}, ('b', 'c'))\n  >>> getcallargs(func, 5, 'foo')\n  ({'a': 5, 'y': {}, 'c': None, 'b': 'foo', 'x': ()}, ('c',))\n  >>> getcallargs(func, 5, c=['a', 'b'])\n  ({'a': 5, 'y': {}, 'c': ['a', 'b'], 'b': 'foo', 'x': ()}, ('b',))\n  >>> getcallargs(func, 5, 6, 7, 8)\n  ({'a': 5, 'y': {}, 'c': 7, 'b': 6, 'x': (8,)}, ())\n  >>> getcallargs(func, 5, z=3, b=2)\n  ({'a': 5, 'y': {'z': 3}, 'c': None, 'b': 2, 'x': ()}, ('c',))\n  ```\n", "getcallargs fallback for Python 2.6", "Taken from http://code.activestate.com/recipes/551779/, slightly modified"]}], "variables": [], "classes": [], "exports": []}, {"name": "pytest_sftpserver.sftp.util", "documentation": ["encoding: utf-8"], "functions": [{"name": "pytest_sftpserver.sftp.util._mkabspath", "asynchronous": false, "params": [{"name": "path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pytest_sftpserver.sftp.util.abspath", "asynchronous": false, "params": [{"name": "func", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "pytest_sftpserver.sftp", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": []}, {"name": "pytest_sftpserver.sftp.content_provider", "documentation": ["encoding: utf-8"], "functions": [], "variables": [], "classes": [{"name": "pytest_sftpserver.sftp.content_provider.ContentProvider", "bases": ["object"], "methods": [{"name": "pytest_sftpserver.sftp.content_provider.ContentProvider.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "content_object", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "pytest_sftpserver.sftp.content_provider.ContentProvider.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "path", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "pytest_sftpserver.sftp.content_provider.ContentProvider.put", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "path", "type": null, "default": null}, {"name": "data", "type": null, "default": null}], "returns": null, "documentation": []}, {"name"