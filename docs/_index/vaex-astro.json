.."}, {"name": "long_out", "type": null, "default": "..."}, {"name": "lat_out", "type": null, "default": "..."}, {"name": "name_prefix", "type": null, "default": "..."}, {"name": "radians", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Add galactic coordates (long_out, lat_out) from equatorial coordinates.\n\n```\nparam long_in\n\nName/expression for right ascension\n\nparam lat_in\n\nName/expression for declination\n\nparam long_out\n\nOutput name for galactic longitude\n\nparam lat_out\n\nOutput name for galactic latitude\n\nparam name_prefix\n\n\n\nparam radians\n\ninput and output in radians (True), or degrees (False)\n\nreturn\n\n```\n"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.gal2eq", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "long_in", "type": null, "default": "..."}, {"name": "lat_in", "type": null, "default": "..."}, {"name": "long_out", "type": null, "default": "..."}, {"name": "lat_out", "type": null, "default": "..."}, {"name": "name_prefix", "type": null, "default": "..."}, {"name": "radians", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Convert from galactic (l,b) to equatorial (ra,dec) spherical coordinate system.\n\\:param long_in: longitudinal angle l\n\\:param lat_in: latitudinal angle b\n\\:param long_out: right ascension\n\\:param lat_out: declination\n\\:param name_prefix:\n\\:param radians: input and output in radians (True), or degrees (False)\n"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.pm_eq2gal", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "long_in", "type": null, "default": "..."}, {"name": "lat_in", "type": null, "default": "..."}, {"name": "pm_long", "type": null, "default": "..."}, {"name": "pm_lat", "type": null, "default": "..."}, {"name": "pm_long_out", "type": null, "default": "..."}, {"name": "pm_lat_out", "type": null, "default": "..."}, {"name": "name_prefix", "type": null, "default": "..."}, {"name": "right_ascension_galactic_pole", "type": null, "default": "..."}, {"name": "declination_galactic_pole", "type": null, "default": "..."}, {"name": "propagate_uncertainties", "type": null, "default": "..."}, {"name": "radians", "type": null, "default": "..."}, {"name": "inverse", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Transform/rotate proper motions from equatorial to galactic coordinates\n\nTaken from <http://arxiv.org/abs/1306.2945>\n\n```\nparam long_in\n\nName/expression for right ascension\n\nparam lat_in\n\nName/expression for declination\n\nparam pm_long\n\nProper motion for ra\n\nparam pm_lat\n\nProper motion for dec\n\nparam pm_long_out\n\nOutput name for output proper motion on l direction\n\nparam pm_lat_out\n\nOutput name for output proper motion on b direction\n\nparam name_prefix\n\n\n\nparam radians\n\ninput and output in radians (True), or degrees (False)\n\nparap inverse\n\n(For internal use) convert from galactic to equatorial instead\n\nreturn\n\n```\n"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.pm_gal2eq", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "long_in", "type": null, "default": "..."}, {"name": "lat_in", "type": null, "default": "..."}, {"name": "pm_long", "type": null, "default": "..."}, {"name": "pm_lat", "type": null, "default": "..."}, {"name": "pm_long_out", "type": null, "default": "..."}, {"name": "pm_lat_out", "type": null, "default": "..."}, {"name": "name_prefix", "type": null, "default": "..."}, {"name": "right_ascension_galactic_pole", "type": null, "default": "..."}, {"name": "declination_galactic_pole", "type": null, "default": "..."}, {"name": "propagate_uncertainties", "type": null, "default": "..."}, {"name": "radians", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Transform/rotate proper motions from galactic to equatorial coordinates.\n\nInverse of {py}`pm_eq2gal`\n"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.cartesian_angular_momenta", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": "..."}, {"name": "y", "type": null, "default": "..."}, {"name": "z", "type": null, "default": "..."}, {"name": "vx", "type": null, "default": "..."}, {"name": "vy", "type": null, "default": "..."}, {"name": "vz", "type": null, "default": "..."}, {"name": "Lx", "type": null, "default": "..."}, {"name": "Ly", "type": null, "default": "..."}, {"name": "Lz", "type": null, "default": "..."}, {"name": "propagate_uncertainties", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the angular momentum components provided Cartesian positions and velocities.\nBe mindful of the point of origin: ex. if considering Galactic dynamics, and positions and\nvelocities should be as seen from the Galactic centre.\n\n```\nparam x\n\nx-position Cartesian component\n\nparam y\n\ny-position Cartesian component\n\nparam z\n\nz-position Cartesian component\n\nparam vx\n\nx-velocity Cartesian component\n\nparam vy\n\ny-velocity Cartesian component\n\nparam vz\n\nz-velocity Cartesian component\n\nparam Lx\n\nname of virtual column\n\nparam Ly\n\nname of virtual column\n\nparam Lz\n\nname of virtial column\n\npropagate_uncertainties\n\n(bool) whether to propagate the uncertainties of\n```\n\nthe positions and velocities to the angular momentum components\n"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.proper_motion2vperpendicular", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "distance", "type": null, "default": "..."}, {"name": "pm_long", "type": null, "default": "..."}, {"name": "pm_lat", "type": null, "default": "..."}, {"name": "vl", "type": null, "default": "..."}, {"name": "vb", "type": null, "default": "..."}, {"name": "propagate_uncertainties", "type": null, "default": "..."}, {"name": "radians", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Convert proper motion to perpendicular velocities.\n\n```\nparam distance\n\n\n\nparam pm_long\n\n\n\nparam pm_lat\n\n\n\nparam vl\n\n\n\nparam vb\n\n\n\nparam cov_matrix_distance_pm_long_pm_lat\n\n\n\nparam uncertainty_postfix\n\n\n\nparam covariance_postfix\n\n\n\nparam radians\n\n\n\nreturn\n\n```\n"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.celestial", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "long_in", "type": null, "default": null}, {"name": "lat_in", "type": null, "default": null}, {"name": "long_out", "type": null, "default": null}, {"name": "lat_out", "type": null, "default": null}, {"name": "name_prefix", "type": null, "default": "..."}, {"name": "radians", "type": null, "default": "..."}, {"name": "_matrix", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Adds celestial/spherical coordinates"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.equatorial2galactic_cartesian", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "alpha", "type": null, "default": null}, {"name": "delta", "type": null, "default": null}, {"name": "distance", "type": null, "default": null}, {"name": "xname", "type": null, "default": null}, {"name": "yname", "type": null, "default": null}, {"name": "zname", "type": null, "default": null}, {"name": "radians", "type": null, "default": "..."}, {"name": "alpha_gp", "type": null, "default": "..."}, {"name": "delta_gp", "type": null, "default": "..."}, {"name": "l_omega", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["From http://arxiv.org/pdf/1306.2945v2.pdf"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.lbrvrpm2vcartesian", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "long_in", "type": null, "default": "..."}, {"name": "lat_in", "type": null, "default": "..."}, {"name": "distance", "type": null, "default": "..."}, {"name": "pm_long", "type": null, "default": "..."}, {"name": "pm_lat", "type": null, "default": "..."}, {"name": "vr", "type": null, "default": "..."}, {"name": "vx", "type": null, "default": "..."}, {"name": "vy", "type": null, "default": "..."}, {"name": "vz", "type": null, "default": "..."}, {"name": "center_v", "type": null, "default": "..."}, {"name": "propagate_uncertainties", "type": null, "default": "..."}, {"name": "radians", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Convert radial velocity and galactic proper motions (and positions) to cartesian velocities wrt the center_v\n\nBased on <http://adsabs.harvard.edu/abs/1987AJ.....93..864J>\n\n```\nparam long_in\n\nName/expression for galactic longitude\n\nparam lat_in\n\nName/expression for galactic latitude\n\nparam distance\n\nName/expression for heliocentric distance\n\nparam pm_long\n\nName/expression for the galactic proper motion in latitude direction (pm_l*, so cosine(b) term should be included)\n\nparam pm_lat\n\nName/expression for the galactic proper motion in longitude direction\n\nparam vr\n\nName/expression for the radial velocity\n\nparam vx\n\nOutput name for the cartesian velocity x-component\n\nparam vy\n\nOutput name for the cartesian velocity y-component\n\nparam vz\n\nOutput name for the cartesian velocity z-component\n\nparam center_v\n\nExtra motion that should be added, for instance lsr + motion of the sun wrt the galactic restframe\n\nparam radians\n\ninput and output in radians (True), or degrees (False)\n\nreturn\n\n```\n"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.velocity_cartesian2pmvr", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "x", "type": null, "default": "..."}, {"name": "y", "type": null, "default": "..."}, {"name": "z", "type": null, "default": "..."}, {"name": "vx", "type": null, "default": "..."}, {"name": "vy", "type": null, "default": "..."}, {"name": "vz", "type": null, "default": "..."}, {"name": "vr", "type": null, "default": "..."}, {"name": "pm_long", "type": null, "default": "..."}, {"name": "pm_lat", "type": null, "default": "..."}, {"name": "distance", "type": null, "default": "..."}, {"name": "inplace", "type": null, "default": "..."}], "returns": null, "documentation": ["Concert velocities from a cartesian system to proper motions and radial velocities\n\nTODO: errors\n\n```\nparam x\n\nname of x column (input)\n\nparam y\n\ny\n\nparam z\n\nz\n\nparam vx\n\nvx\n\nparam vy\n\nvy\n\nparam vz\n\nvz\n\nparam vr\n\nname of the column for the radial velocity in the r direction (output)\n\nparam pm_long\n\nname of the column for the proper motion component in the longitude direction  (output)\n\nparam pm_lat\n\nname of the column for the proper motion component in the latitude direction, positive points to the north pole (output)\n\nparam distance\n\nExpression for distance, if not given defaults to sqrt(x**2+y**2+z**2), but if this column already exists, passing this expression may lead to a better performance\n\nreturn\n\n```\n"]}, {"name": "vaex.astro.transformations.DataFrameAccessorAstro.parallax2distance", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "parallax", "type": null, "default": "..."}, {"name": "distance_name", "type": null, "default": "..."}, {"name": "parallax_uncertainty", "type": null, 