ams": [{"name": "x", "type": null, "default": null}, {"name": "s", "type": null, "default": null}, {"name": "xp", "type": null, "default": null}], "returns": null, "documentation": ["Interpolate the uniform samples s(x) onto xp (which could also non-uniform). If\nthe samples s(x) are uniform and satisfy the Nyquist-criterion the signal at `xp` is\nreconstructed perfectly.\n\nArgs:\n  x (array, floats): uniform sample points\n  s (array, floats): uniform sample values\n  xp (array, floats): points of interpolated signal\n\nReturns:\n  sp (array, floats): interpolated signal at xp."]}], "variables": [], "classes": [], "exports": []}, {"name": "fsinc.fsinc_2d", "documentation": [], "functions": [{"name": "fsinc.fsinc_2d.sinc2d", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "s", "type": null, "default": null}, {"name": "xp", "type": null, "default": null}, {"name": "yp", "type": null, "default": null}, {"name": "norm", "type": null, "default": "..."}, {"name": "eps", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the fast 2D sinc-transform by ways of the non-uniform fast Fourier transform.\n\nsp = sum sinc(x - xp) * sinc(y - xp) * s\n\nArgs:\n  x (array, floats): sample points, x-coordinate\n  y (array, floats): sample points, y-coordinate\n  s (array, floats or complex): sample values at (x,y)\n  xp (array, floats): target grid\n  yp (array, floats): target grid\n  norm (bool): use normalized sinc: sinc(pi*x)/pi*x (default: False)\n\nReturns:\n  sp (array, floats): transformed signal to (xp, yp)"]}, {"name": "fsinc.fsinc_2d.sincsq2d", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "s", "type": null, "default": null}, {"name": "xp", "type": null, "default": null}, {"name": "yp", "type": null, "default": null}, {"name": "norm", "type": null, "default": "..."}, {"name": "eps", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the fast 2D sinc-transform squared by ways of the non-uniform fast Fourier transform.\n\nsp = sum sinc^2(x - xp) * sinc^2(y - xp) * s\n\nArgs:\n  x (array, floats): sample points, x-coordinate\n  y (array, floats): sample points, y-coordinate\n  s (array, floats or complex): sample values at (x,y)\n  xp (array, floats): target grid\n  yp (array, floats): target grid\n  norm (bool): use normalized sinc: sinc(pi*x)/pi*x (default: False)\n\nReturns:\n  sp (array, floats): transformed signal to (xp, yp)"]}], "variables": [], "classes": [], "exports": []}, {"name": "fsinc.fsinc_1d_nu", "documentation": [], "functions": [{"name": "fsinc.fsinc_1d_nu.sinc1d_interp_nu2", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "s", "type": null, "default": null}, {"name": "xp", "type": null, "default": null}, {"name": "B", "type": null, "default": "..."}], "returns": null, "documentation": ["Interpolate the non-uniform samples s(x) onto xp (which could also be non-uniform).\n\nThis uses Jacobian weighting (the difference between the samples as weighting).\n\nArgs:\n  x (array, floats): non-uniform sample points\n  s (array, floats): non-uniform sample values\n  xp (array, floats): points of interpolated signal\n  B (float): bandlimit of s(x) (default: 3.)\n\nReturns:\n  sp (array, floats): interpolated signal at xp."]}, {"name": "fsinc.fsinc_1d_nu.jacobi_1d", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}], "returns": null, "documentation": ["The difference between each sample is used as weight."]}, {"name": "fsinc.fsinc_1d_nu.sinc1d_interp_nu3", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "s", "type": null, "default": null}, {"name": "xp", "type": null, "default": null}, {"name": "B", "type": null, "default": "..."}], "returns": null, "documentation": ["Interpolate the non-uniform samples s(x) onto xp (which could also be non-uniform).\n\nThis uses a sinc2 weighting of the non-uniform samples according to eq. 34 in Choi and\nMunson, 1998. Or what is referred to as type Sinc-3.\n\nArgs:\n  x (array, floats): non-uniform sample points\n  s (array, floats): non-uniform sample values\n  xp (array, floats): points of interpolated signal\n  B (float): bandlimit of s(x) (default: 3.)\n\nReturns:\n  sp (array, floats): interpolated signal at xp."]}], "variables": [], "classes": [], "exports": []}, {"name": "fsinc.fastgl", "documentation": ["! /usr/bin/env python3"], "functions": [{"name": "fsinc.fastgl.lgwt", "asynchronous": false, "params": [{"name": "nx", "type": null, "default": null}], "returns": null, "documentation": ["Helper for sinc1d, author: Gaute Hope, 2020"]}, {"name": "fsinc.fastgl.lgwt2d", "asynchronous": false, "params": [{"name": "nx", "type": null, "default": null}, {"name": "ny", "type": null, "default": null}], "returns": null, "documentation": ["Helper for sinc2d, author: Gaute Hope, 2020"]}, {"name": "fsinc.fastgl.lgwt_tri", "asynchronous": false, "params": [{"name": "nx", "type": null, "default": null}], "returns": null, "documentation": ["Helper for sincsq1d, author: Gaute Hope, 2020"]}, {"name": "fsinc.fastgl.lgwt_tri_2d", "asynchronous": false, "params": [{"name": "nx", "type": null, "default": null}, {"name": "ny", "type": null, "default": null}], "returns": null, "documentation": ["Helper for sincsq2d, author: Gaute Hope, 2020"]}, {"name": "fsinc.fastgl.besselj1squared", "asynchronous": false, "params": [{"name": "k", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fsinc.fastgl.besselj1squared_test", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "fsinc.fastgl.besseljzero", "asynchronous": false, "params": [{"name": "k", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "fsinc.fastgl.besseljzero_test", "asynchronous"