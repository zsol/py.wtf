: "tests.sincsq2d_test.test_sincsq2d_nu_to_nu", "asynchronous": false, "params": [], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "fsinc.fsinc_1d", "documentation": [], "functions": [{"name": "fsinc.fsinc_1d.sinc1d", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "s", "type": null, "default": null}, {"name": "xp", "type": null, "default": null}, {"name": "norm", "type": null, "default": "..."}, {"name": "eps", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the fast sinc-transform by ways of the non-uniform fast Fourier transform.\n\nsp = sum sinc(x - xp) * s\n\nArgs:\n  x (array, floats): sample points\n  s (array, floats or complex): sample values at x\n  xp (array, floats): target grid\n  norm (bool): use normalized sinc: sinc(pi*x)/pi*x (default: False)\n\nReturns:\n  sp (array, floats): transformed signal to xp"]}, {"name": "fsinc.fsinc_1d.sincsq1d", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "s", "type": null, "default": null}, {"name": "xp", "type": null, "default": null}, {"name": "norm", "type": null, "default": "..."}, {"name": "eps", "type": null, "default": "..."}], "returns": null, "documentation": ["Calculate the fast sinc^2-transform by ways of the non-uniform fast Fourier transform.\n\nsp = sum sinc^2(x - xp) * s\n\n> This uses Gauss-Legendre quadrature.\n\nArgs:\n  x (array, floats): sample points\n  s (array, floats or complex): sample values at x\n  xp (array, floats): target grid\n  norm (bool): use normalized sinc: sinc(pi*x)/pi*x (default: False)\n\nReturns:\n  sp (array, floats): transformed signal to xp"]}], "variables": [], "classes": [], "exports": []}, {"name": "tests.fsinc_interp_2d_test", "documentation": [], "functions": [{"name": "tests.fsinc_interp_2d_test.test_2d_u_to_nu", "asynchronous": false, "params": [{"name": "plot", "type": null, "default": null}], "returns"