ython package.\n\n## Installation\n\n```bash\npip install FluxComp\n```\n\n## Name\n\nIn the German dub of Back to the Future, the Flux Capacitor is translated as the 'Flux Compensator'.\nWe use cosmic ray flux models to compensate the unphysically distributed simulation fluxes to refer to\na physical model.\n\n<!-- ## Installation -->\n\n<!-- ```bash -->\n<!-- pip install fluxcomp -->\n<!-- ``` -->\n"], "modules": [{"name": "fluxcomp.constants", "documentation": [], "functions": [], "variables": [{"name": "fluxcomp.constants.D0_LIFETIME", "type": null, "documentation": []}, {"name": "fluxcomp.constants.DEFAULT_RUN_HEADER_FEATURES", "type": null, "documentation": []}, {"name": "fluxcomp.constants.DEFAULT_EVENT_HEADER_FEATURES", "type": null, "documentation": []}, {"name": "fluxcomp.constants.CORSIKA_FIELD_BYTE_LEN", "type": null, "documentation": []}, {"name": "fluxcomp.constants.PDGID_ERROR_VAL", "type": null, "documentation": []}, {"name": "fluxcomp.constants.PDGID_PROTON_1", "type": null, "documentation": []}, {"name": "fluxcomp.constants.PDGID_PROTON_2", "type": null, "documentation": []}, {"name": "fluxcomp.constants.PDGIDS_PION_KAON", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "fluxcomp", "documentation": [], "functions": [], "variables": [], "classes": [], "exports": [{"name": "fluxcomp.__logo__", "xref": {"fqname": "fluxcomp.version.__logo__", "project": null}}, {"name": "fluxcomp.__version__", "xref": {"fqname": "fluxcomp.version.__version__", "project": null}}, {"name": "fluxcomp.CosmicRayFlux", "xref": {"fqname": "fluxcomp.cosmic_ray_fluxes.CosmicRayFlux", "project": null}}, {"name": "fluxcomp.GlobalFitGST", "xref": {"fqname": "fluxcomp.cosmic_ray_fluxes.GlobalFitGST", "project": null}}, {"name": "fluxcomp.GlobalSplineFit", "xref": {"fqname": "fluxcomp.cosmic_ray_fluxes.GlobalSplineFit", "project": null}}, {"name": "fluxcomp.H3a", "xref": {"fqname": "fluxcomp.cosmic_ray_fluxes.H3a", "project": null}}, {"name": "fluxcomp.H