unctions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "DetectOutput", "xref": {"fqname": "DetectOutput", "project": null}, "params": null}, "documentation": ["Detect and localize the specified object in the input image.\n\nArgs:\n    image (Union[Image.Image, EncodedImage]): The input image to be analyzed.\n    object (str): The object to be detected in the image.\n\nReturns:\n    DetectOutput: A dictionary containing:\n        'objects' (List[Region]): List of detected object regions, where each\n            Region has:\n            - x_min (float): Left boundary of detection box\n            - y_min (float): Top boundary of detection box\n            - x_max (float): Right boundary of detection box\n            - y_max (float): Bottom boundary of detection box"]}, {"name": "moondream.types.VLM.point", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "image", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "Image.Image", "xref": {"fqname": "PIL.Image.Image", "project": "pillow"}, "params": null}, {"name": "EncodedImage", "xref": {"fqname": "moondream.types.EncodedImage", "project": null}, "params": null}]}, "default": null}, {"name": "object", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "PointOutput", "xref": {"fqname": "PointOutput", "project": null}, "params": null}, "documentation": ["Points out all instances of the given object in the input image.\n\nArgs:\n    image (Union[Image.Image, EncodedImage]): The input image to be analyzed for\n        pointing out objects.\n    object (str): The object type to be pointed out in the image.\n\nReturns:\n    PointOutput: A dictionary containing:\n        'points' (List[Point]): List of detected points, where each Point has:\n            - x (float): X coordinate of the point marking the object\n            - y (float): Y coordinate of the point marking the object\n\nThis method identifies instances of the specified object in the image and returns\na list of coordinates marking the location of each instance found. Each point\nindicates the approximate center or most relevant position for that object\ninstance."]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "moondream.cloud_vl", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "moondream.cloud_vl.CloudVL", "bases": ["VLM"], "methods": [{"name": "moondream.cloud_vl.CloudVL.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "api_key", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": null, "documentation": []}, {"name": "moondream.cloud_vl.CloudVL.encode_image", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "image", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "Image.Image", "xref": {"fqname": "PIL.Image.Image", "project": "pillow"}, "params": null}, {"name": "EncodedImage", "xref": {"fqname": "moondream.cloud_vl.types.EncodedImage", "project": null}, "params": null}]}, "default": null}], "returns": {"name": "Base64EncodedImage", "xref": {"fqname": "moondream.cloud_vl.types.Base64EncodedImage", "project": null}, "params": null}, "documentation": []}, {"name": "moondream.cloud_vl.CloudVL._stream_response", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "req", "type": null, "default": null}], "returns": null, "documentation": ["Helper function to stream response chunks from the API."]}, {"name": "moondream.cloud_vl.CloudVL.caption", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "image