, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "g2pkk.special.vowel_ui", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}, {"name": "descriptive", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "g2pkk.special.jamo", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}, {"name": "descriptive", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "g2pkk.special.rieulgiyeok", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}, {"name": "descriptive", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "g2pkk.special.rieulbieub", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}, {"name": "descriptive", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "g2pkk.special.verb_nieun", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}, {"name": "descriptive", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "g2pkk.special.balb", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}, {"name": "descriptive", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "g2pkk.special.palatalize", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}, {"name": "descriptive", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "g2pkk.special.modifying_rieul", "asynchronous": false, "params": [{"name": "inp", "type": null, "default": null}, {"name": "descriptive", "type": null, "default": "..."}, {"name": "verbose", "type": null, "default": "..."}], "returns": null, "documentation": []}], "variables": [{"name": "g2pkk.special.rule_id2text", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "g2pkk.numerals", "documentation": ["https://github.com/kyubyong/g2pK", "-*- coding: utf-8 -*-"], "functions": [{"name": "g2pkk.numerals.process_num", "asynchronous": false, "params": [{"name": "num", "type": null, "default": null}, {"name": "sino", "type": null, "default": "..."}], "returns": null, "documentation": ["Process a string looking like arabic number.\nnum: string. Consists of [0-9,]. e.g., 12,345\nsino: boolean. If True, sino-Korean numerals, i.e., \uc77c, \uc774, .. are considered.\n\n> Otherwise, pure Korean ones in their modifying forms such as \ud55c, \ub450, ... are returned.\n\n```pycon\n>>> process_num(\"123,456,789\", sino=True)\n\uc77c\uc5b5\uc774\ucc9c\uc0bc\ubc31\uc0ac\uc2ed\uc624\ub9cc\uc721\ucc9c\uce60\ubc31\ud314\uc2ed\uad6c\n```\n\n```pycon\n>>> process_num(\"123,456,789\", sino=False)\n\uc77c\uc5b5\uc774\ucc9c\uc0bc\ubc31\uc0ac\uc2ed\uc624\ub9cc\uc721\ucc9c\uce60\ubc31\uc5ec\ub4e0\uc544\ud649\n```\n"]}, {"name": "g2pkk.numerals.convert_num", "asynchronous": false, "params": [{"name": "string", "type": null, "default": null}], "returns": null, "documentation": ["Convert a annotated string such that arabic numerals inside are spelled out.\n\\>>> convert_num(\"\uc6b0\ub9ac 3\uc2dc/B 10\ubd84/B\uc5d0 \ub9cc\ub098\uc790.\")\n\uc6b0\ub9ac \uc138\uc2dc/B \uc2ed\ubd84/B\uc5d0 \ub9cc\ub098\uc790.\n"]}], "variables": [{"name": "g2pkk.numerals.BOUND_NOUNS", "type": null, "documentation": []}], "classes": [], "exports": []}]}