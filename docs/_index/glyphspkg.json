ame": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, {"name": "List", "xref": {"fqname": "typing.List", "project": "--std--"}, "params": [{"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}]}, "documentation": ["From glyphsLib.parser", "https://github.com/googlefonts/glyphsLib", "Licensed under Apache-2.0"]}, {"name": "glyphspkg.plist._fl7_format_clean", "asynchronous": false, "params": [{"name": "d", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["FontLab 7 glyphs source format exports include a final closing semicolon.\nThis method removes the semicolon before passing the string to the parser."]}], "variables": [], "classes": [], "exports": []}, {"name": "glyphspkg", "documentation": [], "functions": [], "variables": [{"name": "glyphspkg.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "glyphspkg.__version__", "xref": {"fqname": "glyphspkg._version.version", "project": null}}]}, {"name": "glyphspkg.filenames", "documentation": ["This module implements the algorithm for converting between a \"user name\" -\nsomething that a user can choose arbitrarily inside a font editor - and a file\nname suitable for use in a wide range of operating systems and filesystems.\n\nThe `UFO 3 specification <http://unifiedfontobject.org/versions/ufo3/conventions/>`_\nprovides an example of an algorithm for such conversion, which avoids illegal\ncharacters, reserved file names, ambiguity between upper- and lower-case\ncharacters, and clashes with existing files.\n\nThis code was originally copied from\n`ufoLib <https://github.com/unified-font-object/ufoLib/blob/8747da7/Lib/ufoLib/filenames.py>`_\nby Tal Leming and is copyright (c) 2005-2016, The RoboFab Developers:\n\n-       Erik van Blokland\n-       Tal Leming\n-       Just van Rossum", "From fontTools.misc.filenames", "https://github.com/fonttools/fonttools", "Licensed under the MIT licence"], "functions": [{"name": "glyphspkg.filenames.userNameToFileName", "asynchronous": false, "params": [{"name": "userName", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "existing", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "prefix", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "suffix", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["Converts from a user name to a file name.\n\nTakes care to avoid illegal characters, reserved file names, ambiguity\nbetween upper- and lower-case characters, and clashes with existing files.\n\nArgs:\n\n: userName (str): The input file name.\n  existing: A case-insensitive list of all existing file names.\n  prefix: Prefix to be prepended to the file name.\n  suffix: Suffix to be appended to the file name.\n\nReturns:\n\n: A suitable filename.\n\nRaises:\n\n: NameTranslationError: If no suitable name could be generated.\n\nExamples:\n\n```\n>>> userNameToFileName(\"a\") == \"a\"\nTrue\n>>> userNameToFileName(\"A\") == \"A_\"\nTrue\n>>> userNameToFileName(\"AE\") == \"A_E_\"\nTrue\n>>> userNameToFileName(\"Ae\") == \"A_e\"\nTrue\n>>> userNameToFileName(\"ae\") == \"ae\"\nTrue\n>>> userNameToFileName(\"aE\") == \"aE_\"\nTrue\n>>> userNameToFileName(\"a.alt\") == \"a.alt\"\nTrue\n>>> userNameToFileName(\"A.alt\") == \"A_.alt\"\nTrue\n>>> userNameToFileName(\"A.Alt\") == \"A_.A_lt\"\nTrue\n>>> userNameToFileName(\"A.aLt\") == \"A_.aL_t\"\nTrue\n>>> userNameToFileName(u\"A.alT\") == \"A_.alT_\"\nTrue\n>>> userNameToFileName(\"T_H\") == \"T__H_\"\nTrue\n>>> userNameToFileName(\"T_h\") == \"T__h\"\nTrue\n>>> userNameToFileName(\"t_h\") == \"t_h\"\nTrue\n>>> userNameToFileName(\"F_F_I\") == \"F__F__I_\"\nTrue\n>>> userNameToFileName(\"f_f_i\") == \"f_f_i\"\nTrue\n>>> userNameToFileName(\"Aacute_V.swash\") == \"A_acute_V_.swash\"\nTrue\n>>> userNameToFileName(\".notdef\") == \"_notdef\"\nTrue\n>>> userNameToFileName(\"con\") == \"_con\"\nTrue\n>>> userNameToFileName(\"CON\") == \"C_O_N_\"\nTrue\n>>> userNameToFileName(\"con.alt\") == \"_con.alt\"\nTrue\n>>> userNameToFileName(\"alt.con\") == \"alt._con\"\nTrue\n```\n"]}, {"name": "glyphspkg.filenames.handleClash1", "asynchronous": false, "params": [{"name": "userName", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": null}, {"name": "existing", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "prefix", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "suffix", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["existing should be a case-insensitive list\nof all existing file names.\n\n```pycon\n>>> prefix = (\"0\" * 5) + \".\"\n>>> suffix = \".\" + (\"0\" * 10)\n>>> existing = [\"a\" * 5]\n```\n\n```pycon\n>>> e = list(existing)\n>>> handleClash1(userName=\"A\" * 5, existing=e,\n...         prefix=prefix, suffix=suffix) == (\n...         '00000.AAAAA000000000000001.0000000000')\nTrue\n```\n\n```pycon\n>>> e = list(existing)\n>>> e.append(prefix + \"aaaaa\" + \"1\".zfill(15) + suffix)\n>>> handleClash1(userName=\"A\" * 5, existing=e,\n...         prefix=prefix, suffix=suffix) == (\n...         '00000.AAAAA000000000000002.0000000000')\nTrue\n```\n\n```pycon\n>>> e = list(existing)\n>>> e.append(prefix + \"AAAAA\" + \"2\".zfill(15) + suffix)\n>>> handleClash1(userName=\"A\" * 5, existing=e,\n...         prefix=prefix, suffix=suffix) == (\n...         '00000.AAAAA000000000000001.0000000000')\nTrue\n```\n"]}, {"name": "glyphspkg.filenames.handleClash2", "asynchronous": false, "params": [{"name": "existing", "type": {"name": "list", "xref": {"fqname": "functions.list", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "prefix", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}, {"name": "suffix", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": ["existing should be a case-insensitive list\nof all existing file names.\n\n```pycon\n>>> prefix = (\"0\" * 5) + \".\"\n>>> suffix = \".\" + (\"0\" * 10)\n>>> existing = [prefix + str(i) + suffix for i in range(100)]\n```\n\n```pycon\n>>> e = list(existing)\n>>> handleClash2(existing=e, prefix=prefix, suffix=suffix) == (\n...         '00000.100.0000000000')\nTrue\n```\n\n```pycon\n>>> e = list(existing)\n>>> e.remove(prefix + \"1\" + suffix)\n>>> handleClash2(existing=e, prefix=prefix, suffix=suffix) == (\n...         '00000.1.0000000000')\nTrue\n```\n\n```pycon\n>>> e = list(existing)\n>>> e.remove(prefix + \"2\" + suffix)\n>>> handleClash2(existing=e, prefix=prefix, suffix=suffix) == (\n...         '00000.2.0000000000')\nTrue\n```\n"]}], "variables": [{"name": "glyphspkg.filenames.illegalCharacters", "type": null, "documentation": []}, {"name": "glyphspkg.filenames.reservedFileNames", "type": null, "documentation": []}, 