!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\n% !! This file is generated by oca-gen-addon-readme !!\n% !! changes will be overwritten.                   !!\n% !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\n% !! source digest: sha256:c9525543728037ce0c5d0f43d49e4b4fc3e92ac7db9d78fb963488c43cc6d181\n% !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\n\n{{ badge1 }} {{ badge2 }} {{ badge3 }} {{ badge4 }} {{ badge5 }}\n\nAllows to associate employees and equipments to workspaces.\n\n**Table of contents**\n\n```{contents}\n:local: true\n```\n\n## Implemented Uses\n\n**Employees**\n\n- Employees can be assigned to workspaces.\n\n**Workspaces**\n\n- Each workspace has employees and equipment asigned to it. It represents a real workspace.\n\n**Table of contents**\n\n```{contents}\n:local: true\n```\n\n## Bug Tracker\n\nBugs are tracked on [GitHub Issues](https://github.com/OCA/hr/issues).\nIn case of trouble, please check there if your issue has already been reported.\nIf you spotted it first, help us to smash it by providing a detailed and welcomed\n[feedback](https://github.com/OCA/hr/issues/new?body=module:%20hr_maintenance_workspace%0Aversion:%2014.0%0A%0A**Steps%20to%20reproduce**%0A-%20...%0A%0A**Current%20behavior**%0A%0A**Expected%20behavior**).\n\nDo not contact contributors directly about support or help with technical issues.\n\n## Credits\n\n### Authors\n\n- SDi Digital Group\n\n### Contributors\n\n- Valent\u00edn Georgian Castravete \\<<mailto:valentincastravete@gmail.com>>\n- Jorge Luis Quinteros \\<<mailto:quinterosorellana04@gmail.com>>\n\n### Maintainers\n\nThis module is maintained by the OCA.\n\n```{image} https://odoo-community.org/logo.png\n:alt: Odoo Community Association\n:target: https://odoo-community.org\n```\n\nOCA, or the Odoo Community Association, is a nonprofit organization whose\nmission is to support the collaborative development of Odoo features and\npromote its widespread use.\n\nCurrent [maintainers](https://odoo-community.org/page/maintainer-role):\n\n{{ maintainer-valentincastravete }} {{ maintainer-JorgeQuinteros }}\n\nThis module is part of the [OCA/hr](https://github.com/OCA/hr/tree/14.0/hr_maintenance_workspace) project on GitHub.\n\nYou are welcome to contribute. To learn how please visit <https://odoo-community.org/page/Contribute>.\n"], "modules": [{"name": "odoo.addons.hr_maintenance_workspace.models.hr_employee", "documentation": ["Copyright 2023 SDi Digital Group (https://www.sdi.es/odoo-cloud)", "License AGPL-3.0 or later (https://www.gnu.org/licenses/agpl.html)."], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.hr_maintenance_workspace.models.hr_employee.HrEmployee", "bases": ["models.Model"], "methods": [{"name": "odoo.addons.hr_maintenance_workspace.models.hr_employee.HrEmployee._compute_workspace_count", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "odoo.addons.hr_maintenance_workspace.models.hr_employee.HrEmployee.button_employee_workspaces", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [{"name": "odoo.addons.hr_maintenance_workspace.models.hr_employee.HrEmployee._inherit", "type": null, "documentation": []}, {"name": "odoo.addons.hr_maintenance_workspace.models.hr_employee.HrEmployee.workspace_ids", "type": null, "documentation": []}, {"name": "odoo.addons.hr_maintenance_workspace.models.hr_employee.HrEmployee.workspace_count", "type": null, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "odoo.addons.hr_maintenance_workspace.models.equipment", "documentation": ["Copyright 2023 SDi Digital Group (https://www.sdi.es/odoo-cloud)", "License AGPL-3.0 or later (https://www.gnu.org/licenses/agpl.html)."], "functions": [], "variables": [], "classes": [{"name": "odoo.addons.hr_maintenance_workspace.m