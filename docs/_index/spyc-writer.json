{"name": "spyc-writer", "metadata": {"name": "SPyC_Writer", "version": "1.0.1", "classifiers": ["License :: OSI Approved :: MIT License"], "home_page": null, "license": null, "documentation_url": null, "dependencies": [], "summary": "A program to output data in the Thermo Galactic SPC file format.", "upload_time": 1734381910}, "documentation": ["# SPyC_Writer\n\nA writer for the Thermo Galactic SPC file format, widely used in Thermo \nScientific GRAMS and other applications, written in Python. \n\nThe only outside library used is numpy. The remainder of libraries used all come\nfrom the python standard library. Other outside libraries are used for testing, \nbut the core module does not use them. Use Python 3.10+.\n\nThe module has been cross-validated using https://github.com/rohanisaac/spc and \n[spectragryph](https://www.effemm2.de/spectragryph/) by parsing the output file \nand verifying it matches what is expected.\n\nValidation has been done on Y, XY, XYYY, and XYXYXY file types. All instances \nwere successfully parsed.\n\n[Wiley's Know It All](https://sciencesolutions.wiley.com/knowitall-spectroscopy-software/) \nwas also used for validating. It successfully parsed all formats except XYXYXY, which it \nstates is invalid.\n\n## Tests\n\nTests are written using pytest and verified using https://github.com/rohanisaac/spc. This package appears to not\nhave been updated in a while and contains a few errors, but it provides a straight forward interface in python for verifying\nparsing.\n\n## To-Do\n\n- Widen support for other SPC aspects that are currently listed as unsupported\n\t- Allow old file format\n\t- Provide option for not writing as IEEE float\n\t- etc.\n- Troubleshoot why KIA considers XYXYXY formats invalid\n- Expand tests\n- Expand input validation and provide informative error messages for wrong input\n\n## References\n\nThe Thermo Galactic spc-sdk code:\n- https://github.com/bz-dev/spc-sdk\n\nThe newer format specification document:\n- https://www.yumpu.com/en/document/read/40416248/a-brief-guide-to-spc-file-format-and-using-gspcio\n\nThe older format specification document (has greater detail in parts than newer doc):\n- https://ensembles-eu.metoffice.gov.uk/met-res/aries/technical/GSPC_UDF.PDF\n\n## Changelog\n\n- 2024-12-16 1.0.1\n    - adjusted data validation to shape instead of size\n- 2023-10-02 1.0.0\n    - fixed for Python 3.11\n- 2022-12-05 0.2.0\n    - published to PyPi\n- 2022-06-06 0.1.0\n    - initial version\n"], "modules": [{"name": "SPyC_Writer.SPCDate", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "SPyC_Writer.SPCDate.SPCDate", "bases": [], "methods": [{"name": "SPyC_Writer.SPCDate.SPCDate.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "time", "type": {"name": "datetime", "xref": {"fqname": "datetime", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "SPyC_Writer.SPCDate.SPCDate.get", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}], "returns": null, "documentation": []}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": []}], "exports": []}, {"name": "SPyC_Writer.common", "documentation": [], "functions": [{"name": "SPyC_Writer.common.fit_byte_block", "asynchronous": false, "params": [{"name": "field", "type": {"name": "bytearray", "xref": {"fqname": "functions.bytearray", "project": "--std--"}, "params": null}, "default": null}, {"name": "limit", "type": {"name": "int", "xref": {"fqname": "functions.int", "project": "--std--"}, "params": null}, "default": null}], "returns": {"name": "bytes", "xref": {"fqname": "functions.bytes", "project": "--std--"}, "params": null}, "documentation": []}], "variables": [{"name": "SPyC_Writer.common.RES_DESC_LIMIT", "type": null, "documentation": []}, {"name": "SPyC_Writer.common.SRC_INSTRUMENT_LIMIT", "type": null, "documentation": []}, {"name": "SPyC_Writer.common.MEMO_LIMIT", "type": null, "documentation": []}, {"name": "SPyC_Writer.common.AXES_LIMIT", "type": null, "documentation": []}, {"name": "SPyC_Writer.common.METHOD_FILE_LIMIT", "type": null, "documentation": []}, {"name": "SPyC_Writer.common.SPARE_LIMIT", "type": null, "documentation": []}, {"name": "SPyC_Writer.common.RESERVE_LIMIT", "type": null, "documentation": []}, {"name": "SPyC_Writer.common.LOG_RESERVE_LIMIT", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "SPyC_Writer.SPCEnums", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "SPyC_Writer.SPCEnums.SPCFileType", "bases": ["IntFlag"], "methods": [], "class_variables": [{"name": "SPyC_Writer.SPCEnums.SPCFileType.DEFAULT", "type": null, "documentation": ["Will be 32 bit single file, one trace, with even x values"]}, {"name": "SPyC_Writer.SPCEnums.SPCFileType.SIXTEENPREC", "type": null, "documentation": ["32 bit float or 16 bit spc format, currently only support 32 "]}, {"name": "SPyC_Writer.SPCEnums.SPCFileType.TCGRAM", "type": null, "documentation": ["Enables fexper in older software (not used accroding to old format doc)"]}, {"name": "SPyC_Writer.SPCEnums.SPCFileType.TMULTI", "type": null, "documentation": ["Multiple traces format (set if more than one subfile), Y vs YYYY, XY vs XYYY/XYXY"]}, {"name": "SPyC_Writer.SPCEnums.SPCFileType.TRANDM", "type": null, "documentation": ["If TMULTI and TRANDM=1 then arbitrary time (Z) values, must pass full z array"]}, {"name": "SPyC_Writer.SPCEnums.SPCFileType.TORDRD", "type": null, "documentation": ["If TMULTI and TORDRD=1 then ordered but uneven z, must pass full z array if true, else only z_inc and single z value in z array "]}, {"name": "SPyC_Writer.SPCEnums.SPCFileType.TALABS", "type": null, "documentation": ["If true, use the specified custom axes"]}, {"name": "SPyC_Writer.SPCEnums.SPCFileType.TXYXYS", "type": null, "documentation": ["If true the file is XYXYXY, flase is considered XYYYYYY "]}, {"name": "SPyC_Writer.SPCEnums.SPCFileType.TXVALS", "type": null, "documentation": ["Non even X values, must pass full x array "]}], "instance_variables": [], "inner_classes": [], "documentation": ["Describes the various file format flags.\nSee the old specification for greater detail on what each setting changes."]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode", "bases": ["IntFlag"], "methods": [], "class_variables": [{"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPNONE", "type": null, "documentation": ["No post processing "]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPCOMP", "type": null, "documentation": ["Compute (run PPCOMP?.ABP) "]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPDLLC", "type": null, "documentation": ["Compute with DLL (run PPCOMP?.DLL) "]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPTRANS", "type": null, "documentation": ["Transmission (run PPTRANS?.ABP) "]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPABSRB", "type": null, "documentation": ["Absorbance (run PPABSRB?.ABP) "]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPKMUNK", "type": null, "documentation": ["Kuebelka-Munk (run PPKMUNK?.ABP) "]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPPEAK", "type": null, "documentation": ["GRAMS built-in peak picking and reporting "]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPSRCH", "type": null, "documentation": ["Library Search associated w/experiment's LIB driver "]}, {"name": "SPyC_Writer.SPCEnums.SPCProcessCode.PPUSER", "type": null, "documentation": ["General user-written post program (run PPUSER?.ABP) "]}], "instance_variables": [], "inner_classes": [], "documentation": ["From GRAMSDDE.h", "Currently only support PPNONE"]}, {"name": "SPyC_Writer.SPCEnums.SPCModFlags", "bases": ["IntFlag"], "methods": [], "class_variables": [{"name": "SPyC_Writer.SPCEnums.SPCModFlags.UNMOD", "type": null, "documentation": ["unmodified