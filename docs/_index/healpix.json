fault": null}], "returns": null, "documentation": []}, {"name": "python.healpix.test.test_chealpix.test_npix2nside", "asynchronous": false, "params": [{"name": "nside_dirty", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "python.healpix.test.test_chealpix.test_npix2nside_invalid", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "python.healpix.test.test_chealpix.test_nside2order", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "order", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "python.healpix.test.test_chealpix.test_nside2order_invalid", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "python.healpix.test.test_chealpix.test_order2nside", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "order", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "python.healpix.test.test_chealpix.test_order2nside_invalid", "asynchronous": false, "params": [], "returns": null, "documentation": []}, {"name": "python.healpix.test.test_chealpix.test_uniq_nest", "asynchronous": false, "params": [{"name": "order", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "python.healpix.test.test_chealpix.test_uniq_ring", "asynchronous": false, "params": [{"name": "order", "type": null, "default": null}], "returns": null, "documentation": []}], "variables": [], "classes": [], "exports": []}, {"name": "python.healpix", "documentation": ["Python package for HEALPix discretisation of the sphere", "author: Nicolas Tessore <n.tessore@ucl.ac.uk>", "license: BSD-3-Clause"], "functions": [{"name": "python.healpix.is_power_of_two", "asynchronous": false, "params": [{"name": "n", "type": null, "default": null}], "returns": null, "documentation": ["Return True if n is a power of two, or False otherwise."]}, {"name": "python.healpix.check_nside", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}], "returns": null, "documentation": ["Check whether nside is a valid resolution parameter."]}, {"name": "python.healpix.thetaphi_from_lonlat", "asynchronous": false, "params": [{"name": "lon", "type": null, "default": null}, {"name": "lat", "type": null, "default": null}, {"name": "theta", "type": null, "default": "..."}, {"name": "phi", "type": null, "default": "..."}], "returns": null, "documentation": ["convert longitude and latitude in degree to theta and phi in radian"]}, {"name": "python.healpix.lonlat_from_thetaphi", "asynchronous": false, "params": [{"name": "theta", "type": null, "default": null}, {"name": "phi", "type": null, "default": null}, {"name": "lon", "type": null, "default": "..."}, {"name": "lat", "type": null, "default": "..."}], "returns": null, "documentation": ["convert theta and phi in radian to longitude and latitude in degree"]}, {"name": "python.healpix.ang2vec", "asynchronous": false, "params": [{"name": "theta", "type": null, "default": null}, {"name": "phi", "type": null, "default": null}, {"name": "lonlat", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "python.healpix.vec2ang", "asynchronous": false, "params": [{"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "z", "type": null, "default": null}, {"name": "lonlat", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "python.healpix.ang2pix", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "theta", "type": null, "default": null}, {"name": "phi", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}, {"name": "lonlat", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "python.healpix.pix2ang", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "ipix", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}, {"name": "lonlat", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "python.healpix.vec2pix", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "x", "type": null, "default": null}, {"name": "y", "type": null, "default": null}, {"name": "z", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "python.healpix.pix2vec", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "ipix", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "python.healpix.nside2npix", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "python.healpix.npix2nside", "asynchronous": false, "params": [{"name": "npix", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "python.healpix.nside2order", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}], "returns": null, "documentation": ["Return the HEALPix order for a given NSIDE parameter."]}, {"name": "python.healpix.order2nside", "asynchronous": false, "params": [{"name": "order", "type": null, "default": null}], "returns": null, "documentation": ["Return the NSIDE parameter for a given HEALPix order."]}, {"name": "python.healpix.randang", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "ipix", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}, {"name": "lonlat", "type": null, "default": "..."}, {"name": "rng", "type": null, "default": "..."}], "returns": null, "documentation": ["Sample random spherical coordinates from the given HEALPix pixels.\n\nThis function produces one pair of random spherical coordinates from each\nHEALPix pixel listed in `ipix`, which can be scalar or array-like.  The\nindices use the `nside` resolution parameter and either the RING scheme\n(if `nest` is false, the default) or the NEST scheme (if `nest` is true).\n\nReturns either a tuple `theta, phi` of mathematical coordinates in radians\nif `lonlat` is False (the default), or a tuple `lon, lat` of longitude and\nlatitude in degrees if `lonlat` is True.  The output is of the same shape\nas the input.\n\nAn optional numpy random number generator can be provided using `rng`;\notherwise, a new numpy.random.default_rng() is used."]}, {"name": "python.healpix.randvec", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "ipix", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}, {"name": "rng", "type": null, "default": "..."}], "returns": null, "documentation": ["Sample random unit vectors from the given HEALPix pixels.\n\nThis function produces one random unit vector from each HEALPix pixel\nlisted in `ipix`, which can be scalar or array-like.  The pixel indices use\nthe `nside` resolution parameter and either the RING scheme (if `nest` is\nfalse, the default) or the NEST scheme (if `nest` is true).\n\nReturns a tuple `x, y, z` of normalised vector components with the same\nshape as the input.\n\nAn optional numpy random number generator can be provided using `rng`;\notherwise, a new numpy.random.default_rng() is used."]}, {"name": "python.healpix.nest2ring", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "ipix", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "python.healpix.ring2nest", "asynchronous": false, "params": [{"name": "nside", "type": null, "default": null}, {"name": "ipix", "type": null, "default": null}], "returns": null, "documentation": []}, {"name": "python.healpix.uniq2pix", "asynchronous": false, "params": [{"name": "uniq", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}], "returns": null, "documentation": ["Convert from UNIQ to RING or NEST pixel scheme.\n\nReturns a tuple `order, ipix` of HEALPix orders and pixel indices in\nthe RING scheme (if `nest` is false, the default) or the NEST scheme\n(if `nest` is true)."]}, {"name": "python.healpix.pix2uniq", "asynchronous": false, "params": [{"name": "order", "type": null, "default": null}, {"name": "ipix", "type": null, "default": null}, {"name": "nest", "type": null, "default": "..."}], "returns": null, "documentation": ["Convert RING or NEST to UNIQ pixel scheme.\n\nReturns a pixel index in the UNIQ scheme for each pair of HEALPix\norder `order` and pixel index `ipix` in the RING scheme (if `nest`\nis false, the default) or the NEST scheme (if `nest` is true)."]}], "variables": [{"name": "python.healpix.__version__", "type": null, "documentation": []}, {"name": "python.healpix.NSIDE_MAX", "type": null, "documentation": ["Maximum admissible value for the NSIDE parameter.\n\nIf nside > NSIDE_MAX is used, the resulting pixel indices can overflow their\nunderlying integer type in the C library functions."]}], "classes": [], "exports": []}]}