{"name": "ipm-python", "metadata": {"name": "ipm-python", "version": "1.2.2", "classifiers": ["License :: OSI Approved :: MIT License", "Operating System :: OS Independent", "Programming Language :: Python :: 3"], "home_page": "https://github.com/IngotStudio/ipm", "license": null, "documentation_url": null, "dependencies": ["tqdm"], "summary": "\u6539\u8fdb\u7248 Python \u8f6f\u4ef6\u5305\u7ba1\u7406\u5668\uff0c\u652f\u6301\u56fd\u5185\u955c\u50cf\u548c\u52a8\u6001\u8fdb\u5ea6\u6761\u3002", "upload_time": 1732701593}, "documentation": ["# IPM-Python - \u6539\u8fdb\u7248 Python \u8f6f\u4ef6\u5305\u7ba1\u7406\u5668\r\n\r\n`ipm-python` \u662f\u4e00\u4e2a\u4e13\u4e3a\u4e2d\u56fd\u7528\u6237\u8bbe\u8ba1\u7684\u6539\u8fdb\u7248 Python \u8f6f\u4ef6\u5305\u7ba1\u7406\u5668\uff0c\u65e8\u5728\u7b80\u5316\u5305\u7ba1\u7406\u6d41\u7a0b\uff0c\u63d0\u5347\u4f7f\u7528\u4f53\u9a8c\u3002\u5b83\u5185\u7f6e\u963f\u91cc\u4e91\u955c\u50cf\u6e90\uff0c\u652f\u6301\u52a8\u6001\u8fdb\u5ea6\u6761\u3001\u7248\u672c\u7ba1\u7406\u548c\u66f4\u591a\u529f\u80fd\uff0c\u8ba9\u8f6f\u4ef6\u5305\u7684\u5b89\u88c5\u548c\u7ba1\u7406\u66f4\u9ad8\u6548\u3002\r\n\r\n---\r\n\r\n## \u529f\u80fd\u7279\u70b9\r\n\r\n- **\u56fd\u5185\u955c\u50cf\u652f\u6301**\uff1a\u9ed8\u8ba4\u4f7f\u7528\u963f\u91cc\u4e91 PyPI \u955c\u50cf\u6e90\uff0c\u63d0\u5347\u5b89\u88c5\u901f\u5ea6\u3002\r\n- **\u52a8\u6001\u8fdb\u5ea6\u6761**\uff1a\u5b9e\u65f6\u663e\u793a\u5b89\u88c5/\u5378\u8f7d\u8fdb\u5ea6\uff0c\u7528\u6237\u4f53\u9a8c\u66f4\u53cb\u597d\u3002\r\n- **\u7b80\u5316\u547d\u4ee4**\uff1a\u63d0\u4f9b\u66f4\u76f4\u89c2\u3001\u66f4\u6613\u8bb0\u7684\u547d\u4ee4\u683c\u5f0f\u3002\r\n- **\u591a\u529f\u80fd\u652f\u6301**\uff1a\r\n  - \u5b89\u88c5\u6700\u65b0\u7248\u672c\r\n  - \u5b89\u88c5\u6307\u5b9a\u7248\u672c\r\n  - \u5378\u8f7d\u8f6f\u4ef6\u5305\r\n  - \u5217\u51fa\u5df2\u5b89\u88c5\u7684\u8f6f\u4ef6\u5305\r\n\r\n---\r\n\r\n## \u5b89\u88c5\r\n\r\n\u786e\u4fdd\u60a8\u5df2\u5b89\u88c5 Python 3.6 \u53ca\u4ee5\u4e0a\u7248\u672c\u3002\r\n\r\n1. \u4f7f\u7528 pip \u5b89\u88c5\uff1a\r\n   ```bash\r\n   pip install ipm-python\r\n\r\n"], "modules": [{"name": "ipm", "documentation": ["IPM-Python - \u6539\u8fdb\u7248 Python \u8f6f\u4ef6\u5305\u7ba1\u7406\u5668", "__init__.py"], "functions": [], "variables": [{"name": "ipm.__version__", "type": null, "documentation": []}, {"name": "ipm.__author__", "type": null, "documentation": []}, {"name": "ipm.__email__", "type": null, "documentation": []}], "classes": [], "exports": []}, {"name": "ipm.downloader", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "ipm.downloader.Downloader", "bases": [], "methods": [{"name": "ipm.downloader.Downloader.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "mirror_url", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "ipm.downloader.Downloader.download_package", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "package_name", "type": null, "default": null}, {"name": "destination", "type": null, "default": null}, {"name": "version", "type": null, "default": "..."}], "returns": null, "documentation": ["\u4e0b\u8f7d\u6307\u5b9a\u5305\u7684\u6587\u4ef6"]}], "class_variables": [], "instance_variables": [], "inner_classes": [], "documentation": ["\u8d1f\u8d23\u4ece\u955c\u50cf\u6e90\u4e0b\u8f7d\u6587\u4ef6"]}], "exports": []}, {"name": "ipm.progress", "documentation": [], "functions": [], "variables": [], "classes": [{"name": "ipm.progress.ProgressBar", "bases": [], "methods": [{"name": "ipm.progress.ProgressBar.__init__", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "total_size", "type": null, "default": null}, {"name": "description", "type": null, "default": "..."}], "returns": null, "documentation": []}, {"name": "ipm.progress.ProgressBar.update", "asynchronous": false, "params": [{"name": "self", "type": null, "default": 