se. Can at most use 1 per chromosome or chromosome/strand tuple.\n            Will only lead to speedups on large datasets.\n```\n\n* for nearest returns no empty rows if there is no overlap (we follow Bioframe where nulls are returned)\n#\n"], "modules": [{"name": "polars_bio.range_viz", "documentation": [], "functions": [{"name": "polars_bio.range_viz.visualize_intervals", "asynchronous": false, "params": [{"name": "df", "type": {"name": "Union", "xref": {"fqname": "typing.Union", "project": "--std--"}, "params": [{"name": "pd.DataFrame | pl.DataFrame", "xref": null, "params": null}]}, "default": null}, {"name": "label", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "default": "..."}], "returns": {"name": "None", "xref": {"fqname": "constants.None", "project": "--std--"}, "params": null}, "documentation": ["Visualize the overlapping intervals.\n\nParameters:\n    df: Pandas DataFrame or Polars DataFrame. The DataFrame containing the overlapping intervals"]}], "variables": [], "classes": [], "exports": []}, {"name": "polars_bio", "documentation": [], "functions": [], "variables": [{"name": "polars_bio.logger", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "polars_bio.ctx", "xref": {"fqname": "polars_bio.range_op.ctx", "project": null}}, {"name": "polars_bio.FilterOp", "xref": {"fqname": "polars_bio.polars_bio.FilterOp", "project": null}}, {"name": "polars_bio.nearest", "xref": {"fqname": "polars_bio.range_op.nearest", "project": null}}, {"name": "polars_bio.overlap", "xref": {"fqname": "polars_bio.range_op.overlap", "project": null}}, {"name": "polars_bio.vizualize_intervals", "xref": {"fqname": "polars_bio.vizualize_intervals", "project": null}}]}, {"name": "polars_bio.range_op", "documentation": [], "functions": [{"name": "polars_bio.range_op.overlap", "asynchronous": false, "params": [{"name": "df1", "type": {"name": "Union", "xref": {"fqname": "typing_extensions.Union", "project": 