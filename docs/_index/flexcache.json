ls."], "functions": [], "variables": [{"name": "flexcache.__version__", "type": null, "documentation": []}, {"name": "flexcache.__version__", "type": null, "documentation": []}], "classes": [], "exports": [{"name": "flexcache.__version__", "xref": {"fqname": "flexcache.__version__", "project": null}}, {"name": "flexcache.BaseHeader", "xref": {"fqname": "flexcache.flexcache.BaseHeader", "project": null}}, {"name": "flexcache.BasicPythonHeader", "xref": {"fqname": "flexcache.flexcache.BasicPythonHeader", "project": null}}, {"name": "flexcache.DiskCache", "xref": {"fqname": "flexcache.flexcache.DiskCache", "project": null}}, {"name": "flexcache.DiskCacheByHash", "xref": {"fqname": "flexcache.flexcache.DiskCacheByHash", "project": null}}, {"name": "flexcache.DiskCacheByMTime", "xref": {"fqname": "flexcache.flexcache.DiskCacheByMTime", "project": null}}, {"name": "flexcache.InvalidateByExist", "xref": {"fqname": "flexcache.flexcache.InvalidateByExist", "project": null}}, {"name": "flexcache.InvalidateByMultiPathsMtime", "xref": {"fqname": "flexcache.flexcache.InvalidateByMultiPathsMtime", "project": null}}, {"name": "flexcache.InvalidateByPathMTime", "xref": {"fqname": "flexcache.flexcache.InvalidateByPathMTime", "project": null}}, {"name": "flexcache.NameByFields", "xref": {"fqname": "flexcache.flexcache.NameByFields", "project": null}}, {"name": "flexcache.NameByFileContent", "xref": {"fqname": "flexcache.flexcache.NameByFileContent", "project": null}}, {"name": "flexcache.NameByHashIter", "xref": {"fqname": "flexcache.flexcache.NameByHashIter", "project": null}}, {"name": "flexcache.NameByMultiPaths", "xref": {"fqname": "flexcache.flexcache.NameByMultiPaths", "project": null}}, {"name": "flexcache.NameByObj", "xref": {"fqname": "flexcache.flexcache.NameByObj", "project": null}}, {"name": "flexcache.NameByPath", "xref": {"fqname": "flexcache.flexcache.NameByPath", "project": null}}]}, {"name": "flexcache.testsuite.test_header", "documentation": [], "functions": [{"name