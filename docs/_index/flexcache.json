d version\nof the source_object represented by this header."]}], "class_variables": [{"name": "flexcache.flexcache.BaseHeader.source", "type": {"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "flexcache.flexcache.BaseHeader.converter_id", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "flexcache.flexcache.BaseHeader._source_type", "type": {"name": "ClassVar", "xref": {"fqname": "typing.ClassVar", "project": "--std--"}, "params": [{"name": "Any", "xref": {"fqname": "typing.Any", "project": "--std--"}, "params": null}]}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Header with no information except the converter_id\n\nAll header files must inherit from this.", "########", "Header", "########"]}, {"name": "flexcache.flexcache.BasicPythonHeader", "bases": ["BaseHeader"], "methods": [], "class_variables": [{"name": "flexcache.flexcache.BasicPythonHeader.system", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "flexcache.flexcache.BasicPythonHeader.python_implementation", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}, {"name": "flexcache.flexcache.BasicPythonHeader.python_version", "type": {"name": "str", "xref": {"fqname": "functions.str", "project": "--std--"}, "params": null}, "documentation": []}], "instance_variables": [], "inner_classes": [], "documentation": ["Header with basic Python information."]}, {"name": "flexcache.flexcache.InvalidateByExist", "bases": ["BaseHeader"], "methods": [{"name": "flexcache.flexcache.InvalidateByExist.is_valid", "asynchronous": false, "params": [{"name": "self", "type": null, "default": null}, {"name": "cache_path", "type": {"name": "pathlib.Path", "xref": {"fqname": "pathlib.Path",